{"id":11652,"date":"2023-03-27T16:15:36","date_gmt":"2023-03-27T16:15:36","guid":{"rendered":"http:\/\/alomariya.test\/%d8%a7%d8%b3%d8%aa%d8%af%d8%b1%d8%a7%d9%83-%d8%b9%d9%84%d9%89-%d8%b4%d9%8a%d8%ae-%d8%a7%d9%84%d8%a3%d8%b2%d9%87%d8%b1%d9%81%d9%8a-%d9%83%d9%84%d9%85%d8%aa%d9%87-%d8%b9%d9%86%d8%af-%d8%a7%d9%81%d8%aa-2\/"},"modified":"2023-03-27T16:15:36","modified_gmt":"2023-03-27T16:15:36","slug":"%d8%a7%d8%b3%d8%aa%d8%af%d8%b1%d8%a7%d9%83-%d8%b9%d9%84%d9%89-%d8%b4%d9%8a%d8%ae-%d8%a7%d9%84%d8%a3%d8%b2%d9%87%d8%b1%d9%81%d9%8a-%d9%83%d9%84%d9%85%d8%aa%d9%87-%d8%b9%d9%86%d8%af-%d8%a7%d9%81%d8%aa-2","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d8%a7%d8%b3%d8%aa%d8%af%d8%b1%d8%a7%d9%83-%d8%b9%d9%84%d9%89-%d8%b4%d9%8a%d8%ae-%d8%a7%d9%84%d8%a3%d8%b2%d9%87%d8%b1%d9%81%d9%8a-%d9%83%d9%84%d9%85%d8%aa%d9%87-%d8%b9%d9%86%d8%af-%d8%a7%d9%81%d8%aa-2\/","title":{"rendered":"\u0627\u0633\u062a\u062f\u0631\u0627\u0643 \u0639\u0644\u0649 \u0634\u064a\u062e \u0627\u0644\u0623\u0632\u0647\u0631<br \/>\u0641\u064a \u0643\u0644\u0645\u062a\u0647 \u0639\u0646\u062f \u0627\u0641\u062a\u062a\u0627\u062d \u0645\u0631\u0643\u0632 \u0645\u0635\u0631 \u0627\u0644\u062b\u0642\u0627\u0641\u064a \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a"},"content":{"rendered":"<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0628\u0633\u0645 \u0627\u0644\u0644\u0647 \u0648\u0627\u0644\u062d\u0645\u062f \u0644\u0644\u0647\u060c \u0648\u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0648\u0633\u0644\u0645 \u0639\u0644\u0649 \u0631\u0633\u0648\u0644 \u0627\u0644\u0644\u0647 \u0648\u0622\u0644\u0647 \u0648\u0635\u062d\u0628\u0647.<\/p>\n<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0645\u0627 \u0643\u0627\u062f \u0634\u064a\u062e \u0627\u0644\u0623\u0632\u0647\u0631 \u0627\u0644\u062f\u0643\u062a\u0648\u0631 \u0623\u062d\u0645\u062f \u0627\u0644\u0637\u064a\u0628 \u0648\u0641\u0642\u0647 \u0627\u0644\u0644\u0647 \u064a\u0633\u062a\u0631\u0633\u0644 \u0641\u064a \u0643\u0644\u0645\u062a\u0647 \u0623\u0645\u0627\u0645 \u0627\u0644\u0631\u0626\u064a\u0633 \u0627\u0644\u0633\u064a\u0633\u064a \u0645\u0634\u064a\u062f\u0627 \u0628\u0627\u0641\u062a\u062a\u0627\u062d \u0627\u0644\u0645\u0633\u062c\u062f \u0627\u0644\u0643\u0628\u064a\u0631 \u0641\u064a \u0627\u0644\u0639\u0627\u0635\u0645\u0629 \u0627\u0644\u0625\u062f\u0627\u0631\u064a\u0629\u060c \u062d\u062a\u0649 \u0633\u0642\u0637 \u0641\u064a\u0645\u0627 \u0643\u0646\u0627 \u0646\u0648\u062f \u0623\u0644\u0627 \u064a\u0633\u0642\u0637 \u0641\u064a\u0647\u060c \u0648\u0647\u0648 \u0627\u0644\u062d\u0631\u064a\u0635 \u0639\u0644\u0649 \u062a\u0636\u0645\u064a\u0646 \u0643\u0644\u0645\u062a\u0647 \u0644\u0646\u0635\u0627\u0626\u062d \u0645\u062d\u062a\u0634\u0645\u0629 \u0644\u0644\u0639\u0627\u0644\u0645 \u0628\u0623\u062c\u0645\u0639\u0647 \u0648\u0644\u0645\u0646 \u064a\u0642\u0648\u062f\u0647 \u0645\u0646 \u0631\u062c\u0627\u0644 \u0639\u0644\u0645 \u0648\u0633\u064a\u0627\u0633\u0629.<\/p>\n<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0648\u0644\u0642\u062f \u0643\u0627\u0646 \u0623\u0648\u0644 \u0645\u0627 \u0648\u0642\u0639 \u0641\u064a\u0647 \u0634\u064a\u062e \u0627\u0644\u0623\u0632\u0647\u0631\u060c \u0632\u0639\u0645\u0647 \u0644\u062a\u0639\u0627\u0646\u0642 \u0627\u0644\u0639\u0628\u0627\u062f\u0629 \u0648&quot;\u0627\u0644\u0639\u0644\u0645 \u0648\u0627\u0644\u0645\u0639\u0631\u0641\u0629&quot;\u060c \u0645\u0646 \u062f\u0648\u0646 \u062a\u0646\u0628\u0647 \u0625\u0644\u0649 \u0623\u0646\u0647 \u0628\u0647\u0630\u0627 \u0627\u0644\u0642\u0648\u0644 \u064a\u0624\u0633\u0633 \u0644\u0644\u0627\u0632\u062f\u0648\u0627\u062c\u064a\u0629 \u0627\u0644\u0639\u0644\u0645\u0627\u0646\u064a\u0629\u060c \u0648\u0644\u0648 \u0645\u0646 \u063a\u064a\u0631 \u0642\u0635\u062f. \u0648\u0644\u0645 \u064a\u0646\u0641\u0639 \u0627\u0644\u0634\u064a\u062e \u0645\u0627 \u0627\u0633\u062a\u062f\u0644 \u0628\u0647 \u0645\u0646 \u062d\u062f\u064a\u062b \u0631\u0633\u0648\u0644 \u0627\u0644\u0644\u0647 \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645\u060c \u0648\u0647\u0648 \u0642\u062f \u0641\u062a\u062d \u0627\u0644\u0628\u0627\u0628 \u0623\u0645\u0627\u0645 \u0627\u0644\u0633\u0627\u0645\u0639 \u0639\u0644\u0649 \u0627\u0644\u0645\u062c\u0647\u0648\u0644\u060c \u0623\u0648 \u0639\u0644\u0649 \u0627\u0644\u0645\u0639\u062a\u0627\u062f \u0645\u0646 \u0627\u0644\u062e\u0637\u0627\u0628 \u0627\u0644\u062f\u062c\u0627\u0644\u064a \u0627\u0644\u0633\u0627\u0626\u062f \u0641\u064a \u0632\u0645\u0627\u0646\u0646\u0627. \u0648\u0647\u0630\u0627\u060c \u0644\u0623\u0646 \u0627\u0644\u0639\u0628\u0627\u062f\u0629 \u0641\u064a \u062f\u064a\u0646\u0646\u0627\u060c \u0647\u064a \u0627\u0644\u062a\u064a \u062a\u0623\u062a\u064a \u0625\u0644\u0649 \u0627\u0644\u0639\u0628\u062f \u0628\u0627\u0644\u0639\u0644\u0645 \u0627\u0644\u0646\u0627\u0641\u0639\u060c \u0639\u0646\u062f\u0645\u0627 \u064a\u062a\u0642\u0628\u0644\u0647\u0627 \u0627\u0644\u0644\u0647 \u0648\u064a\u062c\u0632\u064a \u0639\u0646\u0647\u0627 \u0628\u0641\u0636\u0644\u0647. \u064a\u0642\u0648\u0644 \u0627\u0644\u0644\u0647 \u062a\u0639\u0627\u0644\u0649: {\u0648\u064e\u0671\u062a\u0651\u064e\u0642\u064f\u0648\u0627\u06df \u0671\u0644\u0644\u0651\u064e\u0647\u064e\u06d6 \u0648\u064e\u06cc\u064f\u0639\u064e\u0644\u0651\u0650\u0645\u064f\u0643\u064f\u0645\u064f \u0671\u0644\u0644\u0651\u064e\u0647\u064f\u06d7 \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0628\u0650\u0643\u064f\u0644\u0651\u0650 \u0634\u064e\u06cc\u06e1\u0621\u064d \u0639\u064e\u0644\u0650\u06cc\u0645\u064c} [\u0627\u0644\u0628\u0642\u0631\u0629: \u0662\u0668\u0662]. \u0648\u0623\u0645\u0627 \u0639\u0644\u0645 \u0623\u062d\u0643\u0627\u0645 \u0627\u0644\u0639\u0628\u0627\u062f\u0627\u062a \u0625\u0646 \u0643\u0627\u0646 \u0627\u0644\u0634\u064a\u062e \u064a\u0642\u0635\u062f\u0647\u060c \u0641\u0625\u0646\u0647 \u0639\u0644\u0645 \u0623\u0648\u0644\u064a\u0651 \u062e\u0627\u062f\u0645 \u0644\u0644\u0639\u0628\u0627\u062f\u0629\u060c \u0648\u0628\u0627\u0644\u062a\u0627\u0644\u064a \u0641\u0644\u064a\u0633 \u0647\u0648 \u0627\u0644\u0646\u062a\u064a\u062c\u0629 \u0627\u0644\u0645\u0631\u062c\u0648\u0629 \u0645\u0646\u0647\u0627. \u0648\u0645\u0646 \u0647\u0646\u0627\u060c \u064a\u0645\u0643\u0646\u0646\u0627 \u0627\u0644\u0642\u0648\u0644 \u0628\u0623\u0646 \u0627\u0644\u0639\u0644\u0645 \u0639\u0644\u0645\u0627\u0646: \u0639\u0644\u0645\u064c \u0633\u0628\u0628\u064c \u0648\u062e\u0627\u062f\u0645\u064c\u060c \u0648\u0639\u0644\u0645 \u0645\u0637\u0644\u0648\u0628 \u0628\u0627\u0644\u062a\u0642\u0648\u0649. \u0648\u0627\u0644\u0623\u0648\u0644 \u0644\u0627 \u064a\u0628\u0644\u063a \u0623\u0646 \u064a\u0643\u0648\u0646 \u062a\u0641\u0633\u064a\u0631\u0627 \u0644\u0643\u0644\u0645\u0629 &quot;\u0639\u0644\u0645&quot; \u0641\u064a \u0643\u062b\u064a\u0631 \u0645\u0646 \u0645\u0648\u0627\u0636\u0639 \u0627\u0644\u0642\u0631\u0622\u0646 \u0627\u0644\u0643\u0631\u064a\u0645\u060c \u0648\u064a\u0628\u0642\u0649 \u0627\u0644\u062b\u0627\u0646\u064a \u0647\u0648 \u0627\u0644\u0639\u0644\u0645 \u0628\u0627\u0644\u0645\u0639\u0646\u0649 \u0627\u0644\u062a\u0627\u0645 \u0627\u0644\u0635\u062d\u064a\u062d.<\/p>\n<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0648\u0623\u0645\u0627 \u0633\u0642\u0637\u0629 \u0634\u064a\u062e \u0627\u0644\u0623\u0632\u0647\u0631 \u0627\u0644\u062b\u0627\u0646\u064a\u0629\u060c \u0641\u0647\u064a \u062c\u0639\u0644\u0647 \u0639\u0644\u0645 \u0644\u0627 \u0625\u0644\u0647 \u0625\u0644\u0627 \u0627\u0644\u0644\u0647 \u0645\u0646 \u0634\u0631\u0648\u0637 \u0627\u0644\u0625\u0633\u0644\u0627\u0645 (\u0627\u0644\u0645\u0631\u062a\u0628\u0629)\u060c \u0648\u0647\u0648 \u0645\u0627 \u0644\u0627 \u064a\u0635\u062d. \u0648\u0642\u062f \u0632\u0627\u062f \u0645\u0646 \u0641\u062f\u0627\u062d\u0629 \u0627\u0644\u062e\u0637\u0623 \u0623\u0646 \u0623\u0646\u0643\u0631 \u0627\u0644\u0634\u064a\u062e \u0634\u0647\u0627\u062f\u0629 \u0627\u0644\u0625\u0633\u0644\u0627\u0645 \u0639\u0644\u0649 \u0645\u0627 \u064a\u0639\u0637\u064a\u0647 \u0627\u0644\u062a\u0633\u0644\u064a\u0645\u060c \u0645\u0639 \u0623\u0646 \u0627\u0644\u062a\u0633\u0644\u064a\u0645 \u0647\u0648 \u0623\u0635\u0644 \u0627\u0644\u0625\u064a\u0645\u0627\u0646 \u0627\u0644\u0645\u062c\u0645\u0644 \u0627\u0644\u0630\u064a \u064a\u0642\u0648\u0645 \u0639\u0644\u064a\u0647 \u0627\u0644\u062f\u064a\u0646 \u0641\u064a \u0623\u0648\u0644\u0649 \u0645\u0631\u0627\u062a\u0628\u0647. \u064a\u0642\u0648\u0644 \u0627\u0644\u0644\u0647 \u062a\u0639\u0627\u0644\u0649: {\u0641\u064e\u0644\u064e\u0627 \u0648\u064e\u0631\u064e\u0628\u0651\u0650\u0643\u064e \u0644\u064e\u0627 \u06cc\u064f\u0624\u06e1\u0645\u0650\u0646\u064f\u0648\u0646\u064e \u062d\u064e\u062a\u0651\u064e\u0649\u0670 \u06cc\u064f\u062d\u064e\u0643\u0651\u0650\u0645\u064f\u0648\u0643\u064e \u0641\u0650\u06cc\u0645\u064e\u0627 \u0634\u064e\u062c\u064e\u0631\u064e \u0628\u064e\u06cc\u06e1\u0646\u064e\u0647\u064f\u0645\u06e1 \u062b\u064f\u0645\u0651\u064e \u0644\u064e\u0627 \u06cc\u064e\u062c\u0650\u062f\u064f\u0648\u0627\u06df \u0641\u0650\u06cc\u06e4 \u0623\u064e\u0646\u0641\u064f\u0633\u0650\u0647\u0650\u0645\u06e1 \u062d\u064e\u0631\u064e\u062c\u064b\u0627 \u0645\u0651\u0650\u0645\u0651\u064e\u0627 \u0642\u064e\u0636\u064e\u06cc\u06e1\u062a\u064e \u0648\u064e\u06cc\u064f\u0633\u064e\u0644\u0651\u0650\u0645\u064f\u0648\u0627\u06df \u062a\u064e\u0633\u06e1\u0644\u0650\u06cc\u0645\u064b\u0627} [\u0627\u0644\u0646\u0633\u0627\u0621: 65]\u061b \u0641\u0627\u0646\u0638\u0631 \u0643\u064a\u0641 \u062c\u0639\u0644 \u0627\u0644\u0644\u0647 \u0627\u0644\u062a\u0633\u0644\u064a\u0645 \u0633\u0628\u0628\u0627 \u0644\u0644\u0625\u064a\u0645\u0627\u0646 \u0648\u0625\u0646 \u062c\u0627\u0621 \u062a\u0631\u062a\u064a\u0628\u0647 \u0645\u062a\u0623\u062e\u0631\u0627 \u0641\u064a \u0627\u0644\u0622\u064a\u0629 \u0627\u0644\u0643\u0631\u064a\u0645\u0629. \u0648\u0623\u0645\u0627 \u0642\u0648\u0644 \u0627\u0644\u0644\u0647 \u062a\u0639\u0627\u0644\u0649 (\u0627\u0644\u0630\u064a \u0627\u0633\u062a\u062f\u0644 \u0628\u0647 \u0627\u0644\u0634\u064a\u062e): {\u0641\u064e\u0671\u0639\u06e1\u0644\u064e\u0645\u06e1 \u0623\u064e\u0646\u0651\u064e\u0647\u064f\u06e5 \u0644\u064e\u0627\u06e4 \u0625\u0650\u0644\u064e\u0640\u0670\u0647\u064e \u0625\u0650\u0644\u0651\u064e\u0627 \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0648\u064e\u0671\u0633\u06e1\u062a\u064e\u063a\u06e1\u0641\u0650\u0631\u06e1 \u0644\u0650\u0630\u064e\u0646\u06e2\u0628\u0650\u0643\u064e \u0648\u064e\u0644\u0650\u0644\u06e1\u0645\u064f\u0624\u06e1\u0645\u0650\u0646\u0650\u06cc\u0646\u064e \u0648\u064e\u0671\u0644\u06e1\u0645\u064f\u0624\u06e1\u0645\u0650\u0646\u064e\u0640\u0670\u062a\u0650\u06d7 \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u06cc\u064e\u0639\u06e1\u0644\u064e\u0645\u064f \u0645\u064f\u062a\u064e\u0642\u064e\u0644\u0651\u064e\u0628\u064e\u0643\u064f\u0645\u06e1 \u0648\u064e\u0645\u064e\u062b\u06e1\u0648\u064e\u0649\u0670\u0643\u064f\u0645\u06e1} [\u0645\u062d\u0645\u062f: \u0661\u0669]\u060c \u0641\u0625\u0646\u0647 \u0642\u062f \u062a\u0648\u062c\u0647 \u0627\u0644\u0643\u0644\u0627\u0645 \u0641\u064a\u0647 \u0625\u0644\u0649 \u0627\u0644\u0646\u0628\u064a \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645 \u0648\u0645\u0650\u0646 \u0628\u0639\u062f\u0647 \u0644\u0648\u0631\u062b\u062a\u0647\u061b \u0648\u0627\u0644\u062f\u0644\u064a\u0644 \u0647\u0648 \u0623\u0646 \u0639\u0648\u0627\u0645 \u0627\u0644\u0645\u0624\u0645\u0646\u064a\u0646 \u0644\u0627 \u064a\u0646\u0627\u0644\u0647\u0645 \u0645\u0646 \u0647\u0630\u0647 \u0627\u0644\u0645\u0631\u062a\u0628\u0629 \u0625\u0644\u0627 \u0627\u0644\u0627\u0633\u062a\u063a\u0641\u0627\u0631 \u0645\u0646 \u0642\u0650\u0628\u0644 \u0627\u0644\u0646\u0628\u064a \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645 \u0644\u0647\u0645. \u0648\u0627\u0644\u0627\u0633\u062a\u063a\u0641\u0627\u0631 \u0627\u0644\u0645\u0630\u0643\u0648\u0631 \u0647\u0646\u0627\u060c \u062f\u0627\u062e\u0644 \u0636\u0645\u0646 \u0627\u0644\u062a\u0632\u0643\u064a\u0629 \u0627\u0644\u062a\u064a \u064a\u0632\u0643\u064a\u0647\u0627 \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645 \u0644\u0647\u0645. \u0648\u0623\u0645\u0627 \u0627\u0644\u0627\u0633\u062a\u063a\u0641\u0627\u0631 \u0627\u0644\u0645\u062e\u0635\u0648\u0635 \u0627\u0644\u0630\u064a \u0644\u0644\u0646\u0628\u064a \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645 \u0641\u064a \u0646\u0641\u0633\u0647\u060c \u0641\u0647\u0648 \u062d\u0627\u0635\u0644 \u0639\u0644\u0649 \u0627\u0644\u062a\u0645\u0627\u0645 \u0628\u0627\u0644\u0645\u0639\u0646\u0649 \u0627\u0644\u0645\u0639\u0644\u0648\u0645 \u0644\u062e\u0648\u0627\u0635 \u0647\u0630\u0647 \u0627\u0644\u0623\u0645\u0629\u061b \u0648\u0625\u0646\u0645\u0627 \u0648\u0631\u062f \u0647\u0646\u0627 \u062d\u062a\u0649 \u064a\u0643\u0648\u0646 \u0633\u0628\u0628\u0627 \u0644\u0644\u0627\u0633\u062a\u0632\u0627\u062f\u0629 \u0645\u0646 \u0627\u0644\u0639\u0644\u0645 \u0628\u0627\u0644\u0644\u0647\u060c \u0643\u0645\u0627 \u0623\u0645\u0631 \u0627\u0644\u0644\u0647 \u0646\u0628\u064a\u0651\u0647 \u0641\u064a \u0642\u0648\u0644\u0647 \u062a\u0639\u0627\u0644\u0649: {\u0648\u064e\u0642\u064f\u0644 \u0631\u0651\u064e\u0628\u0651\u0650 \u0632\u0650\u062f\u06e1\u0646\u0650\u06cc \u0639\u0650\u0644\u06e1\u0645\u064b\u0627} [\u0637\u0647: 114]. \u0648\u0647\u0630\u0627 \u0627\u0644\u0627\u0633\u062a\u063a\u0641\u0627\u0631 \u0627\u0644\u062e\u0627\u0635 \u064a\u0646\u0627\u0644\u0647 \u0627\u0644\u0648\u0631\u062b\u0629 \u0628\u0627\u0644\u062a\u0628\u0639 \u0644\u0644\u0646\u0628\u064a \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645\u060c \u0644\u0627 \u0628\u0627\u0644\u0623\u0635\u0627\u0644\u0629. \u0648\u0623\u0645\u0627 \u0627\u0644\u0639\u0627\u0645\u0629\u060c \u0641\u0644\u0645 \u064a\u0643\u0644\u0641\u0647\u0645 \u0627\u0644\u0644\u0647 \u0647\u0646\u0627 \u0627\u0633\u062a\u063a\u0641\u0627\u0631\u0627\u060c \u0644\u0623\u0646\u0647\u0645 \u064a\u062c\u0647\u0644\u0648\u0646 \u0645\u0639\u0646\u0627\u0647\u061b \u0628\u0644 \u0643\u0644\u0641 \u0628\u0647 \u0627\u0644\u0645\u062a\u0628\u0648\u0639 \u0644\u0647\u0645 \u0648\u0627\u0644\u0625\u0645\u0627\u0645 \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645\u061b \u0648\u064a\u0628\u0642\u0649 \u0627\u0644\u0627\u0633\u062a\u063a\u0641\u0627\u0631 \u0627\u0644\u0645\u0637\u0644\u0648\u0628 \u0644\u0644\u0639\u0627\u0645\u0629\u060c \u0645\u0639\u0646\u0649 \u0642\u0634\u0631\u064a\u0627 \u0644\u0647\u0630\u0627 \u0627\u0644\u0645\u0639\u0646\u0649 \u0627\u0644\u0623\u0635\u0644\u064a. \u0648\u062d\u062a\u0649 \u064a\u0639\u0644\u0645 \u0627\u0644\u0646\u0627\u0633 \u0627\u0644\u0641\u0631\u0642 \u0628\u064a\u0646 \u0627\u0644\u0627\u0633\u062a\u063a\u0641\u0627\u0631\u064a\u0652\u0646 \u0648\u062c\u0628 \u0623\u0646 \u0646\u0630\u0643\u0631 \u0623\u0646 \u0627\u0644\u0627\u0633\u062a\u063a\u0641\u0627\u0631 \u0628\u0627\u0644\u0645\u0639\u0646\u0649 \u0627\u0644\u0623\u0635\u0644\u064a \u062a\u0643\u0648\u0646 \u0646\u062a\u064a\u062c\u062a\u0647 \u0646\u0648\u0631\u0627 \u064a\u064f\u0630\u0647\u0628 \u0638\u0644\u0645\u0629 \u0630\u0627\u062a \u0627\u0644\u0639\u0628\u062f\u060c \u0641\u064a \u062d\u064a\u0646 \u062a\u0643\u0648\u0646 \u0646\u062a\u064a\u062c\u0629 \u0627\u0644\u0627\u0633\u062a\u063a\u0641\u0627\u0631 \u0627\u0644\u0635\u0648\u0631\u064a \u0623\u062c\u0648\u0631\u0627 \u062a\u0632\u064a\u062f \u0641\u064a \u0643\u0641\u0629 \u062d\u0633\u0646\u0627\u062a \u0635\u0627\u062d\u0628\u0647\u0627. \u0648\u0627\u0644\u0623\u0645\u0631\u0627\u0646 (\u0627\u0644\u0646\u0648\u0631 \u0648\u0627\u0644\u0623\u062c\u0648\u0631)\u060c \u0644\u0627 \u064a\u0646\u0628\u063a\u064a \u0627\u0644\u062e\u0644\u0637 \u0628\u064a\u0646\u0647\u0645\u0627\u060c \u0625\u0646 \u0643\u0627\u0646 \u0627\u0644\u0639\u0628\u062f \u062d\u0631\u064a\u0635\u0627 \u0639\u0644\u0649 \u0641\u0647\u0645 \u0645\u0639\u0627\u0646\u064a \u0627\u0644\u0642\u0631\u0622\u0646 \u0639\u0644\u0649 \u0648\u062c\u0647\u0647\u0627. \u0641\u0627\u0644\u062e\u0637\u0627\u0628 \u0641\u064a \u0627\u0644\u0622\u064a\u0629 \u0627\u0644\u062a\u064a \u0630\u0643\u0631\u0647\u0627 \u0627\u0644\u0634\u064a\u062e \u0625\u0630\u0627\u064b \u062e\u0637\u0627\u0628 \u0644\u0644\u0648\u0627\u0635\u0644\u064a\u0646 \u0639\u0646\u062f \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0637\u0631\u064a\u0642\u060c \u0644\u0627 \u0625\u0644\u0649 \u0627\u0644\u0645\u0628\u062a\u062f\u0626\u064a\u0646 \u0643\u0645\u0627 \u062a\u0648\u0647\u0645 \u0627\u0644\u0634\u064a\u062e. \u0648\u0634\u062a\u0627\u0646 \u0645\u0627 \u0628\u064a\u0646 \u0627\u0644\u0628\u062f\u0627\u064a\u0629 \u0648\u0627\u0644\u0646\u0647\u0627\u064a\u0629 \u0644\u0648 \u0643\u0627\u0646 \u0627\u0644\u0634\u064a\u062e \u064a\u062a\u0646\u0628\u0647!... \u0648\u0625\u0646 \u0647\u0630\u0627 \u0627\u0644\u062e\u0644\u0637 \u0641\u064a \u0627\u0644\u0645\u0639\u0627\u0646\u064a \u0645\u0646 \u0642\u0650\u0628\u0644 \u0639\u0644\u0645\u0627\u0621 \u0627\u0644\u062f\u064a\u0646 \u0642\u062f \u0623\u0642\u0639\u062f \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0639\u0646 \u0627\u0644\u0646\u0647\u0648\u0636 \u0625\u0644\u0649 \u0637\u0644\u0628 \u0633\u0644\u0648\u0643 \u0627\u0644\u0637\u0631\u064a\u0642\u061b \u0648\u0625\u0646\u0647\u0627 \u0644\u0645\u0635\u064a\u0628\u0629 \u0639\u0638\u064a\u0645\u0629\u060c \u0645\u0627 \u0632\u0627\u0644\u062a \u0627\u0644\u0623\u0645\u0629 \u062a\u0639\u0627\u0646\u064a \u0645\u0646 \u0622\u062b\u0627\u0631\u0647\u0627 \u0627\u0644\u0633\u064a\u0626\u0629 \u0643\u0645\u0627 \u0644\u0627 \u064a\u062e\u0641\u0649 \u0639\u0646 \u0646\u0638\u0631 \u0645\u0646 \u062a\u0633\u0644\u062d \u0628\u0627\u0644\u0625\u0646\u0635\u0627\u0641...<\/p>\n<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0648\u0646\u062d\u0646 \u0625\u0630 \u0646\u0642\u0648\u0644 \u0647\u0646\u0627 \u0645\u0627 \u0646\u0642\u0648\u0644\u060c \u0644\u0627 \u062a\u063a\u064a\u0628 \u0639\u0646\u0627 \u0645\u0643\u0627\u0646\u0629 \u0634\u064a\u062e \u0627\u0644\u0623\u0632\u0647\u0631 \u0648\u0644\u0627 \u0637\u064a\u0628\u0648\u0628\u062a\u0647\u061b \u0643\u0645\u0627 \u0644\u0627 \u064a\u063a\u064a\u0628 \u0639\u0646\u0627 \u062d\u0631\u0635\u0647 \u0639\u0644\u0649 \u0625\u062e\u0644\u0627\u0635 \u0627\u0644\u0646\u0635\u064a\u062d\u0629 \u0644\u0644\u0633\u0627\u0645\u0639\u064a\u0646 \u062d\u0643\u0627\u0645\u0627 \u0648\u0645\u062d\u0643\u0648\u0645\u064a\u0646\u061b \u0648\u0644\u0648\u0644\u0627 \u0623\u0646 \u0627\u0644\u0633\u0643\u0648\u062a \u0639\u0644\u0649 \u0645\u0627 \u0630\u0643\u0631\u0647 \u0645\u0646 \u0623\u062e\u0637\u0627\u0621 \u0628\u064a\u0651\u0646\u0629 \u0640 \u062a\u062d\u0631\u0641 \u0645\u0646 \u0645\u0639\u0627\u0646\u064a \u0627\u0644\u062f\u064a\u0646 \u0644\u062f\u0649 \u0627\u0644\u0633\u0627\u0645\u0639\u064a\u0646 \u0648\u062a\u0643\u0631\u0633 \u0627\u0644\u0627\u0631\u062a\u0643\u0627\u0633 \u0627\u0644\u0630\u064a \u0646\u062d\u0646 \u0641\u064a\u0647 \u0640 \u062d\u0631\u0627\u0645\u060c \u0645\u0627 \u0643\u0646\u0627 \u0646\u0643\u062a\u0628 \u0647\u0630\u0627 \u0627\u0644\u0645\u0642\u0627\u0644. \u0648\u0644\u0639\u0644 \u0641\u064a\u0645\u0627 \u0642\u062f\u0645\u0646\u0627\u0647 \u0645\u0646 \u0639\u0630\u0631 \u0645\u0627 \u064a\u0634\u0641\u0639 \u0644\u0646\u0627 \u0639\u0646\u062f \u0623\u062e\u064a\u0646\u0627 \u0627\u0644\u0623\u0643\u0628\u0631 \u0634\u064a\u062e \u0627\u0644\u0623\u0632\u0647\u0631\u060c \u0643\u0641\u0627\u0646\u0627 \u0627\u0644\u0644\u0647 \u0648\u0625\u064a\u0627\u0647 \u0627\u0644\u0633\u0648\u0621 \u0645\u0646 \u0628\u064a\u0646 \u0623\u064a\u062f\u064a\u0646\u0627 \u0648\u0645\u0646 \u062e\u0644\u0641\u0646\u0627 \u0648\u0639\u0646 \u0623\u064a\u0645\u0627\u0646\u0646\u0627 \u0648\u0639\u0646 \u0634\u0645\u0627\u0626\u0644\u0646\u0627\u060c \u0648\u0631\u062f \u0623\u0645\u062a\u0646\u0627 \u0625\u0644\u0649 \u0635\u062d\u064a\u062d \u0627\u0644\u062f\u064a\u0646 \u062d\u062a\u0649 \u064a\u0639\u0648\u062f \u0644\u0647\u0627 \u0645\u062c\u062f\u0647\u0627 \u0627\u0644\u062f\u0646\u064a\u0648\u064a \u0648\u0627\u0644\u0623\u062e\u0631\u0648\u064a. \u0628\u0627\u0631\u0643 \u0627\u0644\u0644\u0647 \u0641\u064a \u0634\u064a\u062e \u0627\u0644\u0623\u0632\u0647\u0631 \u0648\u062c\u0639\u0644\u0647 \u0635\u062f\u0651\u0627\u0639\u0627 \u0628\u0627\u0644\u062d\u0642 \u0623\u0645\u0651\u0627\u0631\u0627 \u0628\u0627\u0644\u0645\u0639\u0631\u0648\u0641 \u0648\u0646\u0647\u0651\u0627\u0621 \u0639\u0646 \u0627\u0644\u0645\u0646\u0643\u0631\u061b \u0648\u0628\u0627\u0631\u0643 \u0641\u064a \u0645\u0635\u0631 \u0648\u0623\u0647\u0644\u0647\u0627 \u0648\u062c\u0639\u0644 \u0623\u0645\u0648\u0631\u0647\u0645 \u0625\u0644\u0649 \u062e\u064a\u0627\u0631\u0647\u0645\u060c \u0648\u0639\u0641\u0627 \u0639\u0646\u0627 \u0648\u0639\u0646\u0647\u0645 \u0628\u0641\u0636\u0644\u0647 \u0648\u0645\u064e\u0646\u0651\u0647\u060c \u0648\u0628\u0628\u0631\u0643\u0629 \u0647\u0630\u0627 \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u0643\u0631\u064a\u0645 \u0644\u062f\u064a\u0647: \u0634\u0647\u0631 \u0631\u0645\u0636\u0627\u0646 \u0627\u0644\u0630\u064a \u0623\u064f\u0646\u0632\u0644 \u0641\u064a\u0647 \u0627\u0644\u0642\u0631\u0622\u0646. \u0622\u0645\u064a\u0646\u060c \u0648\u0627\u0644\u062d\u0645\u062f \u0644\u0644\u0647 \u0631\u0628 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0646.<br \/>&nbsp;<\/p>\n","protected":false},"excerpt":{"rendered":"<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0628\u0633\u0645 \u0627\u0644\u0644\u0647 \u0648\u0627\u0644\u062d\u0645\u062f \u0644\u0644\u0647\u060c \u0648\u0635\u0644\u0649 \u06