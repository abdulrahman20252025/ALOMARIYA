3a\u0644\u0627\u0642 \u0645\u0631\u0643\u0632 \u0627\u0644\u0623\u0644\u0628\u0627\u0646\u064a \u0644\u0644\u062f\u0631\u0627\u0633\u0627\u062a \u0648\u0627\u0644\u0623\u0628\u062d\u0627\u062b\u060c \u0628\u062a\u0627\u0631\u064a\u062e: 21\/04\/1447\u0647\u0640\u060c \u0627\u0644\u0645\u0648\u0627\u0641\u0642 \u0644\u0640: 14\/10\/2025\u0645. \u0648\u0644\u0642\u062f \u0639\u0644\u0644\u062a \u0627\u0644\u0648\u0632\u0627\u0631\u0629 \u0642\u0631\u0627\u0631\u0647\u0627 \u0628\u0640: [\u0642\u064a\u0627\u0645 \u0627\u0644\u0645\u0631\u0643\u0632 \u0628\u0623\u0646\u0634\u0637\u0629 \u0648\u062a\u062f\u0631\u064a\u0633 \u0648\u0646\u0634\u0631 \u0623\u0641\u0643\u0627\u0631 \u062a\u062a\u0639\u0627\u0631\u0636 \u0645\u0639 \u0627\u0644\u0641\u0643\u0631 \u0627\u0644\u062f\u064a\u0646\u064a \u0627\u0644\u0639\u0627\u0645 \u0644\u0644\u0645\u062c\u062a\u0645\u0639 \u0627\u0644\u0623\u0631\u062f\u0646\u064a\u060c \u0648\u062a\u0645\u0633 \u0628\u0627\u0644\u062b\u0648\u0627\u0628\u062a \u0627\u0644\u062f\u064a\u0646\u064a\u0629 \u0648\u0627\u0644\u0639\u0642\u062f\u064a\u0651\u0629\u060c \u0648\u062a\u062e\u0631\u062c \u0639\u0646 \u0627\u0644\u0623\u0647\u062f\u0627\u0641 \u0627\u0644\u062a\u064a \u0631\u064f\u062e\u0651\u0635 \u0627\u0644\u0645\u0631\u0643\u0632 \u0644\u0623\u062c\u0644\u0647\u0627\u061b \u0645\u0645\u0627 \u064a\u0624\u062f\u0651\u064a \u0625\u0644\u0649 \u0627\u0644\u0639\u0628\u062b \u0628\u0627\u0644\u0648\u062d\u062f\u0629 \u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u0648\u0627\u0644\u062a\u0646\u0648\u0639 \u0627\u0644\u062b\u0642\u0627\u0641\u064a \u0648\u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u060c \u0627\u0644\u0623\u0645\u0631 \u0627\u0644\u0630\u064a \u064a\u062a\u0639\u0627\u0631\u0636 \u0645\u0639 \u0631\u0624\u064a\u0629 \u0627\u0644\u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0647\u0627\u062f\u0641\u0629 \u0625\u0644\u0649 \u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0648\u0633\u0637\u064a\u0629 \u0648\u0627\u0644\u0627\u0639\u062a\u062f\u0627\u0644 \u0648\u0627\u0644\u062f\u0639\u0648\u0629 \u0625\u0644\u0649 \u0627\u0644\u0644\u0647 \u0628\u0627\u0644\u062d\u0643\u0645\u0629 \u0648\u0627\u0644\u0645\u0648\u0639\u0638\u0629 \u0627\u0644\u062d\u0633\u0646\u0629] (\u0645\u0646\u0642\u0648\u0644 \u0646\u0635\u0651\u0627 \u0639\u0646 \u0642\u0631\u0627\u0631 \u0627\u0644\u0648\u0632\u0627\u0631\u0629).<\/span><\/p>\n<p><span class=\"custom-indent\">\u0648\u0631\u063a\u0645 \u0639\u062f\u0645 \u0645\u0648\u0627\u0641\u0642\u062a\u0646\u0627 \u0646\u062d\u0646\u060c \u0645\u0646 \u0627\u0644\u062c\u0647\u0629 \u0627\u0644\u0639\u0644\u0645\u064a\u0629\u060c \u0639\u0644\u0649 \u0639\u0628\u0627\u0631\u0627\u062a \u0643\u0640: \"\u0627\u0644\u0641\u0643\u0631 \u0627\u0644\u062f\u064a\u0646\u064a\"\u060c \u0644\u0643\u0648\u0646 \u0627\u0644\u062f\u064a\u0646 \u0645\u0624\u0633\u0651\u064e\u0633\u0627 \u0639\u0644\u0649 \u0627\u0644\u0648\u062d\u064a \u0644\u0627 \u0639\u0644\u0649 \u0627\u0644\u0641\u0643\u0631\u060c \u0641\u0625\u0646\u0646\u0627 \u0646\u0634\u064a\u062f \u0628\u0647\u0630\u0627 \u0627\u0644\u0642\u0631\u0627\u0631 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a \u0644\u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0623\u0648\u0642\u0627\u0641 \u0627\u0644\u0623\u0631\u062f\u0646\u064a\u0629\u060c \u0648\u0646\u0647\u064a\u0628 \u0628\u0643\u0644 \u0646\u0638\u064a\u0631\u0627\u062a\u0647\u0627 \u0641\u064a \u0627\u0644\u0628\u0644\u062f\u0627\u0646 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0648\u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a\u0629\u060c \u0623\u0646 \u062a\u062d\u0630\u0648 \u062d\u0630\u0648\u0647\u0627 \u0641\u064a \u0627\u0644\u0642\u0631\u064a\u0628 \u0627\u0644\u0639\u0627\u062c\u0644\u061b \u0648\u0647\u0630\u0627\u060c \u0642\u0637\u0639\u0627 \u0644\u0623\u0633\u0628\u0627\u0628 \u0627\u0644\u0641\u062a\u0646\u0629 \u0648\u0627\u0644\u0636\u0644\u0627\u0644 \u0641\u064a \u0645\u062c\u062a\u0645\u0639\u0627\u062a\u0646\u0627\u060c \u0648\u0639\u0648\u062f\u0629 \u0628\u0647\u0627 \u0625\u0644\u0649 \u0627\u0644\u0645\u062d\u062c\u0651\u0629 \u0627\u0644\u0628\u064a\u0636\u0627\u0621 \u0648\u0627\u0644\u062f\u064a\u0646 \u0627\u0644\u062d\u0646\u064a\u0641\u060c \u0628\u0639\u062f\u0645\u0627 \u0639\u0645\u0644\u062a \u0641\u064a\u0646\u0627 \u0623\u064a\u0627\u062f\u064a \u0627\u0644\u0634\u064a\u0627\u0637\u064a\u0646 \u0648\u0627\u0644\u0645\u0633\u062a\u0639\u0645\u0631\u064a\u0646 \u0628\u0634\u062a\u0649 \u0627\u0644\u0648\u0633\u0627\u0626\u0644\u060c \u0628\u0642\u0635\u062f \u0625\u0628\u0639\u0627\u062f\u0646\u0627 \u0639\u0646 \u0633\u0628\u0628 \u0642\u0648\u062a\u0646\u0627 \u0627\u0644\u0623\u0648\u0644\u060c \u0648\u0627\u0644\u0630\u064a \u0647\u0648 \u0627\u0644\u0625\u0633\u0644\u0627\u0645 \u0644\u0644\u0647 \u0639\u0644\u0649 \u0627\u0644\u0633\u0646\u0651\u0629 \u0627\u0644\u0645\u062d\u0645\u062f\u064a\u0651\u0629 \u0627\u0644\u0634\u0631\u064a\u0641\u0629 \u0648\u0627\u0644\u0637\u0627\u0647\u0631\u0629...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0648\u0641\u0651\u064e\u0642 \u0627\u0644\u0644\u0647 \u0648\u0644\u0627\u0629 \u0623\u0645\u0648\u0631\u0646\u0627 \u062c\u0645\u064a\u0639\u0627\u060c \u0625\u0644\u0649 \u0627\u0644\u0639\u0648\u062f\u0629 \u0628\u0646\u0627 \u0625\u0644\u0649 \u0635\u0631\u064a\u062d \u0627\u0644\u062d\u0642\u060c \u0639\u0646 \u0637\u0631\u064a\u0642 \u0625\u0639\u0627\u062f\u0629 \u0627\u0644\u0646\u0638\u0631 \u0641\u064a \u0627\u0644\u0642\u0648\u0627\u0646\u064a\u0646 \u0648\u0627\u0644\u0646\u0635\u0648\u0635 \u0627\u0644\u062a\u0646\u0638\u064a\u0645\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u062e\u0627\u0644\u0641 \u0623\u0635\u0644 \u0627\u0644\u062f\u064a\u0646\u060c \u0648\u0634\u0643\u0631 \u0627\u0644\u0644\u0647 \u0644\u0623\u062e\u064a\u0646\u0627 \u0648\u0632\u064a\u0631 \u0627\u0644\u0623\u0648\u0642\u0627\u0641 \u0627\u0644\u0623\u0631\u062f\u0646\u064a \u062e\u0637\u0648\u062a\u0647 \u0627\u0644\u062c\u0631\u064a\u0626\u0629 \u