{"id":43314,"date":"2025-11-25T20:15:21","date_gmt":"2025-11-25T20:15:21","guid":{"rendered":"https:\/\/www.alomariya.org\/?p=43314"},"modified":"2025-11-25T20:15:21","modified_gmt":"2025-11-25T20:15:21","slug":"%d9%82%d8%b1%d8%a7%d8%b1-%d8%aa%d8%b1%d8%a7%d9%85%d8%a8-%d8%b5%d8%a7%d8%a6%d8%a8","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d9%82%d8%b1%d8%a7%d8%b1-%d8%aa%d8%b1%d8%a7%d9%85%d8%a8-%d8%b5%d8%a7%d8%a6%d8%a8\/","title":{"rendered":"\u0642\u0631\u0627\u0631 \u062a\u0631\u0627\u0645\u0628 \u0635\u0627\u0626\u0628!..."},"content":{"rendered":"<p>&nbsp;<\/p>\n<p><span class=\"custom-indent\">\u0625\u0646 \u0642\u0631\u0627\u0631 \u0627\u0644\u0631\u0626\u064a\u0633 \u062a\u0631\u0627\u0645\u0628\u060c \u0628\u062a\u0635\u0646\u064a\u0641 \u062c\u0645\u0627\u0639\u0627\u062a \"\u0627\u0644\u0625\u062e\u0648\u0627\u0646 \u0627\u0644\u0645\u0633\u0644\u0645\u0648\u0646\" \u0625\u0631\u0647\u0627\u0628\u064a\u0629\u060c \u0643\u0627\u0646 \u064a\u0646\u0628\u063a\u064a \u0623\u0646 \u062a\u0633\u0628\u0642 \u0625\u0644\u064a\u0647 \u0627\u0644\u062f\u0648\u0644 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0648\u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a\u0629 \u0643\u0644\u0647\u0627\u060c \u0644\u0648 \u0623\u0646\u0647\u0627 \u0643\u0627\u0646\u062a \u062a\u0646\u0637\u0644\u0642 \u0645\u0646 \u062f\u064a\u0646\u0647\u0627\u061b \u0648\u0644\u0643\u0646\u0651 \u0627\u0644\u062d\u0642\u064a\u0642\u0629 \u0627\u0644\u0645\u0631\u0651\u0629\u060c \u0647\u064a \u062b\u0628\u0648\u062a \u0627\u0633\u062a\u0639\u0645\u0627\u0644 \u0628\u0639\u0636\u0647\u0627 \u0644\u0644\u062a\u0646\u0638\u064a\u0645\u0627\u062a \u0627\u0644\u0625\u062e\u0648\u0627\u0646\u064a\u0629\u060c \u0641\u064a \u062d\u0631\u0628\u0647\u0627 \u0639\u0644\u0649 \u0623\u062e\u0648\u0627\u062a\u0647\u0627 \u0645\u0646 \u062f\u0648\u0644 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0623\u0646\u0641\u0633\u0647\u0645. \u063a\u064a\u0631 \u0623\u0646\u0646\u0627 \u0641\u064a \u0627\u0644\u0645\u0642\u0627\u0628\u0644\u060c \u0644\u0627 \u0646\u062f\u0639\u0648 \u062a\u0644\u0643 \u0627\u0644\u062f\u0648\u0644\u060c \u0625\u0644\u0649 \u0627\u0644\u062e\u0631\u0648\u062c \u0639\u0646 \u0623\u0635\u0648\u0644 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u061b \u0648\u0647\u0630\u0627\u060c \u0644\u0623\u0646\u0647\u0645 \u0633\u064a\u0643\u0648\u0646\u0648\u0646 \u0645\u0624\u064a\u0651\u062f\u064a\u0646 \u0644\u062a\u0646\u0638\u064a\u0645\u0627\u062a \u0627\u0644\u0625\u062e\u0648\u0627\u0646 \u0641\u064a \u0627\u0644\u0623\u0635\u0644 \u0627\u0644\u0641\u0633\u0642\u064a\u0651 \u0627\u0644\u0630\u064a \u0647\u0645 \u0639\u0644\u064a\u0647. \u0644\u0630\u0644\u0643\u060c \u0641\u0646\u062d\u0646 \u0646\u062f\u0639\u0648 \u0625\u0644\u0649 \u0627\u0644\u062d\u062f \u0645\u0646 \u0634\u0631\u0651 \u0627\u0644\u062c\u0645\u0627\u0639\u0627\u062a \u0627\u0644\u0625\u062e\u0648\u0627\u0646\u064a\u0629\u060c \u0628\u0627\u0644\u0639\u0648\u062f\u0629 \u0625\u0644\u0649 \u0635\u062d\u064a\u062d \u0627\u0644\u062f\u0651\u064a\u0646 \u0627\u0644\u0630\u064a \u0642\u062f \u0637\u064f\u0645\u0633 \u0645\u0646\u0630 \u0642\u0631\u0648\u0646 \u0645\u062a\u062a\u0627\u0644\u064a\u0629\u061b \u0623\u064a \u0645\u0646\u0630 \u0627\u0644\u0627\u0646\u0642\u0644\u0627\u0628 \u0627\u0644\u0643\u0628\u064a\u0631 \u0644\u0645\u0639\u0627\u0648\u064a\u0629!... \u0648\u0646\u062d\u0646 \u0644\u0627 \u0646\u0628\u063a\u064a \u0627\u0644\u062e\u0631\u0648\u062c \u0645\u0646 \u0645\u0631\u0636\u064d \u0625\u0644\u0649 \u0645\u0631\u0636\u064d\u060c \u0628\u0644 \u0646\u0631\u064a\u062f \u0627\u0644\u062e\u0631\u0648\u062c \u0645\u0646 \u062d\u0627\u0644 \u0627\u0644\u0645\u0631\u0636 \u0625\u0644\u0649 \u062d\u0627\u0644 \u0627\u0644\u0635\u0651\u062d\u0651\u0629...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0644\u0642\u062f \u0639\u0645\u0644\u0646\u0627 \u0646\u062d\u0646\u060c \u0645\u0646\u0630 \u0639\u064e\u0642\u062f\u064a\u0652\u0646 \u0648\u0646\u0635\u0641\u060c \u0639\u0644\u0649 \u0641\u0636\u062d \u0627\u0644\u0623\u0633\u0627\u0633 \u0627\u0644\u0641\u0627\u0633\u062f \u0627\u0644\u0630\u064a \u062a\u0642\u0648\u0645 \u0639\u0644\u064a\u0647 \u0627\u0644\u062c\u0645\u0627\u0639\u0627\u062a \u0627\u0644\u0625\u062e\u0648\u0627\u0646\u064a\u0629 \u0648\u0645\u0627 \u064a\u062a\u0641\u0631\u0651\u0639 \u0639\u0646\u0647\u0627 \u0645\u0646 \u0627\u0644\u0632\u0648\u0627\u0626\u062f \u0627\u0644\u062b\u0639\u0628\u0627\u0646\u064a\u0629 (\u0641\u064a \u0645\u0642\u0627\u0628\u0644 \u0627\u0644\u062f\u0648\u062f\u064a\u0629)\u060c \u0639\u0644\u0649 \u0627\u0644\u0635\u0639\u064a\u062f\u064a\u0652\u0646 \u0627\u0644\u0639\u0642\u062f\u064a \u0648\u0627\u0644\u0639\u0645\u0644\u064a. \u0648\u0623\u062b\u0628\u062a\u0646\u0627 \u0628\u0627\u0644\u0623\u062f\u0644\u0629 \u0627\u0644\u0634\u0631\u0639\u064a\u0629 \u0648\u0628\u0627\u0644\u0628\u0631\u0627\u0647\u064a\u0646 \u0627\u0644\u0639\u0642\u0644\u064a\u0629\u060c \u0623\u0646 \u0627\u0644\u062c\u0645\u0627\u0639\u0627\u062a \u0627\u0644\u0625\u062e\u0648\u0627\u0646\u064a\u0629\u060c \u062a\u0639\u0645\u0644 \u0636\u062f\u0651 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0648\u0636\u062f\u0651 \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0643\u0644\u0647\u0627\u061b \u0648\u0630\u0644\u0643 \u0644\u0623\u0646\u0647\u0627 \u062a\u0639\u062a\u0645\u062f \u0623\u0633\u0644\u0648\u0628 \u0627\u0644\u062a\u0646\u0638\u064a\u0645\u0627\u062a \u0627\u0644\u0633\u0651\u0631\u0651\u064a\u0651\u0629 \u0645\u0646 \u0645\u062b\u064a\u0644\u0627\u062a \u0627\u0644\u0645\u0627\u0633\u0648\u0646\u064a\u0629 \u0648\u0627\u0644\u0635\u0647\u064a\u0648\u0646\u064a\u0629 \u0627\u0644\u062f\u062c\u0651\u0627\u0644\u064a\u0651\u0629 (\u0644\u0627 \u0627\u0644\u064a\u0647\u0648\u062f\u064a\u0629)\u060c \u0648\u0644\u0627 \u062a\u0623\u0628\u0647 \u0644\u0645\u062e\u0627\u0644\u0641\u0629 \u0627\u0644\u0623\u0635\u0648\u0644 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a\u0629 \u0648\u0627\u0644\u0623\u0631\u0643\u0627\u0646\u061b \u0648\u0644\u0643\u0646\u0646\u0627 \u0648\u062c\u062f\u0646\u0627 \u0645\u0642\u0627\u0648\u0645\u0629 \u0644\u0622\u0631\u0627\u0626\u0646\u0627\u060c \u0642\u0648\u064a\u0629 \u062c\u062f\u0627\u061b \u0644\u0623\u0646 \u062a\u0644\u0643 \u0627\u0644\u0645\u0642\u0627\u0648\u0645\u0629 \u062a\u0642\u0641 \u062e\u0644\u0641\u0647\u0627 \u062f\u0648\u0644\u060c \u0627\u062e\u062a\u0627\u0631\u062a \u0623\u0646 \u062a\u0643\u0648\u0646 \u0636\u0645\u0646 \u062d\u0632\u0628 \u0627\u0644\u0634\u064a\u0637\u0627\u0646...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0648\u0631\u063a\u0645 \u062a\u062d\u0630\u064a\u0631\u0646\u0627 \u0645\u0646 \u0647\u0630\u0647 \u0627\u0644\u0622\u0641\u0629 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a\u0629 \u0627\u0644\u062a\u064a \u0623\u0635\u0627\u0628\u062a \u0627\u0644\u0623\u0645\u0629 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a\u0629\u060c \u0648\u0628\u0644\u063a \u0634\u0631\u0651\u0647\u0627 \u0627\u0644\u0639\u0627\u0644\u064e\u0645\u064a\u0646\u060c \u0641\u0625\u0646 \u0628\u0639\u0636 \u0627\u0644\u062f\u0648\u0644 \u0627\u0644\u0645\u0640\u064f\u063a\u0631\u0636\u0629\u060c \u0643\u0642\u0637\u0631 \u0648\u062a\u0631\u0643\u064a\u0627\u060c \u0642\u062f \u0623\u0635\u0631\u0651\u062a\u0627 \u0639\u0644\u0649 \u062f\u0639\u0645 \u0627\u0644\u0645\u0640\u064f\u0637\u0627\u0631\u064e\u062f\u064a\u0646 \u0645\u0646 \u0627\u0644\u0625\u062e\u0648\u0627\u0646\u060c \u0648\u062c\u0645\u0639\u0647\u0627 \u0644\u0647\u0645 \u062a\u062d\u062a \u0639\u0628\u0627\u0621\u062a\u0647\u0627 \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a\u0629\u060c \u0645\u0646 \u0623\u062c\u0644 \u0627\u062a\u062e\u0627\u0630\u0647\u0645 \u0633\u0644\u0627\u062d\u0627 \u062a\u064f\u0636\u0631\u064e\u0628 \u0628\u0644\u062f\u0627\u0646\u0647\u0645 \u0627\u0644\u0623\u0635\u0644\u064a\u0629 \u0628\u0647\u060c \u0648\u064a\u064f\u062e\u0631\u0651\u0628 \u0627\u0644\u0639\u0627\u0644\u0645 \u0627\u0644\u0633\u0651\u0627\u0639\u064a \u0625\u0644\u0649 \u0627\u0644\u0623\u062e\u0648\u0629 \u0648\u0627\u0644\u0633\u0644\u0627\u0645. \u0648\u0645\u0646 \u0627\u0644\u0645\u0639\u0644\u0648\u0645 \u0623\u0646 \u0634\u0631\u0639\u0646\u0627 \u064a\u064f\u062d\u0631\u0651\u0645 \u0639\u0644\u0649 \u0627\u0644\u0645\u0633\u0644\u0645 \u0645\u0642\u0627\u062a\u0644\u0629 \u0623\u062e\u064a\u0647 \u0627\u0644\u0645\u0633\u0644\u0645\u060c \u0648\u062a\u0628\u0639\u0627 \u0644\u0630\u0644\u0643 \u062a\u062d\u0631\u0645 \u0643\u0644 \u0627\u0644\u0633\u064a\u0627\u0633\u0627\u062a \u0627\u0644\u0645\u062e\u0627\u0644\u0641\u0629 \u0644\u0623\u0635\u0648\u0644 \u0627\u0644\u062f\u064a\u0646 \u0641\u064a \u062a\u0644\u0643 \u0627\u0644\u0628\u0644\u062f\u0627\u0646\u060c \u0648\u064a\u062d\u0631\u0645 \u0643\u0644 \u0639\u0645\u0644 \u064a\u0642\u0648\u0645 \u0639\u0644\u0649 \u0627\u0644\u0641\u062a\u0646\u0629 \u0648\u0639\u0644\u0649 \u062d\u0631\u0645\u0627\u0646 \u0634\u0639\u0648\u0628 \u0628\u0623\u0633\u0631\u0647\u0627\u060c \u0645\u0646 \u062d\u0642\u0651\u0647\u0627 \u0641\u064a \u0627\u0644\u062a\u0646\u0645\u064a\u0629 \u0648\u0627\u0644\u0631\u062e\u0627\u0621\u061b \u062e\u0635\u0648\u0635\u0627 \u0625\u0630\u0627 \u0643\u0627\u0646 \u0627\u0644\u0623\u0645\u0631 \u064a\u062a\u0636\u0645\u0651\u0646 \u0625\u0639\u0627\u0646\u0629 \u0644\u0639\u062f\u0648\u0651\u064d \u0639\u0644\u0649 \u0627\u0644\u0635\u0641\u0651 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a \u0627\u0644\u0630\u064a \u0643\u0627\u0646 \u064a\u0646\u0628\u063a\u064a \u0623\u0646 \u064a\u0643\u0648\u0646 \u0648\u0627\u062d\u062f\u0627...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0646\u0639\u0645\u060c \u0625\u0646 \u0627\u0644\u062f\u0648\u0644 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a\u0629 \u062c\u0644\u0651\u0647\u0627\u060c \u0645\u0627 \u062a\u0632\u0627\u0644 \u062a\u0639\u0645\u0644 \u0628\u0627\u0644\u0645\u0646\u0637\u0642 \u0630\u0627\u062a\u0647\u060c \u0636\u0645\u0646 \u0627\u0644\u0639\u062f\u0627\u0648\u0627\u062a \u0627\u0644\u0628\u064a\u0646\u064a\u0629\u061b \u0648\u0644\u0643\u0646 \u0647\u0630\u0627 \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u0641\u0627\u0633\u062f \u0627\u0644\u0645\u062e\u0627\u0644\u0641 \u0635\u0631\u0627\u062d\u0629 \u0644\u0623\u0635\u0648\u0644 \u062f\u064a\u0646\u0646\u0627\u060c \u0644\u0627 \u064a\u0645\u0643\u0646 \u0623\u0646 \u064a\u0635\u064a\u0631 \u0648\u0627\u0642\u0639\u0627 \u0645\u0640\u064f\u0639\u062a\u064e\u0628\u064e\u0631\u0627\u064b \u064a\u064f\u0628\u0646\u0649 \u0639\u0644\u064a\u0647. \u0644\u0630\u0644\u0643\u060c \u0641\u0625\u0646 \u0643\u0644 \u0627\u0644\u062f\u0648\u0644 \u0627\u0644\u0645\u062d\u0627\u0631\u0628\u0629 \u0644\u0634\u0642\u064a\u0642\u0627\u062a\u0647\u0627 \u062e\u064f\u0641\u064a\u0629 \u0623\u0648 \u0639\u0644\u0627\u0646\u064a\u0629\u060c \u0647\u064a \u062a\u0633\u062a\u062c\u0644\u0628 \u0639\u0644\u0649 \u0646\u0641\u0633\u0647\u0627 \u063a\u0636\u0628 \u0627\u0644\u0644\u0647 \u0648\u0644\u0639\u0646\u062a\u0647\u060c \u0627\u0644\u0644\u0630\u064a\u0652\u0646 \u0644\u0646 \u062a\u062a\u062e\u0644\u0651\u0641 \u0646\u062a\u0627\u0626\u062c\u0647\u0645\u0627 \u0643\u062b\u064a\u0631\u0627\u060c \u0648\u0625\u0646 \u062a\u062e\u0644\u0651\u0641\u062a \u0642\u0644\u064a\u0644\u0627 \u0644\u062d\u0643\u0645\u0629 \u064a\u0639\u0644\u0645\u0647\u0627 \u0647\u0648 \u0633\u0628\u062d\u0627\u0646\u0647. \u0648\u0646\u062d\u0646 \u0646\u0631\u0649\u060c \u0623\u0646 \u062a\u0644\u0643 \u0627\u0644\u0646\u062a\u0627\u0626\u062c \u0642\u062f \u0628\u062f\u0623\u062a \u0641\u064a \u0627\u0644\u0638\u0647\u0648\u0631 \u0625\u0644\u0649 \u0639\u0627\u0644\u0645 \u0627\u0644\u0634\u0647\u0627\u062f\u0629\u061b \u0641\u0645\u0646 \u0634\u0627\u0621\u062a \u0645\u0646 \u0627\u0644\u062f\u0648\u0644 \u062a\u062f\u0627\u0631\u0643 \u0623\u0645\u0631\u0647\u0627\u060c \u0641\u0625\u0646\u0647 \u0644\u0645 \u064a\u0639\u062f \u0645\u0646 \u0645\u0640\u064f\u062a\u0651\u064e\u0633\u064e\u0639\u064d \u0623\u0645\u0627\u0645\u0647\u0627\u060c \u0642\u0628\u0644 \u062d\u0644\u0648\u0644 \u0627\u0644\u062a\u063a\u064a\u064a\u0631 \u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0630\u064a \u0633\u064a\u0639\u0631\u0641\u0647 \u0627\u0644\u0639\u0627\u0644\u0645\u060c \u0648\u0627\u0644\u0630\u064a \u0633\u064a\u0643\u0648\u0646 \"\u062a\u0633\u0648\u0646\u0627\u0645\u064a\" \u062a\u0627\u0631\u064a\u062e\u064a\u0627 \u063a\u064a\u0631 \u0645\u0633\u0628\u0648\u0642 \u0627\u0644\u0645\u062b\u064a\u0644...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0625\u0646 \u062a\u0631\u0643\u064a\u0627\u060c \u0642\u062f \u0628\u062f\u0623\u062a \u0628\u0639\u062f \u0648\u0635\u0648\u0644 \u062d\u0632\u0628 \"\u0627\u0644\u0639\u062f\u0627\u0644\u0629 \u0648\u0627\u0644\u062a\u0646\u0645\u064a\u0629\" \u0627\u0644\u062a\u0631\u0643\u064a \u0625\u0644\u0649 \u0633\u064f\u062f\u0651\u0629 \u0627\u0644\u062d\u0643\u0645\u060c \u0642\u0648\u064a\u0629 \u0645\u064e\u0647\u064a\u0628\u0629 \u0627\u0644\u062c\u0627\u0646\u0628\u061b \u0644\u0643\u0646\u0651\u0647\u0627 \u0639\u0627\u062f\u062a \u0628\u0639\u062f \u0625\u0635\u0631\u0627\u0631\u0647\u0627 \u0639\u0644\u0649 \u062c\u0645\u0639 \u0627\u0644\u0641\u0627\u0633\u0642\u064a\u0646 \u0639\u0646 \u0627\u0644\u062f\u0651\u064a\u0646 \u0645\u0646 \u0627\u0644\u0642\u064a\u0627\u062f\u0627\u062a \u0627\u0644\u0625\u062e\u0648\u0627\u0646\u064a\u0629\u060c \u062a\u0628\u062f\u0623 \u0628\u0627\u0644\u0646\u0632\u0648\u0644 \u0639\u0644\u0649 \u0627\u0644\u0635\u0639\u064a\u062f\u064a\u0652\u0646 \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f\u064a \u0648\u0627\u0644\u0633\u064a\u0627\u0633\u064a. \u0648\u0647\u064a \u0625\u0646 \u0644\u0645 \u062a\u0631\u0652\u0639\u064e\u0648\u0650\u060c \u0633\u064a\u0646\u0642\u0644\u0628 \u0641\u064a\u0647\u0627 \u0627\u0644\u0623\u0645\u0631 \u0627\u0646\u0642\u0644\u0627\u0628\u0627\u060c \u064a\u0624\u062f\u0651\u064a \u0627\u0644\u0634\u0639\u0628\u064f \u0627\u0644\u062a\u0631\u0643\u064a \u062b\u0645\u0646\u0647 \u063a\u0627\u0644\u064a\u0627...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0648\u0623\u0645\u0627 \u0642\u0637\u0631\u060c \u0627\u0644\u062a\u064a \u0642\u0628\u0644\u062a \u0623\u0646 \u062a\u062c\u0639\u0644 \u0645\u0646 \u0646\u0641\u0633\u0647\u0627 \u0645\u0646\u0635\u0651\u0629 \u0644\u0645\u062d\u0627\u0631\u0628\u0629 \u062f\u0648\u0644 \u0644\u0647\u0627 \u0645\u0643\u0627\u0646\u062a\u0647\u0627 \u0641\u064a \u0645\u0627\u0636\u064a \u0627\u0644\u0625\u0633\u0644\u0627\u0645 \u0648\u0641\u064a \u0645\u0633\u062a\u0642\u0628\u0644\u0647 \u0643\u0627\u0644\u0645\u063a\u0631\u0628 \u0648\u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\u060c \u062e\u064f\u0641\u064a\u0629 \u0648\u0639\u0644\u0627\u0646\u064a\u0629\u060c \u0644\u0627 \u0628\u062f \u0645\u0646 \u0623\u0646 \u064a\u062d\u064a\u0642 \u0628\u0647\u0627 \u0645\u0643\u0652\u0631\u064f\u0647\u0627\u060c \u0648\u0645\u0646 \u0623\u0646 \u062a\u062e\u062a\u0641\u064a \u064a\u0648\u0645\u0627 \u0645\u0627 \u0643\u0645\u0627 \u0638\u0647\u0631\u062a... \u0641\u0647\u0644 \u062a\u0638\u0646\u0651 \u0646\u0641\u0633\u0647\u0627 \u0628\u0639\u0638\u0645\u0629 \u0627\u0644\u0645\u063a\u0631\u0628 \u0641\u064a \u0627\u0644\u0639\u0627\u0644\u0645\u061f!... \u0645\u0639 \u0623\u0646 \u0647\u0630\u0627 \u0627\u0644\u0645\u063a\u0631\u0628 \u0644\u0645 \u064a\u0635\u0646\u0639 \u0645\u0639\u0647\u0627 \u0641\u064a \u0645\u062d\u0646\u0647\u0627 \u0625\u0644\u0627 \u0645\u0639\u0631\u0648\u0641\u0627!... \u0648\u0644\u0643\u0646\u060c \u0648\u0643\u0645\u0627 \u064a\u064f\u0642\u0627\u0644: \"\u0643\u0644 \u0625\u0646\u0627\u0621\u064d \u0628\u0645\u0627 \u0641\u064a\u0647 \u064a\u0646\u0636\u062d\u064f!...\"\u061b \u0641\u0627\u0644\u0645\u063a\u0631\u0628 \u0628\u0644\u062f \u0627\u0644\u062c\u0648\u062f \u0648\u0627\u0644\u062e\u064a\u0631\u060c \u0648\u0644\u0646 \u064a\u062c\u062f \u0645\u0646\u0647 \u0627\u0644\u0639\u0627\u0644\u0645 \u0625\u0644\u0627 \u062c\u0648\u062f\u0627 \u0648\u062e\u064a\u0631\u0627!... \u0631\u063a\u0645 \u0627\u0644\u0645\u062d\u0646 \u0648\u0627\u0644\u0635\u0651\u0650\u0639\u0627\u0628...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0648\u0623\u0645\u0627 \u0627\u0644\u062c\u0632\u0627\u0626\u0631\u060c \u0627\u0644\u062a\u064a \u064a\u064f\u062d\u0627\u0631\u0628 \u0642\u0627\u062f\u062a\u0647\u0627 \u0641\u064a \u0627\u0644\u0645\u063a\u0631\u0628 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064e\u060c \u0645\u0646\u0630 \u0623\u0646 \u0646\u0634\u0623\u062a \u062f\u0648\u0644\u062a\u0647\u0627 \u0641\u064a \u0633\u0646\u0629 1962\u060c \u0641\u0625\u0646\u0647\u0627 \u0644\u0646 \u062a\u0639\u0631\u0641 \u0625\u0644\u0627 \u0627\u0644\u0633\u0642\u0648\u0637 \u0648\u0627\u0644\u0627\u0646\u062f\u062b\u0627\u0631\u060c \u0645\u0639 \u0625\u0635\u0631\u0627\u0631\u0647\u0627 \u0639\u0644\u0649 \u0645\u0627 \u0647\u064a \u0639\u0644\u064a\u0647 \u0645\u0646 \u0633\u0648\u0621 \u0648\u0634\u0631\u0651\u061b \u0648\u0642\u062f \u0630\u0643\u0631\u062a \u0647\u0630\u0627 \u0644\u0645\u0646 \u0644\u0642\u064a\u062a\u064f \u0645\u0646 \u0625\u062e\u0648\u0627\u0646\u0646\u0627 \u0627\u0644\u062c\u0632\u0627\u0626\u0631\u064a\u0651\u064a\u0646 \u0623\u0648 \u0639\u0631\u0641\u062a\u0647\u0645\u060c \u0641\u064a \u0645\u0646\u0627\u0633\u0628\u0627\u062a \u0639\u062f\u0651\u0629. \u0644\u0645 \u0623\u0643\u0646 \u064a\u0648\u0645\u0627 \u0641\u064a \u062e\u0637\u0627\u0628\u064a \u0645\u062a\u0639\u0635\u0651\u0628\u0627 \u0644\u0628\u0644\u062f\u064a \u0644\u0643\u0648\u0646\u0647 \u0628\u0644\u062f\u064a\u061b \u0641\u0647\u0630\u0627 \u0623\u0633\u0644\u0648\u0628 \u064a\u0639\u062a\u0645\u062f\u0647 \u0627\u0644\u062c\u0627\u0647\u0644\u0648\u0646\u060c \u0648\u0623\u0646\u0627 \u0628\u062d\u0645\u062f \u0627\u0644\u0644\u0647\u060c \u0644\u0633\u062a \u0645\u0646\u0647\u0645\u061b \u0648\u0644\u0643\u0646\u0651\u0646\u064a \u0643\u0646\u062a \u0623\u064f\u062e\u0628\u0631 \u0628\u0645\u0646\u0637\u0642 \u0627\u0644\u0642\u064e\u062f\u064e\u0631\u0650 \u0627\u0644\u0625\u0644\u0647\u064a\u0651\u060c \u0627\u0644\u0630\u064a \u0644\u0627 \u0631\u0627\u062f \u0644\u0647 \u0645\u0646 \u0623\u062d\u062f\u064d \u0645\u0646 \u0627\u0644\u0645\u062e\u0644\u0648\u0642\u064a\u0646. \u0648\u0648\u0627\u0644\u0644\u0647\u060c \u0625\u0646 \u0644\u0645 \u064a\u062a\u0628 \u0642\u0627\u062f\u0629 \u0627\u0644\u062c\u0632\u0627\u0626\u0631\u060c \u0623\u0648 \u064a\u062a\u0648\u0644\u0651\u064e \u0627\u0644\u0642\u064a\u0627\u062f\u0629\u064e \u0628\u062f\u0644\u0647\u0645\u060c \u063a\u064a\u0631\u064f\u0647\u0645 \u0645\u0646 \u0623\u062e\u064a\u0627\u0631 \u0627\u0644\u062c\u0632\u0627\u0626\u0631\u060c \u0641\u0625\u0646\u0651 \u0627\u0644\u0627\u0646\u062f\u062b\u0627\u0631 \u0623\u0633\u0631\u0639 \u0625\u0644\u064a\u0647\u0645 \u0645\u0646 \u0645\u0633\u0627\u0626\u0647\u0645 \u0625\u0646 \u0643\u0627\u0646\u0648\u0627 \u0645\u0640\u064f\u0635\u0628\u0650\u062d\u064a\u0646\u061b \u0623\u0648 \u0645\u0646 \u0635\u0628\u0627\u062d\u0647\u0645 \u0625\u0646 \u0643\u0627\u0646\u0648\u0627 \u0645\u0640\u064f\u0645\u0633\u064a\u0646!... \u0648\u0639\u0644\u0649 \u0643\u0644 \u062d\u0627\u0644\u060c \u0641\u0642\u0631\u064a\u0628\u0627 \u062c\u062f\u0651\u0627\u060c \u0633\u064a\u0639\u0648\u062f \u0627\u0644\u0645\u063a\u0631\u0628 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a \u0625\u0644\u0649 \u0645\u0627 \u0643\u0627\u0646 \u0639\u0644\u064a\u0647 \u0645\u0646 \u0648\u062d\u062f\u0629 \u0648\u0642\u0648\u0629\u061b \u0644\u0643\u0646 \u0628\u0639\u062f \u0623\u0646 \u064a\u0633\u062a\u0639\u064a\u062f \u0627\u0644\u0645\u063a\u0631\u0628 \u0627\u0644\u0623\u0642\u0635\u0649 \u0644\u0645\u0631\u062a\u064e\u0643\u0632\u0627\u062a\u0647 \u0627\u0644\u062f\u064a\u0646\u064a\u0629 \u0641\u064a \u062a\u0645\u0627\u0645 \u0635\u0648\u0631\u062a\u0647\u0627\u060c \u0648\u0628\u0639\u062f \u0623\u0646 \u062a\u064f\u0635\u062d\u0651\u064e\u062d \u0641\u064a\u0647 \u0627\u0644\u0633\u064a\u0627\u0633\u0627\u062a \u0643\u0644\u0647\u0627\u060c \u0639\u0644\u0649 \u0646\u0648\u0631\u064d \u0645\u0646 \u0627\u0644\u0644\u0647 \u0648\u0636\u064e\u0648\u0652\u0621\u064d \u0645\u0646 \u0627\u0644\u0634\u0631\u064a\u0639\u0629 \u0627\u0644\u063a\u0631\u0651\u0627\u0621...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0625\u0646 \u062a\u0631\u0627\u0645\u0628\u060c \u0627\u0644\u0630\u064a \u0627\u0647\u062a\u062f\u0649 \u0625\u0644\u0649 \u062a\u0635\u0646\u064a\u0641 \u062c\u0645\u0627\u0639\u0627\u062a \u0627\u0644\u0625\u062e\u0648\u0627\u0646 \u0648\u062a\u0646\u0638\u064a\u0645\u0627\u062a\u0647\u0627 \u0639\u0628\u0631 \u0627\u0644\u0639\u0627\u0644\u0645\u060c \u0642\u062f \u0627\u0647\u062a\u062f\u0649 \u0628\u0646\u0648\u0631 \u0627\u0644\u0639\u0642\u0644\u060c \u0628\u0639\u062f \u0623\u0646 \u062a\u062a\u0628\u0639 \u0627\u0644\u0622\u062b\u0627\u0631 \u0627\u0644\u0633\u064a\u0651\u0626\u0629 \u0627\u0644\u062a\u064a \u0646\u062c\u0645\u062a \u0639\u0646 \u062a\u0644\u0643 \u0627\u0644\u062a\u0646\u0638\u064a\u0645\u0627\u062a \u0641\u064a \u0627\u0644\u0639\u0627\u0644\u0645 \u0643\u0644\u0651\u0647. \u0648\u0643\u0627\u0630\u0628\u064c\u060c \u0645\u0646 \u064a\u062e\u0631\u062c \u0645\u0646 \u0627\u0644\u0625\u062e\u0648\u0627\u0646 \u0623\u0648 \u0645\u0646 \u0627\u0644\u0645\u062a\u0623\u062e\u0648\u0646\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u0646\u062a\u0646\u0632\u0651\u0647 \u0639\u0646 \u0630\u0643\u0631\u0647\u0645 \u0628\u0627\u0644\u0623\u0633\u0645\u0627\u0621\u060c \u0625\u0646 \u062e\u0631\u062c \u064a\u0632\u0639\u0645 \u0623\u0646\u0647\u0645 \u0644\u0627 \u064a\u062a\u0628\u0646\u0651\u0648\u0646 \u0627\u0644\u0639\u0646\u0641 \u0627\u0644\u0645\u0627\u062f\u064a\u061b \u0648\u0630\u0644\u0643\u060c \u0644\u0623\u0646 \u0627\u0644\u062a\u0623\u0635\u064a\u0644\u0627\u062a \u0627\u0644\u0646\u0638\u0631\u064a\u0629 \u0627\u0644\u062a\u064a \u0625\u0646 \u0627\u0639\u062a\u0628\u0631\u0646\u0627 \u0627\u0644\u0623\u0633\u0627\u0633 \u0627\u0644\u0645\u0640\u064f\u0634\u062a\u0631\u0643 \u0641\u064a\u0647\u0627\u060c \u062a\u0646\u0635\u0651 \u0639\u0644\u0649 \u0630\u0644\u0643\u060c \u0648\u062a\u062f\u0639\u0648 \u0625\u0644\u0649 \u0627\u0644\u0627\u0633\u062a\u0639\u062f\u0627\u062f \u0644\u0647. \u0648\u0647\u0646\u0627\u060c \u0642\u062f \u064a\u0633\u062a\u0639\u062c\u0644 \u0645\u0646 \u0627\u0646\u0641\u0639\u0644 \u0644\u0644\u0623\u064a\u062f\u064a\u0648\u0644\u0648\u062c\u064a\u0627 \u0627\u0644\u0625\u062e\u0648\u0627\u0646\u064a\u0629\u060c \u0644\u064a\u0633\u062a\u062f\u0631\u0643 \u0639\u0644\u064a\u0651 \u0628\u0627\u0644\u062c\u0647\u0627\u062f \u0627\u0644\u0645\u0634\u0631\u0648\u0639 \u0641\u064a \u062f\u064a\u0646\u0646\u0627\u060c \u0641\u0623\u0642\u0648\u0644 \u0644\u0647 \u0648\u0644\u0645\u0646 \u0639\u0644\u0649 \u0634\u0627\u0643\u0644\u062a\u0647: \u0623\u0646\u062a\u0645 \u0644\u0633\u062a\u0645 \u0639\u0644\u0649 \u062c\u0647\u0627\u062f \u0645\u0634\u0631\u0648\u0639\u064d\u060c \u0644\u0627 \u0645\u0646 \u0627\u0644\u062c\u0647\u0629 \u0627\u0644\u0646\u0638\u0631\u064a\u0629\u060c \u0648\u0644\u0627 \u0645\u0646 \u0627\u0644\u062c\u0647\u0629 \u0627\u0644\u0639\u0645\u0644\u064a\u0629\u061b \u0644\u0623\u0646\u0643\u0645 \u062a\u064f\u062d\u0627\u0631\u0628\u0648\u0646 \u0623\u0642\u0648\u0627\u0645\u0643\u0645\u060c \u0648\u0645\u0650\u0646 \u0628\u0639\u062f\u0647\u0627 \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u062c\u0645\u0639\u0627\u0621\u061b \u0644\u0627 \u0644\u0634\u064a\u0621\u060c \u0625\u0644\u0627 \u0644\u0623\u0646\u0647\u0627 \u062a\u062e\u0627\u0644\u0641\u0643\u0645 \u0641\u064a \u0627\u0644\u0631\u0623\u064a \u0627\u0644\u0633\u064a\u0627\u0633\u064a\u060c \u0628\u0645\u0627 \u0623\u0646\u0647 \u0644\u0627 \u0639\u0642\u064a\u062f\u0629 \u0644\u0643\u0645 \u062a\u064f\u0639\u062a\u0628\u0631 \u0641\u064a \u0627\u0644\u062f\u0651\u064a\u0646. \u0648\u0623\u0645\u0627 \u0627\u0644\u062c\u0647\u0627\u062f \u0641\u064a \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u060c \u0641\u0644\u0627 \u064a\u0646\u0634\u0623 \u0639\u0646 \u0647\u0630\u0627 \u0627\u0644\u0645\u0628\u062f\u0623\u060c \u062e\u0635\u0648\u0635\u0627 \u0645\u0639 \u0645\u0627 \u0639\u0631\u0641\u0647 \u0627\u0644\u0645\u0633\u0644\u0645\u0648\u0646 \u0623\u0646\u0641\u0633\u0647\u0645 \u0645\u0646 \u0641\u0633\u0648\u0642 \u0639\u0646 \u0627\u0644\u062f\u064a\u0646 \u0628\u0627\u0644\u062a\u062f\u0631\u064a\u062c \u0648\u0639\u0628\u0631 \u0627\u0644\u0642\u0631\u0648\u0646\u060c \u0645\u0646 \u0633\u0648\u0621 \u0641\u064a \u0627\u0644\u0646\u0648\u0627\u064a\u0627 \u0648\u0627\u0644\u0623\u0639\u0645\u0627\u0644 \u062c\u0645\u064a\u0639\u0627\u061b \u062d\u062a\u0649 \u0623\u0635\u0628\u062d \u0643\u0644 \u0627\u0644\u0623\u063a\u0631\u0627\u0631 \u0645\u0646 \u0633\u0641\u0647\u0627\u0626\u0646\u0627\u060c \u064a\u0639\u062a\u0642\u062f\u0648\u0646 \u062c\u0627\u0632\u0645\u064a\u0646\u060c \u0628\u0623\u0646\u0646\u0627 \u064a\u0646\u0628\u063a\u064a \u0623\u0646 \u0646\u062d\u0627\u0631\u0628 \u0643\u0644 \u0643\u0627\u0641\u0631 \u0623\u0648 \u0645\u0644\u062d\u062f\u061b \u0648\u0627\u0644\u0623\u0645\u0631 \u0644\u064a\u0633 \u0643\u0630\u0644\u0643 \u062c\u0632\u0645\u0627 \u0648\u0628\u0627\u0644\u0642\u0637\u0639. \u062d\u0631\u0628 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0644\u0644\u0643\u0627\u0641\u0631\u064a\u0646\u060c \u064a\u0646\u0628\u063a\u064a \u0623\u0646 \u064a\u0633\u062a\u062f\u0639\u064a\u0647\u0627 \u0627\u0644\u0627\u0639\u062a\u062f\u0627\u0621 \u0639\u0644\u064a\u0646\u0627 \u0648\u062d\u062f\u0647\u061b \u0648\u0623\u0645\u0627 \u0645\u064e\u0646 \u0639\u0627\u0645\u064e\u0644\u0646\u0627 \u0628\u0645\u0646\u0637\u0642 \u0627\u0644\u0646\u0651\u062f\u0651\u064a\u0651\u0629 \u0648\u0627\u0644\u0625\u062e\u0627\u0621 \u0641\u064a \u0627\u0644\u0628\u0634\u0631\u064a\u0629\u060c \u0641\u0647\u0648 \u0623\u062e\u0648\u0646\u0627\u060c \u0648\u064a\u062d\u0631\u0645 \u0639\u0644\u064a\u0646\u0627 \u062d\u0631\u0645\u0629 \u0645\u063a\u0644\u0651\u0638\u0629 \u0623\u0646 \u0646\u064f\u0644\u062d\u0642 \u0628\u0647 \u0636\u0631\u0631\u0627\u060c \u0645\u0647\u0645\u0627 \u0628\u0644\u063a \u0641\u064a \u0627\u0644\u0635\u0651\u063a\u0631!... \u0648\u0625\u0644\u0627\u060c \u0641\u0643\u064a\u0641 \u0643\u0627\u0646\u062a \u0627\u0644\u0623\u0645\u0645 \u0641\u064a\u0645\u0627 \u0633\u0628\u0642 \u0645\u0646 \u0627\u0644\u062a\u0627\u0631\u064a\u062e \u062a\u062a\u0633\u0627\u0628\u0642 \u0625\u0644\u0649 \u0627\u0644\u062f\u062e\u0648\u0644 \u0641\u064a \u062f\u064a\u0646 \u0627\u0644\u0644\u0647 \u0623\u0641\u0648\u0627\u062c\u0627\u061f!... \u0644\u0627 \u064a\u0645\u0643\u0646 \u0623\u0646 \u064a\u0643\u0648\u0646 \u0630\u0644\u0643\u060c \u0625\u0644\u0627 \u0639\u0646 \u0645\u0639\u0631\u0641\u0629 \u0644\u062a\u0644\u0643 \u0627\u0644\u0634\u0639\u0648\u0628 \u0648\u0627\u0644\u0623\u0645\u0645\u060c \u0628\u0639\u062f\u0627\u0644\u0629 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u060c \u0648\u0628\u062d\u0631\u0635\u0647 \u0639\u0644\u0649 \u063a\u064a\u0631 \u0623\u0628\u0646\u0627\u0626\u0647\u060c \u0628\u0623\u0643\u062b\u0631 \u0645\u0646 \u062d\u0631\u0635\u0647 \u0639\u0644\u0649 \u0623\u0628\u0646\u0627\u0626\u0647. \u0623\u0641\u0646\u0643\u0648\u0646 \u062f\u0639\u0627\u0629 \u062c\u0627\u0647\u0644\u064a\u0629\u060c \u0648\u0642\u062f \u0647\u062f\u0627\u0646\u0627 \u0627\u0644\u0644\u0647 \u0625\u0644\u0649 \u0623\u0642\u0648\u0645 \u0627\u0644\u0633\u0628\u0644\u061f!... \u0644\u0627 \u0648\u0627\u0644\u0644\u0647!... \u0645\u0627 \u0628\u0642\u064a \u0641\u064a\u0646\u0627 \u0639\u0631\u0642 \u064a\u0646\u0628\u0636 \u0628\u0630\u0643\u0631 \u0627\u0644\u0644\u0647!...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0625\u0646\u0646\u0627 \u0646\u062f\u0639\u0648 \u0633\u0627\u0626\u0631 \u0627\u0644\u0639\u0627\u0644\u0645\u060c \u0625\u0644\u0649 \u0627\u0644\u0639\u0645\u0644 \u0628\u0639\u0645\u0644 \u0627\u0644\u0631\u0626\u064a\u0633 \u062a\u0631\u0627\u0645\u0628\u061b \u0648\u0625\u0644\u0649 \u0627\u0644\u0627\u0642\u062a\u062f\u0627\u0621 \u0628\u0627\u0644\u0631\u0626\u064a\u0633 \u0627\u0644\u0639\u0627\u0644\u0645\u064a \u0627\u0644\u0645\u062d\u062a\u0631\u0645 \"\u0628\u0648\u062a\u064a\u0646\"\u060c \u0641\u0647\u0645\u0627 \u064a\u0639\u0644\u0645\u0627\u0646 \u062d\u0642\u064a\u0642\u0629 \u0627\u0644\u0623\u0645\u0648\u0631\u060c \u0648\u064a\u0641\u0631\u0651\u0642\u0627\u0646 \u0628\u064a\u0646 \u0627\u0644\u062e\u064a\u0631 \u0627\u0644\u0623\u0635\u0644\u064a \u0648\u0627\u0644\u062e\u064a\u0631 \u0627\u0644\u0632\u0651\u0627\u0626\u0641\u061b \u0648\u0628\u064a\u0646 \u0627\u0644\u0634\u0631 \u0627\u0644\u0623\u0635\u0644\u064a\u0651 \u0648\u0627\u0644\u0634\u0631\u0651 \u0627\u0644\u0640\u0645\u064f\u062a\u064e\u062e\u064e\u0641\u0651\u064a. \u0648\u0627\u0644\u062d\u0645\u062f \u0644\u0644\u0647 \u0627\u0644\u0630\u064a \u062c\u0639\u0644 \u0644\u0647\u0630\u0627 \u0627\u0644\u0639\u0627\u0644\u0645\u060c \u062d\u0643\u0645\u0627\u0621 \u0645\u0646 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0648\u0645\u0646 \u063a\u064a\u0631\u0647\u0645\u060c \u064a\u0639\u0645\u0644\u0648\u0646 \u0628\u062c\u062f\u0651 \u0645\u0646 \u0623\u062c\u0644 \u062a\u062c\u0646\u064a\u0628 \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0633\u0648\u0621 \u0627\u0644\u0645\u0640\u064f\u0646\u0642\u0644\u064e\u0628 \u0648\u0627\u0644\u062e\u0627\u062a\u0645\u0629. \u0648\u0644\u0627 \u064a\u063a\u062a\u0631\u0651 \u0623\u062d\u062f \u0645\u0646 \u0623\u0628\u0646\u0627\u0621 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u0644\u0627 \u0639\u0644\u0645 \u0644\u0647\u0645 \u0628\u062f\u064a\u0646\u0647\u0645\u060c \u0642\u0628\u0644 \u0633\u0648\u0627\u0647\u060c \u0628\u0645\u0627 \u062a\u064f\u0646\u062a\u062c\u0647 \u0627\u0644\u062a\u0646\u0638\u064a\u0645\u0627\u062a \u0627\u0644\u0625\u0631\u0647\u0627\u0628\u064a\u0629 \u0645\u0646 \u062e\u0637\u0627\u0628 \u0644\u0644\u0643\u0631\u0627\u0647\u064a\u0629\u060c \u062a\u0645\u062c\u0651\u0647 \u0627\u0644\u0637\u0628\u0627\u0639 \u0627\u0644\u0633\u0644\u064a\u0645\u0629 \u062a\u0644\u0642\u0627\u0626\u064a\u0651\u0627 \u0648\u0628\u0627\u0644\u0641\u0637\u0631\u0629... \u0634\u0643\u0631\u0627 \u062a\u0631\u0627\u0645\u0628\u060c \u0648\u0634\u0643\u0631\u0627 \u0628\u0648\u062a\u064a\u0646!... \u0623\u0639\u0627\u0646\u0643\u0645\u0627 \u0627\u0644\u0644\u0647 \u0639\u0644\u0649 \u0645\u0627 \u0641\u064a\u0647 \u062e\u064a\u0631\u064f \u0628\u064e\u0644\u064e\u062f\u064a\u0652\u0643\u0645\u0627\u060c \u0648\u062e\u064a\u0631 \u0627\u0644\u0639\u0627\u0644\u0645 \u0628\u0639\u062f\u0647\u0645\u0627...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0647\u0630\u0627 \u0631\u0623\u064a\u064f\u0646\u0627 \u0642\u062f \u0623\u0639\u0644\u0646\u0651\u0627\u0647\u060c \u0645\u0646 \u062f\u0648\u0646 \u062d\u0633\u0627\u0628 \u0644\u0634\u064a\u0621 \u0625\u0644\u0627 \u0627\u0644\u062d\u0642\u061b \u0648\u0633\u064a\u0643\u0648\u0646 \u0644\u0643\u0644 \u0645\u0640\u064f\u0635\u062f\u0651\u0642 \u0644\u0647 \u0623\u0648 \u0645\u0643\u0630\u0651\u0628\u060c \u0645\u0627 \u064a\u064f\u0624\u0643\u0651\u062f\u0647 \u0623\u0648 \u064a\u0646\u0641\u064a\u0647\u060c \u0645\u0650\u0646 \u0646\u0641\u0633\u0647 \u0648\u0645\u0650\u0646 \u0628\u0644\u062f\u0647\u060c \u0648\u0642\u0631\u064a\u0628\u0627 \u0641\u064a \u0627\u0644\u0632\u0645\u0627\u0646 \u063a\u064a\u0631\u064e \u0628\u0639\u064a\u062f. \u0641\u0627\u0644\u0644\u0647\u0645\u0651 \u0647\u0644 \u0628\u0644\u0651\u063a\u062a\u061f \u0627\u0644\u0644\u0647\u0645 \u0641\u0627\u0634\u0647\u062f!...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0648\u0627\u0644\u062d\u0645\u062f \u0644\u0644\u0647 \u0631\u0628 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0646...<\/span><\/p>\n","protected":false},"excerpt":{"rendered":"<p>&nbsp; \u0625\u064