{"id":12087,"date":"2015-09-29T11:27:00","date_gmt":"2015-09-29T11:27:00","guid":{"rendered":"http:\/\/alomariya.test\/%d8%a5%d8%b5%d8%af%d8%a7%d8%b1%d8%a7%d8%aa-%d8%ac%d8%af%d9%8a%d8%af%d8%a9\/"},"modified":"2015-09-29T11:27:00","modified_gmt":"2015-09-29T11:27:00","slug":"%d8%a5%d8%b5%d8%af%d8%a7%d8%b1%d8%a7%d8%aa-%d8%ac%d8%af%d9%8a%d8%af%d8%a9","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d8%a5%d8%b5%d8%af%d8%a7%d8%b1%d8%a7%d8%aa-%d8%ac%d8%af%d9%8a%d8%af%d8%a9\/","title":{"rendered":"\u0625\u0635\u062f\u0627\u0631\u0627\u062a \u062c\u062f\u064a\u062f\u0629"},"content":{"rendered":"<p>&nbsp; &nbsp; &nbsp; &nbsp;\u062a\u0639\u0644\u0646 \u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u0645\u0648\u0642\u0639 \u0644\u0644\u0632\u0648\u0627\u0631 \u0627\u0644\u0643\u0631\u0627\u0645 \u0623\u0646 \u0645\u062c\u0645\u0648\u0639\u0629 \u0645\u0646 \u0627\u0644\u0643\u062a\u0628 -\u0648\u0639\u062f\u062f\u0647\u0627 \u0633\u0628\u0639\u0629- \u0642\u062f \u0635\u062f\u0631\u062a \u0647\u0630\u0647 \u0627\u0644\u0623\u064a\u0627\u0645 \u0639\u0646 \u062f\u0627\u0631 \u0627\u0644\u0646\u0648\u0631 \u0627\u0644\u0645\u0628\u064a\u0646 \u0627\u0644\u0623\u0631\u062f\u0646\u064a\u0629. \u0641\u0639\u0644\u0649 \u0627\u0644\u0631\u0627\u063a\u0628\u064a\u0646 \u0641\u064a \u0627\u0642\u062a\u0646\u0627\u0626\u0647\u0627 \u0627\u0644\u0627\u062a\u0635\u0627\u0644 \u0645\u0628\u0627\u0634\u0631\u0629 \u0628\u0627\u0644\u062f\u0627\u0631 \u0627\u0644\u0645\u0630\u0643\u0648\u0631\u0629\u060c \u0623\u0648 \u0637\u0644\u0628\u0647\u0627 \u0645\u0646 \u0627\u0644\u0645\u0639\u0627\u0631\u0636 \u0627\u0644\u0645\u062e\u062a\u0635\u0629 \u0648\u0627\u0644\u0645\u0643\u062a\u0628\u0627\u062a.<br \/>\u0648\u0627\u0644\u0643\u062a\u0628 \u0647\u064a:<br \/><strong>1<\/strong>. \u062d\u062f\u064a\u062b \u0627\u0644\u0645\u0631\u0622\u0629.<br \/><strong>2<\/strong>. \u0625\u062a\u062d\u0627\u0641 \u0627\u0644\u0645\u0644\u0648\u0643 \u0628\u0634\u0631\u062d \u062a\u0627\u0626\u064a\u0629 \u0627\u0644\u0633\u0644\u0648\u0643 \u0627\u0644\u062d\u0631\u0627\u0642\u064a\u0629.<br \/><strong>3<\/strong>. \u0627\u0644\u0623\u0645\u062b\u0627\u0644 \u0627\u0644\u062a\u0639\u0631\u0641\u064a\u0629.<br \/><strong>4<\/strong>. \u0627\u0644\u062f\u0631\u0648\u0633 \u0627\u0644\u0645\u0635\u0631\u064a\u0629.<br \/><strong>5<\/strong>. \u0627\u0644\u0645\u0646\u0647\u0627\u062c \u0627\u0644\u0642\u0648\u064a\u0645 \u0641\u064a \u0627\u0644\u062a\u0632\u0643\u064a\u0629.<br \/><strong>6<\/strong>. \u0627\u0644\u0646\u0633\u0628\u064a\u0629 \u0627\u0644\u0639\u0644\u0645\u064a\u0629.<br \/><strong>7<\/strong>. \u062a\u0639\u0631\u064a\u0641 \u0627\u0644\u062e\u0635\u0648\u0635 \u0628\u0645\u0643\u0627\u0645\u0646 \u0627\u0644\u0634\u0631\u0641 \u0627\u0644\u0645\u062e\u0635\u0648\u0635.<\/p>\n<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0647\u0630\u0627\u060c \u0648\u064a\u064f\u0646\u062a\u0638\u0631 \u0623\u0646 \u062a\u0635\u062f\u0631 \u0643\u062a\u0628 \u0623\u062e\u0631\u0649 \u0639\u0646 \u0627\u0644\u062f\u0627\u0631 \u0646\u0641\u0633\u0647\u0627\u060c \u0641\u064a \u0627\u0644\u0645\u0633\u062a\u0642\u0628\u0644 \u0627\u0644\u0642\u0631\u064a\u0628 \u0625\u0646 \u0634\u0627\u0621 \u0627\u0644\u0644\u0647.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>&nbsp; &nbsp; &nbsp; &nbsp;\u062a\u0639\u0644\u0646 \u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u0645\u0648\u0642\u0639 \u0644\u0644\u0632\u0648\u0627\u0631 \u0627\u0644\u0643\u0631\u0627\u0645 \u0623\u0646 \u0645\u062c\u0645\u0648\u0639\u0629 \u0645\u0646 \u0627\u0644\u0643\u062a\u0628 -\u0648\u0639\u062f\u062f\u0647\u0627 \u0633\u0628\u0639\u0629- \u0642\u062f \u0635\u062f\u0631\u062a \u0647\u0630\u0647 \u0627\u0644\u0623\u064a\u0627\u0645 \u0639\u0646 \u062f\u0627\u0631 \u0627\u0644\u0646\u0648\u0631 \u0627\u0644\u0645\u0628\u064a\u0646 \u0627\u0644\u0623\u0631\u062f\u0646\u064a\u0629. \u0641\u0639\u0644\u0649 \u0627\u0644\u0631\u0627\u063a\u0628\u064a\u0646 \u0641\u064a \u0627\u0642\u062a\u0646\u0627\u0626\u0647\u0627 \u0627\u0644\u0627\u062a\u0635\u0627\u0644 \u0645\u0628\u0627\u0634\u0631\u0629 \u0628\u0627\u0644\u062f\u0627\u0631 \u0627\u0644\u0645\u0630\u0643\u0648\u0631\u0629\u060c \u0623\u0648 \u0637\u0644\u0628\u0647\u0627 \u0645\u0646 \u0627\u0644\u0645\u0639\u0627\u0631\u0636 \u0627\u0644\u0645\u062e\u062a\u0635\u0629 \u0648\u0627\u0644\u0645\u0643\u062a\u0628\u0627\u062a.\u0648\u0627\u0644\u0643\u062a\u0628 \u0647\u064a:1. \u062d\u062f\u064a\u062b \u0627\u0644\u0645\u0631\u0622\u0629.2. \u0625\u062a\u062d\u0627\u0641 \u0627\u0644\u0645\u0644\u0648\u0643 \u0628\u0634\u0631\u062d \u062a\u0627\u0626\u064a\u0629 \u0627\u0644\u0633\u0644\u0648\u0643 \u0627\u0644\u062d\u0631\u0627\u0642\u064a\u0629.3. \u0627\u0644\u0623\u0645\u062b\u0627\u0644 \u0627\u0644\u062a\u0639\u0631\u0641\u064a\u0629.4. \u0627\u0644\u062f\u0631\u0648\u0633 \u0627\u0644\u0645\u0635\u0631\u064a\u0629.5. \u0627\u0644\u0645\u0646\u0647\u0627\u062c \u0627\u0644\u0642\u0648\u064a\u0645 \u0641\u064a \u0627\u0644\u062a\u0632\u0643\u064a\u0629.6. \u0627\u0644\u0646\u0633\u0628\u064a\u0629 [&hellip;]<\/p>\n","protected":false},"author":2,"featured_media":0,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"footnotes":""},"categories":[3],"tags":[],"class_list":["post-12087","post","type-post","status-publish","format-standard","hentry","category-3"],"acf":[],"yoast_head":"<!-- This site is optimized with the Yoast SEO plugin v24.9 - https:\/\/yoast.com\/wordpress\/plugins\/seo\/ -->\n<title>\u0625\u0635\u062f\u0627\u0631\u0627\u062a \u062c\u062f\u064a\u062f\u0629 - \u0639\u0628\u062f \u0627\u0644\u063a\u0646\u064a \u0627\u0644\u0639\u0645\u0631\u064a \u0627\u0644\u062d\u0633\u0646\u064a<\/title>\n<meta name=\"description\" content=\"\u0625\u0635\u062f\u0627\u0631\u0627\u062a \u062c\u062f\u064a\u062f\u0629\" \/>\n<meta name=\"robots\" content=\"index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1\" \/>\n<lin