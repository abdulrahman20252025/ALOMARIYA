a\u062f \u0627\u0644\u0645\u0633\u0645\u0649 &quot;\u0627\u0644\u062d\u0648\u0627\u0631 \u0627\u0644\u063a\u0627\u0626\u0628&quot;\u060c \u0641\u064a \u0645\u062a\u0646\u0627\u0648\u0644 \u0627\u0644\u0642\u0631\u0627\u0621 \u0627\u0644\u0643\u0631\u0627\u0645\u060c \u0641\u064a \u0642\u0633\u0645 &quot;\u0645\u0624\u0644\u0641\u0627\u062a \u0627\u0644\u0634\u064a\u062e&quot;\u060c \u0641\u064a \u0627\u0646\u062a\u0638\u0627\u0631 \u0625\u0644\u062d\u0627\u0642 \u0627\u0644\u0623\u062c\u0632\u0627\u0621 \u0627\u0644\u0623\u062e\u0631\u0649 \u0628\u0647\u060c \u0648\u0642\u0628\u0644 \u0627\u0644\u0639\u0645\u0644 \u0639\u0644\u0649 \u0637\u0628\u0627\u0639\u062a\u0647 \u0637\u0628\u0627\u0639\u0629 \u0648\u0631\u0642\u064a\u0629\u060c \u0625\u0646 \u0634\u0627\u0621 \u0627\u0644\u0644\u0647.<br \/>\u0646\u0631\u062c\u0648 \u0623\u0646 \u0646\u0643\u0648\u0646 \u0628\u0639\u0645\u0644\u0646\u0627 \u0647\u0630\u0627\u060c \u0642\u062f \u0633\u0627\u0647\u0645\u0646\u0627 \u0641\u064a \u0625\u062b\u0631\u0627\u0621 \u0627\u0644\u062e\u0632\u0627\u0646\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0628\u0645\u0627 \u064a\u064f\u0646\u0627\u0633\u0628 \u0627\u0644\u0639\u0635\u0631 \u0645\u0646 \u0627\u0644\u0643\u062a\u0628.<br \/>\u0643\u0645\u0627 \u0646\u0631\u062c\u0648 \u0645\u0646 \u0627\u0644\u0644\u0647 \u0627\u0644\u0642\u0628\u0648\u0644 \u0644\u0644\u062c\u0645\u064a\u0639 \u0648\u062d\u0633\u0646 \u0627\u0644\u062a\u0648\u0641\u064a\u0642 \u0648\u0627\u0644\u0633\u062f\u0627\u062f.<\/p>\n<p>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;= \u0648\u0634\u0