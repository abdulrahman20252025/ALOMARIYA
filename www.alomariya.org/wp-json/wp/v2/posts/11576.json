{"id":11576,"date":"2012-06-12T00:00:00","date_gmt":"2012-06-12T00:00:00","guid":{"rendered":"http:\/\/alomariya.test\/%d8%a3%d8%b2%d9%85%d8%a9-%d8%a7%d9%84%d8%aa%d8%af%d9%8a%d9%86\/"},"modified":"2025-11-19T15:28:12","modified_gmt":"2025-11-19T15:28:12","slug":"%d8%a3%d8%b2%d9%85%d8%a9-%d8%a7%d9%84%d8%aa%d8%af%d9%8a%d9%86","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d8%a3%d8%b2%d9%85%d8%a9-%d8%a7%d9%84%d8%aa%d8%af%d9%8a%d9%86\/","title":{"rendered":"\u0623\u0632\u0645\u0629 \u0627\u0644\u062a\u062f\u064a\u0646..."},"content":{"rendered":"<p>&nbsp;<\/p>\n<p><span class=\"custom-indent\">\u0643\u0627\u0646 \u0627\u0644\u0646\u0627\u0633 \u0641\u064a \u0627\u0644\u0639\u0642\u0648\u062f \u0627\u0644\u0633\u0627\u0628\u0642\u0629 \u064a\u062a\u062d\u062f\u062b\u0648\u0646 \u0639\u0646 \u0627\u0644\u0635\u062d\u0648\u0629 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a\u0629\u060c \u0648\u064a\u0639\u0642\u062f\u0648\u0646 \u0639\u0644\u064a\u0647\u0627 \u0643\u0644 \u0627\u0644\u0622\u0645\u0627\u0644 \u0627\u0644\u0645\u0645\u0643\u0646\u0629\u061b \u0648\u0627\u0634\u062a\u063a\u0644 \u0636\u0645\u0646\u0647\u0627 \u0628\u0627\u0644\u062f\u0639\u0648\u0629 \u0625\u0644\u0649 \u0627\u0644\u0625\u0633\u0644\u0627\u0645 \u0648\u0625\u0639\u0627\u062f\u0629 \u0625\u0628\u0631\u0627\u0632 \u0645\u0639\u0627\u0644\u0645\u0647 \u0639\u062f\u062f \u0643\u0628\u064a\u0631 \u0645\u0646 \u0623\u0628\u0646\u0627\u0621 \u0627\u0644\u0623\u0645\u0629 \u0645\u0645\u0646 \u064a\u064f\u0639\u062f\u0651\u0648\u0646 \u0645\u0646 \u0627\u0644\u0639\u0644\u0645\u0627\u0621\u060c \u0623\u0648 \u0645\u0645\u0646 \u0644\u0647\u0645 \u0642\u062f\u0631\u0629 \u0639\u0644\u0649 \u062a\u0648\u062c\u064a\u0647 \u0627\u0644\u062c\u0645\u0627\u0647\u064a\u0631 \u0628\u0623\u0633\u0627\u0644\u064a\u0628 \u0627\u0644\u0648\u0639\u0638 \u0627\u0644\u0645\u062e\u062a\u0644\u0641\u0629.<\/span><br \/>\n<span class=\"custom-indent\">\u0648\u0642\u062f \u0634\u0627\u0621 \u0627\u0644\u0644\u0647 \u0623\u0646 \u0623\u0634\u0647\u062f \u2013\u0648\u0623\u0646\u0627 \u0634\u0627\u0628 \u0641\u064a \u0628\u062f\u0627\u064a\u0629 \u0627\u0644\u0639\u0634\u0631\u064a\u0646\u064a\u0627\u062a- \u0645\u064a\u0644\u0627\u062f \u0639\u062f\u0629 \u062c\u0645\u0627\u0639\u0627\u062a\u060c \u0643\u0627\u0646\u062a \u0645\u062e\u062a\u0644\u0641\u0629 \u0645\u0646 \u062d\u064a\u062b \u0645\u0646\u0627\u0647\u062c \u0627\u0644\u0639\u0645\u0644 \u0648\u0645\u0646 \u062d\u064a\u062b \u0627\u0644\u0623\u0648\u0644\u0648\u064a\u0627\u062a. \u0648\u0642\u062f \u0643\u0646\u062a -\u0628\u0639\u062f \u0623\u0646 \u062e\u0627\u0644\u0637\u062a \u0646\u0641\u0631\u0627 \u0645\u0645\u0646 \u0627\u0646\u062a\u0633\u0628\u0648\u0627 \u0625\u0644\u064a\u0647\u0627- \u0623\u0642\u0648\u0644: \u0625\u0646 \u0627\u0644\u0635\u062d\u0648\u0629 \u0641\u064a \u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0635\u062d\u0648\u0629. \u0648\u0644\u0645 \u0623\u0643\u0646 \u0623\u0631\u0649 \u0623\u0646 \u0645\u0646 \u064a\u0633\u062a\u0645\u0639 \u0625\u0644\u064a \u064a\u0641\u0642\u0647 \u0639\u0646\u064a \u0645\u0627 \u0623\u0642\u0648\u0644\u060c \u0628\u0644 \u0643\u0627\u0646 \u0643\u0644\u0627\u0645\u064a \u064a\u0645\u0631 \u0645\u0646 \u062f\u0648\u0646 \u062a\u0639\u0644\u064a\u0642.<\/span><br \/>\n<span class=\"custom-indent\">\u0648\u0645\u0636\u062a \u0627\u0644\u0633\u0646\u0648\u0646 \u0648\u0646\u062d\u0646 \u0646\u0631\u062c\u0648 \u0642\u0637\u0627\u0641 \u0628\u0639\u0636 \u062b\u0645\u0631\u0627\u062a \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a\u060c \u0641\u0625\u0630\u0627 \u0628\u0627\u0644\u062d\u0635\u0627\u062f \u0647\u0632\u064a\u0644 \u0628\u0627\u0644\u0645\u0642\u0627\u0631\u0646\u0629 \u0625\u0644\u0649 \u0645\u0627 \u0628\u064f\u0630\u0644 \u0645\u0646 \u062c\u0647\u062f \u0648\u0645\u0627 \u0642\u064f\u062f\u0645\u062a \u0645\u0646 \u062a\u0636\u062d\u064a\u0627\u062a. \u0648\u0644\u064a\u062a \u0627\u0644\u0623\u0645\u0631 \u0627\u0646\u062d\u0635\u0631 \u0641\u064a \u0627\u0644\u0641\u062c\u0648\u0629 \u0627\u0644\u0641\u0627\u0635\u0644\u0629 \u0628\u064a\u0646 \u0627\u0644\u0639\u0645\u0644 \u0648\u0645\u0631\u062f\u0648\u062f\u0647\u061b \u0648\u0644\u0643\u0646\u0647 \u064a\u062a\u0639\u062f\u0649 \u0647\u0630\u0627 \u0625\u0644\u0649 \u0645\u0627 \u064a\u0634\u064a\u0631 \u0625\u0644\u0649 \u0648\u062c\u0648\u062f \u062e\u0644\u0644 \u0641\u064a \u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u062a\u062f\u064a\u0646 \u0628\u0631\u0645\u062a\u0647\u0627\u061b \u0646\u0639\u0646\u064a \u0623\u0646\u0646\u0627 \u0646\u0639\u064a\u0634 \u0623\u0632\u0645\u0629 \u062a\u062f\u064a\u0646\u060c \u0633\u0648\u0627\u0621 \u0623\u0642\u0631\u0631\u0646\u0627 \u0628\u0630\u0644\u0643 \u0623\u0645 \u0644\u0645 \u0646\u0642\u0631. \u0648\u0644\u0639\u0644 \u0627\u0644\u0635\u062d\u0648\u0629 \u0641\u064a \u0627\u0646\u062a\u0638\u0627\u0631 \u0627\u0633\u062a\u0643\u0645\u0627\u0644 \u0635\u062d\u0648\u062a\u0647\u0627!..<\/span><br \/>\n<span class=\"custom-indent\">\u0644\u0627 \u064a\u0634\u0643 \u0623\u062d\u062f \u0623\u0646 \u0627\u0644\u0623\u0645\u0629 \u0644\u0627 \u064a\u0639\u0648\u0632\u0647\u0627 \u0648\u062c\u0648\u062f \u0639\u0644\u0645\u0627\u0621 \u0628\u0639\u062f\u062f \u0644\u0645 \u064a\u062a\u0648\u0627\u0641\u0631 \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0623\u0632\u0645\u0646\u0629 \u0627\u0644\u0633\u0627\u0628\u0642\u0629\u060c \u0648\u0644\u0627 \u064a\u0646\u0642\u0635\u0647\u0627 \u0627\u0644\u0645\u0624\u062f\u0648\u0646 \u0644\u0641\u0631\u0627\u0626\u0636\u0647\u0645 \u0648\u0627\u0644\u062d\u0631\u064a\u0635\u0648\u0646 \u0639\u0644\u0649 \u0645\u0631\u0636\u0627\u0629 \u0631\u0628\u0647\u0645\u060c \u0645\u0646 \u062d\u064a\u062b \u0627\u0644\u0646\u064a\u0629 \u0648\u0627\u0644\u0642\u0635\u062f\u061b \u0648\u0644\u0643\u0646 \u0645\u0639 \u0630\u0644\u0643\u060c \u0644\u0645 \u0646\u0634\u0647\u062f \u0645\u064a\u0644\u0627\u062f \u0631\u062c\u0627\u0644 \u0645\u0646 \u0635\u0646\u0641 \u0623\u0643\u0627\u0628\u0631 \u0627\u0644\u0623\u0648\u0644\u064a\u0646\u060c \u0628\u0645\u0627 \u064a\u062a\u0646\u0627\u0633\u0628 \u0648\u0627\u0644\u0639\u062f\u062f \u0627\u0644\u0625\u062c\u0645\u0627\u0644\u064a \u0644\u0644\u0645\u0633\u0644\u0645\u064a\u0646. \u0648\u0645\u0639 \u0647\u0630\u0627\u060c \u0645\u0627 \u0631\u0623\u064a\u0646\u0627 \u0623\u062d\u062f\u0627 \u064a\u0646\u0628\u0647 \u0625\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u0645\u0642\u0627\u0631\u0646\u0627\u062a\u060c \u062d\u062a\u0649 \u0646\u062a\u0645\u0643\u0646 \u0645\u0646 \u062a\u0642\u064a\u064a\u0645 \u062a\u062c\u0631\u0628\u0629 \u0639\u0634\u0646\u0627\u0647\u0627\u060c \u0644\u0639\u0644\u0646\u0627 \u0646\u0635\u0648\u0651\u0628\u0647\u0627 \u0625\u0646 \u0643\u0627\u0646\u062a \u0641\u064a \u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u062a\u0635\u0648\u064a\u0628..<\/span><br \/>\n<span class=\"custom-indent\">\u0623\u0645\u0627 \u0646\u062d\u0646 \u0641\u0646\u062c\u0632\u0645 \u0623\u0646 \u062a\u062f\u064a\u0646\u0646\u0627 \u0641\u064a\u0647 \u062e\u0644\u0644 \u0644\u0627 \u0628\u062f \u0623\u0646 \u064a\u064f\u0635\u0644\u062d \u0625\u0646 \u0643\u0646\u0627 \u0646\u0631\u064a\u062f \u0623\u0646 \u0646\u0644\u062d\u0642 \u0628\u0627\u0644\u0633\u0627\u0628\u0642\u064a\u0646. \u0648\u0644\u0642\u062f \u0645\u0646 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a \u0628\u062a\u0645\u064a\u064a\u0632 \u0645\u0648\u0636\u0639 \u0627\u0644\u062e\u0644\u0644 \u0645\u0646\u0630 \u0627\u0644\u0628\u062f\u0627\u064a\u0629\u060c \u0644\u0645\u0627 \u0644\u0645\u0633\u062a \u0639\u0644\u0627\u0645\u0627\u062a \u0627\u0644\u0628\u0639\u062f \u0645\u0646 \u0646\u0641\u0633\u064a \u0639\u0646\u062f \u0628\u062f\u0627\u064a\u0629 \u0627\u0644\u062a\u0632\u0627\u0645\u064a\u061b \u0641\u0623\u062e\u0630 \u0627\u0644\u0644\u0647 \u0628\u064a\u062f\u064a \u0644\u0645\u0627 \u0633\u0644\u0643\u062a \u0637\u0631\u064a\u0642 \u0623\u0647\u0644 \u0627\u0644\u0644\u0647\u060c \u0639\u0644\u0649 \u0645\u0627 \u064a\u0642\u062a\u0636\u064a\u0647 \u0627\u0644\u0633\u0644\u0648\u0643 \u0645\u0646 \u0630\u0643\u0631 \u0648\u062d\u0636\u0648\u0631.<\/span><br \/>\n<span class=\"custom-indent\">\u0648\u0625\u0646 \u0645\u0627 \u0646\u0631\u064a\u062f \u0623\u0646 \u0646\u0646\u0628\u0647 \u0625\u0644\u064a\u0647 \u0647\u0646\u0627\u060c \u0647\u0648 \u0623\u0646 \u0627\u0644\u062a\u062f\u064a\u0646 \u0645\u0646 \u063a\u064a\u0631 \u062a\u0632\u0643\u064a\u0629\u060c \u0642\u062f \u064a\u0632\u064a\u062f \u0628\u0647 \u0635\u0627\u062d\u0628\u0647 \u0628\u0639\u062f\u0627 \u0645\u0646 \u0627\u0644\u0644\u0647\u061b \u0644\u0623\u0646 \u0627\u0644\u0623\u0639\u0645\u0627\u0644 \u0627\u0644\u0645\u0634\u0631\u0648\u0639\u0629 \u0644\u064a\u0633\u062a \u0645\u0642\u0635\u0648\u062f\u0629 \u0644\u0630\u0627\u062a\u0647\u0627\u060c \u0648\u0625\u0646\u0645\u0627 \u0647\u064a \u0638\u0631\u0648\u0641 \u0644\u0645\u0639\u0627\u0645\u0644\u0629 \u0627\u0644\u0644\u0647 \u0641\u064a\u0647\u0627. \u0648\u0645\u0639\u0627\u0645\u0644\u0629 \u0627\u0644\u0644\u0647 \u062a\u062a\u0637\u0644\u0628 \u062a\u0647\u064a\u0624\u0627 \u0644\u0647\u0627\u060c \u0648\u0627\u0644\u062a\u0647\u064a\u0624 \u064a\u062a\u0637\u0644\u0628 \u0639\u0644\u0645\u0627 \u0628\u0627\u0644\u0645\u0639\u0627\u0645\u064e\u0644\u061b \u0648\u0627\u0644\u0639\u0644\u0645 \u064a\u062a\u0637\u0644\u0628 \u062a\u0647\u064a\u0626\u0629 \u0627\u0644\u0645\u062d\u0644 \u0644\u0647\u060c \u0648\u062a\u0647\u064a\u0626\u0629 \u0627\u0644\u0645\u062d\u0644 \u062a\u062a\u0637\u0644\u0628 \u0645\u062c\u0627\u0647\u062f\u0629\u061b \u0648\u0627\u0644\u0645\u062c\u0627\u0647\u062f\u0629 \u062a\u062a\u0637\u0644\u0628 \u0627\u0633\u062a\u0639\u062f\u0627\u062f\u0627. \u0644\u0630\u0644\u0643\u060c \u0641\u0625\u0646 \u0627\u0644\u062a\u0632\u0643\u064a\u0629 \u0645\u0646 \u0627\u0644\u062a\u062f\u064a\u0646\u060c \u0647\u064a \u0643\u0627\u0644\u0631\u0648\u062d \u0645\u0646 \u0627\u0644\u062c\u0633\u062f. \u0641\u0645\u0646 \u062a\u0632\u0643\u0649 \u0648\u0639\u0628\u062f \u0627\u0644\u0644\u0647\u060c \u0643\u0627\u0646\u062a \u0639\u0628\u0627\u062f\u062a\u0647 \u062d\u0642\u064a\u0642\u064a\u0629\u060c \u064a\u0632\u062f\u0627\u062f \u0628\u0647\u0627 \u0631\u0641\u0639\u0629 \u0639\u0646\u062f \u0631\u0628\u0647\u061b \u0648\u0645\u0646 \u0623\u0647\u0645\u0644 \u0646\u0641\u0633\u0647\u060c \u0641\u0625\u0646 \u0639\u0628\u0627\u062f\u062a\u0647 \u062a\u0643\u0648\u0646 \u0635\u0648\u0631\u064a\u0629 \u0644\u0627 \u062d\u0642\u064a\u0642\u0629 \u0644\u0647\u0627.<\/span><br \/>\n<span class=\"custom-indent\">\u0648\u0635\u062d\u0648\u0629 \u0627\u0644\u0635\u062d\u0648\u0629\u060c \u0627\u0644\u062a\u064a \u0646\u0623\u0645\u0644 \u0623\u0646 \u0646\u0639\u0628\u064f\u0631 \u0625\u0644\u064a\u0647\u0627\u060c \u0647\u064a \u0627\u0644\u062a\u0632\u0643\u064a\u0629 \u0627\u0644\u062a\u064a \u064a\u062d\u064a\u0649 \u0628\u0647\u0627 \u062a\u062f\u064a\u0646\u0646\u0627\u060c \u0648\u064a\u0639\u0648\u062f \u0625\u0644\u0649 \u0642\u0644\u0648\u0628\u0646\u0627 \u0627\u0644\u0633\u0645\u0639 \u0648\u0627\u0644\u0625\u0628\u0635\u0627\u0631\u061b \u062d\u062a\u0649 \u0646\u0639\u0644\u0645 \u0645\u0627 \u0646\u0623\u062a\u064a \u0648\u0645\u0627 \u0646\u0630\u0631.<\/span><br \/>\n<span class=\"custom-indent\">\u0623\u0645\u0627 \u0627\u0644\u062a\u062f\u064a\u0646 \u0645\u0639 \u0627\u0644\u063a\u0641\u0644\u0629\u060c \u0641\u0625\u0646\u0647 \u0642\u062f \u0641\u062a\u062d \u0627\u0644\u0628\u0627\u0628 \u2013\u0639\u0646\u062f\u0645\u0627 \u0623\u0631\u062f\u0646\u0627 \u0633\u062f \u062e\u0644\u062a\u0647 \u0628\u0645\u0627 \u0646\u062f\u0631\u0643- \u0623\u0645\u0627\u0645 \u0627\u0644\u0645\u0646\u0627\u0647\u062c \u0627\u0644\u0643\u0641\u0631\u064a\u0629 \u0641\u064a \u0627\u0644\u0639\u0645\u0644\u061b \u0641\u0627\u0634\u062a\u063a\u0644\u0646\u0627 \u0628\u0627\u0644\u062a\u062e\u0637\u064a\u0637\u060c \u0648\u0628\u0625\u0639\u062f\u0627\u062f \u0648\u0633\u0627\u0626\u0644 \u0627\u0644\u062a\u0646\u0641\u064a\u0630\u061b \u0648\u0635\u0631\u0646\u0627 \u0646\u0642\u064a\u0633 \u0627\u0644\u0646\u062a\u0627\u0626\u062c \u0628\u0645\u0627 \u062a\u0639\u0637\u064a\u0647 \u0627\u0644\u0639\u0644\u0648\u0645 \u0627\u0644\u0625\u062d\u0635\u0627\u0626\u064a\u0629\u060c \u0648\u0646\u0633\u064a\u0646\u0627 \u0623\u0646 \u0627\u0644\u0623\u0645\u0631 \u0643\u0644\u0647 \u0628\u064a\u062f \u0627\u0644\u0644\u0647. \u0644\u0645 \u064a\u0643\u0644\u0641\u0646\u0627 \u0633\u0628\u062d\u0627\u0646\u0647 \u0623\u0646 \u0646\u062f\u0628\u0631 \u0634\u0624\u0648\u0646 \u0645\u0644\u0643\u0647\u060c \u0644\u0623\u0646 \u0645\u0646 \u064a\u062f\u0628\u0631 \u0634\u0631\u0648\u0642 \u0627\u0644\u0634\u0645\u0633 \u0648\u0647\u0628\u0648\u0628 \u0627\u0644\u0631\u064a\u062d\u060c \u0644\u0627 \u064a\u0639\u062c\u0632\u0647 \u0623\u0646 \u064a\u062f\u0628\u0631 \u0634\u0624\u0648\u0646 \u0639\u0628\u0627\u062f\u0647 \u0627\u0644\u0641\u0631\u062f\u064a\u0629\u061b \u0648\u0644\u0643\u0646\u0647 \u0644\u0645\u0627 \u0643\u0644\u0641\u0646\u0627 \u0628\u0645\u0627 \u0643\u0644\u0641\u0646\u0627\u060c \u0641\u0625\u0646\u0645\u0627 \u0623\u0631\u0627\u062f \u0645\u0646\u0627 \u0623\u0646 \u0646\u0639\u0648\u062f \u0625\u0644\u064a\u0647 \u0641\u064a\u0645\u0627 \u0643\u0644\u0641\u0646\u0627\u060c \u0644\u0627 \u0623\u0646 \u0646\u062a\u0648\u0647\u0645 \u0627\u0633\u062a\u0642\u0644\u0627\u0644\u064a\u062a\u0646\u0627 \u0639\u0646\u0647 \u0648\u0646\u062c\u0647\u062f \u0641\u064a \u0627\u0644\u0642\u064a\u0627\u0645 \u0628\u0627\u0644\u062a\u0643\u0627\u0644\u064a\u0641. \u0648\u0647\u0630\u0627 \u0639\u064a\u0646 \u0645\u0627 \u0648\u0642\u0639 \u0641\u064a\u0647 \u0627\u0644\u0645\u062a\u062f\u064a\u0646\u0648\u0646.. \u0648\u0644\u0648 \u062a\u062a\u0628\u0639\u062a \u0623\u062d\u0648\u0627\u0644 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0627\u0644\u064a\u0648\u0645\u060c \u0648\u0647\u0645 \u064a\u062a\u062e\u0628\u0637\u0648\u0646 \u0648\u064a\u062a\u0644\u0645\u0633\u0648\u0646 \u0637\u0631\u064a\u0642\u0647\u0645 \u0628\u064a\u0646 \u0631\u0643\u0627\u0645 \u0645\u0646 \u0627\u0644\u0646\u0638\u0631\u064a\u0627\u062a \u0648\u0627\u0644\u062a\u0648\u062c\u0647\u0627\u062a\u060c \u0644\u0631\u0623\u064a\u062a \u0646\u062a\u064a\u062c\u0629 \u0627\u0644\u062a\u062f\u064a\u0646 \u0645\u0646 \u063a\u064a\u0631 \u062a\u0632\u0643\u064a\u0629 \u0645\u0627\u062b\u0644\u0629 \u0623\u0645\u0627\u0645 \u0646\u0627\u0638\u0631\u064a\u0643\u060c \u0644\u0627 \u062a\u0634\u0643 \u0641\u064a\u0647\u0627.<\/span><br \/>\n<span class=\"custom-indent\">\u0627\u0644\u062a\u0632\u0643\u064a\u0629\u060c \u062a\u0639\u0648\u062f \u0628\u0643 \u0625\u0644\u0649 \u0631\u0628\u0643\u060c \u0641\u062a\u062c\u062f\u0647 \u0627\u0644\u0622\u0646 \u0645\u062f\u0628\u0631\u0627 \u0644\u0623\u0645\u0648\u0631\u0643 \u0643\u0645\u0627 \u0643\u0627\u0646 \u0644\u0643 \u0641\u064a \u0628\u0637\u0646 \u0623\u0645\u0643\u060c \u0644\u0627 \u0641\u0631\u0642! \u0641\u062a\u062f\u062e\u0644 \u0641\u064a \u0627\u0646\u0633\u062c\u0627\u0645 \u0636\u0645\u0646 \u0639\u0628\u0627\u062f\u0647 \u0645\u0646 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0646\u060c \u062a\u0639\u0628\u062f\u0647 \u0639\u0644\u0649 \u0639\u0644\u0645\u060c \u0648\u062a\u0646\u0633\u0644\u062e \u0628\u064a\u0646 \u064a\u062f\u064a\u0647 \u0645\u0646 \u062f\u0639\u0627\u0648\u0627\u0643 \u0627\u0644\u0632\u0627\u0626\u0641\u0629\u060c \u0648\u062a\u062a\u0628\u0631\u0623 \u0645\u0646 \u0631\u0628\u0648\u0628\u064a\u062a\u0643 \u0627\u0644\u0645\u0631\u0647\u0650\u0642\u0629. \u0647\u0630\u0647 \u0647\u064a \u062d\u0642\u064a\u0642\u0629 \u0627\u0644\u062f\u064a\u0646\u060c \u0648\u0644\u064a\u0633 \u0627\u0644\u062f\u064a\u0646 \u0645\u0632\u0627\u062d\u0645\u0629 \u0644\u0631\u0628 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0646.<\/span><br \/>\n<span class=\"custom-indent\">\u0648\u0627\u0644\u06