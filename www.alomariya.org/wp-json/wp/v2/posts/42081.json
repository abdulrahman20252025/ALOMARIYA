{"id":42081,"date":"2025-06-23T17:58:02","date_gmt":"2025-06-23T17:58:02","guid":{"rendered":"https:\/\/www.alomariya.org\/?p=42081"},"modified":"2025-06-23T17:59:45","modified_gmt":"2025-06-23T17:59:45","slug":"%d8%aa%d8%ad%d9%8a%d8%a9-%d8%a5%d9%84%d9%89-%d8%a3%d9%84%d9%83%d8%b3%d9%86%d8%af%d8%b1-%d8%af%d9%88%d8%ba%d9%8a%d9%86-2","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d8%aa%d8%ad%d9%8a%d8%a9-%d8%a5%d9%84%d9%89-%d8%a3%d9%84%d9%83%d8%b3%d9%86%d8%af%d8%b1-%d8%af%d9%88%d8%ba%d9%8a%d9%86-2\/","title":{"rendered":"\u062a\u062d\u064a\u0629 \u0625\u0644\u0649 \u0623\u0644\u0643\u0633\u0646\u062f\u0631 \u062f\u0648\u063a\u064a\u0646"},"content":{"rendered":"<p>&nbsp;<\/p>\n<p><span class=\"custom-indent\">\u0644\u0642\u062f \u0627\u0637\u0644\u0639\u062a \u0645\u0624\u062e\u0651\u0631\u0627\u060c \u0639\u0644\u0649 \u062d\u0648\u0627\u0631 \u0644\u0644\u0645\u0641\u0643\u0651\u0631 \u0627\u0644\u0631\u0648\u0633\u064a \"\u0623\u0644\u0643\u0633\u0646\u062f\u0631 \u062f\u0648\u063a\u064a\u0646\"\u060c \u064a\u062a\u0646\u0627\u0648\u0644 \u0641\u064a\u0647 \u062d\u0631\u0648\u0628 \u0622\u062e\u0631 \u0627\u0644\u0632\u0645\u0627\u0646\u060c \u0641\u0623\u064f\u0639\u062c\u0628\u062a \u0628\u0647 \u0623\u064a\u0651\u0645\u0627 \u0625\u0639\u062c\u0627\u0628\u060c \u0648\u0623\u062d\u0628\u0628\u062a \u0623\u0646 \u0623\u064f\u062e\u0628\u0631\u0647 \u0628\u0625\u0639\u062c\u0627\u0628\u064a\u060c \u0645\u0646 \u0628\u0627\u0628 \u0627\u0644\u0625\u0642\u0631\u0627\u0631 \u0644\u0647 \u0628\u0627\u0644\u0645\u0643\u0627\u0646\u0629 \u0627\u0644\u0641\u0643\u0631\u064a\u0629\u060c \u0648\u062a\u0648\u062f\u0651\u062f\u0627 \u0625\u0644\u064a\u0647\u060c \u0644\u0623\u0646 \u0627\u0644\u062a\u0648\u062f\u0651\u062f \u0623\u0635\u0644 \u0627\u0646\u062a\u0634\u0627\u0631 \u0627\u0644\u0645\u062d\u0628\u0651\u0629 \u0628\u064a\u0646 \u0627\u0644\u0646\u0627\u0633...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0625\u0646 \"\u062f\u0648\u063a\u064a\u0646\" \u0645\u062b\u0627\u0644 \u0644\u0644\u0645\u0641\u0643\u0631 \u0627\u0644\u0645\u0642\u062a\u062f\u0631\u060c \u0627\u0644\u0630\u064a \u064a\u062a\u0641\u062d\u0635 \u0627\u0644\u0645\u0642\u0648\u0644\u0627\u062a \u0645\u0646 \u0627\u0644\u062c\u0647\u0629 \u0627\u0644\u062a\u064a \u062a\u0646\u062a\u0633\u0628 \u0625\u0644\u064a\u0647\u0627\u060c \u0648\u0644\u0627 \u064a\u064f\u0633\u0627\u0631\u0639 \u0643\u063a\u064a\u0631\u0647 \u0625\u0644\u0649 \u0627\u0644\u0625\u0646\u0643\u0627\u0631\u060c \u0644\u0623\u0646 \u0645\u0642\u0648\u0644\u0629 \u0645\u0627 \u062a\u062e\u0627\u0644\u0641 \u0645\u0627 \u0647\u0648 \u0639\u0644\u064a\u0647 \u0645\u0646 \u062c\u0647\u062a\u0647. \u0648\u0644\u0639\u0645\u0631\u064a \u0625\u0646 \u0647\u0630\u0627 \u0644\u0647\u0648 \u0627\u0644\u0645\u0637\u0644\u0648\u0628 \u0641\u064a \u0627\u0644\u0645\u0641\u0643\u0631\u064a\u0646 \u0645\u0646 \u0625\u0646\u0635\u0627\u0641\u060c \u0639\u0645\u0644\u0627 \u0639\u0644\u0649 \u062a\u0648\u0633\u064a\u0639 \u0627\u0644\u0639\u0642\u0644\u0627\u0646\u064a\u0629 \u0646\u0641\u0633\u0647\u0627\u060c \u0644\u0627 \u0625\u063a\u0644\u0627\u0642\u0627 \u0644\u0647\u0627 \u0645\u0639 \u0632\u0639\u0645\u0647\u0627...<\/span><\/p>\n<p><span class=\"custom-indent\">\u0643\u0645 \u0645\u0646 \u062a\u0627\u0641\u0647 \u0645\u0646 \u0623\u0628\u0646\u0627\u0621 \u0623\u0645\u062a\u0646\u0627\u060c \u0642\u062f \u064a\u0639\u062f\u0651 \u0639\u0642\u0644\u0627\u0646\u064a\u0629 \u062f\u0648\u063a\u064a\u0646 \u062e\u0631\u0627\u0641\u064a\u0629\u060c \u0648\u0647\u0648 \u0644\u0627 \u064a\u0628\u0644\u063a \u062d\u062f\u0647 \u0627\u0644\u0623\u062f\u0646\u0649 \u0641\u064a \u0645\u062c\u0627\u0644 \u0627\u0644\u0639\u0642\u0644\u0627\u0646\u064a\u0629 \u0627\u0644\u0645\u0634\u062a\u0631\u0643\u0629. \u0641\u0647\u0644 \u064a\u0633\u062a\u0641\u064a\u062f \u0633\u0641\u0647\u0627\u0624\u0646\u0627 \u0645\u0646 \u0639\u0642\u0644\u0627\u0621 \u0627\u0644\u0623\u0645\u0645 \u0627\u0644\u0623\u062e\u0631\u0649\u061f... \u0623\u0645 \u0633\u0646\u0628\u0642\u0649 \u0639\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u0639\u062a\u0647 \u0627\u0644\u0639\u0627\u0645\u060c \u0627\u0644\u0630\u064a \u0643\u0627\u0646 \u064a\u0623\u0646\u0641 \u0645\u0646\u0647 \u0639\u0631\u0628 \u0627\u0644\u062c\u0627\u0647\u0644\u064a\u0651\u0629!...<\/span><\/p>\n<p><span class=\"custom-indent\"> \u0645\u0632\u064a\u062f\u0627 \u0645\u0646 \u0627\u0644\u062a\u0623\u0644\u0651\u0642 \u0648\u0627\u0644\u0625\u0646\u062c\u0627\u0632\u060c \u0644\u0623\u062e\u064a\u0646\u0627 \"\u062f\u0648\u063a\u064a\u0646\"\u060c \u0648\u0645\u0632\u064a\u062f\u0627 \u0645\u0646 \u0628\u0632\u0648\u063a \u0646\u062c\u0648\u0645 \u0634\u062e\u0635\u064a\u0627\u062a \u062a\u064f\u0634\u0628\u0647\u0647 \u0641\u064a \u0633\u0645\u0648\u0642\u0647 \u0648\u062d\u0635\u0627\u0641\u062a\u0647\u061b \u0641\u0625\u0646 \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0623\u062d\u0648\u062c \u0645\u0627 \u062a\u0643\u0648\u0646 \u0625\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u0635\u0646\u0641 \u0641\u064a \u0622\u062e\u0631 \u0627\u0644\u0632\u0645\u0627\u0646!...<\/span><\/p>\n<p>&nbsp;<\/p>\n<p>&nbsp;<\/p>\n<p style=\"text-align: left;\">\u0631\u0627\u0628\u0637 \u0627\u0644\u0641\u064a\u062f\u064a\u0648:<\/p>\n<p><iframe loading=\"lazy\" title=\"\u0623\u0628\u0639\u0627\u062f \u0631\u0648\u0633\u064a\u0629 | \u0625\u0633\u0631\u0627\u0626\u064a\u0644 \u0648\u0625\u064a\u0631\u0627\u0646.. \u0645\u064a\u062a\u0627\u0641\u064a\u0632\u064a\u0642\u064a\u0627 \u062f\u0648\u063a\u064a\u0646\" width=\"500\" height=\"281\" src=\"https:\/\/www.youtube.com\/embed\/PAwlQjSU5u0?feature=oembed\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen><\/iframe><\/p>\n","protected":false},"excerpt":{"rendered":"<p>&nbsp; \u0644\u0642\u062f \u0627\u0637\u0644\u0639\