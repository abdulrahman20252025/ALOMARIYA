{"id":11559,"date":"2014-10-17T08:50:57","date_gmt":"2014-10-17T08:50:57","guid":{"rendered":"http:\/\/alomariya.test\/%d8%b3%d8%b9%d8%af-%d8%a7%d9%84%d8%af%d9%8a%d9%86-%d8%a7%d9%84%d9%87%d9%84%d8%a7%d9%84%d9%8a-%d9%88%d8%a7%d9%84%d8%a5%d8%b3%d9%84%d8%a7%d9%85-%d8%a7%d9%84%d8%af%d8%ac%d8%a7%d9%84%d9%8a\/"},"modified":"2014-10-17T08:50:57","modified_gmt":"2014-10-17T08:50:57","slug":"%d8%b3%d8%b9%d8%af-%d8%a7%d9%84%d8%af%d9%8a%d9%86-%d8%a7%d9%84%d9%87%d9%84%d8%a7%d9%84%d9%8a-%d9%88%d8%a7%d9%84%d8%a5%d8%b3%d9%84%d8%a7%d9%85-%d8%a7%d9%84%d8%af%d8%ac%d8%a7%d9%84%d9%8a","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d8%b3%d8%b9%d8%af-%d8%a7%d9%84%d8%af%d9%8a%d9%86-%d8%a7%d9%84%d9%87%d9%84%d8%a7%d9%84%d9%8a-%d9%88%d8%a7%d9%84%d8%a5%d8%b3%d9%84%d8%a7%d9%85-%d8%a7%d9%84%d8%af%d8%ac%d8%a7%d9%84%d9%8a\/","title":{"rendered":"\u0633\u0639\u062f \u0627\u0644\u062f\u064a\u0646 \u0627\u0644\u0647\u0644\u0627\u0644\u064a \u0648\u0627\u0644\u0625\u0633\u0644\u0627\u0645 \u0627\u0644\u062f\u062c\u0627\u0644\u064a"},"content":{"rendered":"<div style=\"text-align:center\"><strong>\u0627\u0644\u0631\u0627\u0628\u0637:&nbsp;<a href=\"http:\/\/youtu.be\/tgG7_EbPur4\" target=\"_blank\">http:\/\/youtu.be\/tgG7_EbPur4<\/a><\/strong><\/div>\n<p>&nbsp;&nbsp; &nbsp; &nbsp; &nbsp;\u0645\u0627 \u0641\u062a\u0626\u0646\u0627 \u0646\u062d\u0630\u0650\u0651\u0631 \u0643\u0644 \u0645\u0631\u0629 \u0645\u0646 \u062a\u0633\u0631\u0651\u0628 \u0627\u0644\u0641\u0643\u0631 \u0627\u0644\u062f\u062c\u0627\u0644\u064a \u0625\u0644\u0649 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646\u061b \u0630\u0644\u0643 \u0627\u0644\u0641\u0643\u0631 \u0627\u0644\u0630\u064a \u064a\u064f\u0631\u0627\u062f \u0645\u0646\u0647 \u062a\u0647\u064a\u064a\u0621 \u0627\u0644\u0646\u0627\u0633 -\u0648\u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u062e\u0627\u0635\u0629\u060c \u0645\u0646 \u0643\u0648\u0646\u0647\u0645 \u0623\u0635\u062d\u0627\u0628 \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0627\u0644\u0625\u0644\u0647\u064a\u0629 \u0627\u0644\u062e\u0627\u062a\u0645\u0629-\u060c \u0644\u0642\u0628\u0648\u0644 \u0627\u0644\u062f\u064a\u0646 \u0627\u0644\u062f\u062c\u0627\u0644\u064a \u0627\u0644\u0639\u0648\u0644\u0645\u064a. \u0648\u0625\u0646 \u0645\u0627 \u0635\u062f\u0631 \u0639\u0646 \u062f. \u0633\u0639\u062f \u0627\u0644\u062f\u064a\u0646 \u0627\u0644\u0647\u0644\u0627\u0644\u064a \u0645\u0624\u062e\u0631\u0627 \u0639\u0644\u0649 \u0642\u0646\u0627\u0629 \u0627\u0644\u064a\u0648\u0645\u060c \u0641\u064a \u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u0642\u0627\u0647\u0631\u0629 \u0627\u0644\u064a\u0648\u0645\u060c \u0628\u062a\u0627\u0631\u064a\u062e: 24-11- 2014\u0645\u060c \u0645\u0646 \u0623\u0646 \u0627\u0644\u0645\u0633\u0644\u0645 \u0647\u0648 \u0645\u0646 \u0634\u0647\u062f \u0623\u0646 \u0644\u0627 \u0625\u0644\u0647 \u0625\u0644\u0627 \u0627\u0644\u0644\u0647\u060c \u0648\u0625\u0646\u0652 \u0644\u0645 \u064a\u0624\u0645\u0646 \u0628\u0645\u062d\u0645\u062f \u0631\u0633\u0648\u0644\u0627 \u0644\u0644\u0647\u060c \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645\u060c \u0644\u0647\u0648 \u0627\u0644\u0637\u0627\u0645\u0629 \u0627\u0644\u0643\u0628\u0631\u0649\u060c \u0627\u0644\u062a\u064a \u0645\u0627 \u0623\u0628\u0642\u062a \u0644\u0644\u062f\u064a\u0646 \u062d\u062f\u0648\u062f\u0627 \u0648\u0644\u0627 \u0645\u0639\u0627\u0644\u0645!..<br \/>&nbsp;<br \/>&nbsp; &nbsp; &nbsp; &nbsp;\u0648\u0631\u063a\u0645 \u0623\u0646 \u0639\u062f\u062f\u0627 \u0645\u0646 \u0623\u0647\u0644 \u0627\u0644\u0634\u0631\u064a\u0639\u0629 \u0642\u062f \u0631\u062f\u0648\u0627 \u0639\u0644\u0649 \u0643\u0644\u0627\u0645 \u0627\u0644\u0647\u0644\u0627\u0644\u064a \u0645\u0646 \u0628\u0627\u0628\u060c \u0645\u0627 \u064a\u064f\u0639\u0644\u0645 \u0645\u0646 \u0627\u0644\u062f\u064a\u0646 \u0628\u0627\u0644\u0636\u0631\u0648\u0631\u0629\u060c \u0648\u0645\u0627 \u0647\u0648 \u0645\u0646 \u0637\u0648\u0631 \u0635\u0628\u064a\u0627\u0646 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646\u061b \u0641\u0625\u0646\u0646\u0627 \u0646\u0631\u064a\u062f \u0623\u0646 \u0646\u0628\u0631\u0632 \u062c\u0648\u0627\u0646\u0628 \u0645\u0646 \u0647\u0630\u0647 \u0627\u0644\u0645\u0633\u0623\u0644\u0629\u060c \u0642\u062f \u062a\u063a\u064a\u0628 \u0639\u0646 \u062c\u0644 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646\u061b \u0645\u0639 \u0627\u0644\u0639\u0645\u0644 \u0639\u0644\u0649 \u0639\u062f\u0645 \u062a\u0643\u0631\u0627\u0631 \u0645\u0627 \u0642\u064a\u0644 \u0645\u0646 \u0642\u0650\u0628\u0644 \u0627\u0644\u0631\u0627\u062f\u0651\u064a\u0646. \u0641\u0646\u0642\u0648\u0644:<br \/>&nbsp;<br \/><span style=\"color:#ff0000\">1.<\/span> \u0625\u0646 \u0627\u0644\u0634\u0647\u0627\u062f\u0629 \u0647\u064a: \u0644\u0627 \u0625\u0644\u0647 \u0625\u0644\u0627 \u0627\u0644\u0644\u0647 \u0645\u062d\u0645\u062f \u0631\u0633\u0648\u0644 \u0627\u0644\u0644\u0647. \u0641\u0647\u064a \u0634\u0647\u0627\u062f\u0629 \u0644\u0647\u0627 \u0634\u0642\u0627\u0646\u060c \u0648\u0644\u064a\u0633\u062a \u0634\u0647\u0627\u062f\u062a\u064a\u0646\u060c \u0625\u0644\u0627 \u0645\u0646 \u0628\u0627\u0628 \u0627\u0644\u0645\u062c\u0627\u0632\u060c \u0648\u0627\u0644\u0627\u0642\u062a\u0636\u0627\u0621 \u0627\u0644\u0644\u063a\u0648\u064a. \u0648\u0625\u0646 \u0643\u0627\u0646 \u0627\u0644\u0647\u0644\u0627\u0644\u064a \u0642\u062f \u062a\u062e\u0644\u0649 \u0639\u0646 \u0646\u0635\u0641\u0647\u0627\u060c \u0641\u0645\u0627 \u0623\u062f\u0631\u0627\u0646\u0627 \u0623\u0646\u0647 \u0644\u0646 \u064a\u062a\u0646\u0627\u0632\u0644 -\u0647\u0648 \u0623\u0648 \u0623\u062d\u062f \u0623\u0645\u062b\u0627\u0644\u0647- \u0639\u0646 \u0646\u0635\u0641 \u0627\u0644\u0646\u0635\u0641 \u0627\u0644\u0628\u0627\u0642\u064a\u060c \u0641\u064a\u0642\u0648\u0644: \u0645\u0646 \u0642\u0627\u0644 \u0644\u0627 \u0625\u0644\u0647\u060c \u0647\u0648 \u0645\u0639\u062f\u0648\u062f \u0645\u0646 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646\u061b \u0645\u0627 \u062f\u0627\u0645 \u0647\u0630\u0627 \u0627\u0644\u062c\u0632\u0621\u060c \u0647\u0648 \u0645\u0646 \u0627\u0644\u0634\u0647\u0627\u062f\u0629 \u0623\u064a\u0636\u0627.<br \/>&nbsp;<br \/><span style=\"color:#ff0000\">2.<\/span> \u0625\u0646 \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0628\u0627\u0644\u0623\u0635\u0627\u0644\u0629 \u0647\u064a \u0644\u0645\u062d\u0645\u062f \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645\u061b \u0648\u062c\u0645\u064a\u0639 \u0627\u0644\u0631\u0633\u0644 \u0645\u0645\u0646 \u0633\u0648\u0627\u0647\u060c \u0647\u0645 \u0646\u0648\u0627\u0628 \u0644\u0647 \u0641\u064a \u0623\u0632\u0645\u0646\u062a\u0647\u0645\u060c \u0639\u0644\u064a\u0647\u0645 \u0627\u0644\u0633\u0644\u0627\u0645\u060c \u0644\u064a\u0633 \u063a\u064a\u0631. \u0648\u0644\u0647\u0630\u0627 \u0643\u0627\u0646\u0648\u0627 \u0645\u0623\u0645\u0648\u0631\u064a\u0646 \u0628\u0627\u0644\u062a\u062e\u0644\u064a \u0639\u0646 \u0627\u0644\u0645\u0631\u062a\u0628\u0629 \u0644\u0647\u060c \u0625\u0646 \u0647\u0645 \u0623\u062f\u0631\u0643\u0647\u0645 \u0632\u0645\u0627\u0646\u0647 \u0627\u0644\u0634\u0631\u064a\u0641. \u0648\u0642\u062f \u0642\u0627\u0644 \u0627\u0644\u0644\u0647 \u0641\u064a \u0647\u0630\u0627: {\u0648\u064e\u0625\u0650\u0630\u0652 \u0623\u064e\u062e\u064e\u0630\u064e \u0627\u0644\u0644\u064e\u0651\u0647\u064f \u0645\u0650\u064a\u062b\u064e\u0627\u0642\u064e \u0627\u0644\u0646\u064e\u0651\u0628\u0650\u064a\u0650\u0651\u064a\u0646\u064e \u0644\u064e\u0645\u064e\u0627 \u0622\u062a\u064e\u064a\u0652\u062a\u064f\u0643\u064f\u0645\u0652 \u0645\u0650\u0646\u0652 \u0643\u0650\u062a\u064e\u0627\u0628\u064d \u0648\u064e\u062d\u0650\u0643\u0652\u0645\u064e\u0629\u064d \u062b\u064f\u0645\u064e\u0651 \u062c\u064e\u0627\u0621\u064e\u0643\u064f\u0645\u0652 \u0631\u064e\u0633\u064f\u0648\u0644\u064c \u0645\u064f\u0635\u064e\u062f\u0650\u0651\u0642\u064c \u0644\u0650\u0645\u064e\u0627 \u0645\u064e\u0639\u064e\u0643\u064f\u0645\u0652 \u0644\u064e\u062a\u064f\u0624\u0652\u0645\u0650\u0646\u064f\u0646\u064e\u0651 \u0628\u0650\u0647\u0650 \u0648\u064e\u0644\u064e\u062a\u064e\u0646\u0652\u0635\u064f\u0631\u064f\u0646\u064e\u0651\u0647\u064f \u0642\u064e\u0627\u0644\u064e \u0623\u064e\u0623\u064e\u0642\u0652\u0631\u064e\u0631\u0652\u062a\u064f\u0645\u0652 \u0648\u064e\u0623\u064e\u062e\u064e\u0630\u0652\u062a\u064f\u0645\u0652 \u0639\u064e\u0644\u064e\u0649 \u0630\u064e\u0644\u0650\u0643\u064f\u0645\u0652 \u0625\u0650\u0635\u0652\u0631\u0650\u064a \u0642\u064e\u0627\u0644\u064f\u0648\u0627 \u0623\u064e\u0642\u0652\u0631\u064e\u0631\u0652\u0646\u064e\u0627 \u0642\u064e\u0627\u0644\u064e \u0641\u064e\u0627\u0634\u0652\u0647\u064e\u062f\u064f\u0648\u0627 \u0648\u064e\u0623\u064e\u0646\u064e\u0627 \u0645\u064e\u0639\u064e\u0643\u064f\u0645\u0652 \u0645\u0650\u0646\u064e \u0627\u0644\u0634\u064e\u0651\u0627\u0647\u0650\u062f\u0650\u064a\u0646\u064e } [\u0622\u0644 \u0639\u0645\u0631\u0627\u0646: 81]. \u0641\u0627\u0644\u0631\u0633\u0644 \u0639\u0644\u064a\u0647\u0645 \u0627\u0644\u0633\u0644\u0627\u0645 \u0645\u0623\u0645\u0648\u0631\u0648\u0646 \u0628\u0627\u062a\u0628\u0627\u0639\u0647 \u0634\u0647\u0627\u062f\u0629\u060c \u0643\u0645\u0627 \u0647\u0645 \u0645\u0624\u0645\u0646\u0648\u0646 \u0628\u0647 \u063a\u064a\u0628\u0627. \u0648\u0644\u0648\u0644\u0627 \u0647\u0630\u0627 \u0627\u0644\u0639\u0644\u0645 \u0648\u0627\u0644\u0625\u064a\u0645\u0627\u0646\u060c \u0645\u0627 \u0643\u0627\u0646 \u0644\u0639\u064a\u0633\u0649 \u0639\u0644\u064a\u0647 \u0627\u0644\u0633\u0644\u0627\u0645 \u0623\u0646 \u064a\u0642\u0648\u0644: {\u064a\u064e\u0627\u0628\u064e\u0646\u0650\u064a \u0625\u0650\u0633\u0652\u0631\u064e\u0627\u0626\u0650\u064a\u0644\u064e \u0625\u0650\u0646\u0650\u0651\u064a \u0631\u064e\u0633\u064f\u0648\u0644\u064f \u0627\u0644\u0644\u064e\u0651\u0647\u0650 \u0625\u0650\u0644\u064e\u064a\u0652\u0643\u064f\u0645\u0652 \u0645\u064f\u0635\u064e\u062f\u0650\u0651\u0642\u064b\u0627 \u0644\u0650\u0645\u064e\u0627 \u0628\u064e\u064a\u0652\u0646\u064e \u064a\u064e\u062f\u064e\u064a\u064e\u0651 \u0645\u0650\u0646\u064e \u0627\u0644\u062a\u064e\u0651\u0648\u0652\u0631\u064e\u0627\u0629\u0650 \u0648\u064e\u0645\u064f\u0628\u064e\u0634\u0650\u0651\u0631\u064b\u0627 \u0628\u0650\u0631\u064e\u0633\u064f\u0648\u0644\u064d \u064a\u064e\u0623\u0652\u062a\u0650\u064a \u0645\u0650\u0646\u0652 \u0628\u064e\u0639\u0652\u062f\u0650\u064a \u0627\u0633\u0652\u0645\u064f\u0647\u064f \u0623\u064e\u062d\u0652\u0645\u064e\u062f\u064f } [\u0627\u0644\u0635\u0641: 6]. \u0648\u0647\u0630\u0627 \u064a\u0639\u0646\u064a \u0623\u0646\u0647 \u0639\u0644\u064a\u0647 \u0627\u0644\u0633\u0644\u0627\u0645\u060c \u0645\u0623\u0645\u0648\u0631 \u0639\u0644\u0649 \u0648\u062c\u0647 \u0627\u0644\u0648\u062c\u0648\u0628 \u0623\u0646 \u064a\u0643\u0648\u0646 \u062a\u0627\u0628\u0639\u0627 \u0644\u0645\u062d\u0645\u062f \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645\u061b \u0648\u0639\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u062d\u0627\u0644 \u0633\u064a\u0643\u0648\u0646\u060c \u0639\u0646\u062f \u0646\u0632\u0648\u0644\u0647 \u0641\u064a \u0622\u062e\u0631 \u0627\u0644\u0632\u0645\u0627\u0646. \u0646\u0639\u0646\u064a \u0623\u0646\u0647 \u0633\u064a\u0646\u0632\u0644 \u0648\u0644\u064a\u0627 \u0645\u0646 \u0623\u0648\u0644\u064a\u0627\u0621 \u0623\u0645\u062a\u0646\u0627\u060c \u0644\u0627 \u0631\u0633\u0648\u0644\u0627 \u0644\u0628\u0646\u064a \u0625\u0633\u0631\u0627\u0626\u064a\u0644. \u0641\u0625\u0646 \u0643\u0627\u0646 \u0647\u0630\u0627 \u0634\u0623\u0646 \u0639\u064a\u0633\u0649 \u0639\u0644\u064a\u0647 \u0627\u0644\u0633\u0644\u0627\u0645\u060c \u0641\u0643\u064a\u0641 \u064a\u062d\u0643\u0645 \u0647\u0630\u0627 \u0627\u0644\u0647\u0644\u0627\u0644\u064a \u0628\u0625\u0633\u0644\u0627\u0645 \u0645\u0646 \u0644\u0627 \u064a\u0624\u0645\u0646 \u0628\u0646\u0628\u064a\u0646\u0627 \u0645\u0646 \u0623\u062d\u062f \u0645\u062f\u0651\u0639\u064a \u0627\u062a\u0650\u0651\u0628\u0627\u0639 \u0639\u064a\u0633\u0649\u061f!.. \u0628\u0644 \u0625\u0646 \u0643\u0644 \u0645\u0646 \u0644\u0627 \u064a\u0624\u0645\u0646 \u0628\u0645\u062d\u0645\u062f \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645 \u0627\u0644\u064a\u0648\u0645\u060c \u0645\u0646 \u0623\u0647\u0644 \u0627\u0644\u0643\u062a\u0627\u0628 \u0623\u0648 \u0645\u0645\u0646 \u0633\u0648\u0627\u0647\u0645\u060c \u0648\u0645\u0627\u062a \u0639\u0644\u0649 \u0630\u0644\u0643\u060c \u0641\u0625\u0646\u0647 \u0645\u0646 \u0623\u0647\u0644 \u0627\u0644\u0646\u0627\u0631 \u064a\u0642\u064a\u0646\u0627. \u0647\u0630\u0627 \u062d\u0643\u0645 \u0627\u0644\u0644\u0647\u060c \u0627\u0644\u0630\u064a \u0644\u0627 \u062a\u0628\u062f\u064a\u0644 \u0641\u064a\u0647 \u0648\u0644\u0627 \u062a\u063a\u064a\u064a\u0631!<br \/>&nbsp;<br \/><span style=\"color:#ff0000\">3. <\/span>\u0625\u0646 \u0627\u0639\u062a\u0642\u0627\u062f \u0623\u0646 \u0627\u0644\u0625\u064a\u0645\u0627\u0646 \u0628\u0645\u062d\u0645\u062f \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645\u060c \u0644\u064a\u0633 \u0636\u0631\u0648\u0631\u064a\u0627 \u0644\u062b\u0628\u0648\u062a \u0625\u0633\u0644\u0627\u0645 \u0627\u0644\u0645\u0631\u0621\u060c \u0647\u0648 \u0643\u0641\u0631 \u0635\u0631\u064a\u062d\u060c \u064a\u0646\u0628\u063a\u064a \u0623\u0646 \u064a\u064f\u0633\u062a\u062a\u0627\u0628 \u0645\u0646\u0647 \u0635\u0627\u062d\u0628\u0647\u061b \u0648\u0625\u0644\u0627 \u0639\u064f\u062f\u0651 \u0645\u0646 \u0627\u0644\u0645\u0631\u062a\u062f\u0651\u064a\u0646.<br \/>&nbsp;<br \/><span style=\"color:#ff0000\">4. <\/span>\u0623\u0645\u0627 \u062d\u0645\u0644 \u0627\u0644\u062d\u062f\u064a\u062b \u0627\u0644\u0646\u0628\u0648\u064a: &laquo;\u0627\u0644\u0652\u0645\u064f\u0633\u0652\u0644\u0650\u0645\u064f \u0645\u064e\u0646\u0652 \u0633\u064e\u0644\u0650\u0645\u064e \u0627\u0644\u0652\u0645\u064f\u0633\u0652\u0644\u0650\u0645\u064f\u0648\u0646\u064e \u0645\u0650\u0646\u0652 \u0644\u0650\u0633\u064e\u0627\u0646\u0650\u0647\u0650\u060c \u0648\u064e\u064a\u064e\u062f\u0650\u0647\u0650&raquo;[\u0645\u062a\u0641\u0642 \u0639\u0644\u064a\u0647]\u060c \u0639\u0644\u0649 \u0627\u0644\u0645\u0639\u0646\u0649 \u0627\u0644\u0644\u063a\u0648\u064a \u0627\u0644\u0639\u0627\u0645\u060c \u0628\u062d\u064a\u062b \u064a\u062f\u062e\u0644 \u0641\u064a\u0647 \u0643\u0644 \u0645\u0646 \u0633\u0627\u0644\u0645 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0645\u0646 \u0627\u0644\u0643\u0641\u0627\u0631\u060c \u0641\u0647\u0648 \u062c\u0647\u0644 \u0648\u062a\u062d\u0631\u064a\u0641 \u0645\u0628\u0637\u0644\u061b \u0644\u0623\u0646 \u0627\u0644\u0645\u0642\u0635\u0648\u062f \u0628\u0627\u0644\u062d\u062f\u064a\u062b \u0627\u0644\u0641\u0631\u062f \u0627\u0644\u0645\u0633\u0644\u0645 \u0628\u064a\u0646 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646. \u0648\u0627\u0644\u0645\u0639\u0646\u0649 \u0647\u0648 \u0623\u0646 \u0627\u0644\u0645\u0633\u0644\u0645 \u0644\u0627 \u064a\u0635\u062d \u0625\u0633\u0644\u0627\u0645\u0647\u060c \u062d\u062a\u0649 \u0644\u0627 \u064a\u0643\u0648\u0646 \u0645\u0646\u0647 \u0623\u0630\u0649 \u0644\u0625\u062e\u0648\u0627\u0646\u0647. \u0647\u0630\u0627 \u0641\u062d\u0633\u0628.<br \/>&nbsp;<br \/>&nbsp; &nbsp; &nbsp; &nbsp;\u0641\u0644\u064a\u062d\u0630\u0631 \u0627\u0644\u0645\u0633\u0644\u0645\u0648\u0646 \u0639\u0644\u0649 \u0623\u0646\u0641\u0633\u0647\u0645 \u0645\u0646 \u0627\u0644\u0647\u0644\u0627\u0644\u064a \u0648\u0623\u0634\u0628\u0627\u0647\u0647 \u0645\u0646 \u0641\u0642\u0647\u0627\u0621 \u0625\u0628\u0644\u064a\u0633\u060c \u0648\u0644\u064a\u0639\u0644\u0645\u0648\u0627 \u0623\u0646\u0647 \u0644\u0627 \u064a\u0646\u0641\u0639\u0647\u0645 \u0639\u0646\u062f \u0631\u0628\u0647\u0645 \u0625\u0644\u0627 \u0627\u0644\u062d\u0642\u061b \u0641\u0645\u0646 \u0623\u0631\u0627\u062f \u0623\u0646 \u064a\u064e\u0633\u0644\u064e\u0645 \u0644\u0647 \u062f\u064a\u0646\u0647\u060c \u0641\u0644\u064a\u062a\u0645\u0633\u0643 \u0628\u0645\u0627 \u062c\u0627\u0621 \u0641\u064a \u0627\u0644\u0642\u0631\u0622\u0646 \u0648\u0627\u0644\u0633\u0646\u0629 \u0645\u0646 \u063a\u064a\u0631 \u062a\u0623\u0648\u064a\u0644 \u0648\u0644\u0627 \u062a\u0639\u0637\u064a\u0644\u061b \u0648\u0644\u064a\u0635\u0628\u0631 \u0639\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u0641\u062a\u0646\u060c \u0641\u0625\u0646 \u0644\u0647\u0627 \u0646\u0647\u0627\u064a\u0629\u061b \u0625\u0645\u0627 \u0628\u0627\u0644\u0645\u0648\u062a\u060c \u0648\u0625\u0645\u0627 \u0628\u0638\u0647\u0648\u0631 \u0627\u0644\u062d\u0642 \u062c\u0644\u064a\u0627 \u0644\u0644\u0639\u0645\u0648\u0645.<br \/>&nbsp;<br \/>&nbsp; &nbsp; &nbsp; &nbsp;{\u0647\u064e\u0630\u064e\u0627 \u0628\u064e\u064a\u064e\u0627\u0646\u064c \u0644\u0650\u0644\u0646\u064e\u0651\u0627\u0633\u0650 \u0648\u064e\u0647\u064f\u062f\u064b\u0649 \u0648\u064e\u0645\u064e\u0648\u0652\u0639\u0650\u0638\u064e\u0629\u064c \u0644\u0650\u0644\u0652\u0645\u064f\u062a\u064e\u0651\u0642\u0650\u064a\u0646\u064e} [\u0622\u0644 \u0639\u0645\u0631\u0627\u0646: 138]. \u0648\u0627\u0644\u062d\u0645\u062f \u0644\u0644\u0647 \u0631\u0628 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0646.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u0627\u0644\u0631\u0627\u0628\u0637:&nbsp;http:\/\/youtu.be\/tgG7_EbPur4 &nbsp;&nbsp; &nbsp; &nbsp; &nbsp;\u0645\u0627 \u0641\u062a\u0626\u0646\u0627 \u0646\u062d\u0630\u0650\u0651\u0631 \u0643\u0644 \u0645\u0631\u0629 \u0645\u0646 \u062a\u0633\u0631\u0651\u0628 \u0627\u0644\u0641\u0643\u0631 \u0627\u0644\u062f\u062c\u0627\u0644\u064a \u0625\u0644\u0649 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646\u061b \u0630\u0644\u0643 \u0627\u0644\u0641\u0643\u0631 \u0627\u0644\u0630\u064a \u064a\u064f\u0631\u0627\u062f \u0645\u0646\u0647 \u062a\u0647\u064a\u064a\u0621 \u0627\u0644\u0646\u0627\u0633 -\u0648\u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u062e\u0627\u0635\u0629\u060c \u0645\u0646 \u0643\u0648\u0646\u0647\u0645 \u0623\u0635\u062d\u0627\u0628 \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0627\u0644\u0625\u0644\u0647\u064a\u0629 \u0627\u0644\u062e\u0627\u062a\u0645\u0629-\u060c \u0644\u0642\u0628\u0648\u0644 \u0627\u0644\u062f\u064a\u0646 \u0627\u0644\u062f\u062c\u0627\u0644\u064a \u0627\u0644\u0639\u0648\u0644\u0645\u064a. \u0648\u0625\u0646 \u0645\u0627 \u0635\u062f\u0631 \u0639\u0646 \u062f. \u0633\u0639\u062f \u0627\u0644\u062f\u064a\u0646 \u0627\u0644\u0647\u0644\u0627\u0644\u064a \u0645\u0624\u062e\u0631\u0627 \u0639\u0644\u0649 \u0642\u0646\u0627\u0629 \u0627\u0644\u064a\u0648\u0645\u060c \u0641\u064a \u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u0642\u0627\u0647\u0631\u0629 \u0627\u0644\u064a\u0648\u0645\u060c \u0628\u062a\u0627\u0631\u064a\u062e: 24-11- 2014\u0645\u060c \u0645\u0646 \u0623\u0646 [&hellip;]<\/p>\n","protected":false},"author":2,"featured_media":0,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"footnotes":""},"categories":[9],"tags":[],"class_list":["post-11559","post","type-post","status-publish","format-standard","hentry","category-9"],"acf":[],"yoast_head":"<!-- This site is optimized with the Yoast SEO plugin v24.9 - https:\/\/yoast.com\/wordpress\/plugins\/seo\/ -->\n<title>\u0633\u0639\u062f \u0627\u0644\u062f\u064a\u0646 \u0627\u0644\u0647\u0644\u0627\u0644\u064a \u0648\u0627\u0644\u0625\u0633\u0644\u0627\u0645 \u0627\u0644\u062f\u062c\u0627\u0644\u064a - \u0639\u0628\u062f \u0627\u0644\u063a\u0646\u064a \u0627\u0644\u0639\u0645\u0631\u064a \u0627\u0644\u062d\u0633\u0646\u064a<\/title>\n<meta name=\"description\" content=\"\u0633\u0639\u062f \u0627\u0644\u062f\u064a\u0646 \u0627\u0644\u0647\u0644\u0627\u0644\u064a \u0648\u0627\u0644\u0625\u0633\u0644\u0627\u0645 \u0627\u0644\u062f\u062c\u0627\u0644\u064a\" 