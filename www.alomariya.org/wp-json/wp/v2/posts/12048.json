0\u0640\u062a\u064e\u0642\u0652\u0628\u0640\u0640\u0650\u0644\u0652 \u0642\u0650\u0628\u0652\u0640\u0640\u0640\u0640\u0644\u064e\u0640\u0640\u062a\u0650\u064a<br \/>\n\u064a\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u064e\u0627\u0646\u064e\u0627 \u062b\u064e\u0640\u0640\u0640\u0645\u064e\u0651 \u062d\u064e\u0640\u0640\u0640\u0640\u0642\u0651\u0627\u064b\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0645\u0650\u0640\u0640\u0640\u0640\u0640\u0646\u0652 \u063a\u064e\u064a\u0640\u0640\u0640\u0640\u0640\u0652\u0631\u0652 \u063a\u064e\u064a\u0652\u0640\u0640\u0640\u0640\u0640\u0631\u0650\u064a\u064e\u0629\u0650<br \/>\n\u0639\u064e\u0644\u064e\u0651\u0645\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0646\u0650\u064a \u0627\u0644\u0652\u0640\u0639\u064e\u0640\u0640\u0644\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u064a\u0645\u064f\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0645\u0650\u0640\u0640\u0640\u0640\u0646\u0652 \u062f\u064f\u0648\u0646\u0650 \u0645\u064e\u0640\u0640\u0640\u062f\u0652\u0631\u064e\u0633\u064e\u0640\u0640\u0640\u0640\u0640\u0629\u0650<br \/>\n\u0641\u064e\u0640\u0640\u0640\u0640\u0635\u0650\u0640\u0640\u0640\u0640\u0631\u0652\u062a\u064f \u0645\u064f\u0639\u064e\u0640\u0640\u0640\u0640\u0644\u0650\u0651\u0640\u0640\u0640\u0645\u0627\u064b\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0644\u0650\u0645\u064e\u0640\u0640\u0640\u0640\u0646\u0652 \u064a\u064e\u0631\u0652\u0636\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0649 \u0631\u064f\u0641\u0652\u0640\u0642\u064e\u0640\u0640\u062a\u0650\u064a<br \/>\n\u0648\u064e\u0644\u0627\u064e \u0641\u064e\u0640\u0640\u0640\u0640\u0640\u062e\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u064e \u0641\u0650\u064a \u0630\u064e\u0627\u0643\u064e\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0644\u0627\u064e \u0648\u064e\u0644\u0627\u064e \u0645\u0650\u0640\u0640\u0640\u0640\u0640\u0646\u0652 \u0645\u0650\u0640\u0646\u064e\u0651\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0629\u0650<br \/>\n\u0641\u064e\u0627\u0644\u0652\u0640\u0640\u0640\u0643\u0640\u0640\u0640\u0640\u0640\u064f\u0644\u064f\u0651 \u0645\u0650\u0640\u0640\u0640\u0646\u064e \u0627\u0644\u0652\u062d\u064e\u0640\u0640\u0640\u0642\u0650\u0651\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0641\u0650\u0640\u064a \u0639\u064e\u064a\u0640\u0640\u0640\u0640\u0640\u0640\u0652\u0646\u0650 \u0628\u064e\u0635\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u064a\u0631\u064e\u062a\u0650\u0640\u0640\u064a<br \/>\n\u0648\u064e\u0627\u0644\u0652\u0640\u0641\u064e\u0640\u0640\u0640\u0636\u0652\u0640\u0640\u0640\u0640\u0640\u0644\u064f \u0645\u0650\u0640\u0640\u0640\u0640\u0646\u064e \u0627\u0644\u0644\u0647\u0650\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e\u062d\u0652\u0640\u0640\u0640\u0640\u0640\u062f\u064e\u0647\u064f \u0648\u064e\u0633\u0650\u0640\u0640\u0640\u0640\u064a\u0644\u064e\u062a\u0640\u0640\u0640\u0650\u0640\u0640\u0640\u064a<br \/>\n\u0648\u064e\u0627\u0644\u0640\u0640\u0640\u0634\u064f\u0651\u0640\u0640\u0640\u0640\u0643\u0652\u0631\u064f \u0644\u0650\u0640\u0640\u0640\u0645\u0640\u064e\u0640\u0640\u0646\u0652 \u0643\u064e\u0627\u0646\u064e\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0625\u0650\u0644\u0640\u0640\u0640\u064e\u064a\u0652\u0640\u0640\u0640\u0640\u0640\u0647\u0650 \u0648\u064e\u0627\u0633\u0650\u0640\u0640\u0640\u0637\u0640\u0640\u0640\u0640\u064e\u0640\u0640\u0640\u062a\u0650\u064a<br \/>\n\u0641\u064e\u0627\u0646\u0652\u0640\u0640\u0640\u0638\u064f\u0640\u0640\u0640\u0631\u0652 \u0641\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u064a\u064e\u0651 \u0646\u064f\u0640\u0640\u0640\u0640\u0648\u0631\u064e\u0647\u064f\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0644\u0627\u064e \u062a\u064e\u0646\u0652\u0640\u0640\u0640\u0640\u0640\u0638\u064f\u0640\u0640\u0640\u0640\u0631\u0652 \u0644\u0650\u0638\u0640\u0640\u0640\u0640\u064f\u0644\u0652\u0645\u064e\u062a\u0650\u0640\u064a<br \/>\n\u0623\u064e\u0646\u064e\u0627 \u0639\u064e\u0640\u0640\u0640\u0640\u0640\u0628\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u062f\u064f\u0647\u064f \u062d\u064e\u0640\u0640\u0640\u0640\u0640\u0642\u0651\u0627\u064b\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0644\u0627\u064e\u0639\u064e\u0640\u0640\u0640\u0640\u0628\u0652\u0640\u0640\u0640\u0640\u0640\u062f\u064c \u0644\u0650\u0646\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0639\u0652\u0640\u0640\u0640\u0645\u064e\u0629\u0650<br \/>\n\u0648\u064e\u0627\u0644\u0623\u064e\u0643\u0652\u0640\u0640\u0640\u0640\u0640\u0648\u064e\u0627\u0646\u064f \u0643\u064f\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0644\u0640\u064f\u0651\u0640\u0647\u0627\u064e\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0639\u0650\u0640\u0640\u0640\u0640\u0640\u0646\u0640\u0640\u0640\u0640\u0640\u0640\u0652\u062f\u064e\u0646\u064e\u0627 \u0643\u064e\u0627\u0644\u0640\u0640\u0640\u0640\u0640\u0640\u0630\u064e\u0651\u0631\u064e\u0651\u0629\u0650<br \/>\n\u0648\u064e\u0627\u0644\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0630\u064e\u0651\u0631\u064e\u0651\u0629\u064f \u0644\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0648\u0652\u0644\u0627\u0647\u064f\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0644\u064e\u0645\u0652 \u062a\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u062d\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0638\u064e \u0628\u0650\u0644\u0640\u064e\u0641\u0652\u062a\u064e\u0640\u0640\u0640\u062a\u0650\u064a<br \/>\n\u0641\u064e\u0640\u0640\u0640\u0640\u0640\u0639\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u062c\u064e\u0628\u0627\u064b \u0644\u0650\u0640\u0634\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0648\u0652\u0642\u064d\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0645\u064e\u0627 \u0644\u064e\u0640\u0640\u0640\u0640\u0640\u0647\u064f \u0645\u0650\u0640\u0640\u0640\u0640\u0640\u0646\u0652 \u063a\u064e\u0627\u064a\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0629\u0650<br \/>\n\u0648\u064e\u0639\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u062c\u0640\u0640\u0640\u064e\u0628\u0627\u064b \u0644\u0627\u0650\u0634\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u062a\u0650\u0640\u064a\u064e\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0642\u064d \u0641\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u064a \u0639\u064e\u0640\u0640\u0640\u0640\u0640\u064a\u0652\u0646\u0650 \u0648\u064f\u0635\u0652\u0644\u064e\u062a\u0650\u064a<br \/>\n\u0643\u064e\u062a\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0645\u0652\u062a\u064f \u062d\u064e\u0627\u0644\u0650\u0640\u0640\u0640\u064a \u0639\u064e\u0640\u0650\u0651\u0646\u064a\u064e\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0641\u0640\u0640\u0640\u0640\u0623\u064e\u0646\u064e\u0627 \u0641\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u064a \u063a\u064e\u0640\u0640\u0640\u0641\u0652\u0640\u0640\u0644\u064e\u0640\u0640\u0640\u0629\u064d<br \/>\n\u0648\u064e\u0645\u064e\u0627 \u0647\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u064a\u064e \u063a\u064e\u0640\u0640\u0641\u0652\u0640\u0640\u0640\u0640\u0640\u0644\u064e\u0629\u064c\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0628\u064e\u0640\u0640\u0640\u0640\u0640\u0644\u0652 \u0647\u0640\u0640\u0640\u0640\u0640\u0650\u064a\u0652 \u0639\u064e\u0640\u064a\u0652\u0646\u064f \u064a\u064e\u0642\u0652\u0638\u064e\u062a\u0650\u064a<br \/>\n\u0648\u064e\u0644\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0648\u0652 \u0628\u064f\u062d\u0652\u0640\u0640\u0640\u0640\u0640\u062a\u064f \u0628\u0650\u0623\u064e\u0645\u0652\u0631\u0650\u064a\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0644\u0623\u064e\u063a\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u064e\u0642\u0652\u062a\u064f \u062c\u0650\u064a\u0640\u0640\u0631\u064e\u062a\u0650\u0640\u0640\u0640\u064a<br \/>\n\u0644\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0643\u0650\u0640\u0640\u0640\u0646\u064e\u0651 \u0645\u064f\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u064e\u0627\u062f\u064e\u0646\u064e\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0628\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0642\u064e\u0627\u0621\u064f \u0634\u064e\u0640\u0640\u0640\u0640\u0631\u0650\u064a\u0640\u0640\u0640\u0639\u064e\u0640\u0640\u0640\u0640\u0629\u0650<br \/>\n\u0643\u064e\u0627\u0644\u0633\u0640\u0640\u0640\u064e\u0651\u0641\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u064a\u0646\u064e\u0629\u0650 \u0639\u064e\u0640\u0640\u0640\u0640\u0644\u064e\u0649\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0628\u064e\u062d\u0652\u0640\u0640\u0640\u0640\u0631\u064d \u0645\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0646\u0652 \u062d\u064e\u0642\u0650\u0640\u0640\u064a\u0640\u0642\u064e\u062a\u0650\u0640\u0640\u064a<br \/>\n\u0647\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0630\u064e\u0627 \u0647\u064f\u0648\u064e \u0645\u064e\u0646\u0652\u0640\u0640\u0640\u0647\u064e\u062c\u064f\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0627\u0644\u0633\u064e\u0651\u0640\u0640\u0640\u0640\u0640\u0644\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0641\u0650 \u0648\u064e\u0627\u0644\u0652\u0640\u0642\u064f\u0640\u0640\u062f\u0652\u0648\u064e\u0629\u0650<br \/>\n\u0641\u064e\u0627\u0639\u0652\u0645\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0644\u0652 \u0639\u064e\u0644\u064e\u064a\u0652\u0640\u0640\u0640\u0647\u0650 \u0648\u064e\u0643\u064f\u0640\u0646\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u062d\u064e\u0627\u0641\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0638\u0627\u064b \u0644\u0650\u0640\u0639\u064f\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0647\u0652\u0640\u0640\u0640\u062f\u064e\u062a\u0650\u064a<br \/>\n\u0641\u064e\u0625\u0650\u0646\u0650\u0651\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u064a \u0645\u064f\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0641\u064e\u0627\u062e\u0650\u0640\u0631\u064c\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0628\u0650\u0643\u0640\u0640\u0640\u0640\u0640\u0640\u064f\u0645\u0652 \u0641\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u064a \u0627\u0644\u0622\u