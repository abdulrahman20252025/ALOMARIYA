{"id":11354,"date":"2012-11-07T19:41:35","date_gmt":"2012-11-07T19:41:35","guid":{"rendered":"http:\/\/alomariya.test\/%d8%a7%d9%84%d8%b1%d8%af-%d8%b9%d9%84%d9%89-%d8%af-%d8%b9%d9%84%d9%8a-%d8%a7%d9%84%d8%b4%d8%a8%d9%84-%d8%aa%d8%aa%d9%85%d8%a9\/"},"modified":"2012-11-07T19:41:35","modified_gmt":"2012-11-07T19:41:35","slug":"%d8%a7%d9%84%d8%b1%d8%af-%d8%b9%d9%84%d9%89-%d8%af-%d8%b9%d9%84%d9%8a-%d8%a7%d9%84%d8%b4%d8%a8%d9%84-%d8%aa%d8%aa%d9%85%d8%a9","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d8%a7%d9%84%d8%b1%d8%af-%d8%b9%d9%84%d9%89-%d8%af-%d8%b9%d9%84%d9%8a-%d8%a7%d9%84%d8%b4%d8%a8%d9%84-%d8%aa%d8%aa%d9%85%d8%a9\/","title":{"rendered":"\u0627\u0644\u0631\u062f \u0639\u0644\u0649 \u062f. \u0639\u0644\u064a \u0627\u0644\u0634\u0628\u0644 (\u062a\u062a\u0645\u0629)"},"content":{"rendered":"<p><u>\u062e\u0627\u062a\u0645\u0629:<\/u><br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0645\u0627 \u0643\u0646\u0627 \u0646\u062a\u0645\u0646\u0649 \u0623\u0646 \u0646\u064f\u0636\u0637\u0631 \u0625\u0644\u0649 \u0642\u0648\u0644 \u0645\u0627 \u0642\u0644\u0646\u0627\u0647\u060c \u0648\u0644\u0643\u0646 \u0628\u0644\u063a \u0627\u0644\u0623\u0645\u0631 \u0645\u0646 \u0627\u0644\u062f\u0643\u062a\u0648\u0631 \u0627\u0644\u0645\u062a\u0643\u0644\u0645 \u0641\u064a \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0645\u0628\u0644\u063a\u0627 \u0645\u0646 \u0627\u0644\u062c\u0647\u0644 \u0648\u0627\u0644\u0648\u0642\u0627\u062d\u0629\u060c \u0644\u0645 \u064a\u062a\u0631\u0643 \u0644\u0646\u0627 \u0645\u0639\u0647 \u062e\u064a\u0627\u0631\u0627 \u0622\u062e\u0631.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0648\u0644\u0648 \u0623\u0646\u0647 \u0648\u0642\u0651\u0631 \u0627\u0644\u0644\u0647 \u0648\u0631\u0633\u0648\u0644\u0647 \u0644\u0643\u064f\u0646\u0627 \u0627\u062d\u062a\u0645\u0644\u0646\u0627 \u0645\u0646\u0647 \u063a\u064a\u0631 \u0630\u0644\u0643\u060c \u0648\u0644\u0643\u0646\u0647 \u064a\u0623\u0628\u0649 \u0625\u0644\u0627 \u0623\u0646 \u064a\u0642\u0648\u0644 \u0645\u0627 \u0644\u0627 \u064a\u062c\u0648\u0632 \u0627\u0644\u0633\u0643\u0648\u062a \u0639\u0646\u0647 \u0628\u062d\u0627\u0644 \u0645\u0646 \u0627\u0644\u0623\u062d\u0648\u0627\u0644\u061b \u0644\u0623\u0646 \u0627\u0644\u0633\u0643\u0648\u062a \u0639\u0646 \u0630\u0644\u0643 \u064a\u062c\u0639\u0644\u0646\u0627 \u0634\u0631\u0643\u0627\u0621 \u0644\u0647 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0625\u062b\u0645 \u0627\u0644\u0639\u0638\u064a\u0645.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0648\u0625\u0646 \u0627\u0644\u0623\u0645\u0629 \u062c\u0645\u0639\u0627\u0621 \u0639\u0644\u064a\u0647\u0627 \u0623\u0646 \u062a\u062a\u0646\u0628\u0647 \u0625\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u062a\u0636\u0644\u064a\u0644\u060c \u0627\u0644\u0630\u064a \u064a\u062c\u0639\u0644\u0647\u0627 \u062a\u062e\u0633\u0631 \u0635\u0644\u062a\u0647\u0627 \u0628\u0631\u0628\u0647\u0627\u060c \u0648\u0625\u0646 \u0623\u0628\u0642\u062a \u0639\u0644\u0649 \u0631\u0633\u0648\u0645 \u0645\u0646 \u0627\u0644\u062a\u062f\u064a\u0651\u0646 \u0644\u0627 \u062a\u063a\u0646\u064a \u0639\u0646\u0647\u0627 \u0634\u064a\u0626\u0627.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0646\u062d\u0646 \u0646\u0639\u0644\u0645 \u0623\u0646 \u0639\u0631\u0636 \u0627\u0644\u0648\u0647\u0627\u0628\u064a\u0629 \u0644\u0644\u062a\u0648\u062d\u064a\u062f\u060c \u064a\u0633\u062a\u0647\u0648\u064a \u0636\u0639\u0627\u0641 \u0627\u0644\u0639\u0642\u0648\u0644 \u0627\u0644\u0630\u064a\u0646 \u064a\u062a\u0648\u0647\u0645\u0648\u0646 \u0623\u0646 \u0625\u062f\u0631\u0627\u0643\u0647\u0645 \u0647\u0648 \u0623\u0639\u0644\u0649 \u0645\u0627 \u064a\u0643\u0648\u0646\u061b \u0641\u064a\u062a\u0639\u0635\u0628\u0648\u0646 \u0644\u0647\u0630\u0627 \u0627\u0644\u0641\u0643\u0631 \u0627\u0644\u0637\u0627\u0631\u0626 \u0639\u0644\u0649 \u0627\u0644\u0623\u0645\u0629\u060c \u0645\u0646 \u063a\u064a\u0631 \u0623\u0646 \u064a\u062a\u0628\u0635\u0631\u0648\u0627 \u0648\u064a\u0646\u0638\u0631\u0648\u0627 \u0625\u0644\u0649 \u0645\u0627 \u064a\u0646\u062a\u062c \u0639\u0646\u0647 \u0645\u0646 \u0646\u0642\u0636 \u0644\u0639\u064f\u0631\u0649 \u0627\u0644\u0625\u064a\u0645\u0627\u0646. \u0648\u0644\u0648 \u0623\u0646\u0647\u0645 \u0627\u0633\u062a\u0642\u0631\u0623\u0648\u0627 \u0627\u0644\u0623\u062d\u0648\u0627\u0644\u060c \u0644\u0639\u0644\u0645\u0648\u0627 \u0645\u0646 \u062f\u0648\u0646 \u0631\u064a\u0628 \u0623\u0646 \u0627\u0644\u0623\u0645\u0629 \u0623\u0635\u0627\u0628\u0647\u0627 \u0627\u0644\u0648\u0647\u0646 \u0639\u0646\u062f\u0645\u0627 \u0646\u0628\u062a \u0641\u064a \u062e\u0627\u0635\u0631\u062a\u0647\u0627 \u0647\u0630\u0627 \u0627\u0644\u0633\u0647\u0645 \u0627\u0644\u0634\u064a\u0637\u0627\u0646\u064a\u060c \u0627\u0644\u0630\u064a \u0648\u062c\u0651\u0647 \u0628\u0623\u0633\u0647\u0627 \u0625\u0644\u064a\u0647\u0627 \u0628\u062f\u0627\u0639\u064a \u062a\u0645\u062d\u064a\u0635 \u0627\u0644\u062a\u0648\u062d\u064a\u062f.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0645\u0627 \u0632\u0644\u0646\u0627 \u0646\u0643\u0631\u0631 -\u0643\u0644\u0645\u0627 \u0633\u0646\u062d\u062a \u0627\u0644\u0641\u0631\u0635\u0629- \u0623\u0646 \u062a\u0648\u062d\u064a\u062f \u0627\u0644\u0648\u0647\u0627\u0628\u064a\u0629 \u062a\u0648\u062d\u064a\u062f \u0646\u0638\u0631\u064a \u063a\u064a\u0631 \u0634\u0631\u0639\u064a. \u0646\u0642\u0648\u0644 \u0647\u0630\u0627\u060c \u062d\u062a\u0649 \u0644\u0627 \u064a\u063a\u062a\u0631 \u0623\u062d\u062f \u0628\u0645\u0627 \u064a\u0638\u0647\u0631 \u0644\u0647 \u0645\u0646 \u062d\u0631\u0635 \u0639\u0644\u0649 \u0625\u0641\u0631\u0627\u062f \u0627\u0644\u0644\u0647 \u0628\u0627\u0644\u0639\u0628\u0648\u062f\u064a\u0629 \u0641\u064a \u0643\u0644\u0627\u0645\u0647\u0645\u061b \u0641\u064a \u062d\u064a\u0646 \u0623\u0646 \u0627\u0644\u0635\u0644\u0629 \u0628\u0627\u0644\u0646\u0628\u064a \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645 \u062a\u0636\u064a\u0639 \u0645\u0646\u0647\u060c \u0648\u064a\u0628\u0642\u0649 \u0645\u0646 \u063a\u064a\u0631 \u0645\u062f\u062f \u0625\u064a\u0645\u0627\u0646\u064a.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0627\u0644\u062a\u0648\u062d\u064a\u062f \u0627\u0644\u0634\u0631\u0639\u064a\u060c \u064a\u0646\u0628\u063a\u064a \u0623\u0646 \u064a\u0648\u0627\u0641\u0642 \u0627\u0644\u0648\u062d\u064a \u0644\u0627 \u0627\u0644\u0641\u0643\u0631 \u0648\u0627\u0644\u0646\u0638\u0631. \u0648\u0645\u0646 \u0643\u0627\u0646 \u064a\u0638\u0646 \u0623\u0646 \u0627\u0644\u062f\u064a\u0646 \u064a\u0636\u0628\u0637\u0647 \u0627\u0644\u0639\u0642\u0644 \u0641\u0647\u0648 \u0645\u0646 \u0623\u062c\u0647\u0644 \u0627\u0644\u062c\u0647\u0627\u0644\u061b \u0625\u0630 \u0644\u0648 \u0643\u0627\u0646 \u0627\u0644\u0623\u0645\u0631 \u0643\u0630\u0644\u0643\u060c \u0644\u0643\u0627\u0646 \u0627\u0644\u062f\u064a\u0646 \u0645\u0630\u0647\u0628\u0627 \u0641\u0643\u0631\u064a\u0627 (\u0623\u064a\u062f\u064a\u0648\u0644\u0648\u062c\u064a\u0627). \u0648\u0627\u0644\u0648\u0627\u0642\u0639 \u0623\u0646 \u0627\u0644\u062f\u064a\u0646 \u062f\u064a\u0646\u060c \u0648\u0627\u0644\u0623\u064a\u062f\u064a\u0648\u0644\u0648\u062c\u064a\u0627 \u0623\u064a\u062f\u064a\u0648\u0644\u0648\u062c\u064a\u0627. \u0648\u0647\u0630\u0627 \u0627\u0644\u062e\u0644\u0637 \u0627\u0644\u0630\u064a \u062a\u0639\u064a\u0634\u0647 \u0627\u0644\u0623\u0645\u0629 \u0641\u064a \u0632\u0645\u0627\u0646\u0646\u0627\u060c \u064a\u062f\u0644 \u0639\u0644\u0649 \u0627\u062e\u062a\u0644\u0627\u0637 \u0627\u0644\u0645\u0641\u0627\u0647\u064a\u0645\u060c \u0627\u0644\u0646\u0627\u062a\u062c \u0639\u0646 \u0627\u062e\u062a\u0644\u0627\u0637 \u0627\u0644\u0645\u0634\u0627\u0631\u0628. \u0641\u0627\u0644\u062a\u0639\u0644\u064a\u0645 \u0627\u0644\u0646\u0638\u0627\u0645\u064a \u0627\u0644\u0630\u064a \u064a\u0633\u062a\u0642\u064a \u0645\u0646\u0647\u0627\u062c \u062a\u0631\u0628\u064a\u062a\u0647 \u0645\u0646 \u0627\u0644\u0641\u0643\u0631 \u0627\u0644\u0643\u0641\u0631\u064a\u060c \u0644\u0645 \u064a\u062a\u0631\u0643 \u0648\u064f\u062c\u062f\u0627\u0646 \u0627\u0644\u0623\u0645\u0629 \u0645\u0646 \u063a\u064a\u0631 \u0623\u0646 \u064a\u0637\u0628\u0639 \u0641\u064a\u0647 \u0623\u0633\u0633\u0647 \u0648\u0645\u0628\u0627\u062f\u0626\u0647! \u0648\u0644\u0643\u0646 \u0627\u0644\u0645\u0633\u0644\u0645 \u0627\u0644\u0639\u0627\u0645\u064a \u0648\u0627\u0644\u0645\u062a\u062e\u0635\u0635 \u0645\u0639\u0627\u060c \u0644\u0627 \u064a\u0633\u062a\u0637\u064a\u0639\u0627\u0646 \u062f\u0627\u0626\u0645\u0627 \u062a\u0628\u064a\u0651\u0646 \u0645\u062f\u0649 \u0627\u0644\u063a\u0632\u0648 \u0627\u0644\u0639\u0642\u0644\u064a \u0627\u0644\u0630\u064a \u0646\u0627\u0644 \u0645\u0646 \u0627\u0644\u0623\u0645\u0629 \u0645\u0646\u0627\u0644\u0647.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0628\u0644\u063a \u0627\u0644\u0623\u0645\u0631 \u0645\u0646 \u0627\u0644\u062a\u0623\u062b\u0631 \u0628\u0627\u0644\u0641\u0643\u0631 \u0627\u0644\u063a\u0631\u0628\u064a\u060c \u0623\u0646 \u0635\u0627\u0631 \u0627\u0644\u0641\u0642\u0647\u0627\u0621 \u064a\u0639\u062a\u0645\u062f\u0648\u0646\u0647 \u0641\u064a \u0641\u0647\u0645 \u0627\u0644\u0642\u0631\u0622\u0646 \u0648\u0627\u0644\u062d\u062f\u064a\u062b \u0623\u062d\u064a\u0627\u0646\u0627\u060c \u0645\u0646 \u063a\u064a\u0631 \u0623\u0646 \u064a\u0641\u0637\u0646\u0648\u0627 \u0625\u0644\u0649 \u0623\u0635\u0644\u0647 \u0627\u0644\u0638\u0644\u0645\u0627\u0646\u064a\u061b \u0627\u0644\u0634\u064a\u0621 \u0627\u0644\u0630\u064a \u062c\u0639\u0644 \u0627\u0644\u0636\u0644\u0627\u0644\u0627\u062a \u062a\u0646\u062a\u062c \u0639\u0646\u0647\u0645\u060c \u0648\u0647\u0645 \u0644\u0627 \u064a\u0634\u0639\u0631\u0648\u0646.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0648\u0627\u0644\u0641\u0643\u0631 \u0627\u0644\u0648\u0647\u0627\u0628\u064a \u0627\u0644\u062a\u064a\u0645\u064a\u060c \u0642\u062f \u0648\u0627\u0641\u0642 \u0627\u0644\u0641\u0643\u0631 \u0627\u0644\u063a\u0631\u0628\u064a \u0641\u064a \u0641\u0635\u0644 \u0634\u0637\u0631 \u0643\u0628\u064a\u0631 \u0645\u0646 \u0627\u0644\u062f\u064a\u0646 \u0639\u0646 \u0623\u0635\u0644\u0647 \u0627\u0644\u063a\u064a\u0628\u064a\u060c \u0641\u0646\u0634\u0623 \u0645\u0646\u0647 \u0645\u0630\u0647\u0628 \u0645\u0627\u062f\u064a \u0641\u064a \u0627\u0644\u062f\u064a\u0646\u060c \u064a\u062a\u0646\u0643\u0631 \u0644\u0643\u0644 \u0645\u0627 \u0644\u0627 \u064a\u064f\u062f\u0631\u0643 \u0628\u0627\u0644\u062d\u0633 \u0627\u0644\u0645\u0634\u062a\u0631\u0643. \u0648\u062d\u062a\u0649 \u0644\u0627 \u064a\u0646\u0641\u0636\u062d \u0627\u0644\u0623\u0645\u0631\u060c \u0648\u064a\u062a\u0646\u0628\u0647 \u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0647\u0630\u0627 \u0627\u0644\u0627\u0646\u062d\u0631\u0627\u0641 \u0627\u0644\u0633\u0627\u0641\u0631\u060c \u062c\u0639\u0644\u0648\u0627 \u0623\u0645\u0631 \u0627\u0644\u063a\u064a\u0628 \u0645\u064f\u0646\u062d\u0635\u0631\u0627 \u0641\u064a \u0645\u0631\u062d\u0644\u0629 \u0645\u062e\u0635\u0648\u0635\u0629 \u0645\u0646 \u0627\u0644\u0632\u0645\u0627\u0646\u060c \u0648\u0627\u0644\u062a\u064a \u0647\u064a \u0627\u0644\u0642\u0631\u0646 \u0627\u0644\u0623\u0648\u0644 \u0641\u0645\u0627 \u0628\u0639\u062f\u0647 \u0628\u0642\u0644\u064a\u0644. \u0648\u0628\u0647\u0630\u0627\u060c \u0635\u0627\u0631 \u0627\u0644\u062f\u064a\u0646 \u0639\u0646\u062f\u0647\u0645 \u062a\u0627\u0631\u064a\u062e\u064a\u0627\u060c \u0644\u0627 \u064a\u0641\u064a\u062f \u0627\u0644\u0625\u0646\u0633\u0627\u0646 \u0627\u0644\u0645\u0639\u0627\u0635\u0631 \u0641\u064a \u0634\u064a\u0621.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0648\u0627\u0644\u062f\u064a\u0646 \u0625\u0630\u0627 \u0635\u0627\u0631 \u062a\u0627\u0631\u064a\u062e\u064a\u0627\u060c \u0644\u0645 \u064a\u0639\u062f \u064a\u0635\u0644 \u0628\u064a\u0646 \u0627\u0644\u0639\u0628\u062f \u0648\u0631\u0628\u0647\u061b \u0641\u064a\u0641\u0642\u062f \u0645\u0639 \u0627\u0646\u0639\u062f\u0627\u0645 \u0647\u0630\u0647 \u0627\u0644\u0635\u0644\u0629 \u0631\u0648\u062d\u0647\u060c \u0648\u064a\u062a\u062d\u0648\u0644 \u0625\u0644\u0649 \u0639\u0642\u0627\u0626\u062f \u0641\u0643\u0631\u064a\u0629\u060c \u062a\u0632\u064a\u062f \u0645\u0646 \u0623\u0645\u0631\u0627\u0636 \u0627\u0644\u0646\u0627\u0633 \u0648\u062a\u062f\u0641\u0639\u0647\u0645 \u0625\u0644\u0649 \u0627\u0644\u0627\u0642\u062a\u062a\u0627\u0644 \u0641\u064a\u0645\u0627 \u0628\u064a\u0646\u0647\u0645 \u0623\u0643\u062b\u0631 \u0641\u0623\u0643\u062b\u0631.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u064a\u062e\u0644\u0637 \u0643\u062b\u064a\u0631 \u0645\u0646 \u0627\u0644\u0646\u0627\u0633 \u0628\u064a\u0646 \u0627\u0644\u0642\u062a\u0627\u0644 \u0641\u064a \u0633\u0628\u064a\u0644 \u0627\u0644\u0644\u0647\u060c \u0627\u0644\u0630\u064a \u0643\u0627\u0646 \u0634\u0631\u0639\u064a\u0627 \u0644\u0627 \u064a\u062f\u062e\u0644\u0647 \u0647\u0648\u0649 \u0648\u0644\u0627 \u0639\u0635\u0628\u064a\u0629\u060c \u0648\u0628\u064a\u0646 \u0627\u0644\u0642\u062a\u0627\u0644 \u0627\u0644\u0630\u064a \u0647\u0648 \u0646\u062a\u064a\u062c\u0629 \u0645\u064e\u0631\u0636\u064a\u0629\u060c \u0644\u0646\u0641\u0648\u0633 \u0627\u0643\u062a\u0646\u0641\u062a\u0647\u0627 \u0627\u0644\u0638\u0644\u0645\u0629 \u0648\u0641\u0642\u062f\u062a \u0645\u0639\u0647\u0627 \u0627\u0644\u0647\u062f\u0649. \u0647\u0630\u0627 \u0627\u0644\u062e\u0644\u0637 \u0627\u0644\u0648\u0627\u0642\u0639\u060c \u0647\u0648 \u0628\u0633\u0628\u0628 \u0627\u0644\u0646\u0638\u0631 \u0625\u0644\u0649 \u0627\u0644\u0635\u0648\u0631\u0629 \u062f\u0648\u0646 \u0627\u0644\u0628\u0648\u0627\u0639\u062b. \u0648\u0647\u0648 \u0645\u0646 \u0627\u0644\u0641\u0643\u0631 \u0627\u0644\u0633\u0637\u062d\u064a \u0627\u0644\u0630\u064a \u064a\u0645\u064a\u0651\u0632 \u0647\u0630\u0647 \u0627\u0644\u0637\u0627\u0626\u0641\u0629 \u0645\u0646\u0630 \u0638\u0647\u0648\u0631\u0647\u0627.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0648\u0625\u0646 \u0643\u0627\u0646 \u062a\u0645\u064a\u064a\u0632 \u0627\u0644\u0645\u0631\u0621 \u0644\u062d\u0627\u0644 \u0646\u0641\u0633\u0647\u060c \u0645\u0646 \u0623\u0639\u0633\u0631 \u0627\u0644\u0623\u0645\u0648\u0631 \u0641\u064a \u0627\u0644\u063a\u0627\u0644\u0628\u061b \u0641\u0625\u0646 \u0627\u0644\u0639\u0644\u0627\u0645\u0627\u062a \u0648\u0627\u0644\u0628\u0631\u0627\u0647\u064a\u0646\u060c \u0644\u0627 \u064a\u0639\u0633\u0631 \u0639\u0644\u0649 \u0645\u062a\u062a\u0628\u0639\u0647\u0627 \u0631\u0628\u0637\u0647\u0627 \u0628\u0623\u0635\u0648\u0644\u0647\u0627 \u0648\u0646\u062a\u0627\u0626\u062c\u0647\u0627 \u0625\u0646 \u0647\u0648 \u0644\u0645 \u064a\u0633\u0639 \u0641\u064a \u063a\u0634 \u0646\u0641\u0633\u0647. \u0648\u0645\u0646 \u0647\u0630\u0647 \u0627\u0644\u0639\u0644\u0627\u0645\u0627\u062a\u060c \u0623\u0646 \u064a\u0646\u0638\u0631 \u0627\u0644\u0645\u0631\u0621 \u0625\u0644\u0649 \u0623\u064a \u062d\u0632\u0628 \u064a\u0645\u064a\u0644. \u0648\u0627\u0644\u0639\u0628\u0631\u0629 \u0641\u064a \u0647\u0630\u0627\u060c \u0644\u064a\u0633\u062a \u0628\u0627\u0644\u0623\u0633\u0645\u0627\u0621\u061b \u0644\u0623\u0646 \u0627\u0644\u062a\u062e\u0641\u064a \u062e\u0644\u0641 \u0627\u0644\u0623\u0633\u0645\u0627\u0621 \u0627\u0644\u062d\u0642 \u0647\u0648 \u0645\u0646 \u062a\u0644\u0628\u064a\u0633 \u0627\u0644\u0634\u064a\u0627\u0637\u064a\u0646 \u0639\u0644\u0649 \u0645\u0631 \u0627\u0644\u0642\u0631\u0648\u0646. \u0648\u0644\u0646 \u062a\u062c\u062f \u0623\u0628\u062f\u0627\u060c \u0623\u062d\u062f\u0627 \u0645\u0646 \u0627\u0644\u0636\u0627\u0644\u064a\u0646\u060c \u064a\u0635\u0641 \u0646\u0641\u0633\u0647 \u0628\u0627\u0644\u0636\u0644\u0627\u0644\u060c \u0648\u064a\u064f\u062e\u0628\u0631 \u0623\u0646\u0647 \u0645\u064f\u062e\u062a\u0627\u0631 \u0644\u0647 \u0631\u063a\u0645 \u0630\u0644\u0643\u061b \u0648\u0644\u0643\u0646 \u0627\u0644\u0623\u0645\u0631 \u0633\u064a\u064f\u0639\u0631\u0636 \u0639\u0644\u0649 \u0623\u0646\u0647 \u0627\u062a\u0628\u0627\u0639 \u0644\u0644\u062d\u0642\u060c \u0648\u062a\u0635\u062d\u064a\u062d \u0644\u0645\u0627 \u0634\u0627\u0639 \u0645\u0646 \u0627\u0644\u0627\u0646\u062d\u0631\u0627\u0641. \u0641\u0645\u0627 \u0628\u0642\u064a \u0625\u0644\u0627 \u0623\u0646 \u064a\u0646\u0638\u0631 \u0627\u0644\u0645\u0631\u0621 \u0647\u0644 \u0647\u0648 \u0645\u0646 \u0627\u0644\u062d\u0632\u0628 \u0627\u0644\u0630\u064a \u064a\u0643\u0648\u0646 \u0645\u0646\u0647 \u0623\u0647\u0644 \u0627\u0644\u0644\u0647 \u0641\u064a \u0632\u0645\u0627\u0646\u0647 \u062e\u0635\u0648\u0635\u0627 \u0648\u0641\u064a \u0627\u0644\u0623\u0632\u0645\u0646\u0629 \u0627\u0644\u0645\u062a\u0623\u062e\u0631\u0629\u060c \u0623\u0645 \u0623\u0646\u0647 \u0641\u064a \u0627\u0644\u062c\u0627\u0646\u0628 \u0627\u0644\u0645\u0642\u0627\u0628\u0644. \u0648\u0644\u0642\u062f \u062e\u0635\u0635\u0646\u0627 \u0627\u0644\u0623\u0632\u0645\u0646\u0629 \u0627\u0644\u0645\u062a\u0623\u062e\u0631\u0629 \u0628\u0627\u0644\u0630\u0643\u0631\u060c \u0644\u0623\u0646 \u0627\u0644\u0636\u0627\u0644\u064a\u0646 \u064a\u0632\u0639\u0645\u0648\u0646 \u0623\u0646\u0647\u0645 \u0645\u062a\u0628\u0639\u0648\u0646 \u0644\u0644\u0646\u0628\u064a \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645\u060c \u0648\u0644\u0644\u0635\u062d\u0627\u0628\u0629 \u0648\u0627\u0644\u062a\u0627\u0628\u0639\u064a\u0646\u061b \u064a\u0648\u0647\u0645\u0648\u0646 \u0628\u0647\u0630\u0627 \u0645\u0646 \u0644\u0627 \u064a\u064f\u062d\u0633\u0646 \u0627\u0644\u0646\u0638\u0631 \u0641\u064a \u0627\u0644\u0623\u062d\u0648\u0627\u0644\u060c \u0648\u0644\u064a\u0633 \u0644\u0647 \u0646\u0648\u0631 \u064a\u0633\u062a\u0642\u0631\u0626 \u0628\u0647 \u0627\u0644\u0623\u0642\u0648\u0627\u0644. \u0641\u0643\u0627\u0646 \u0623\u0647\u0644 \u0627\u0644\u0644\u0647 \u0645\u0646 \u0643\u0644 \u0632\u0645\u0646\u060c \u0627\u0644\u0645\u0646\u0627\u0631\u0629 \u0627\u0644\u062a\u064a \u064a\u0642\u064a\u0633 \u0625\u0644\u064a\u0647\u0627 \u0627\u0644\u0645\u0631\u0621 \u062d\u0627\u0644\u0647 \u0648\u062d\u0627\u0644 \u063a\u064a\u0631\u0647 \u0645\u0646 \u0627\u0644\u0646\u0627\u0633. \u0641\u0625\u0646 \u0648\u062c\u062f \u0646\u0641\u0633\u0647 \u0645\u062d\u0628\u0627 \u0644\u0647\u0645\u060c \u0645\u0643\u062b\u0631\u0627 \u0644\u0633\u0648\u0627\u062f\u0647\u0645\u060c \u0641\u0644\u064a\u062d\u0645\u062f \u0627\u0644\u0644\u0647 \u0639\u0644\u0649 \u0641\u0636\u0644\u0647\u061b \u0648\u0625\u0646 \u0648\u062c\u062f \u063a\u064a\u0631 \u0630\u0644\u0643\u060c \u0641\u0644\u064a\u0639\u0644\u0645 \u0623\u0646\u0647 \u0645\u0646 \u0627\u0644\u0645\u062d\u0631\u0641\u064a\u0646 \u0627\u0644\u0645\u062d\u0627\u0631\u0628\u064a\u0646 \u0644\u0644\u062f\u064a\u0646\u060c \u0648\u0625\u0646 \u0643\u0627\u0646 \u0641\u064a \u0638\u0627\u0647\u0631\u0647 \u0628\u0647 \u0645\u0646 \u0627\u0644\u0645\u062a\u0644\u0628\u0633\u064a\u0646.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0648\u0647\u0624\u0644\u0627\u0621 \u0627\u0644\u0648\u0647\u0627\u0628\u064a\u0629 \u0627\u0644\u0630\u064a\u0646 \u0644\u0627 \u064a\u0647\u0646\u0623 \u0644\u0647\u0645 \u0628\u0627\u0644 \u0625\u0644\u0627 \u0628\u0627\u0644\u0648\u0642\u0648\u0639 \u0641\u064a \u0623\u0626\u0645\u0629 \u0627\u0644\u0647\u062f\u0649\u060c \u0645\u0645\u0646 \u0623\u062c\u0645\u0639\u062a \u0627\u0644\u0623\u0645\u0629 \u0639\u0644\u0649 \u0635\u0644\u0627\u062d\u0647\u0645 \u0648\u062e\u0635\u0648\u0635 \u0645\u0643\u0627\u0646\u062a\u0647\u0645\u060c \u0642\u062f \u0634\u0647\u062f\u0648\u0627 \u0639\u0644\u0649 \u0623\u0646\u0641\u0633\u0647\u0645 \u0628\u0627\u0644\u0641\u0633\u0642 \u0648\u0627\u0644\u0636\u0644\u0627\u0644 \u0628\u0639\u0645\u0644\u0647\u0645 \u0630\u0627\u0643. \u0648\u0630\u0644\u0643 \u0644\u0623\u0646 \u0627\u0644\u0646\u0648\u0631 \u0644\u0627 \u064a\u064f\u0639\u0627\u062f\u064a \u0627\u0644\u0646\u0648\u0631\u060c \u0648\u0627\u0644\u0647\u062f\u0649 \u0644\u0627 \u064a\u064f\u0639\u0627\u062f\u064a \u0627\u0644\u0647\u062f\u0649\u061b \u0648\u0625\u0646\u0645\u0627 \u064a\u0642\u0639 \u0627\u0644\u062a\u0646\u0627\u0641\u0631 \u0628\u064a\u0646 \u0627\u0644\u0623\u0636\u062f\u0627\u062f. \u0648\u0645\u0646 \u0634\u0643 \u0641\u064a \u0643\u0648\u0646 \u0627\u0644\u062c\u064a\u0644\u0627\u0646\u064a \u0648\u0627\u0644\u0631\u0641\u0627\u0639\u064a \u0645\u062b\u0644\u0627\u060c \u0645\u0646 \u0623\u0647\u0644 \u0627\u0644\u0646\u0648\u0631\u060c \u0641\u0625\u0646\u0647 \u064a\u062d\u062a\u0627\u062c \u0625\u0644\u0649 \u0637\u0628\u064a\u0628 \u0628\u0635\u0631 \u0642\u0628\u0644 \u0637\u0628\u064a\u0628 \u0627\u0644\u0628\u0635\u064a\u0631\u0629.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp; &nbsp;&nbsp;\u0648\u0646\u062d\u0646 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0631\u062f\u060c \u0645\u0627 \u0623\u0631\u062f\u0646\u0627 \u0625\u0644\u0627 \u0623\u0646 \u064a\u0639\u0644\u0645 \u0627\u0644\u0642\u0627\u0631\u0626 \u0623\u0646 \u0647\u0624\u0644\u0627\u0621 \u0627\u0644\u0642\u0648\u0645\u060c \u0644\u0627 \u0645\u064f\u0633\u062a\u0646\u062f \u0644\u0647\u0645 \u0645\u0646 \u0627\u0644\u0639\u0644\u0645 \u0648\u0625\u0646 \u0643\u0627\u0646\u0648\u0627 \u0643\u062b\u064a\u0631\u0627 \u0645\u0627 \u064a\u0648\u0647\u0645\u0648\u0646 \u0627\u0644\u0633\u0627\u0645\u0639 \u0628\u0630\u0644\u0643\u061b \u0648\u0625\u0646\u0645\u0627 \u0645\u064f\u0633\u062a\u0646\u062f\u0647\u0645 \u0628\u063a\u0636 \u062f\u0641\u064a\u0646 \u0644\u0631\u0633\u0648\u0644 \u0627\u0644\u0644\u0647 \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645\u060c \u0644\u0627 \u0646\u062f\u0631\u064a \u0633\u0628\u0628\u0627 \u0644\u0647 \u0625\u0644\u0627 \u0643\u0648\u0646\u0647\u0645 \u0645\u0646 \u0623\u062a\u0628\u0627\u0639 \u0627\u0644\u0634\u064a\u0627\u0637\u064a\u0646. \u064a\u062a\u0643\u0644\u0645\u0648\u0646 \u0628\u0645\u0627 \u0644\u0627 \u064a\u0637\u064a\u0642 \u0645\u062e\u0644\u0648\u0642 \u0623\u0646 \u064a\u0633\u0645\u0639\u0647\u060c \u0648\u0647\u0645 \u064a\u0632\u0639\u0645\u0648\u0646 \u0623\u0646 \u063a\u064a\u0631\u062a\u0647\u0645 \u0644\u0644\u0647! \u0643\u0630\u0628\u0648\u0627 \u0648\u0627\u0644\u0644\u0647! \u0641\u0625\u0646 \u0645\u0646 \u064a\u0641\u0631\u0642 \u0628\u064a\u0646 \u0627\u0644\u0644\u0647 \u0648\u0631\u0633\u0648\u0644\u0647\u060c \u0644\u0647\u0648 \u0627\u0644\u0643\u0627\u0641\u0631 \u062d\u0642\u0627. {\u0625\u0650\u0646\u064e\u0651 \u0627\u0644\u064e\u0651\u0630\u0650\u064a\u0646\u064e \u064a\u064e\u0643\u0652\u0641\u064f\u0631\u064f\u0648\u0646\u064e \u0628\u0650\u0627\u0644\u0644\u064e\u0651\u0647\u0650 \u0648\u064e\u0631\u064f\u0633\u064f\u0644\u0650\u0647\u0650 \u0648\u064e\u064a\u064f\u0631\u0650\u064a\u062f\u064f\u0648\u0646\u064e \u0623\u064e\u0646\u0652 \u064a\u064f\u0641\u064e\u0631\u0650\u0651\u0642\u064f\u0648\u0627 \u0628\u064e\u064a\u0652\u0646\u064e \u0627\u0644\u0644\u064e\u0651\u0647\u0650 \u0648\u064e\u0631\u064f\u0633\u064f\u0644\u0650\u0647\u0650 \u0648\u064e\u064a\u064e\u0642\u064f\u0648\u0644\u064f\u0648\u0646\u064e \u0646\u064f\u0624\u0652\u0645\u0650\u0646\u064f \u0628\u0650\u0628\u064e\u0639\u0652\u0636\u064d \u0648\u064e\u0646\u064e\u0643\u0652\u0641\u064f\u0631\u064f \u0628\u0650\u0628\u064e\u0639\u0652\u0636\u064d \u0648\u064e\u064a\u064f\u0631\u0650\u064a\u062f\u064f\u0648\u0646\u064e \u0623\u064e\u0646\u0652 \u064a\u064e\u062a\u064e\u0651\u062e\u0650\u0630\u064f\u0648\u0627 \u0628\u064e\u064a\u0652\u0646\u064e \u0630\u064e\u0644\u0650\u0643\u064e \u0633\u064e\u0628\u0650\u064a\u0644\u064b\u0627 (150) \u0623\u064f\u0648\u0644\u064e\u0626\u0650\u0643\u064e \u0647\u064f\u0645\u064f \u0627\u0644\u0652\u0643\u064e\u0627\u0641\u0650\u0631\u064f\u0648\u0646\u064e \u062d\u064e&zwj;\u0642\u064b\u0651\u0627 \u0648\u064e\u0623\u064e\u0639\u0652\u062a\u064e\u062f\u0652\u0646\u064e\u0627 \u0644\u0650\u0644\u0652\u0643\u064e\u0627\u0641\u0650\u0631\u0650\u064a\u0646\u064e \u0639\u064e\u0630\u064e\u0627\u0628\u064b\u0627 \u0645\u064f\u0647\u0650\u064a\u0646\u064b\u0627}[\u0627\u0644\u0646\u0633\u0627\u0621: 150-151].<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0644\u0643\u0646\u0646\u0627 \u0646\u0641\u0631\u0642 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0637\u0627\u0626\u0641\u0629 \u0628\u064a\u0646 \u0627\u0644\u0623\u0626\u0645\u0629 \u0627\u0644\u0645\u0636\u0644\u064a\u0646\u060c \u0627\u0644\u0630\u064a\u0646 \u064a\u0639\u0644\u0645\u0648\u0646 \u0645\u0627 \u064a\u0642\u0648\u0644\u0648\u0646\u060c \u0648\u064a\u0635\u0631\u0648\u0646 \u0639\u0644\u0649 \u0633\u0644\u0648\u0643 \u0637\u0631\u064a\u0642 \u0627\u0644\u0628\u0639\u062f \u0648\u0647\u0645 \u0631\u0627\u0636\u0648\u0646\u060c \u0648\u0628\u064a\u0646 \u0645\u0646 \u0627\u0633\u062a\u0647\u0648\u0627\u0647\u0645 \u0627\u0644\u0643\u0644\u0627\u0645 \u0648\u0632\u064f\u064a\u0651\u0646 \u0644\u0647\u0645 \u0645\u0627 \u064a\u062a\u0628\u0639\u0648\u0646. \u0644\u0630\u0644\u0643 \u0641\u0625\u0646\u0646\u0627 \u0646\u0631\u062c\u0648 \u0623\u0646 \u064a\u062a\u0646\u0628\u0647 \u0643\u0644 \u0645\u0646 \u0627\u0639\u062a\u0642\u062f \u0645\u0646 \u0627\u0644\u0646\u0627\u0633 \u0645\u0627 \u064a\u0639\u062a\u0642\u062f\u0648\u0646\u060c \u0648\u064a\u062b\u0648\u0628\u0648\u0627 \u0625\u0644\u0649 \u0635\u0648\u0627\u0628\u0647\u0645 \u0642\u0628\u0644 \u0623\u0646 \u0644\u0627 \u064a\u0624\u0630\u0646 \u0644\u0647\u0645 \u0648\u0644\u0627 \u0647\u0645 \u064a\u064f\u0633\u062a\u0639\u062a\u0628\u0648\u0646.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0648\u0646\u062d\u0646 \u0625\u0630 \u0646\u0645\u062f \u064a\u062f\u0646\u0627 \u0625\u0644\u0649 \u0643\u0644 \u0645\u0646 \u0644\u0647 \u063a\u064a\u0631\u0629 \u0639\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u062f\u064a\u0646\u060c \u0645\u0633\u062a\u0639\u062f\u0648\u0646 \u0628\u0641\u0636\u0644 \u0627\u0644\u0644\u0647 \u0623\u0646 \u0646\u0632\u064a\u0644 \u0627\u0644\u0634\u0628\u0647\u0629 \u0639\u0645\u0646 \u0627\u062a\u0635\u0644 \u0628\u0646\u0627 \u0648\u0623\u0631\u0627\u062f \u0627\u0644\u0644\u062d\u0648\u0642 \u0628\u0627\u0644\u0645\u0647\u062f\u064a\u064a\u0646 \u0645\u0646 \u0627\u0644\u0633\u0627\u0628\u0642\u064a\u0646\u061b \u0633\u0627\u0626\u0644\u064a\u0646 \u0627\u0644\u0644\u0647 \u0623\u0646 \u064a\u062c\u0645\u0639 \u0627\u0644\u0623\u0645\u0629 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a\u0629 \u0639\u0644\u0649 \u0643\u0644\u0645\u0629 \u0633\u0648\u0627\u0621 \u0645\u0646 \u0627\u0644\u062d\u0642 \u0648\u0627\u0644\u0646\u0648\u0631 \u0627\u0644\u0645\u0628\u064a\u0646\u060c \u062d\u062a\u0649 \u062a\u0639\u0648\u062f \u0625\u0644\u064a\u0647\u0627 \u0627\u0644\u0639\u0632\u0629 \u0627\u0644\u062a\u064a \u0643\u0627\u0646\u062a \u0644\u0628\u0627\u0633\u0647\u0627 \u0642\u0628\u0644 \u0623\u0646 \u062a\u0639\u0645\u0644 \u0627\u0644\u0641\u062a\u0646 \u0639\u0645\u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0622\u062e\u0650\u0631\u064a\u0646.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0648\u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0648\u0633\u0644\u0645 \u0639\u0644\u0649 \u0645\u062d\u0645\u062f \u0623\u0634\u0631\u0641 \u0645\u0628\u0639\u0648\u062b \u0628\u0627\u0644\u0647\u062f\u0649 \u0648\u0627\u0644\u0646\u0648\u0631\u060c \u0648\u0639\u0644\u0649 \u0622\u0644\u0647 \u0648\u0635\u062d\u0628\u0647 \u0648\u062a\u0627\u0628\u0639\u064a\u0647 \u0645\u0646 \u0623\u0647\u0644 \u0627\u0644\u0641\u0627\u0642\u0629 \u0648\u0623\u0647\u0644 \u0627\u0644\u062f\u062b\u0648\u0631. \u0648\u0627\u0644\u062d\u0645\u062f \u0644\u0644\u0647 \u0631\u0628 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0646.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u062e\u0627\u062a\u0645\u0629:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0645\u0627 \u0643\u0646\u0627 \u0646\u062a\u0645\u0646\u0649 \u06