{"id":12058,"date":"2024-12-19T13:19:26","date_gmt":"2024-12-19T13:19:26","guid":{"rendered":"http:\/\/alomariya.test\/%d8%a5%d9%90%d8%b0%d8%a7-%d9%82%d9%8e%d9%80%d8%a7%d9%85%d9%8e-%d9%83%d9%8f%d9%80%d9%84%d9%8f%d9%91-%d8%ad%d9%90%d9%80%d8%a8%d9%8d%d9%91\/"},"modified":"2025-03-02T10:26:10","modified_gmt":"2025-03-02T10:26:10","slug":"%d8%a7%d8%b0%d8%a7_%d9%82%d8%a7%d9%85_%d9%83%d9%84_%d8%ad%d8%a8","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d8%a7%d8%b0%d8%a7_%d9%82%d8%a7%d9%85_%d9%83%d9%84_%d8%ad%d8%a8\/","title":{"rendered":"\u0625\u0650\u0630\u0627 \u0642\u064e\u0640\u0627\u0645\u064e \u0643\u064f\u0640\u0644\u064f\u0651 \u062d\u0650\u0640\u0628\u064d\u0651"},"content":{"rendered":"<p style=\"text-align: center; font-size: 16px; line-height: 2.5em;\">\u0625\u0650\u0630\u0627 \u0642\u064e\u0640\u0627\u0645\u064e \u0643\u064f\u0640\u0644\u064f\u0651 \u062d\u0650\u0640\u0628\u064d\u0651 \u064a\u064e\u0640\u0630\u0652\u0643\u064f\u0640\u0631\u064f \u062d\u0650\u0628\u064e\u0651\u0640\u0640\u0640\u0640\u0640\u0640\u0647\u064f\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0630\u064e\u0643\u064e\u0640\u0631\u0652\u062a\u064f \u0644\u064e\u064a\u0652\u0640\u0644\u064e\u0640\u0649 \u0628\u064e\u0639\u0652\u0640\u062f\u064e \u0623\u064e\u0646\u0652 \u0644\u064e\u0640\u0645\u0652 \u0623\u064e\u0643\u064f \u0646\u064e\u0627\u0633\u0650\u0640\u0640\u064a\u064e\u0627<br \/>\n\u0648\u064e\u0630\u0650\u0643\u0652\u0640\u0631\u0650\u064a \u0644\u064e\u0640\u0647\u064e\u0627 \u0630\u0650\u0643\u0652\u0640\u0631\u064c \u0641\u064e\u0640\u0648\u0652\u0642\u064e \u0643\u064f\u0640\u0644\u0650\u0651 \u0631\u064f\u062a\u0652\u0628\u064e\u0640\u0640\u0640\u0629\u064d\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u064a\u064e\u0640\u062c\u0650\u0640\u0644\u064f\u0651 \u0639\u064e\u0640\u0646\u0652 \u0625\u0650\u062f\u0652\u0631\u0627\u0643\u0650 \u0645\u064e\u0646\u0652 \u0644\u064e\u064a\u0652\u0640\u0633\u064e \u0647\u064f\u0648\u064e \u0647\u0650\u0640\u0640\u064a\u0627<br \/>\n\u0648\u064e\u0643\u064a\u0652\u0641\u064e \u062a\u064f\u0646\u0652\u0633\u0649 \u0645\u064e\u0646\u0652 \u062d\u064f\u0633\u0652\u0646\u064f\u0647\u0627 \u0641\u064a \u0643\u064f\u0644\u0650\u0651 \u0634\u064e\u064a\u0652\u0621\u064d\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0623\u064e\u0645\u0652 \u0643\u064e\u064a\u0652\u0641\u064e \u064a\u064e\u0630\u0652\u0643\u064f\u0640\u0631\u064f\u0647\u0627 \u0645\u064e\u0646\u0652 \u0644\u0627 \u0632\u0627\u0644\u064e \u0641\u0627\u0646\u0650\u0640\u0640\u0640\u064a\u0627<br \/>\n\u0633\u064e\u0644\u0650\u0645\u064e\u062a\u0652 \u0643\u064e\u0640\u0645\u0652 \u0644\u064e\u0640\u0647\u0627 \u0645\u0650\u0646\u0652 \u0635\u064e\u0640\u0631\u064a\u0639\u064d \u0623\u064e\u062e\u064e\u0640\u0630\u064e\u062a\u0652\u0640\u0640\u0640\u0647\u064f\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0639\u064e\u0646\u0652 \u0646\u064e\u0641\u0652\u0633\u0650\u0647\u0650 \u0645\u0627 \u064a\u064e\u0632\u0627\u0644\u064f \u0645\u064e\u064a\u0652\u062a\u0640\u0627\u064b \u0628\u0650\u0640\u0647\u0627 \u062d\u0640\u0640\u0640\u064a\u0651\u0640\u0627<br \/>\n\u0648\u064e\u0631\u0650\u062b\u064e\u0640\u062a\u0652 \u0645\u0650\u0640\u0646\u0652\u0640\u0647\u064f \u062c\u0650\u0633\u0652\u0640\u0640\u0645\u0627\u064b \u0623\u064e\u062a\u0652\u0644\u064e\u0640\u0641\u064e\u0640\u062a\u0652\u0640\u0647\u064f \u0633\u064e\u0640\u0642\u064e\u0640\u0640\u0640\u0645\u0627\u064b\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e\u0641\u064f\u0640\u0640\u0640\u0624\u0627\u062f\u0627\u064b \u0643\u064e\u0633\u0640\u064a\u0640\u0631\u0627\u064b \u0647\u064f\u0640\u0648\u064e \u0643\u064e\u0641\u064f\u0640\u0640\u0640\u0640\u0640\u0640\u0624\u064e\u0627\u062f\u0650\u064a\u064e\u0640\u0627<br \/>\n\u0641\u064e\u064a\u064e\u0627 \u0644\u064e\u064a\u0652\u062a\u064e \u0634\u0650\u0639\u0652\u0631\u064a \u0643\u064e\u064a\u0652\u0641\u064e \u0623\u064e\u0628\u064f\u062b\u064f\u0651 \u062d\u064f\u0640\u0640\u0640\u0631\u0652\u0642\u064e\u0640\u0640\u0629\u064b\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0623\u064e\u0645\u0652 \u0643\u064e\u064a\u0652\u0641\u064e \u064a\u064e\u0640\u062a\u0650\u0645\u064f\u0651 \u0644\u0650\u0640\u064a \u0623\u064e\u0646\u0652 \u0623\u064e\u0634\u0652\u0640\u0643\u064f\u0640\u0648\u064e \u0645\u064e\u0627 \u0628\u0650\u0640\u0640\u0640\u064a\u064e\u0627<br \/>\n\u0639\u064e\u0632\u064e\u0645\u064e\u062a\u0652 \u0639\u064e\u0640\u0644\u0640\u064e\u0649 \u0642\u064e\u0640\u062a\u0652\u0640\u0644\u0650\u0640\u064a \u0628\u064e\u0640\u0639\u0652\u0640\u062f\u064e \u0623\u064e\u0646\u0652 \u0623\u064e\u0645\u064e\u0651\u0646\u064e\u062a\u0652\u0640\u0640\u0646\u0650\u064a\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e\u0627\u0644\u0652\u0640\u063a\u064e\u0640\u062f\u0652\u0631\u064f \u0644\u064e\u0640\u0647\u064e\u0627 \u0637\u064e\u0640\u0628\u0652\u0640\u0639\u064c \u0628\u0650\u0640\u062a\u064f\u0651 \u0644\u064e\u0640\u0647\u064f \u0631\u064e\u0627\u062c\u0650\u0640\u0640\u0640\u064a\u0640\u0627<br \/>\n\u0648\u064e\u0627\u0644\u0652\u0640\u0645\u064e\u0640\u0648\u0652\u062a\u064f \u0635\u064e\u0628\u0640\u0627\u0628\u064e\u0640\u0629\u064b \u0628\u0650\u0640\u0633\u0650\u0640\u0647\u064e\u0627\u0645\u0650 \u0644\u064e\u0640\u062d\u0652\u0640\u0638\u0650\u0640\u0640\u0640\u0647\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0647\u064f\u0640\u0648\u064e \u0623\u064e\u0633\u0652\u0640\u0645\u0649 \u063a\u0640\u0627\u064a\u0640\u0627\u062a\u0640\u064a \u0648\u064e\u0623\u063a\u0652\u0640\u0644\u0640\u0649 \u0623\u064e\u0645\u0627\u0646\u0650\u0640\u0640\u064a\u0627<br \/>\n\u0623\u064e\u062d\u0650\u0640\u0628\u064e\u0651\u062a\u0640\u064a \u0623\u064e\u0633\u0652\u0640\u0640\u0639\u0650\u0641\u064f\u0640\u0648\u0646\u0640\u064a \u0623\u064e\u0639\u0640\u064a\u0646\u0640\u0648\u0646\u0640\u064a \u0639\u064e\u0640\u0640\u0640\u0644\u0640\u0649\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u063a\u064e\u0640\u0631\u0627\u0645\u0640\u064a \u0628\u0650\u0640\u0640\u0623\u064e\u0644\u0640\u0652\u062d\u0627\u0646\u064d \u062a\u064f\u0640\u062d\u064e\u0640\u0631\u0650\u0651\u0643\u064f \u0645\u0640\u0627 \u0641\u0650\u0640\u0640\u0640\u0640\u0640\u064a\u0627<br \/>\n\u062a\u064e\u0640\u0647\u064f\u0640\u0628\u064f\u0651 \u0639\u064e\u0644\u0640\u0649 \u0642\u064e\u0640\u0644\u0652\u0628\u0640\u064a \u0643\u064e\u0623\u064e\u0646\u0652\u0633\u0640\u0627\u0645\u0650 \u0628\u064f\u0643\u0652\u0640\u0640\u0640\u0640\u0631\u064e\u0629\u064d\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u062a\u064f\u0640\u0628\u064e\u0640\u0631\u0650\u0651\u062f\u064f \u0644\u064e\u0640\u0647\u0640\u064a\u0628\u0640\u0627\u064b \u0623\u064e\u0630\u0627\u0628\u064e \u0636\u064f\u0640\u0640\u0644\u0640\u0648\u0639\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u064a\u0627<br \/>\n\u0632\u064e\u0645\u0652\u0640\u0632\u0650\u0645\u0652 \u064a\u0627 \u0646\u0627\u064a\u064e \u0634\u064e\u0640\u0648\u0652\u0642\u064d \u0630\u064e\u0643\u0650\u0651\u0640\u0631\u0652\u0646\u064a \u0645\u064e\u0640\u0646\u0640\u0640\u0627\u0632\u0650\u0644\u0627\u064b\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0646\u064e\u0640\u0632\u064e\u0644\u0652\u0646\u0627\u0647\u0627 \u0642\u064e\u0640\u062f\u064a\u0640\u0645\u0627\u064b \u0643\u0640\u0627\u0646\u064e \u0627\u0644\u0652\u0639\u064e\u064a\u0652\u0640\u0634\u064f \u0647\u0627\u0646\u0650\u0640\u0640\u0640\u064a\u0627<br \/>\n\u0648\u064e\u0646\u064e\u0640\u0648\u0650\u0651\u0639\u0652 \u0641\u0640\u064a \u0623\u064e\u0646\u0652\u0640\u063a\u0640\u0627\u0645\u064d \u0643\u064e\u062a\u064e\u0646\u0652\u0640\u0648\u064a\u0639\u0650 \u062d\u064f\u0640\u0633\u0652\u0646\u0650\u0640\u0640\u0640\u0647\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0627\u0650\u062c\u0652\u0647\u064e\u0631\u0652 \u0648\u064e\u062e\u0627\u0644\u0650\u0641\u0652 \u0643\u064e\u0640\u0645\u0627 \u0647\u064f\u0648\u064e \u062d\u0627\u0644\u064f \u062d\u0640\u0627\u0644\u0650\u0640\u0640\u064a\u064e\u0627<br \/>\n\u0648\u064e\u062f\u064e\u0645\u0652\u0640\u062f\u0650\u0645\u0652 \u064a\u0640\u0627 \u0639\u0640\u0648\u062f\u064f \u0645\u064f\u0640\u062f\u0627\u0639\u0650\u0640\u0628\u0640\u0627\u064b \u0644\u0650\u0623\u064e\u0648\u0652\u062a\u0640\u0640\u0640\u0640\u0627\u0631\u0650\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0641\u064f\u0640\u0624\u0627\u062f\u064d \u0644\u064e\u0640\u0645\u0652 \u064a\u064e\u0643\u064f\u0646\u0652 \u0637\u0640\u0648\u0644\u064e \u0639\u064f\u0640\u0645\u0652\u0640\u0631\u0650\u0647\u0650 \u0633\u0640\u0627\u0644\u0650\u0640\u0640\u0640\u064a\u0627<br \/>\n\u0648\u064e\u0648\u064e\u0642\u0650\u0651\u0640\u0639\u0652 \u064a\u0640\u0627 \u062f\u064e\u0641\u064f\u0651 \u0645\u064e\u0648\u0627\u0642\u0650\u0640\u0639\u0640\u0627\u064b \u0644\u0650\u0623\u064e\u0642\u0652\u0640\u0640\u0640\u0640\u0640\u062f\u0627\u0631\u064d\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u062a\u064e\u062b\u064e\u0646\u0651\u0640\u0649 \u0627\u0644\u0652\u0640\u062d\u064e\u0628\u064a\u0640\u0640\u0628\u064f \u0639\u064e\u0640\u0644\u0640\u0649 \u0648\u064e\u0642\u0652\u0640\u0639\u0650\u0640\u0647\u0627 \u0645\u0627\u0634\u0650\u0640\u0640\u0640\u064a\u0627<br \/>\n\u0630\u064e\u0647\u064e\u0628\u0652\u062a\u064f \u0641\u064a\u0647\u0650 \u0641\u064e\u0640\u0645\u064e\u0646\u0652 \u0644\u0640\u064a \u0645\u0650\u0646\u0652\u0643\u064f\u0640\u0645\u0652 \u0628\u0650\u0640\u0645\u064f\u0646\u0652\u0640\u0640\u0640\u0642\u0650\u0640\u0630\u064d\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0623\u064e\u0645\u0652 \u0623\u064e\u0646\u064e\u0651\u0640\u0647\u064f \u0631\u0627\u062c\u0650\u0640\u0639\u064c \u0643\u064e\u0640\u0645\u0640\u0627 \u0639\u064f\u0640\u062f\u0652\u062a\u064f \u062e\u0627\u0648\u0650\u064a\u0640\u0627<br \/>\n\u0625\u0630\u0627 \u0638\u064e\u0641\u064e\u0631\u0652\u062a\u064f \u0628\u0650\u0644\u064e\u0640\u064a\u0652\u0640\u0644\u0640\u0649 \u0648\u064e\u0642\u0652\u062a\u0640\u0627\u064b \u062a\u064e\u0640\u0645\u064e\u0646\u064e\u0651\u0640\u0640\u0640\u0640\u0639\u064e\u062a\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e\u0625\u0646\u0652 \u0639\u064f\u0640\u062f\u0652\u062a\u064f \u0622\u064a\u0650\u0640\u0633\u0640\u0627\u064b \u0628\u064e\u0639\u064e\u0640\u062b\u064e\u0640\u062a\u0652 \u0622\u0645\u0640\u0627\u0644\u0650\u0640\u0640\u0640\u0640\u064a\u0627<br \/>\n\u0623\u064e\u0645\u0648\u062a\u064f \u0625\u0630\u0627 \u0631\u0627\u062d\u064e\u062a\u0652 \u0648\u064e\u0623\u064e\u062d\u0652\u064a\u0649 \u0628\u0650\u063a\u064e\u0640\u0640\u0640\u062f\u0652\u0648\u0650\u0647\u0640\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0641\u064e\u0640\u0646\u0640\u064e\u0647\u0627\u0631\u0650\u064a\u064e \u0628\u064e\u0640\u0639\u0652\u0640\u062b\u064c \u0648\u064e\u0627\u0644\u0652\u0640\u0645\u064e\u0640\u0648\u0652\u062a\u064f \u0644\u064e\u064a\u0640\u0640\u0640\u0640\u0640\u0627\u0644\u0650\u0640\u064a\u064e\u0627<br \/>\n\u0648\u064e\u0642\u0650\u0640\u064a\u0640\u0627\u0645\u064e\u062a\u0640\u064a \u0625\u0630\u0627 \u0645\u0640\u0627 \u0642\u064f\u0640\u0645\u0652\u0640\u062a\u064f \u0628\u0640\u0650\u062d\u064e\u064a\u0650\u0651\u0640\u0640\u0640\u0640\u0647\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0645\u064f\u0640\u0624\u064e\u0630\u0651\u0646\u0640\u0627\u064b \u0644\u0650\u0640\u0639\u064f\u0640\u0634\u0651\u0640\u0627\u0642\u0650\u0640\u0647\u0640\u0627 \u0648\u064e\u0645\u064f\u0640\u0646\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0627\u062f\u0650\u064a\u0640\u0627<br \/>\n\u0623\u064f\u0643\u064e\u0628\u0651\u0640\u0650\u0631\u064f\u0647\u0627 \u0639\u064e\u0646\u0652 \u0646\u064e\u064a\u0652\u0640\u0644\u0650 \u0627\u0644\u0652\u0640\u0645\u064f\u0646\u0649 \u0644\u064e\u0640\u0647\u0640\u0640\u0640\u0627 \u0643\u064e\u0640\u0645\u0640\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0623\u064f\u0643\u064e\u0640\u0628\u0650\u0651\u0640\u0631\u064f \u0639\u064e\u0640\u0646\u0652 \u0633\u0650\u0640\u0640\u0640\u0648\u0649\u064b \u062a\u064e\u0640\u0639\u064e\u0640\u0644\u064f\u0651\u0640\u0642\u064e \u0642\u064e\u0640\u0644\u0652\u0640\u0628\u0650\u0640\u0640\u0640\u0640\u0640\u064a\u064e\u0627<br \/>\n\u0623\u0634\u0652\u0640\u0640\u0640\u0647\u064e\u062f\u064f \u0644\u0650\u0640\u062d\u064f\u0633\u0652\u0640\u0640\u0640\u0640\u0646\u0650\u0647\u0627 \u0628\u0650\u0640\u062a\u064e\u0640\u0641\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u064f\u0651\u062f\u0650\u0647\u0650 \u0641\u0640\u064a\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0633\u064e\u0640\u0640\u0637\u0652\u0648\u064e\u0629\u064d \u0623\u064e\u0630\u0652\u0647\u064e\u0640\u0628\u064e\u062a\u0652 \u0631\u064f\u0634\u0652\u0640\u0640\u062f\u0650\u064a\u064e \u062b\u064f\u0640\u0645\u064e\u0651 \u0644\u064f\u0640\u0628\u0650\u0651\u0640\u0640\u0640\u0640\u064a\u0627<br \/>\n\u0623\u064e\u0642\u0640\u0648\u0644\u064f \u062d\u064e\u0640\u064a\u064e\u0651 \u0639\u064e\u0640\u0644\u0649 \u0635\u064e\u0640\u0640\u0640\u0640\u0644\u0627\u0629\u064d \u0641\u0640\u064a\u0647\u0640\u0640\u0640\u0627 \u0625\u0630\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0631\u064f\u0645\u0652\u062a\u064f\u0640\u0645\u064f \u0627\u0642\u0652\u062a\u0650\u0640\u062f\u0627\u0621\u064b \u064a\u064e\u0640\u0631\u0652\u062d\u064e\u0640\u0645\u064f\u0643\u064f\u0640\u0645\u0652 \u0631\u064e\u0628\u0651\u0640\u064a \u0628\u0650\u0640\u0640\u0640\u0640\u064a\u064e\u0627<br \/>\n\u0648\u064e\u062d\u064e\u0640\u064a\u064e\u0651 \u0639\u064e\u0644\u0640\u0649 \u0627\u0644\u0652\u0641\u064e\u0640\u0640\u0640\u0640\u0644\u0627\u062d\u0650 \u0628\u0650\u0640\u0634\u064e\u0640\u0645\u0650\u0651 \u0646\u064e\u0640\u0634\u0652\u0640\u0640\u0631\u0650\u0647\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0625\u0630\u0627 \u0642\u064f\u0640\u0645\u0652\u062a\u064f\u0640\u0645\u0652 \u0623\u064e\u062f\u064e\u0628\u0640\u0627\u064b \u062f\u064e\u0648\u0652\u0645\u0640\u0627\u064b \u0639\u0640\u0644\u0640\u0649 \u0628\u064e\u0627\u0628\u0650\u0640\u0640\u0640\u064a\u064e\u0627<br \/>\n\u0648\u064e\u0623\u064e\u062e\u0652\u0640\u062a\u0640\u0650\u