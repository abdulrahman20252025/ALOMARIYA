{"id":11521,"date":"2017-08-08T00:37:34","date_gmt":"2017-08-08T00:37:34","guid":{"rendered":"http:\/\/alomariya.test\/%d8%a7%d9%84%d8%b4%d9%8a%d8%ae-%d8%ad%d8%b3%d9%86-%d8%a7%d9%84%d8%aa%d8%b3%d8%aa%d8%b1%d9%8a-%d9%88%d8%a7%d9%84%d8%b3%d9%84%d8%b7%d8%a7%d9%86\/"},"modified":"2025-02-15T11:43:36","modified_gmt":"2025-02-15T11:43:36","slug":"%d8%a7%d9%84%d8%b4%d9%8a%d8%ae-%d8%ad%d8%b3%d9%86-%d8%a7%d9%84%d8%aa%d8%b3%d8%aa%d8%b1%d9%8a-%d9%88%d8%a7%d9%84%d8%b3%d9%84%d8%b7%d8%a7%d9%86","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d8%a7%d9%84%d8%b4%d9%8a%d8%ae-%d8%ad%d8%b3%d9%86-%d8%a7%d9%84%d8%aa%d8%b3%d8%aa%d8%b1%d9%8a-%d9%88%d8%a7%d9%84%d8%b3%d9%84%d8%b7%d8%a7%d9%86\/","title":{"rendered":"\u0627\u0644\u0634\u064a\u062e \u062d\u0633\u0646 \u0627\u0644\u062a\u0633\u062a\u0631\u064a \u0648\u0627\u0644\u0633\u0644\u0637\u0627\u0646"},"content":{"rendered":"<p>&nbsp; &nbsp; &nbsp; &nbsp;\u064a\u0630\u0643\u0631 \u0627\u0644\u0634\u064a\u062e \u0627\u0644\u0634\u0639\u0631\u0627\u0646\u064a \u0631\u0636\u064a \u0627\u0644\u0644\u0647 \u0639\u0646\u0647\u060c \u0641\u064a &quot; \u0627\u0644\u0637\u0628\u0642\u0627\u062a \u0627\u0644\u0643\u0628\u0631\u0649 &quot;&nbsp;<strong><a href=\"#_ftn1\" name=\"_ftnref1\">[1]<\/a>\u060c&nbsp;<\/strong>\u0641\u064a \u062a\u0631\u062c\u0645\u0629 \u0627\u0644\u0634\u064a\u062e \u062d\u0633\u0646 \u0627\u0644\u062a\u0633\u062a\u0631\u064a\u060c \u0631\u0636\u064a \u0627\u0644\u0644\u0647 \u0639\u0646\u0647\u060c \u0645\u0627 \u064a\u0644\u064a:<br \/>[\u0643\u0627\u0646 \u0627\u0644\u0633\u0644\u0637\u0627\u0646 \u064a\u0646\u0632\u0644 \u0625\u0644\u0649 \u0632\u064a\u0627\u0631\u062a\u0647\u060c \u0641\u0644\u0645 \u064a\u0632\u0644 \u0627\u0644\u062d\u0627\u0633\u062f\u0648\u0646 \u0645\u0646 \u0623\u0631\u0628\u0627\u0628 \u0627\u0644\u062f\u0648\u0644\u0629 \u0648\u063a\u064a\u0631\u0647\u0645 \u0628\u0627\u0644\u0633\u0644\u0637\u0627\u0646\u060c \u062d\u062a\u0649 \u063a\u064a\u0631\u0648\u0627 \u0627\u0639\u062a\u0642\u0627\u062f\u0647 \u0641\u064a\u0647\u060c \u0648\u0647\u0645\u0651 \u0628\u062d\u0628\u0633\u0647 \u0623\u0648 \u0646\u0641\u064a\u0647. \u0641\u0623\u0631\u0633\u0644 \u0627\u0644\u0648\u0632\u064a\u0631\u064e \u0625\u0644\u0649 \u0632\u0627\u0648\u064a\u062a\u0647 \u0644\u064a\u0633\u062f \u0628\u0627\u0628\u0647\u0627\u060c \u0648\u0643\u0627\u0646 \u0627\u0644\u0634\u064a\u062e \u062e\u0627\u0631\u062c \u0645\u0635\u0631 \u0641\u064a \u0627\u0644\u0645\u0637\u0631\u064a\u0629\u060c \u0647\u0648 \u0648\u0627\u0644\u0641\u0642\u0631\u0627\u0621\u061b \u0641\u0631\u062c\u0639\u0648\u0627 \u0641\u0648\u062c\u062f\u0648\u0627 \u0627\u0644\u0628\u0627\u0628 \u0645\u0633\u062f\u0648\u062f\u0627\u064b \u0641\u0642\u0627\u0644 \u0627\u0644\u0634\u064a\u062e: \u0645\u0646 \u0633\u062f \u0647\u0630\u0627 \u0627\u0644\u0628\u0627\u0628\u061f \u0641\u0642\u0627\u0644\u0648\u0627: \u0633\u062f\u0647 \u0627\u0644\u0648\u0632\u064a\u0631 \u0641\u0644\u0627\u0646 \u0628\u0623\u0645\u0631 \u0627\u0644\u0633\u0644\u0637\u0627\u0646! \u0641\u0642\u0627\u0644: \u0648\u0646\u062d\u0646 \u0646\u0633\u062f \u0623\u0628\u0648\u0627\u0628 \u0628\u062f\u0646\u0647 \u0648\u0637\u064a\u0642\u0627\u0646\u0647\u061b \u0641\u0639\u0645\u064a \u0627\u0644\u0648\u0632\u064a\u0631 \u0648\u0637\u0631\u0634 \u0648\u062e\u0631\u0633\u060c \u0648\u0627\u0646\u0633\u062f \u0623\u0646\u0641\u0647 \u0639\u0646 \u062e\u0631\u0648\u062c \u0627\u0644\u0646\u0641\u0633\u060c \u0648\u0642\u064f\u0628\u0644\u0647 \u0648\u062f\u0628\u0631\u0647 \u0639\u0646 \u0627\u0644\u0628\u0648\u0644 \u0648\u0627\u0644\u063a\u0627\u0626\u0637\u060c \u0641\u0645\u0627\u062a \u0627\u0644\u0648\u0632\u064a\u0631 \u0641\u064a \u0627\u0644\u062d\u0627\u0644. \u0641\u0628\u0644\u063a \u0630\u0644\u0643 \u0627\u0644\u0633\u0644\u0637\u0627\u0646\u060c \u0641\u0646\u0632\u0644 \u0625\u0644\u064a\u0647 \u0648\u0635\u0627\u0644\u062d\u0647\u060c \u0648\u0641\u062a\u062d \u0644\u0647 \u0627\u0644\u0628\u0627\u0628. \u0648\u0643\u0627\u0646 \u0639\u0633\u0643\u0631 \u0627\u0644\u0633\u0644\u0637\u0627\u0646 \u0643\u0644\u0647 \u0642\u062f \u0627\u0646\u0642\u0627\u062f \u0644\u0633\u064a\u062f\u064a \u062d\u0633\u0646 \u0631\u0636\u064a \u0627\u0644\u0644\u0647 \u0639\u0646\u0647\u060c \u062d\u062a\u0649 \u062e\u0631\u062c\u0648\u0627 \u0639\u0646 \u0637\u0627\u0639\u0629 \u0627\u0644\u0633\u0644\u0637\u0627\u0646 \u0625\u0644\u0649 \u0637\u0627\u0639\u062a\u0647 \u0631\u0636\u064a \u0627\u0644\u0644\u0647 \u0639\u0646\u0647.]<\/p>\n<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0625\u0646 \u0623\u0647\u0644 \u0627\u0644\u0633\u0644\u0637\u0627\u0646 \u0641\u064a \u0627\u0644\u0638\u0627\u0647\u0631\u060c \u0643\u062b\u064a\u0631\u0627 \u0645\u0627 \u064a\u063a\u062a\u0631\u0648\u0646 \u0628\u0645\u0627 \u064a\u0631\u0648\u0646\u0647 \u0645\u0646 \u0627\u0646\u0641\u0639\u0627\u0644 \u0627\u0644\u0639\u0627\u0644\u0645 \u0644\u0647\u0645\u060c \u0648\u064a\u062a\u0648\u0647\u0645\u0648\u0646 \u0623\u0646\u0647 \u0644\u0627 \u0623\u062d\u062f \u0645\u0646 \u0627\u0644\u0639\u0628\u0627\u062f \u064a\u0633\u062a\u0637\u064a\u0639 \u0627\u0644\u0648\u0642\u0648\u0641 \u0641\u064a \u0648\u062c\u0648\u0647\u0647\u0645\u060c \u0645\u0646 \u0623\u0647\u0644 \u0628\u0644\u062f\u0647\u0645 \u0639\u0644\u0649 \u0627\u0644\u062e\u0635\u0648\u0635. \u0648\u0644\u0646 \u064a\u0632\u0627\u0644\u0648\u0627 \u0641\u064a \u0641\u0633\u062d\u0629 \u0645\u0646 \u0623\u0645\u0631\u0647\u0645\u060c \u0645\u0627 \u0644\u0645 \u064a\u0635\u0627\u062f\u0641\u0648\u0627 \u0623\u062d\u062f \u0631\u062c\u0627\u0644 \u0627\u0644\u0628\u0627\u0637\u0646\u060c \u0627\u0644\u0630\u064a\u0646 \u0647\u0645 \u0641\u064a \u0627\u0644\u062d\u0642\u064a\u0642\u0629 \u0623\u0647\u0644 \u0627\u0644\u0633\u0644\u0637\u0627\u0646 \u0639\u0644\u064a\u0647\u0645 \u0645\u0646 \u062c\u0647\u0629 \u0627\u0644\u063a\u064a\u0628\u060c \u0648\u0625\u0646 \u0643\u0627\u0646\u0648\u0627 \u0644\u0627 \u064a\u0634\u0639\u0631\u0648\u0646. \u0648\u0627\u0644\u0642\u0635\u0629 \u0627\u0644\u0645\u0631\u0648\u064a\u0629 \u0639\u0646 \u0627\u0644\u0634\u064a\u062e \u0627\u0644\u062a\u0633\u062a\u0631\u064a \u0631\u0636\u064a \u0627\u0644\u0644\u0647 \u0639\u0646\u0647\u060c \u062a\u062c\u0645\u0639 \u0628\u064a\u0646 \u0627\u0644\u0633\u0644\u0637\u0627\u0646 \u0648\u0627\u0644\u0648\u0632\u064a\u0631\u061b \u0648\u062a\u0628\u064a\u0651\u0646 \u0623\u0646 \u0627\u0644\u0633\u0644\u0637\u0627\u0646 (\u0623\u064a \u0633\u0644\u0637\u0627\u0646) \u0643\u062b\u064a\u0631\u0627 \u0645\u0627 \u064a\u0642\u0639 \u062a\u062d\u062a \u062a\u0623\u062b\u064a\u0631 \u0627\u0644\u0645\u063a\u0631\u0636\u064a\u0646\u060c \u0645\u0645\u0646 \u064a\u0628\u063a\u0636\u0648\u0646 \u0623\u0647\u0644 \u0627\u0644\u0644\u0647. \u0641\u0644\u0645\u0627 \u062a\u0645\u0643\u0646 \u0647\u0646\u0627 \u0627\u0644\u062a\u062d\u0631\u064a\u0636 \u0645\u0646 \u0627\u0644\u0633\u0644\u0637\u0627\u0646\u060c \u0642\u0631\u0631 \u0623\u0646 \u064a\u062a\u062e\u0644\u0635 \u0645\u0646 \u0627\u0644\u0634\u064a\u062e\u061b \u0648\u062c\u0639\u0644 \u0623\u0648\u0644\u0649 \u0645\u0631\u0627\u062d\u0644 \u0627\u0644\u062d\u0631\u0628 \u0639\u0644\u064a\u0647\u060c \u0625\u063a\u0644\u0627\u0642 \u0632\u0627\u0648\u064a\u062a\u0647. \u0648\u0627\u0644\u0648\u0632\u064a\u0631\u060c \u0648\u0625\u0646 \u0644\u0645 \u064a\u0643\u0646 \u0625\u0644\u0627 \u0627\u0644\u0645\u0646\u0641\u0630 \u0644\u0623\u0645\u0631 \u0627\u0644\u0633\u0644\u0637\u0627\u0646\u060c \u0625\u0644\u0627 \u0623\u0646\u0647 \u0643\u0627\u0646 \u064a\u0646\u0628\u063a\u064a \u0639\u0644\u064a\u0647 \u0631\u062f\u0647 \u0639\u0645\u0627 \u0639\u0632\u0645 \u0639\u0644\u064a\u0647\u060c \u0644\u0627 \u0627\u0644\u0645\u0633\u0627\u0631\u0639\u0629 \u0625\u0644\u0649 \u0625\u0645\u0636\u0627\u0626\u0647\u061b \u0648\u0647\u0630\u0627 \u064a\u062c\u0639\u0644\u0647 \u0645\u062d\u0628\u0627 \u0644\u0645\u0627 \u0623\u064f\u0645\u0631 \u0628\u0641\u0639\u0644\u0647\u060c \u0642\u0627\u0635\u062f\u0627 \u0644\u0647. \u0648\u062d\u062a\u0649 \u0625\u0646 \u0644\u0645 \u064a\u0643\u0646\u060c \u0641\u0625\u0646 \u0625\u062e\u0631\u0627\u062c \u0627\u0644\u0641\u0639\u0644 \u0645\u0646 \u062d\u064a\u0651\u0632 \u0627\u0644\u0639\u0632\u0645 \u0625\u0644\u0649 \u0627\u0644\u062d\u0633\u060c \u064a\u064f\u062d\u0627\u0633\u0628 \u0639\u0644\u064a\u0647 \u0645\u0646 \u0623\u062e\u0631\u062c\u0647\u060c \u0642\u0628\u0644 \u0627\u0644\u0622\u0645\u0631 \u0628\u0647. \u0648\u0647\u0630\u0627 \u0647\u0648 \u0627\u0644\u0630\u064a \u062c\u0639\u0644 \u0627\u0644\u0634\u064a\u062e \u0627\u0644\u062a\u0633\u062a\u0631\u064a \u0631\u0636\u064a \u0627\u0644\u0644\u0647 \u0639\u0646\u0647\u060c \u064a\u063a\u0636\u0628 \u0645\u0646 \u0627\u0644\u0648\u0632\u064a\u0631 \u0627\u0644\u0630\u064a \u0627\u062c\u062a\u0631\u0623 \u0639\u0644\u0649 \u063a\u0644\u0642 \u0627\u0644\u0632\u0627\u0648\u064a\u0629\u060c \u0641\u0639\u0627\u0642\u0628\u0647 \u0628\u0625\u063a\u0644\u0627\u0642 \u0645\u0646\u0627\u0641\u0630 \u0628\u062f\u0646\u0647\u061b \u0648\u0647\u0648 \u0645\u0627 \u0639\u062c\u0644 \u0628\u0645\u0648\u062a\u0647 \u0641\u064a \u0627\u0644\u062d\u0627\u0644. \u0648\u0641\u0639\u0644 \u0627\u0644\u0634\u064a\u062e \u0647\u0630\u0627\u060c \u0647\u0648 \u0645\u0646 \u0641\u0639\u0644 \u0627\u0644\u0644\u0647\u061b \u0644\u0623\u0646 \u0627\u0644\u0644\u0647 \u0647\u0648 \u0645\u0646 \u063a\u0636\u0628 \u0644\u0641\u0639\u0644 \u0627\u0644\u0648\u0632\u064a\u0631. \u0648\u0647\u0648 \u0645\u0646 \u0628\u0627\u0628 \u0642\u0648\u0644 \u0627\u0644\u0644\u0647 \u062a\u0639\u0627\u0644\u0649: {\u0641\u064e\u0644\u064e\u0645\u0652 \u062a\u064e\u0642\u0652\u062a\u064f\u0644\u064f\u0648\u0647\u064f\u0645\u0652 \u0648\u064e\u0644\u064e\u0643\u0650\u0646\u0651\u064e \u0627\u0644\u0644\u0651\u064e\u0647\u064e \u0642\u064e\u062a\u064e\u0644\u064e\u0647\u064f\u0645\u0652 \u0648\u064e\u0645\u064e\u0627 \u0631\u064e\u0645\u064e\u064a\u0652\u062a\u064e \u0625\u0650\u0630\u0652 \u0631\u064e\u0645\u064e\u064a\u0652\u062a\u064e \u0648\u064e\u0644\u064e\u0643\u0650\u0646\u0651\u064e \u0627\u0644\u0644\u0651\u064e\u0647\u064e \u0631\u064e\u0645\u064e\u0649} [\u0627\u0644\u0623\u0646\u0641\u0627\u0644: 17]. \u0648\u0647\u0630\u0627 \u0643\u062b\u064a\u0631 \u0627\u0644\u0648\u0642\u0648\u0639 \u0645\u0646 \u0623\u0647\u0644 \u0627\u0644\u0644\u0647 \u0627\u0644\u0645\u062a\u062d\u0642\u0642\u064a\u0646 \u0628\u0627\u0644\u062d\u0642.<\/p>\n<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0648\u0623\u0645\u0627 \u0627\u0644\u0633\u0644\u0637\u0627\u0646\u060c \u0641\u0625\u0646\u0647 \u0639\u0627\u062f \u0625\u0644\u0649 \u0631\u0634\u062f\u0647\u061b \u0648\u0639\u0644\u0645 \u0623\u0646 \u0645\u0646 \u0627\u0644\u0639\u0628\u0627\u062f \u0645\u0646 \u0644\u0647 \u0627\u0644\u0633\u0644\u0637\u0627\u0646 \u0639\u0644\u0649 \u0633\u0644\u0637\u0627\u0646\u0647\u060c \u0648\u0645\u0639 \u0630\u0644\u0643 \u0641\u0647\u0645 \u0644\u0627 \u064a\u0638\u0647\u064e\u0631\u0648\u0646 \u0628\u0647 \u062f\u0627\u0626\u0645\u0627\u060c \u0623\u062f\u0628\u0627 \u0645\u0639 \u0631\u0628\u0647\u0645 \u0630\u064a \u0627\u0644\u0633\u0644\u0637\u0627\u0646 \u0627\u0644\u062d\u0642 \u0627\u0644\u0639\u0638\u064a\u0645. \u0648\u0646\u0632\u0648\u0644\u0647 \u0625\u0644\u0649 \u0627\u0644\u0634\u064a\u062e \u0648\u0627\u0633\u062a\u0631\u0636\u0627\u0624\u0647 \u062f\u0644\u064a\u0644\u0627\u0646 \u0639\u0644\u0649 \u0645\u0639\u0631\u0641\u062a\u0647 \u0628\u0636\u0639\u0641 \u0646\u0641\u0633\u0647 \u0641\u064a \u0645\u0648\u0627\u062c\u0647\u0629 \u0645\u0646 \u0643\u0627\u0646 \u0642\u0627\u0626\u0645\u0627 \u0628\u0631\u0628\u0647. \u0648\u0642\u062f \u0633\u0631\u062a \u0647\u0630\u0647 \u0627\u0644\u0645\u0639\u0631\u0641\u0629 \u0625\u0644\u0649 \u062c\u0646\u0648\u062f\u0647\u060c \u0627\u0644\u0630\u064a\u0646 \u0639\u0627\u062f\u0648\u0627 \u0623\u0637\u0648\u0639 \u0644\u0644\u0634\u064a\u062e \u0645\u0646 \u0627\u0644\u0633\u0644\u0637\u0627\u0646 \u0646\u0641\u0633\u0647. \u0648\u0647\u0630\u0627 \u0643\u0627\u0646 \u062f\u0623\u0628 \u0633\u0644\u0627\u0637\u064a\u0646 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0642\u0628\u0644 \u0623\u0646 \u062a\u0633\u062a\u062d\u0648\u0630 \u0639\u0644\u064a\u0647\u0645 \u0627\u0644\u063a\u0641\u0644\u0629 \u0648\u064a\u0635\u064a\u0631\u0648\u0627 \u0623\u0644\u0639\u0648\u0628\u0629 \u0628\u0623\u064a\u062f\u064a \u0627\u0644\u0643\u0627\u0641\u0631\u064a\u0646\u061b \u0625\u0644\u0649 \u0627\u0644\u062d\u062f \u0627\u0644\u0630\u064a \u0644\u0645 \u064a\u0639\u0648\u062f\u0648\u0627 \u0645\u0639\u0647 \u064a\u0641\u0642\u0647\u0648\u0646 \u0645\u0627 \u0643\u0627\u0646 \u0627\u0644\u0623\u0648\u0644\u0648\u0646 \u064a\u0641\u0642\u0647\u0648\u0646\u0647 \u0628\u0623\u0642\u0644 \u062a\u0639\u0631\u064a\u0641.<\/p>\n<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0648\u0642\u062f \u0639\u0645\u062a \u0627\u0644\u063a\u0641\u0644\u0629 \u0648\u0627\u0633\u062a\u062d\u0643\u0645\u062a \u0641\u064a \u0627\u0644\u0623\u0632\u0645\u0646\u0629 \u0627\u0644\u0645\u062a\u0623\u062e\u0631\u0629\u060c \u062d\u062a\u0649 \u0635\u0627\u0631 \u062c\u0644 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0644\u0627 \u064a\u062e\u062a\u0644\u0641\u0648\u0646 \u0639\u0646 \u0627\u0644\u0643\u0627\u0641\u0631\u064a\u0646 \u0641\u064a \u0627\u0644\u062a\u0635\u062f\u064a\u0642 \u0628\u0643\u0631\u0627\u0645\u0627\u062a \u0623\u0647\u0644 \u0627\u0644\u0642\u0631\u0628. \u0648\u0644\u0643\u0646 \u0627\u0644\u062a\u0635\u062f\u064a\u0642 \u0623\u0648 \u0639\u062f\u0645\u0647\u060c \u0644\u0627 \u064a\u063a\u064a\u0631\u0627\u0646 \u0645\u0646 \u0648\u0627\u0642\u0639 \u0627\u0644\u0623\u0645\u0631 \u0634\u064a\u0626\u0627: \u0648\u0647\u0648 \u0623\u0646 \u0644\u0644\u0647 \u0631\u062c\u0627\u0644\u0627 \u0645\u0646 \u0643\u0644 \u0632\u0645\u0627\u0646\u060c \u0625\u0630\u0627 \u0623\u0631\u0627\u062f\u0648\u0627 \u0634\u064a\u0626\u0627 \u0643\u0627\u0646\u060c \u0639\u0644\u0649 \u0645\u0627 \u0623\u0631\u0627\u062f\u0648\u0627. \u0648\u0647\u0624\u0644\u0627\u0621\u060c \u0645\u0646 \u0643\u0627\u0646\u0648\u0627 \u0645\u0639\u0647\u060c \u0643\u0627\u0646 \u0627\u0644\u063a\u0627\u0644\u0628 \u0628\u0625\u0630\u0646 \u0627\u0644\u0644\u0647 \u0644\u063a\u064a\u0631\u0647. \u0633\u0648\u0627\u0621 \u0623\u0643\u0627\u0646 \u0647\u0630\u0627 \u0627\u0644\u063a\u064a\u0631 \u0645\u0646 \u0623\u0639\u062f\u0627\u0621 \u0627\u0644\u062e\u0627\u0631\u062c\u060c \u0623\u0648 \u0645\u0646 \u062e\u0635\u0648\u0645 \u0627\u0644\u062f\u0627\u062e\u0644. \u0648\u0644\u0642\u062f \u0643\u0627\u0646 \u0627\u0644\u0623\u0642\u062f\u0645\u0648\u0646 \u064a\u062f\u0631\u0643\u0648\u0646 \u0647\u0630\u0627 \u0628\u0627\u0644\u062a\u062c\u0631\u0628\u0629 \u0648\u0627\u0644\u0645\u0634\u0627\u0647\u062f\u0629 \u0627\u0644\u062d\u0633\u064a\u0629\u060c \u0641\u064a\u0633\u0627\u0631\u0639\u0648\u0646 \u0625\u0644\u0649 \u0627\u0633\u062a\u0639\u0637\u0627\u0641\u0647\u0645 \u0648\u0646\u064a\u0644 \u0631\u0636\u0627\u0647\u0645. \u0623\u0645\u0627 \u0641\u064a \u0627\u0644\u0623\u0632\u0645\u0646\u0629 \u0627\u0644\u0645\u062a\u0623\u062e\u0631\u0629\u060c \u0641\u0625\u0646 \u0627\u0644\u062d\u062c\u0627\u0628 \u0642\u062f \u0627\u0646\u0633\u062f\u0644 \u0645\u0646 \u0627\u0644\u062c\u0627\u0646\u0628\u064a\u0646: \u0645\u0646 \u062c\u0627\u0646\u0628 \u0639\u0645\u0648\u0645 \u0627\u0644\u0646\u0627\u0633\u060c \u0639\u0646\u062f \u0646\u0632\u0648\u0644 \u0645\u0646\u0633\u0648\u0628 \u0627\u0644\u0625\u064a\u0645\u0627\u0646 \u0644\u062f\u064a\u0647\u0645 \u0625\u0644\u0649 \u0627\u0644\u062d\u062f \u0627\u0644\u0623\u062f\u0646\u0649\u061b \u0648\u0645\u0646 \u062c\u0627\u0646\u0628 \u0647\u0624\u0644\u0627\u0621 \u0627\u0644\u0631\u062c\u0627\u0644\u060c \u0631\u062d\u0645\u0629 \u0628\u0627\u0644\u0646\u0627\u0633\u060c \u062d\u062a\u0649 \u0644\u0627 \u064a\u0639\u0627\u0642\u0628\u0648\u0627 \u0639\u0644\u0649 \u0633\u0648\u0621 \u0627\u0644\u0623\u062f\u0628 \u0645\u0639\u0647\u0645\u060c \u0639\u0646\u062f \u0639\u062f\u0645 \u0645\u0631\u0627\u0639\u0627\u0629 \u0645\u0643\u0627\u0646\u062a\u0647\u0645. \u063a\u064a\u0631 \u0623\u0646 \u0627\u0644\u0623\u0645\u0631 \u0644\u0627 \u064a\u0644\u0628\u062b \u0623\u0646 \u064a\u0639\u0648\u062f \u0625\u0644\u0649 \u0623\u0634\u062f \u0645\u0627 \u0643\u0627\u0646 \u0639\u0644\u064a\u0647 \u0639\u0646\u062f \u0627\u0644\u0623\u0648\u0644\u064a\u0646\u060c \u0644\u0623\u0646 \u0627\u0644\u062e\u0644\u0627\u0641\u0629 \u0627\u0644\u062e\u0627\u062a\u0645\u0629 \u0633\u062a\u0643\u0648\u0646 \u0642\u0627\u0626\u0645\u0629 \u0639\u0644\u0649 \u0627\u0644\u0648\u0644\u0627\u064a\u0629 \u0641\u064a \u0627\u0644\u0638\u0627\u0647\u0631\u060c \u0628\u0627\u0644\u0625\u0636\u0627\u0641\u0629 \u0625\u0644\u0649 \u0627\u0644\u0628\u0627\u0637\u0646 \u0627\u0644\u0630\u064a \u0643\u0627\u0646 \u0644\u0647\u0627 \u0639\u0644\u0649 \u0627\u0644\u062f\u0648\u0627\u0645. \u0648\u0647\u0630\u0627 \u0633\u064a\u062c\u0639\u0644 \u0639\u0644\u0648\u0645 \u0627\u0644\u0648\u0644\u0627\u064a\u0629 \u0648\u062a\u0635\u0631\u0641\u0627\u062a\u0647\u0627 \u062a\u0639\u0648\u062f \u0625\u0644\u0649 \u0627\u0644\u0634\u064a\u0648\u0639 \u0628\u064a\u0646 \u0627\u0644\u0646\u0627\u0633\u060c \u0628\u0623\u0643\u062b\u0631 \u0645\u0645\u0627 \u0643\u0627\u0646\u062a. \u0648\u0647\u0630\u0627 \u0623\u064a\u0636\u0627 \u0645\u0646 \u0631\u062d\u0645\u0629 \u0627\u0644\u0644\u0647 \u0628\u0647\u0630\u0647 \u0627\u0644\u0623\u0645\u0629\u061b \u0644\u0623\u0646 \u0645\u0643\u0631 \u0627\u0644\u0634\u064a\u0627\u0637\u064a\u0646 \u0641\u064a \u0622\u062e\u0631 \u0627\u0644\u0632\u0645\u0627\u0646\u060c \u0633\u064a\u0635\u0644 \u0625\u0644\u0649 \u0645\u0627 \u0644\u0627 \u064a\u0643\u0627\u062f \u0627\u0644\u0639\u0648\u0627\u0645 \u064a\u0645\u0644\u0643\u0648\u0646 \u0645\u0639\u0647 \u0634\u064a\u0626\u0627 \u0645\u0646 \u0623\u0646\u0641\u0633\u0647\u0645. \u0648\u0646\u062d\u0646 \u0646\u0631\u0649 \u0641\u064a \u0632\u0645\u0627\u0646\u0646\u0627\u060c \u0628\u0639\u0636 \u0630\u0644\u0643\u060c \u0645\u0645\u0627 \u064a\u062f\u062e\u0644 \u0641\u064a \u062a\u0648\u062c\u064a\u0647 \u0639\u0642\u0648\u0644 \u0627\u0644\u0646\u0627\u0633 \u0628\u0634\u062a\u0649 \u0627\u0644\u0648\u0633\u0627\u0626\u0644.<\/p>\n<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0648\u0639\u0644\u0649 \u0627\u0644\u0639\u0645\u0648\u0645\u060c \u0641\u0625\u0646 \u0645\u0646 \u0638\u0647\u0631 \u0641\u064a \u0628\u0644\u062f\u0627\u0646\u0647\u0645 \u0645\u0646 \u0627\u0644\u0623\u0648\u0644\u064a\u0627\u0621 \u0623\u062d\u062f \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0623\u0632\u0645\u0646\u0629\u060c \u0641\u0639\u0644\u064a\u0647\u0645 \u0623\u0646 \u064a\u0648\u0627\u0644\u0648\u0647 \u0628\u0645\u0627 \u064a\u0633\u062a\u0637\u064a\u0639\u0648\u0646\u061b \u062d\u062a\u0649 \u064a\u0643\u0648\u0646\u0648\u0627 \u0641\u064a \u0635\u0641 \u062d\u0632\u0628 \u0627\u0644\u0644\u0647\u060c \u0627\u0644\u0630\u064a \u064a\u0642\u0648\u0644 \u0627\u0644\u0644\u0647 \u062a\u0639\u0627\u0644\u0649 \u0639\u0646\u0647: {\u0648\u064e\u0645\u064e\u0646\u0652 \u064a\u064e\u062a\u064e\u0648\u064e\u0644\u0651\u064e \u0627\u0644\u0644\u0651\u064e\u0647\u064e \u0648\u064e\u0631\u064e\u0633\u064f\u0648\u0644\u064e\u0647\u064f \u0648\u064e\u0627\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0622\u0645\u064e\u0646\u064f\u0648\u0627 \u0641\u064e\u0625\u0650\u0646\u0651\u064e \u062d\u0650\u0632\u0652\u0628\u064e \u0627\u0644\u0644\u0651\u064e\u0647\u0650 \u0647\u064f\u0645\u064f \u0627\u0644\u0652\u063a\u064e\u0627\u0644\u0650\u0628\u064f\u0648\u0646\u064e} [\u0627\u0644\u0645\u0627\u0626\u062f\u0629: 56]\u061b \u0648\u064a\u0642\u0648\u0644 \u0633\u0628\u062d\u0627\u0646\u0647: {\u0623\u064f\u0648\u0644\u064e\u0626\u0650\u0643\u064e \u062d\u0650\u0632\u0652\u0628\u064f \u0627\u0644\u0644\u0651\u064e\u0647\u0650 \u0623\u064e\u0644\u064e\u0627 \u0625\u0650\u0646\u0651\u064e \u062d\u0650\u0632\u0652\u0628\u064e \u0627\u0644\u0644\u0651\u064e\u0647\u0650 \u0647\u064f\u0645\u064f \u0627\u0644\u0652\u0645\u064f\u0641\u0652\u0644\u0650\u062d\u064f\u0648\u0646\u064e} [\u0627\u0644\u0645\u062c\u0627\u062f\u0644\u0629: 22].<br \/>&nbsp;<\/p>\n<hr \/>\n<p><strong><a href=\"#_ftnref1\" name=\"_ftn1\" title=\"\">[1]<\/a><\/strong>. \u0627\u0644\u0637\u0628\u0642\u0627\u062a \u0627\u0644\u0643\u0628\u0631\u0649: 2\/ 66-67<\/p>\n","protected":false},"excerpt":{"rendered":"<p>&nbsp; &nbsp; &nbsp; &nbsp;\u064a\u0630\u0643\u0631 \u0627\u0644\u0634\u064a\u062e \u0627\u0644\u0634\u0639\u0631\u0627\u0646\u064a \u0631\u0636\u064a \u0627\u0644\u0644\u0647 \u0639\u0646\u0647\u060c \u0641\u064a &quot; \u0627\u0644\u0637\u0628\u0642\u0627\u062a \u0627\u0644\u0643\u0628\u0631\u0649 &quot;&nbsp;[1]\u060c&nbsp;\u0641\u064a \u062a\u0631\u062c\u0645\u0629 \u0627\u0644\u0634\u064a\u062e \u062d\u0633\u0646 \u0627\u0644\u062a\u0633\u062a\u0631\u064a\u060c \u0631\u0636\u064a \u0627\u0644\u0644\u0647 \u0639\u0646\u0647\u060c \u0645\u0627 \u064a\u0644\u064a:[\u0643\u0627\u0646 \u0627\u0644\u0633\u0644\u0637\u0627\u0646 \u064a\u0646\u0632\u0644 \u0625\u0644\u0649 \u0632\u064a\u0627\u0631\u062a\u0647\u060c \u0641\u0644\u0645 \u064a\u0632\u0644 \u0627\u0644\u062d\u0627\u0633\u062f\u0648\u0646 \u0645\u0646 \u0623\u0631\u0628\u0627\u0628 \u0627\u0644\u062f\u0648\u0644\u0629 \u0648\u063a\u064a\u0631\u0647\u0645 \u0628\u0627\u0644\u0633\u0644\u0637\u0627\u0646\u060c \u062d\u062a\u0649 \u063a\u064a\u0631\u0648\u0627 \u0627\u0639\u062a\u0642\u0627\u062f\u0647 \u0641\u064a\u0647\u060c \u0648\u0647\u0645\u0651 \u0628\u062d\u0628\u0633\u0647 \u0623\u0648 \u0646\u0641\u064a\u0647. \u0641\u0623\u0631\u0633\u0644 \u0627\u0644\u0648\u0632\u064a\u0631\u064e \u0625\u0644\u0649 \u0632\u0627\u0648\u064a\u062a\u0647 \u0644\u064a\u0633\u062f \u0628\u0627\u0628\u0647\u0627\u060c \u0648\u0643\u0627\u0646 \u0627\u0644\u0634\u064a\u062e \u062e\u0627\u0631\u062c \u0645\u0635\u0631 \u0641\u064a \u0627\u0644\u0645\u0637\u0631\u064a\u0629\u