{"id":12060,"date":"2024-12-21T13:21:26","date_gmt":"2024-12-21T13:21:26","guid":{"rendered":"http:\/\/alomariya.test\/%d9%83%d9%8e%d8%b4%d9%8e%d9%81%d9%8e%d8%aa%d9%92-%d9%87%d9%90%d9%86%d9%92%d8%af%d9%8f\/"},"modified":"2025-03-02T11:48:23","modified_gmt":"2025-03-02T11:48:23","slug":"%d9%83%d8%b4%d9%81%d8%aa_%d9%87%d9%86%d8%af","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d9%83%d8%b4%d9%81%d8%aa_%d9%87%d9%86%d8%af\/","title":{"rendered":"\u0643\u064e\u0634\u064e\u0641\u064e\u062a\u0652 \u0647\u0650\u0646\u0652\u062f\u064f"},"content":{"rendered":"<p>\u0643\u064e\u0634\u064e\u0641\u064e\u062a\u0652 \u0647\u0650\u0646\u0652\u062f\u064f \u062b\u064e\u0648\u0652\u0628\u064e \u0639\u0650\u0632\u064e\u0651\u0629\u064d \u0639\u064e\u0646\u0652 \u0633\u064e\u0640\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0642\u064d \u0645\u0650\u0646\u064e \u0627\u0644\u0652\u0645\u064e\u0631\u0652\u0645\u064e\u0640\u0631\u0650 \u0641\u064e\u062a\u064e\u0640\u0646\u064e \u0627\u0644\u0646\u064e\u0651\u0627\u0638\u0650\u0631\u0650\u064a\u0646\u064e\u0640\u0640\u0627<br \/>\n\u0648\u064e\u062a\u064e\u0640\u062b\u0640\u064e\u0646\u064e\u0651\u0640\u0640\u062a\u0652 \u0641\u0650\u0640\u064a \u0639\u064e\u0640\u0640\u0637\u0652\u0640\u0640\u0641\u064e\u0640\u0640\u0629 \u064d\u0648\u064e\u0631\u064e\u0645\u064e\u0640\u062a\u0652\u0640\u0646\u064e\u0640\u0640\u0640\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0628\u0650\u0633\u0650\u0647\u064e\u0627\u0645\u0650 \u0644\u064e\u062d\u0652\u0638\u064d \u0623\u064e\u062d\u0652\u064a\u064e\u0649 \u0627\u0644\u0652\u0640\u0647\u064e\u0648\u064e\u0649 \u0641\u0650\u064a\u0646\u0640\u064e\u0640\u0627<br \/>\n\u0644\u064e\u0640\u0645\u0652 \u0623\u064e\u0643\u064f\u0646\u0652 \u0642\u064e\u0640\u0637\u064f\u0651 \u0623\u064e\u062f\u064e\u0651\u0639\u0650\u0640\u064a \u0642\u064f\u0640\u0648\u064e\u0629\u064b \u0641\u0650\u0640\u0640\u0640\u0640\u064a\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u063a\u064e\u0631\u064e\u0627\u0645\u064d \u0648\u064e\u0645\u064e\u0627 \u0643\u064f\u0646\u0652\u062a\u064f \u0641\u0650\u064a \u0627\u0644\u0652\u062e\u064e\u0627\u0637\u0650\u0628\u0650\u064a\u0646\u064e\u0640\u0627<br \/>\n\u063a\u064e\u0640\u064a\u0640\u0652\u0631\u064e \u0623\u064e\u0646\u0651\u0640\u0650\u064a \u0645\u064e\u0640\u0631\u064e\u0631\u0652\u062a\u064f \u0628\u0650\u0640\u0627\u0644\u0652\u0640\u062d\u064e\u064a\u0650\u0651 \u064a\u064e\u0648\u0652\u0645\u0640\u0640\u0640\u064b\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0643\u064e\u0627\u0646\u064e \u064a\u064e\u0648\u0652\u0645\u064e \u0627\u0644\u0631\u064e\u0651\u062f\u064e\u0649 \u0639\u0650\u0646\u0652\u062f\u064e \u0627\u0644\u0652\u0645\u064e\u0627\u0631\u0650\u0651\u064a\u0646\u064e\u0640\u0640\u0627<br \/>\n\u0648\u064e\u0648\u064e\u062c\u064e\u0640\u062f\u0652\u062a\u064f \u0646\u064e\u0640\u0641\u0652\u0633\u0650\u0640\u064a \u0639\u064e\u0644\u0640\u064e\u0649 \u063a\u064e\u0641\u0652\u0644\u064e\u0629\u064d \u0645\u0650\u0640\u0640\u0640\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0640\u0646\u0650\u0651\u064a \u0645\u064f\u0642\u064e\u0627\u0628\u0650\u0644\u064e \u0648\u064e\u062c\u0652\u0640\u0647\u0650 \u0627\u0644\u0652\u062d\u064f\u0633\u0652\u0640\u0646\u0650 \u064a\u064e\u0642\u0650\u064a\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0641\u064e\u0640\u0639\u064e\u0640\u0644\u0650\u0640\u0645\u0652\u0640\u062a\u064f \u0623\u064e\u0646\u064e\u0651 \u0647\u064e\u0646\u064e\u0627\u064a\u064e \u0642\u064e\u0640\u0640\u062f\u0652 \u0648\u064e\u0644\u064e\u0651\u0640\u0640\u0640\u0640\u0640\u0649\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0639\u064e\u0646\u0650\u0651\u064a \u0636\u0650\u0645\u0652\u0646\u064e \u062c\u064e\u0640\u0645\u0652\u0639\u064d \u0645\u0650\u0640\u0646\u064e \u0627\u0644\u0652\u0640\u0645\u064f\u0648\u064e\u0644\u0650\u0651\u064a\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0642\u064e\u0640\u062f\u0652 \u0645\u064e\u062d\u064e\u0627 \u0646\u064f\u0640\u0648\u0631\u064f \u0648\u064e\u062c\u0652\u0647\u0650\u0647\u064e\u0640\u0627 \u0644\u064e\u0640\u064a\u0652\u0640\u0644\u064e \u0646\u064e\u0648\u0652\u0645\u0650\u0640\u0640\u064a\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0641\u064e\u0640\u0639\u064e\u0627\u062f\u064e \u064a\u064e\u0648\u0652\u0645\u0650\u064a \u0646\u064e\u0647\u064e\u0640\u0627\u0631\u064e \u0627\u0644\u0652\u0648\u064e\u0627\u062c\u0650\u062f\u0650\u064a\u0640\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u064a\u064e\u062c\u0652\u0631\u0650\u064a \u062f\u064e\u0645\u0652\u0639\u0650\u064a \u0639\u064e\u0640\u0644\u064e\u0640\u0649 \u0627\u0644\u0640\u062f\u064e\u0651\u0648\u064e\u0627\u0645\u0650 \u0635\u064e\u0628\u0650\u064a\u0640\u0628\u064b\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0645\u0650\u0646\u0652 \u062a\u064e\u0628\u064e\u0627\u0631\u0650\u064a\u0640\u062d\u0650 \u063a\u064e\u0640\u0631\u064e\u0627\u0645\u064d \u0641\u064e\u064a\u064f\u062f\u0652\u0645\u0650\u064a\u0640\u0640\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0647\u064f\u0640\u0648\u064e \u0645\u064e\u0640\u0640\u0648\u0652\u062a\u064c \u0644\u064e\u0640\u0630\u0650\u064a\u0640\u0630\u064c \u062b\u064f\u0640\u0645\u064e \u062d\u064e\u0640\u064a\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0627\u0629\u064c\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0628\u0650\u0647\u064e\u0627 \u064a\u064e\u062d\u0652\u064a\u064e\u0649 \u0645\u064e\u0646\u0652 \u0643\u064e\u0627\u0646\u064e \u0642\u064e\u0628\u0652\u0644\u064f \u062f\u064e\u0641\u0650\u064a\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0639\u0650\u0634\u0652\u0642\u064f\u0647\u064e\u0627 \u0642\u064e\u0640\u062f\u0652 \u0623\u064e\u0630\u064e\u0627\u0628\u064e \u0644\u064e\u0640\u062d\u0652\u0645\u0650\u064a \u0648\u064e\u0639\u064e\u0638\u0652\u0645\u0650\u064a\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u062a\u064e\u0640\u0631\u064e\u0627\u0647\u064f \u0641\u0650\u0640\u064a \u0623\u064e\u062b\u0652\u0648\u064e\u0627\u0628\u0650\u064a \u0625\u0650\u0646\u0652 \u062a\u064f\u0640\u0644\u0627\u0642\u0650\u0640\u0640\u0640\u0640\u064a\u0646\u064e\u0627<br \/>\n\u062d\u064f\u0640\u0643\u0652\u0640\u0645\u064f\u0646\u064e\u0627 \u062d\u064f\u0643\u0640\u0652\u0645\u064f \u0648\u064e\u0627\u062d\u0650\u062f\u064d \u0641\u0650\u0640\u064a \u0627\u062b\u0652\u0646\u064e\u064a\u0652\u0640\u0640\u0646\u0650\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0625\u0650\u0646\u0652 \u062a\u064f\u0639\u064e\u0627\u062f\u0650\u064a\u0646\u0640\u0650\u064a \u0641\u064e\u0640\u062d\u064e\u062a\u0652\u0645\u0627\u064b \u062a\u064f\u0639\u064e\u0627\u062f\u0650\u064a\u0640\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0648\u064e\u0623\u064e\u063a\u064e\u0640\u0627\u0631\u064f \u0639\u064e\u0644\u064e\u064a\u0640\u0652\u0647\u064e\u0640\u0627 \u0645\u0650\u0646\u0651\u0640\u064a \u0641\u064e\u0623\u064e\u0643\u0652\u0633\u064f\u0640\u0640\u0640\u0640\u0648\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0647\u064e\u0627 \u062b\u064e\u0648\u0652\u0628\u0627\u064b \u0644\u0640\u0650\u062d\u064f\u062f\u064f\u0648\u062b\u064d \u062a\u064e\u0638\u0652\u0640\u0647\u064e\u0640\u0631\u064f \u0637\u0650\u064a\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0623\u064e\u0635\u0652\u0628\u064e\u0640\u062d\u064e \u0627\u0644\u0640\u0652\u062d\u064f\u0640\u0628\u064f\u0651 \u0648\u064e\u0627\u0644\u0652\u0640\u062d\u064e\u0628\u0650\u064a\u0628\u064f \u0645\u0640\u064f\u062d\u0650\u0628\u0651\u0640\u0640\u0640\u064b\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e\u0639\u064e\u0642\u0650\u064a\u0640\u062f\u064e\u0629\u064f \u0627\u0644\u062a\u064e\u0651\u062b\u0652\u0644\u0650\u064a\u062b\u0650 \u0644\u0640\u0650\u064a\u064e \u062f\u0650\u064a\u0646\u064e\u0640\u0640\u0640\u0640\u0640\u0627<br \/>\n\u0641\u064e\u0635\u064e\u0644\u0627\u062a\u064f\u0647\u064e\u0640\u0627 \u0644\u0640\u0650\u064a \u0648\u064e\u0635\u064e\u0640\u0648\u0652\u0645\u0650\u0640\u064a\u064e \u0639\u064e\u0640\u0646\u0652 \u0633\u0650\u0640\u0640\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0640\u0648\u064e\u0627\u0647\u064e\u0627 \u0641\u064e\u0640\u0631\u0652\u0636\u064c \u0628\u0650\u0640\u0647\u0650 \u0635\u0650\u0640\u0631\u0652\u0646\u064e\u0627 \u062a\u064e\u0627\u0626\u0650\u0628\u0650\u064a\u0646\u064e\u0640\u0640\u0627<br \/>\n\u0646\u064e\u0633\u064e\u062e\u0652\u0646\u064e\u0627 \u0628\u0650\u0647\u0650 \u0634\u064e\u0640\u0631\u0652\u0639\u0640\u0627\u064b \u0644\u0650\u0644\u0634\u0650\u0651\u0640\u0631\u0652\u0643\u0650 \u0643\u064e\u0640\u0627\u0646\u064e\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0642\u064e\u0628\u0652\u0644\u064f \u064a\u064e\u0640\u0645\u0652\u0646\u064e\u0639\u064f \u0631\u064f\u062a\u0652\u0628\u064e\u0629\u064e \u0627\u0644\u0652\u0640\u0645\u064f\u062d\u0652\u0633\u0650\u0646\u0650\u064a\u0640\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0648\u064e\u0630\u064f\u0642\u0652\u0640\u0640\u0646\u064e\u0640\u0627 \u062e\u064e\u0640\u0644\u0652\u0640\u0648\u064e\u0629\u064b \u0644\u064e\u0646\u064e\u0640\u0627 \u0641\u064e\u062a\u064e\u0646\u064e\u0627\u0645\u064e\u0640\u0640\u0640\u0640\u0640\u062a\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0623\u064e\u0633\u0652\u0631\u064e\u0627\u0631\u064c \u0635\u064e\u0627\u0631\u064e\u062a\u0652 \u0642\u0650\u0628\u0652\u0644\u064e\u0629\u064e \u0627\u0644\u0652\u0640\u0645\u064f\u0647\u0652\u062a\u064e\u062f\u0650\u064a\u0640\u0640\u0646\u064e\u0627<br \/>\n\u062a\u064f\u0640\u0624\u0652\u062e\u064e\u0640\u0630\u064f \u0628\u0650\u0634\u064e\u0631\u0652\u0637\u0650 \u062a\u064e\u0640\u0631\u0652\u0643\u0650 \u0627\u0644\u0652\u063a\u064e\u064a\u0652\u0640\u0631\u0650 \u0635\u0650\u062f\u0652\u0642\u0640\u064b\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e\u0641\u064e\u0640\u0642\u0652\u0640\u0631\u064d \u0644\u0627 \u063a\u064e\u0646\u064e\u0640\u0627\u0621\u064e \u0645\u0650\u0640\u0646\u0652\u0640\u0647\u064f \u064a\u064e\u0643\u0652\u0641\u0650\u064a\u0646\u064e\u0640\u0640\u0640\u0640\u0627<br \/>\n\u0623\u064e\u0635\u0650\u0640\u0640\u0641\u064f \u062d\u064f\u0633\u0652\u0640\u0640\u0640\u0646\u064e\u0647\u064e\u0640\u0627 \u0648\u064e\u0644\u0627 \u0623\u064f\u062c\u064e\u0640\u0644\u0650\u0651\u0640\u064a\u0640\u0640\u0640\u0647\u0650\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u063a\u064e\u064a\u0652\u0640\u0631\u064e\u0629\u064b \u0644\u0627 \u062c\u064e\u0647\u0652\u0644\u0627\u064b \u0644\u0650\u0623\u064e\u0643\u064f\u0648\u0646\u064e \u0623\u064e\u0645\u0650\u064a\u0640\u0646\u0640\u0640\u0640\u0627<br \/>\n\u0627\u064f\u062f\u0652\u0646\u064f \u0645\u0650\u0646\u0650\u0651\u0640\u064a \u0623\u064f\u0644\u064e\u0640\u0642\u0650\u0651\u0646\u0652\u0640\u0643\u064e \u0639\u0650\u0640\u0644\u0652\u0640\u0645\u0627\u064b \u063a\u064e\u0640\u0631\u0650\u064a\u0628\u0640\u0640\u0640\u0627\u064b\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0641\u064e\u0640\u0646\u064e\u0651 \u0639\u0650\u0634\u0652\u0640\u0642\u064d \u0644\u0650\u0640\u0641\u064e\u0640\u0646\u0650\u0651 \u062d\u064f\u0633\u0652\u0640\u0646\u064d \u062b\u064e\u0645\u0650\u064a\u0646\u0640\u064e\u0640\u0640\u0640\u0627<br \/>\n\u062a\u064e\u0640\u0640\u062f\u0652\u062e\u064f\u0640\u0640\u0644\u064f \u0628\u0650\u0640\u0640\u0647\u0650 \u062c\u064e\u0640\u0640\u0646\u064e\u0651\u0640\u0640\u0629\u064b \u0644\u0640\u0650\u0645\u064e\u0640\u0647\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0627\u0629\u064d\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u062a\u064e\u0634\u0652\u0631\u064e\u0628\u064f \u0627\u0644\u0652\u062e\u064e\u0645\u0652\u0631\u064e \u0645\u064e\u0627\u0621\u064b \u0639\u064e\u0640\u0630\u0652\u0628\u0640\u0627\u064b \u0645\u064e\u0639\u0650\u0640\u064a\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0633\u064f\u0640\u0646\u064e\u0651\u0629\u064f \u0627\u0644\u0652\u0640\u0645\u064f\u0635\u0652\u0640\u0637\u064e\u0640\u0641\u064e\u0649 \u0641\u064e\u0640\u0645\u064e\u0627 \u0644\u064e\u0640\u0646\u064e\u0627 \u0639\u064e\u0646\u0652\u0640\u0640\u0640\u0647\u064e\u0627 \u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u063a\u064f\u0640\u0646\u0652\u0640\u064a\u064e\u0640\u0629\u064c \u0648\u064e\u0625\u0650\u0644\u0627\u064e\u0651 \u0636\u064e\u0640\u0644\u0650\u0644\u0652\u0646\u064e\u0627 \u0633\u0650\u0640\u0646\u0650\u064a\u0646\u0640\u0640\u0640\u0640\u0640\u0627<br \/>\n\u0647\u0650\u0640\u064a\u064e \u0623\u064e\u062d\u0652\u0640\u0642\u064e\u0640\u0627\u0628\u064f \u0646\u0650\u0640\u064a\u0640\u0631\u064e\u0627\u0646\u064d \u0648\u064e\u0639\u064e\u0640\u0640\u0640\u0630\u064e\u0627\u0628\u064f\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0647\u064e\u0640\u062c\u0652\u0631\u064d \u0644\u0627\u064e \u0646\u064e\u0640\u0631\u0652\u062a\u064e\u0636\u0650\u064a\u0647\u0650 \u0644\u0650\u0644\u0640\u0652\u0645\u064f\u0633\u0652\u0640\u0644\u0640\u0650\u0645\u0650\u064a\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0627\u064f\u062f\u0652\u0646\u064f \u0645\u0650\u0640\u0646\u0651\u0640\u0650\u064a \u0648\u064e\u063a\u064e\u0640\u0640\u0646\u0650\u0651 \u0644\u0640\u0650\u064a \u064a\u064e\u0640\u0627 \u0623\u064f\u062e\u064e\u0640\u0640\u0640\u064a\u0650\u0651\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0641\u064e\u0623\u064e\u0643\u064f\u0648\u0646\u064e \u0644\u064e\u0647\u064e\u0627 \u0645\u0650\u0640\u0646\u064e \u0627\u0644\u0633\u064e\u0651\u0640\u0627\u0645\u0650\u0639\u0650\u064a\u0640\u0640\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0648\u064e\u0646\u0640\u064e\u062d\u0652\u0640\u0638\u064e\u0649 \u0628\u0640\u0650\u062c\u0640\u064e\u0645\u0652\u0639\u064d \u0648\u064e\u062a\u064e\u0640\u0644\u0652\u0640\u0648\u0650\u064a\u0640\u0646\u0650 \u062d\u064f\u0640\u0640\u0628\u064d\u0651\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0639\u064f\u0634\u0651\u0627\u0642\u0627\u064b \u0644\u064e\u0640\u0647\u064e\u0627 \u0648\u064e\u0623\u064e\u064a\u0652\u0636\u064b\u0640\u0627 \u0645\u064e\u0640\u0639\u0652\u0634\u064f\u0640\u0648\u0642\u0650\u064a\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0628\u064f\u062d\u0652\u062a\u064f \u0628\u0650\u0628\u064e\u0639\u0652\u0636\u0650 \u0648\u064e\u062c\u0652\u0640\u062f\u064d \u0639\u064e\u0633\u064e\u0640\u0627\u064a\u064e \u0623\u064f\u062e\u064e\u0640\u0640\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0641\u0650\u0651\u0641\u064f \u0645\u0650\u0646\u0652 \u062d\u064f\u0631\u0652\u0642\u064e\u0640\u0629\u0650 \u0644\u064e\u0640\u0647\u0650\u064a\u0628\u064d \u062a\u064e\u0643\u0652\u0648\u0650\u064a\u0646\u064e\u0640\u0640\u0640\u0627<br \/>\n\u0641\u064e\u0640\u0640\u0632\u064e\u0627\u062f\u064e \u0627\u0644\u0652\u0640\u0648\u064e\u062c\u0652\u0640\u062f\u064f \u0648\u064e\u062a\u064e\u0640\u0648\u064e\u0627\u0644\u064e\u0640\u0640\u0649 \u0628\u0640\u0650\u0646\u064e\u0640\u0641\u0652\u0640\u0640\u0640\u0640\u062e\u064d\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0641\u0650\u064a \u0639\u064e\u0630\u064e\u0627\u0628\u064d \u0639\u064e\u0630\u0652\u0628\u064d \u0623\u064e\u0633\u0652\u0645\u064e\u0649 \u0623\u064e\u0645\u064e\u0627\u0646\u0650\u064a\u0646\u064e\u0640\u0640\u0627<br \/>\n\u0641\u064e\u0640\u0640\u0644\u0627 \u0623\u064e\u0628\u0652\u0640\u0631\u064e\u0623\u064e \u0645\u0650\u0640\u0646\u064e\u0651\u0640\u0627 \u0627\u0644\u0644\u0647\u064f \u0623\u064e\u062d\u0652\u0640\u0634\u064e\u0640\u0640\u0640\u0640\u0640\u0627\u0621\u064b\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e\u0644\u0627 \u0623\u064e\u0628\u0652\u0640\u0631\u064e\u062f\u064e \u0634\u064e\u0640\u0648\u0652\u0642\u0627\u064b \u0645\u0650\u0646\u064e\u0651\u0640\u0627 \u064a\u064f\u0641\u0652\u0646\u0650\u064a\u0640\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0648\u064e\u0639\u064e\u0640\u0644\u0640\u064e\u0649 \u0645\u064e\u0640\u0631\u0650\u0651 \u0627\u0644\u0640\u062f\u064e\u0651\u0647\u0652\u0640\u0631\u0650 \u0623\u064e\u0633\u0652\u0640\u0647\u064e\u0640\u0631\u064e \u062c\u064e\u0640\u0641\u0652\u0640\u0646\u0650\u0640\u064a\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u064a\u064e\u0640\u0631\u0652\u0639\u064e\u0640\u0649 \u0637\u064e\u0640\u064a\u0652\u0641\u064e\u0640\u0647\u064e\u0627 \u062e\u064e\u0627\u0641\u0650\u0640\u064a\u0627\u064b \u0648\u064e\