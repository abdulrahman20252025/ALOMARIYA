{"id":12086,"date":"2014-12-31T04:31:29","date_gmt":"2014-12-31T04:31:29","guid":{"rendered":"http:\/\/alomariya.test\/%d8%aa%d9%88%d8%b6%d9%8a%d8%ad-%d9%84%d8%a7-%d8%a8%d8%af-%d9%85%d9%86%d9%87\/"},"modified":"2014-12-31T04:31:29","modified_gmt":"2014-12-31T04:31:29","slug":"%d8%aa%d9%88%d8%b6%d9%8a%d8%ad-%d9%84%d8%a7-%d8%a8%d8%af-%d9%85%d9%86%d9%87","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d8%aa%d9%88%d8%b6%d9%8a%d8%ad-%d9%84%d8%a7-%d8%a8%d8%af-%d9%85%d9%86%d9%87\/","title":{"rendered":"\u062a\u0648\u0636\u064a\u062d \u0644\u0627 \u0628\u062f \u0645\u0646\u0647"},"content":{"rendered":"<p>&nbsp; &nbsp; &nbsp;&nbsp; \u0625\u0646 \u0627\u0644\u0648\u0642\u0627\u0626\u0639 \u0627\u0644\u062a\u064a \u062a\u0645\u0631 \u0628\u0647\u0627 \u0637\u0631\u064a\u0642\u062a\u0646\u0627\u060c \u062a\u0633\u062a\u062f\u0639\u064a \u0645\u0646\u0627 \u0623\u0646 \u0646\u0648\u0636\u062d \u0623\u0645\u0648\u0631\u0627\u060c \u0635\u0627\u0631 \u0644\u0627 \u0628\u062f \u0645\u0646 \u062a\u0648\u0636\u064a\u062d\u0647\u0627\u061b \u062e\u0635\u0648\u0635\u0627 \u0628\u0639\u062f \u062f\u062e\u0648\u0644\u0646\u0627 -\u0645\u0636\u0637\u0631\u064a\u0646- \u0641\u064a \u0627\u0639\u062a\u0635\u0627\u0645 \u0645\u0641\u062a\u0648\u062d\u060c \u0645\u0646\u0630 8 \u062f\u064a\u0633\u0645\u0628\u0631 2014\u060c \u0648\u0625\u0644\u0649 \u062d\u064a\u0646 \u0643\u062a\u0627\u0628\u0629 \u0647\u0630\u0647 \u0627\u0644\u0633\u0637\u0648\u0631.<br \/>&nbsp;<br \/><span style=\"color:#ff0000\">1.<\/span> \u0646\u062d\u0646 \u0637\u0631\u064a\u0642\u0629 \u0635\u0648\u0641\u064a\u0629 (\u062c\u0645\u0627\u0639\u0629 \u062f\u064a\u0646\u064a\u0629)\u060c \u0648\u0644\u0633\u0646\u0627 \u0647\u064a\u0626\u0629 \u0633\u064a\u0627\u0633\u064a\u0629. \u0648\u0647\u0630\u0627 \u064a\u0639\u0646\u064a \u0623\u0646\u0646\u0627 \u0644\u0627 \u0646\u0639\u0645\u0644 \u0644\u0627\u0633\u062a\u0642\u0637\u0627\u0628 \u0627\u0644\u0646\u0627\u0633 \u0645\u0646 \u0623\u062c\u0644 \u063a\u0631\u0636 \u0633\u064a\u0627\u0633\u064a \u064a\u062a\u0639\u0644\u0642 \u0628\u0627\u0644\u062d\u0643\u0645\u060c \u0623\u0648 \u0628\u062a\u062d\u0635\u064a\u0644 \u062f\u0646\u064a\u0627 \u0639\u0627\u062c\u0644\u0629. \u0644\u0643\u0646\u0646\u0627 \u0646\u0644\u0627\u062d\u0638 \u0623\u0646 \u0623\u062c\u0647\u0632\u0629 \u0627\u0644\u062f\u0648\u0644\u0629 \u0627\u0644\u062a\u064a \u062a\u0639\u0627\u0645\u0644\u0646\u0627\u060c \u0643\u0623\u0646\u0647\u0627 \u062a\u0631\u064a\u062f \u0623\u0646 \u062a\u062f\u0641\u0639\u0646\u0627 \u0625\u0644\u0649 \u0623\u0646 \u0646\u0635\u064a\u0631 \u0645\u0639\u0627\u0631\u0636\u064a\u0646 \u0644\u0644\u0646\u0638\u0627\u0645 \u0639\u0645\u0648\u0645\u0627\u060c \u0648\u0644\u0634\u062e\u0635 \u0627\u0644\u0645\u0644\u0643 \u062e\u0635\u0648\u0635\u0627\u060c \u0628\u0645\u062e\u062a\u0644\u0641 \u0645\u0639\u0627\u0645\u0644\u0627\u062a\u0647\u0627\u061b \u0648\u0643\u0623\u0646 \u0647\u0630\u0627 \u064a\u0631\u064a\u062d\u0647\u0627 \u0644\u0633\u0628\u0628 \u0646\u062c\u0647\u0644\u0647\u060c \u0623\u0648 \u064a\u062e\u062f\u0645 \u0623\u063a\u0631\u0627\u0636\u0627 \u0644\u062c\u0647\u0627\u062a \u062a\u062a\u062e\u0641\u0649 \u062e\u0644\u0641\u0647\u0627. \u0648\u0646\u062d\u0646 \u0625\u0632\u0627\u0621 \u0647\u0630\u0627 \u0627\u0644\u0648\u0636\u0639 \u0627\u0644\u0645\u0644\u062a\u0628\u0633\u060c \u0646\u0639\u0644\u0646 \u0623\u0646\u0646\u0627 \u0644\u0646 \u0646\u0643\u0648\u0646 \u0645\u0639\u0627\u0631\u0636\u064a\u0646 \u0644\u0644\u0645\u0644\u0643 \u0623\u0628\u062f\u0627\u061b \u0648\u0625\u0646 \u0641\u064f\u0639\u0644 \u0628\u0646\u0627 \u0623\u0643\u062b\u0631 \u0645\u0645\u0627 \u0641\u064f\u0639\u0644 \u0645\u0646 \u0642\u0628\u0644. \u0647\u0630\u0627\u060c \u0644\u0623\u0646\u0646\u0627 \u0645\u0646\u0637\u0644\u0642\u0648\u0646 \u0641\u064a \u0645\u0648\u0627\u0642\u0641\u0646\u0627 \u0645\u0646 \u0627\u0644\u0634\u0631\u0639 \u0627\u0644\u062d\u0643\u064a\u0645\u060c \u0627\u0644\u0630\u064a \u0646\u064f\u062f\u0631\u0643 \u0645\u0646\u0647 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0645\u0633\u0623\u0644\u0629 -\u0628\u062d\u0645\u062f \u0627\u0644\u0644\u0647- \u0645\u0627 \u0644\u0627 \u064a\u064f\u062f\u0631\u0643\u0647 \u063a\u064a\u0631\u0646\u0627\u060c \u0645\u0646 \u0627\u0644\u0645\u0648\u0627\u0644\u064a\u0646 \u0644\u0644\u062d\u0643\u0645 \u0623\u0648 \u0645\u0646 \u0627\u0644\u0645\u0639\u0627\u0631\u0636\u064a\u0646.<br \/>&nbsp;<br \/><span style=\"color:#ff0000\">2.<\/span> \u0625\u0646 \u0631\u0641\u0636\u0646\u0627 \u0627\u0644\u0627\u0646\u062e\u0631\u0627\u0637 \u0641\u064a \u0645\u0627\u0643\u064a\u0646\u0629 \u0627\u0644\u0641\u0633\u0627\u062f\u060c \u0628\u062d\u0643\u0645 \u062a\u0648\u062c\u0647\u0646\u0627 \u0627\u0644\u062f\u064a\u0646\u064a\u060c \u0648\u0627\u0639\u062a\u0632\u0627\u0644\u0646\u0627 \u062c\u0644 \u0627\u0644\u0623\u0646\u0634\u0637\u0629 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u0645\u062f\u0629 \u0637\u0648\u064a\u0644\u0629 (\u0647\u0643\u0630\u0627 \u0647\u0648 \u0627\u0644\u062a\u0635\u0648\u0641)\u060c \u062c\u0639\u0644 \u0623\u0631\u0643\u0627\u0646 \u0627\u0644\u0641\u0633\u0627\u062f \u0627\u0644\u0625\u0642\u0644\u064a\u0645\u064a \u0627\u0644\u0645\u062a\u0645\u062b\u0644 \u0641\u064a \u0628\u0639\u0636\u064d \u0645\u0646 \u0631\u062c\u0627\u0644 \u0627\u0644\u0633\u0644\u0637\u0629 \u0648\u0628\u0639\u0636\u064d \u0645\u0646 \u0627\u0644\u0645\u062a\u0646\u0641\u0630\u064a\u0646 \u0627\u0644\u0645\u062d\u0644\u064a\u064a\u0646\u060c \u064a\u0635\u0646\u0641\u0648\u0646\u0646\u0627 \u0636\u0645\u0646 \u0623\u0639\u062f\u0627\u0626\u0647\u0645 \u0627\u0644\u0645\u0633\u062a\u0647\u062f\u0641\u064a\u0646. \u0648\u0628\u0645\u0627 \u0623\u0646\u0646\u0627 \u0646\u0642\u0637\u0646 \u0645\u062f\u064a\u0646\u0629 \u0635\u063a\u064a\u0631\u0629 \u0641\u064a \u0623\u0637\u0631\u0627\u0641 \u0627\u0644\u0645\u063a\u0631\u0628\u060c \u0641\u0625\u0646 \u0627\u0644\u0633\u0644\u0637\u0629 \u0627\u0644\u0639\u0627\u0645\u0644\u0629 \u0647\u0646\u0627\u060c \u0623\u0643\u062b\u0631 \u062d\u0631\u064a\u0629 \u0645\u0646 \u062a\u0644\u0643 \u0627\u0644\u062a\u064a \u0641\u064a \u0627\u0644\u0645\u0631\u0627\u0643\u0632 \u0627\u0644\u0639\u0645\u0631\u0627\u0646\u064a\u0629 \u0627\u0644\u0643\u0628\u064a\u0631\u0629\u061b \u0641\u0647\u064a \u062a\u0639\u0645\u0644 \u0628\u0627\u0633\u0645 \u0627\u0644\u0645\u0644\u0643 \u0641\u064a \u0627\u0644\u0638\u0627\u0647\u0631\u060c \u0648\u062a\u0631\u062a\u0643\u0628 \u0641\u064a \u0627\u0644\u0622\u0646 \u0646\u0641\u0633\u0647\u060c \u0645\u0627 \u0644\u0627 \u064a\u064f\u0645\u0643\u0646 \u0625\u0644\u0627 \u0623\u0646 \u064a\u062b\u064a\u0631 \u0631\u064a\u0628\u0629 \u0643\u0644 \u0630\u064a \u063a\u064a\u0631\u0629 \u0635\u0627\u062f\u0642\u0629. \u0648\u0646\u062d\u0646 \u0646\u0639\u064a \u062a\u0645\u0627\u0645 \u0627\u0644\u0648\u0639\u064a \u0627\u0644\u0641\u0631\u0642 \u0628\u064a\u0646 \u0647\u0630\u0647 \u0627\u0644\u0645\u062e\u0627\u0644\u0641\u0627\u062a\u060c \u0648\u0628\u064a\u0646 \u062a\u0648\u062c\u064a\u0647\u0627\u062a \u0627\u0644\u0645\u0644\u0643 \u0648\u0645\u0648\u0627\u0642\u0641\u0647. \u0648\u0645\u0646 \u0647\u0630\u0627 \u0627\u0644\u0645\u0646\u0637\u0644\u0642\u060c \u0641\u0625\u0646\u0646\u0627 \u0646\u0639\u0644\u0646 \u0645\u0648\u0627\u0641\u0642\u062a\u0646\u0627 \u0644\u0645\u0644\u0643 \u0627\u0644\u0628\u0644\u0627\u062f \u062c\u0645\u0644\u0629 \u0648\u062a\u0641\u0635\u064a\u0644\u0627\u061b \u0643\u0645\u0627 \u0646\u0639\u0644\u0646 \u0641\u064a \u0627\u0644\u0622\u0646 \u0646\u0641\u0633\u0647 \u0631\u0641\u0636\u0646\u0627 \u0644\u0644\u0641\u0633\u0627\u062f \u0628\u062c\u0645\u064a\u0639 \u0623\u0646\u0648\u0627\u0639\u0647.<br \/>&nbsp;<br \/><span style=\"color:#ff0000\">3. <\/span>\u0648\u0628\u0645\u0627 \u0623\u0646\u0646\u0627 \u0644\u0627 \u0646\u0639\u0645\u0644 \u0639\u0645\u0644\u0627 \u0633\u064a\u0627\u0633\u064a\u0627 \u0645\u0628\u0627\u0634\u0631\u0627\u060c \u0648\u0644\u0633\u0646\u0627 \u0647\u064a\u0626\u0629 \u0644\u0644\u0623\u0645\u0631 \u0628\u0627\u0644\u0645\u0639\u0631\u0648\u0641 \u0648\u0627\u0644\u0646\u0647\u064a \u0639\u0646 \u0627\u0644\u0645\u0646\u0643\u0631\u061b \u0628\u0644 \u0639\u0644\u0649 \u0627\u0644\u0639\u0643\u0633 \u0645\u0646 \u0647\u0630\u0627\u060c \u0646\u062d\u0646 \u0646\u0639\u0645\u0644 \u0641\u064a \u0645\u062c\u0627\u0644 \u0627\u0644\u0625\u0635\u0644\u0627\u062d \u0627\u0644\u0641\u0631\u062f\u064a\u061b \u0641\u0625\u0646\u0646\u0627 \u0644\u0645 \u0646\u0647\u0627\u062c\u0645 \u0627\u0644\u0641\u0633\u0627\u062f \u0641\u064a \u0625\u0642\u0644\u064a\u0645\u0646\u0627\u060c \u0648\u0644\u0627 \u062d\u0627\u0631\u0628\u0646\u0627\u0647 \u0641\u064a \u0642\u0644\u0627\u0639\u0647\u061b \u0648\u0625\u0646\u0645\u0627 \u0647\u0648 \u0645\u0646 \u0644\u0645 \u064a\u064f\u0637\u0642 \u062a\u0648\u0627\u062c\u062f\u0646\u0627 \u0645\u0639\u0647 \u0641\u064a \u0627\u0644\u062d\u064a\u0651\u0632 \u0627\u0644\u062c\u063a\u0631\u0627\u0641\u064a \u0646\u0641\u0633\u0647. \u0648\u0647\u0630\u0627 \u0625\u0646 \u062f\u0644 \u0639\u0644\u0649 \u0634\u064a\u0621\u060c \u0641\u0625\u0646\u0645\u0627 \u064a\u062f\u0644 \u0639\u0644\u0649 \u0627\u0633\u062a\u0641\u062d\u0627\u0644 \u0627\u0644\u0641\u0633\u0627\u062f\u060c \u0648\u0645\u062d\u0627\u0648\u0644\u062a\u0647 \u0627\u0633\u062a\u062e\u0644\u0627\u0635 \u0627\u0644\u0628\u0644\u0627\u062f \u0644\u0646\u0641\u0633\u0647\u060c \u062d\u0627\u0644\u0627 \u0628\u0647\u0630\u0627 \u0627\u0644\u0641\u0639\u0644 \u0645\u062d\u0644 \u0627\u0644\u062f\u0648\u0644\u0629. \u0648\u0646\u062d\u0646 \u0646\u0639\u064f\u062f\u0651 \u0647\u0630\u0627 \u0627\u0644\u0639\u0645\u0644 \u062e\u064a\u0627\u0646\u0629 \u0644\u0644\u0647 \u0648\u0631\u0633\u0648\u0644\u0647 \u0648\u0644\u0644\u0645\u0624\u0645\u0646\u064a\u0646\u060c \u0648\u062e\u064a\u0627\u0646\u0629 \u0644\u0644\u0645\u0644\u0643 \u0648\u0644\u0644\u0648\u0637\u0646\u061b \u0644\u0623\u0646 \u0627\u0644\u0641\u0627\u0633\u062f\u064a\u0646 \u0639\u0644\u0649 \u0645\u0631 \u0627\u0644\u0632\u0645\u0627\u0646\u060c \u0645\u0627 \u0643\u0627\u0646 \u0644\u0647\u0645 \u0639\u0647\u062f \u0648\u0644\u0627 \u0630\u0645\u0629.<br \/>&nbsp;<br \/><span style=\"color:#ff0000\">4.<\/span> \u0644\u0642\u062f \u0635\u0631\u0646\u0627 \u0646\u0639\u0644\u0645\u060c \u0648\u0646\u062a\u0641\u0647\u0645 \u0639\u0646 \u062a\u062c\u0631\u0628\u0629\u060c \u0643\u064a\u0641 \u062a\u064f\u0635\u0646\u0639 \u0628\u0639\u0636 \u0627\u0644\u0645\u0639\u0627\u0631\u0636\u0627\u062a \u0645\u0646 \u0627\u0644\u064a\u0633\u0627\u0631\u064a\u064a\u0646 \u0648\u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a\u064a\u0646\u060c \u0627\u0644\u0630\u064a\u0646 \u062a\u064f\u0644\u062c\u0626\u0647\u0645 \u0645\u0639\u0627\u0645\u0644\u0629 \u0623\u062c\u0647\u0632\u0629 \u0627\u0644\u062f\u0648\u0644\u0629 \u0627\u0644\u062e\u0627\u0637\u0626\u0629\u060c \u0625\u0644\u0649 \u0645\u0639\u0627\u0631\u0636\u0629 \u0634\u0627\u0645\u0644\u0629 \u0644\u0644\u062d\u0643\u0645. \u0646\u0639\u0646\u064a \u0645\u0646 \u0647\u0630\u0627\u060c \u0623\u0646 \u0633\u0648\u0621 \u0627\u0644\u062a\u062f\u0628\u064a\u0631 \u0627\u0644\u0631\u0633\u0645\u064a\u060c \u064a\u0635\u064a\u0631 \u0639\u0648\u0646\u0627 \u0644\u0642\u0635\u0648\u0631 \u0627\u0644\u0625\u062f\u0631\u0627\u0643 \u0644\u062f\u0649 \u0627\u0644\u0645\u0636\u0637\u0647\u064e\u062f\u064a\u0646\u060c \u0641\u064a\u0646\u062a\u062c \u0639\u0646\u0647\u0645\u0627 \u0648\u0636\u0639 \u0627\u0633\u062a\u062b\u0646\u0627\u0626\u064a \u0642\u062f \u064a\u0633\u062a\u0645\u0631 \u0644\u0639\u0642\u0648\u062f\u061b \u064a\u064f\u062e\u0633\u0631 \u0627\u0644\u0628\u0644\u0627\u062f \u0643\u062b\u064a\u0631\u0627 \u0645\u0646 \u0637\u0627\u0642\u062a\u0647\u0627 \u0648\u0648\u0642\u062a\u0647\u0627. \u0648\u0646\u062d\u0646 -\u0628\u062d\u0645\u062f \u0627\u0644\u0644\u0647- \u0646\u0639\u0644\u0645 \u0645\u0627 \u064a\u064f\u0628\u064a\u064e\u0651\u062a \u0644\u0646\u0627 \u0648\u0644\u0639\u0645\u0648\u0645 \u0627\u0644\u0634\u0639\u0628\u061b \u0648\u0644\u0647\u0630\u0627\u060c \u0641\u0644\u0646 \u064a\u0632\u064a\u062f\u0646\u0627 \u0633\u0648\u0621 \u0627\u0644\u0645\u0639\u0627\u0645\u0644\u0629 \u0627\u0644\u0630\u064a \u0646\u0639\u0627\u0646\u064a \u0645\u0646\u0647\u060c \u0625\u0644\u0627 \u062b\u0628\u0627\u062a\u0627 \u0639\u0644\u0649 \u0645\u0648\u0642\u0641\u0646\u0627\u060c \u0648\u0625\u0635\u0631\u0627\u0631\u0627 \u0645\u062a\u0632\u0627\u064a\u062f\u0627 \u0645\u0639 \u0627\u0644\u0623\u0648\u0642\u0627\u062a.<br \/>&nbsp;<br \/><span style=\"color:#ff0000\">5.<\/span> \u0625\u0646 \u0627\u0644\u0645\u063a\u0631\u0628 \u0641\u064a \u0645\u062d\u064a\u0637\u0647 \u0627\u0644\u0625\u0642\u0644\u064a\u0645\u064a\u060c \u0644\u0627 \u0632\u0627\u0644\u062a \u062a\u062a\u0647\u062f\u062f\u0647 \u0645\u062e\u0627\u0637\u0631 \u0645\u0646 \u0645\u062b\u0644 \u062a\u0644\u0643 \u0627\u0644\u062a\u064a \u0623\u0635\u0627\u0628\u062a \u062f\u0648\u0644\u0627 \u0639\u0631\u0628\u064a\u0629 \u0634\u0642\u064a\u0642\u0629\u060c \u062f\u062e\u0644\u062a \u0645\u0639\u0647\u0627 \u0647\u0630\u0647 \u0627\u0644\u0623\u062e\u064a\u0631\u0629 \u0641\u064a \u0641\u0648\u0636\u0649 \u0645\u062c\u0647\u0648\u0644\u0629 \u0627\u0644\u0639\u0648\u0627\u0642\u0628. \u0648\u0639\u0644\u064a\u0647\u060c \u0641\u0625\u0646\u0646\u0627 \u0646\u0639\u062a\u0628\u0631 \u0623\u0646 \u0623\u064a \u0645\u062e\u0627\u0644\u0641\u0629 \u0644\u0644\u0645\u0644\u0643\u060c \u0648\u0623\u064a \u0639\u0645\u0644 \u0633\u064a\u0627\u0633\u064a \u062c\u0627\u0646\u0628\u064a \u0634\u0627\u0630\u060c \u0633\u064a\u0643\u0648\u0646\u0627\u0646 \u0639\u0645\u0644\u0627 \u0625\u062c\u0631\u0627\u0645\u064a\u0627\u060c \u064a\u0639\u0631\u0651\u0636 \u0627\u0644\u0648\u0637\u0646 \u0644\u0644\u062e\u0637\u0631 \u0627\u0644\u062c\u0633\u064a\u0645. \u0648\u0625\u0646 \u062d\u0631\u064a\u0629 \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u0633\u064a\u0627\u0633\u064a \u0641\u064a \u0627\u0644\u0645\u063a\u0631\u0628\u060c \u064a\u0646\u0628\u063a\u064a \u0623\u0646 \u0644\u0627 \u062a\u0643\u0648\u0646 \u0645\u0637\u064a\u0629 \u0644\u0644\u0645\u063a\u0631\u0636\u064a\u0646\u060c \u062d\u062a\u0649 \u064a\u062d\u0642\u0642\u0648\u0627 \u0645\u0622\u0631\u0628 \u0627\u0644\u0623\u0639\u062f\u0627\u0621 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u064a\u0646 \u0648\u0645\u0648\u0627\u0644\u064a\u0647\u0645 \u0645\u0646 \u0627\u0644\u062f\u0627\u062e\u0644. \u0648\u0648\u062d\u062f\u0629 \u0627\u0644\u063a\u0627\u064a\u0629 \u0648\u0627\u0644\u0639\u0645\u0644\u060c \u0625\u0646 \u0643\u0627\u0646\u062a \u0645\u0633\u062a\u062d\u0628\u0629 \u0641\u064a\u0645\u0627 \u0633\u0628\u0642 \u0645\u0646 \u0627\u0644\u0632\u0645\u0627\u0646\u060c \u0641\u0647\u064a \u0623\u064f\u0648\u0644\u0649 \u0627\u0644\u0623\u0648\u0644\u0648\u064a\u0627\u062a \u0627\u0644\u064a\u0648\u0645. \u0630\u0644\u0643 \u0644\u0623\u0646\u0646\u0627 \u0646\u0631\u064a\u062f \u0644\u0628\u0644\u062f\u0646\u0627 \u0623\u0646 \u064a\u0639\u0628\u0631 \u0647\u0630\u0647 \u0627\u0644\u0645\u0631\u062d\u0644\u0629 \u0627\u0644\u0635\u0639\u0628\u0629 \u0628\u0623\u0642\u0644 \u0627\u0644\u0623\u0636\u0631\u0627\u0631. \u0648\u0641\u064a \u0633\u0628\u064a\u0644 \u062a\u062d\u0642\u064a\u0642 \u0647\u0630\u0647 \u0627\u0644\u063a\u0627\u064a\u0629\u060c \u0644\u0627 \u0628\u062f \u0644\u0646\u0627 \u062c\u0645\u064a\u0639\u0627\u060c \u0623\u0646 \u0646\u062a\u0646\u0627\u0632\u0644 \u0639\u0646 \u0643\u062b\u064a\u0631 \u0645\u0646 \u0645\u0637\u0627\u0644\u0628\u0646\u0627 \u0627\u0644\u0641\u0631\u062f\u064a\u0629 \u0623\u0648 \u0627\u0644\u0641\u0626\u0648\u064a\u0629 \u0648\u0627\u0644\u062c\u0645\u0627\u0639\u064a\u0629.<br \/>&nbsp;<br \/><span style=\"color:#ff0000\">6.<\/span> \u0646\u0631\u064a\u062f \u0645\u0646 \u0627\u0644\u0634\u0639\u0628 \u0627\u0644\u0645\u063a\u0631\u0628\u064a \u0627\u0644\u064a\u0642\u0638\u060c \u0648\u0627\u0644\u0630\u064a \u0641\u0648\u0651\u062a \u0639\u0644\u0649 \u0627\u0644\u0623\u0639\u062f\u0627\u0621 \u0641\u0631\u0635\u0627 \u0643\u062b\u064a\u0631\u0629 \u0639\u0628\u0631 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u060c \u0623\u0646 \u064a\u0648\u0627\u0635\u0644 \u062a\u0645\u0633\u0643\u0647 \u0628\u0634\u062e\u0635 \u0627\u0644\u0645\u0644\u0643\u060c \u0648\u0623\u0646 \u064a\u0643\u0648\u0646 \u0639\u0644\u0649 \u062b\u0642\u0629 \u0648\u064a\u0642\u064a\u0646\u060c \u0623\u0646\u0647 \u0639\u0644\u0649 \u0627\u0644\u062e\u064a\u0627\u0631 \u0627\u0644\u0635\u0627\u0626\u0628\u061b \u0648\u0623\u0646 \u0644\u0627 \u064a\u0646\u0633\u0627\u0642 \u0625\u0644\u0649 \u0645\u0627 \u064a\u0631\u064a\u062f\u0647 \u0631\u0639\u0627\u0629 \u0627\u0644\u0641\u0633\u0627\u062f \u0645\u0646 \u0646\u062a\u0627\u0626\u062c\u061b \u0648\u0644\u064a\u0635\u0628\u0631 \u0639\u0644\u0649 \u0645\u0627 \u064a\u0635\u064a\u0628\u0647 \u0648\u064a\u062d\u062a\u0633\u0628\u061b \u0641\u0625\u0646 \u0627\u0644\u0635\u0628\u0631 \u0639\u0644\u0649 \u0627\u0644\u0634\u062f\u0627\u0626\u062f \u0623\u0647\u0648\u0646 \u0645\u0646 \u0639\u0627\u0631 \u0627\u0644\u062e\u064a\u0627\u0646\u0629.<br \/>&nbsp;<br \/><span style=\"color:#ff0000\">7. <\/span>\u0646\u062d\u0646 \u062c\u0627\u0632\u0645\u0648\u0646 \u0623\u0646 \u0627\u0644\u0645\u063a\u0631\u0628 \u0644\u062f\u064a\u0647 \u0645\u0646 \u0627\u0644\u0645\u0624\u0647\u0644\u0627\u062a \u0645\u0627 \u064a\u062c\u0639\u0644\u0647 \u062d\u0642\u064a\u0642\u0629 \u0627\u0633\u062a\u062b\u0646\u0627\u0621\u060c \u064a\u0641\u0631\u0636 \u062e\u064a\u0627\u0631\u0627\u062a\u0647 \u0641\u064a \u0627\u0644\u0645\u062d\u0627\u0641\u0644 \u0627\u0644\u062f\u0648\u0644\u064a\u0629 \u0648\u0627\u0644\u0625\u0642\u0644\u064a\u0645\u064a\u0629 \u0628\u062c\u062f\u0627\u0631\u0629.<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u062d\u0641\u0638 \u0627\u0644\u0644\u0647 \u0645\u0644\u0643 \u0627\u0644\u0628\u0644\u0627\u062f\u060c \u0648\u062d\u0641\u0638 \u0627\u0644\u0645\u063a\u0627\u0631\u0628\u0629 \u0623\u062c\u0645\u0639\u064a\u0646 \u0645\u0646 \u0643\u0644 \u0633\u0648\u0621\u061b \u0648\u0641\u0631\u062c \u0639\u0646 \u0623\u0647\u0644\u0646\u0627 \u0641\u064a \u0633\u0627\u0626\u0631 \u0628\u0644\u0627\u062f \u0627\u0644\u0639\u0631\u0628 \u0648\u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646.<br \/>&nbsp;<br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<br \/>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;<u> \u0639\u0628\u062f \u0627\u0644\u063a\u0646\u064a \u0627\u0644\u0639\u0645\u0631\u064a \u0627\u0644\u0642\u0627\u0633\u0645\u064a \u0627\u0644\u0625\u062f\u0631\u064a\u0633\u064a \u0627\u0644\u062d\u0633\u0646\u064a<\/u><br \/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u0641\u064a 10 \u0631\u0628\u064a\u0639 \u0627\u0644\u0623\u0648\u0644 1436 \u0627\u0644\u0645\u0648\u0627\u0641\