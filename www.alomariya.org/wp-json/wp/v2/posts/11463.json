{"id":11463,"date":"2021-06-20T18:38:26","date_gmt":"2021-06-20T18:38:26","guid":{"rendered":"http:\/\/alomariya.test\/%d8%a7%d9%84%d8%a3%d8%b2%d9%85%d8%a9-%d8%a8%d9%8a%d9%86-%d8%a7%d9%84%d9%85%d8%ba%d8%b1%d8%a8-%d9%88%d8%a5%d8%b3%d8%a8%d8%a7%d9%86%d9%8a%d8%a7-%d9%88%d8%a2%d9%81%d8%a7%d9%82%d9%87%d8%a7\/"},"modified":"2021-06-20T18:38:26","modified_gmt":"2021-06-20T18:38:26","slug":"%d8%a7%d9%84%d8%a3%d8%b2%d9%85%d8%a9-%d8%a8%d9%8a%d9%86-%d8%a7%d9%84%d9%85%d8%ba%d8%b1%d8%a8-%d9%88%d8%a5%d8%b3%d8%a8%d8%a7%d9%86%d9%8a%d8%a7-%d9%88%d8%a2%d9%81%d8%a7%d9%82%d9%87%d8%a7","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d8%a7%d9%84%d8%a3%d8%b2%d9%85%d8%a9-%d8%a8%d9%8a%d9%86-%d8%a7%d9%84%d9%85%d8%ba%d8%b1%d8%a8-%d9%88%d8%a5%d8%b3%d8%a8%d8%a7%d9%86%d9%8a%d8%a7-%d9%88%d8%a2%d9%81%d8%a7%d9%82%d9%87%d8%a7\/","title":{"rendered":"\u0627\u0644\u0623\u0632\u0645\u0629 \u0628\u064a\u0646 \u0627\u0644\u0645\u063a\u0631\u0628 \u0648\u0625\u0633\u0628\u0627\u0646\u064a\u0627 \u0648\u0622\u0641\u0627\u0642\u0647\u0627"},"content":{"rendered":"<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0644\u0642\u062f \u0627\u0637\u0644\u0639 \u0627\u0644\u0646\u0627\u0633 \u0639\u0644\u0649 \u0627\u0644\u0623\u0632\u0645\u0629 \u0627\u0644\u062a\u064a \u0639\u0631\u0641\u062a\u0647\u0627 \u0627\u0644\u0639\u0644\u0627\u0642\u0627\u062a \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u0629 \u0627\u0644\u0625\u0633\u0628\u0627\u0646\u064a\u0629\u060c \u0628\u0633\u0628\u0628 \u062f\u062e\u0648\u0644 \u0631\u0626\u064a\u0633 \u0627\u0644\u0628\u0648\u0644\u064a\u0633\u0627\u0631\u064a\u0648 \u0625\u0644\u0649 \u0627\u0644\u0623\u0631\u0636 \u0627\u0644\u0625\u0633\u0628\u0627\u0646\u064a\u0629 \u0628\u0647\u0648\u064a\u0629 \u0645\u0632\u0648\u0631\u0629. \u0648\u0645\u0627 \u0644\u0645 \u0646\u0641\u0647\u0645\u0647\u060c \u0647\u0648 \u0645\u0633\u0627\u0631\u0639\u0629 \u0628\u0639\u0636 \u0627\u0644\u0645\u0639\u0627\u0631\u0636\u064a\u0646\u060c \u0648\u0623\u0634\u0628\u0627\u0647 \u0627\u0644\u0645\u0639\u0627\u0631\u0636\u064a\u0646 \u0644\u0644\u0646\u0638\u0627\u0645 \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u060c \u0625\u0644\u0649 \u0627\u0644\u062d\u0637 \u0645\u0646 \u0642\u062f\u0631\u0629 \u0627\u0644\u0645\u063a\u0631\u0628 \u0639\u0644\u0649 \u0627\u0644\u0645\u0648\u0627\u062c\u0647\u0629\u060c \u0648\u0643\u0623\u0646\u0647 \u0644\u064a\u0633 \u062f\u0648\u0644\u0629!... \u0648\u0647\u0630\u0627 \u0627\u0644\u0623\u0645\u0631 \u0625\u0646 \u0643\u0627\u0646 \u064a\u0646\u0628\u0626 \u0639\u0646 \u0634\u064a\u0621\u060c \u0641\u0647\u0648 \u064a\u0646\u0628\u0626 \u0639\u0646 \u0645\u0631\u0636 \u0646\u0641\u0633\u064a \u064a\u064f\u0635\u064a\u0628 \u0627\u0644\u0645\u0639\u0627\u0631\u0636\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u064a\u062f\u062e\u0644\u0648\u0646 \u0641\u064a \u0627\u0644\u0645\u0639\u0627\u0631\u0636\u0629\u060c \u0648\u0647\u0645 \u0644\u0627 \u064a\u0645\u064a\u0651\u0632\u0648\u0646 \u0628\u064a\u0646 \u0645\u0627 \u0647\u0648 \u0634\u062e\u0635\u064a \u0644\u062f\u064a\u0647\u0645\u060c \u0648\u0645\u0627 \u064a\u0646\u0628\u063a\u064a \u0623\u0646 \u064a\u0643\u0648\u0646 \u0648\u0637\u0646\u064a\u0627 \u0639\u0631\u0628\u064a\u0627 \u0625\u0633\u0644\u0627\u0645\u064a\u0627!...<\/p>\n<p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\u0646\u0639\u0645\u060c \u0646\u062d\u0646 \u0644\u0627 \u0646\u0646\u0632\u0647 \u0627\u0644\u062f\u0648\u0644\u0629 \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u0629 \u0639\u0646 \u0627\u0631\u062a\u0643\u0627\u0628 \u0628\u0639\u0636 \u0627\u0644\u0623\u062e\u0637\u0627\u0621\u060c \u0628\u0633\u0628\u0628 \u0636\u0639\u0641 \u0628\u0639\u0636 \u0627\u0644\u0633\u0627\u0647\u0631\u064a\u0646 \u0639\u0644\u0649 \u0627\u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u062f\u064a\u0628\u0644\u0648\u0645\u0627\u0633\u064a\u061b \u0648\u0644\u0643\u0646 \u0625\u0633\u0628\u0627\u0646\u064a\u0627 \u0623\u064a\u0636\u0627\u060c \u0644\u0645 \u064a\u062e\u0644 \u0639\u0645\u0644\u0647\u0627 \u0645\u0646 \u0623\u062e\u0637\u0627\u0621 \u0645\u062a\u0633\u0644\u0633\u0644\u0629. \u0641\u0644\u0645\u0627\u0630\u0627 \u0639\u0642\u062f\u0629 \u0627\u0644\u0646\u0642\u0635 \u0647\u0630\u0647 \u0623\u0645\u0627\u0645 \u0627\u0644\u0628\u0644\u062f\u0627\u0646 \u0627\u0644\u0623\u0648\u0631\u0648\u0628\u064a\u0629\u061f!...<\/p>\n<p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\u0648\u0645\u0646 \u0623\u062e\u0637\u0627\u0621 \u0625\u0633\u0628\u0627\u0646\u064a\u0627\u060c \u0625\u0642\u062d\u0627\u0645\u0647\u0627 \u0644\u0644\u0628\u0631\u0644\u0645\u0627\u0646 \u0627\u0644\u0623\u0648\u0631\u0648\u0628\u064a \u0641\u064a \u0627\u0644\u0623\u0632\u0645\u0629\u060c \u0648\u0627\u0633\u062a\u0635\u062f\u0627\u0631 \u0642\u0631\u0627\u0631 \u0645\u0646\u0647 \u0636\u062f \u0627\u0644\u0645\u063a\u0631\u0628. \u0648\u0647\u0630\u0627 \u064a\u062c\u0639\u0644\u0647\u0627 \u0623\u0648\u0644\u0627\u060c \u062a\u0638\u0647\u0631 \u0628\u0645\u0638\u0647\u0631 \u0627\u0644\u0639\u0627\u062c\u0632 \u0639\u0646 \u0627\u0644\u062a\u0635\u062f\u064a \u0644\u0644\u0645\u063a\u0631\u0628 \u0648\u062d\u062f\u0647\u0627\u061b \u0648\u0647\u0648 \u0623\u0645\u0631 \u0635\u062d\u064a\u062d. \u0641\u0627\u0644\u0645\u063a\u0631\u0628 \u0644\u062f\u064a\u0647 \u0639\u062f\u0629 \u0623\u0648\u0631\u0627\u0642 \u0642\u0648\u064a\u0629\u060c \u0644\u0627 \u064a\u0628\u0631\u0632\u0647\u0627 \u0625\u0644\u0627 \u0648\u0627\u062d\u062f\u0629 \u0628\u0639\u062f \u0627\u0644\u0623\u062e\u0631\u0649\u060c \u0648\u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0627\u0644\u0645\u0646\u0627\u0633\u0628!... \u062b\u0645 \u0625\u0646 \u0631\u062f\u0651\u064e\u064a \u0627\u0644\u0628\u0631\u0644\u0645\u0627\u0646 \u0627\u0644\u0639\u0631\u0628\u064a \u0648\u0627\u0644\u0625\u0641\u0631\u064a\u0642\u064a \u0639\u0644\u0649 \u0627\u0644\u0642\u0631\u0627\u0631 \u0627\u0644\u0623\u0648\u0631\u0648\u0628\u064a\u060c \u0643\u0627\u0646 \u0645\u0643\u0633\u0628\u0627 \u0643\u0628\u064a\u0631\u0627 \u0644\u0644\u0645\u063a\u0631\u0628\u060c \u0623\u0647\u062f\u062a\u0647 \u0625\u0633\u0628\u0627\u0646\u064a\u0627 \u0625\u0644\u064a\u0647!...<\/p>\n<p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\u0648\u0623\u0645\u0627 \u0623\u0644\u0645\u0627\u0646\u064a\u0627 \u0627\u0644\u062a\u064a \u0633\u0628\u0642\u062a \u0627\u0644\u0623\u0632\u0645\u0629 \u0628\u064a\u0646\u0647\u0627 \u0648\u0628\u064a\u0646 \u0627\u0644\u0645\u063a\u0631\u0628 \u0646\u0638\u064a\u0631\u062a\u0647\u0627 \u0625\u0633\u0628\u0627\u0646\u064a\u0627\u060c \u0648\u0627\u0644\u062a\u064a \u0623\u0642\u0628\u0644\u062a \u062a\u0638\u0647\u0631 \u062a\u0623\u064a\u064a\u062f\u0627 \u0644\u0647\u0627 \u0641\u064a \u0628\u0639\u0636 \u0627\u0644\u0625\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u062a\u0646\u0638\u064a\u0645\u064a\u0629 \u0644\u062d\u0631\u0627\u0633\u0629 \u062d\u062f\u0648\u062f \u0633\u0628\u062a\u0629 \u0648\u0645\u0644\u064a\u0644\u064a\u0629\u060c \u0644\u0627 \u062a\u062f\u0631\u064a \u0623\u0646\u0647\u0627 \u062a\u0633\u064a\u0621 \u0625\u0644\u0649 \u0646\u0641\u0633\u0647\u0627 \u0641\u062d\u0633\u0628. \u0641\u0642\u062f \u064a\u0646\u0635\u0644\u062d \u0627\u0644\u0623\u0645\u0631 \u0628\u064a\u0646 \u0627\u0644\u0645\u063a\u0631\u0628 \u0648\u0625\u0633\u0628\u0627\u0646\u064a\u0627 \u0642\u0631\u064a\u0628\u0627\u060c \u0648\u062a\u0628\u0642\u0649 \u0647\u064a \u0627\u0644\u062e\u0627\u0633\u0631\u0629 \u0627\u0644\u0643\u0628\u0631\u0649 \u0645\u0646 \u0627\u0644\u0623\u062d\u062f\u0627\u062b. \u0648\u0642\u062f \u064a\u062e\u0637\u0626 \u0645\u0646 \u064a\u0632\u0646 \u0639\u0644\u0627\u0642\u0627\u062a \u0627\u0644\u0645\u063a\u0631\u0628 \u0628\u0623\u0648\u0631\u0648\u0628\u0627 \u0628\u0645\u0639\u062f\u0644 \u0627\u0644\u0646\u0645\u0648\u060c \u0623\u0648 \u0628\u0642\u0648\u0629 \u0627\u0644\u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u062f\u0627\u062e\u0644\u064a\u0629\u060c \u0648\u063a\u064a\u0631 \u0630\u0644\u0643\u061b \u0648\u064a\u0638\u0646 \u0623\u0646 \u0627\u0644\u0645\u063a\u0631\u0628 \u0644\u0627 \u0634\u064a\u0621 \u0644\u0647 \u0641\u064a \u0627\u0644\u0645\u0642\u0627\u0628\u0644\u060c \u0648\u0625\u0646 \u0643\u0646\u0627 \u0646\u0631\u062c\u0648 \u0623\u0646 \u064a\u0643\u0648\u0646 \u0623\u0643\u062b\u0631 \u0642\u0648\u0629 \u0645\u0646 \u063a\u064a\u0631 \u0634\u0643 \u0641\u064a \u0627\u0644\u062c\u0648\u0627\u0646\u0628 \u0627\u0644\u0645\u0630\u0643\u0648\u0631\u0629\u061b \u062e\u0635\u0648\u0635\u0627 \u0648\u0647\u0648 \u064a\u0633\u062a\u0637\u064a\u0639 \u0630\u0644\u0643 \u0628\u0633\u0647\u0648\u0644\u0629!... \u0648\u0644\u0643\u0646 \u0627\u0644\u0645\u063a\u0631\u0628 \u062f\u0648\u0644\u0629 \u0625\u0642\u0644\u064a\u0645\u064a\u0629 \u0635\u0627\u0639\u062f\u0629 \u0627\u0644\u064a\u0648\u0645\u060c \u0644\u0627 \u064a\u0645\u0643\u0646 \u0644\u0623\u064a \u062f\u0648\u0644\u0629 \u0641\u064a \u0627\u0644\u0639\u0627\u0644\u0645 \u062a\u062c\u0627\u0647\u0644\u0647\u0627\u061b \u0648\u064a\u0645\u0643\u0646\u0647\u0627 \u0623\u0646 \u062a\u0636\u0631 \u0628\u0623\u0648\u0631\u0648\u0628\u0627 \u0625\u0636\u0631\u0627\u0631\u0627 \u0643\u0628\u064a\u0631\u0627\u060c \u0639\u0646 \u0637\u0631\u064a\u0642 \u0641\u062a\u062d \u0627\u0644\u0647\u062c\u0631\u0629 \u0625\u0644\u064a\u0647\u0627\u061b \u0648\u0639\u0646 \u0637\u0631\u064a\u0642 \u062a\u0648\u0638\u064a\u0641 \u0627\u0644\u0645\u0647\u0627\u062c\u0631\u064a\u0646 \u0627\u0644\u0645\u062a\u062c\u0646\u0633\u064a\u0646 \u0648\u0627\u0644\u0645\u0642\u064a\u0645\u064a\u0646 \u0647\u0646\u0627\u0643\u061b \u0648\u0639\u0646 \u0637\u0631\u064a\u0642 \u0646\u0633\u062c \u0639\u0644\u0627\u0642\u0627\u062a \u0645\u062a\u0646\u0648\u0639\u0629 \u0628\u0623\u0645\u0631\u064a\u0643\u0627 \u0648\u0628\u0631\u064a\u0637\u0627\u0646\u064a\u0627 \u0645\u0646 \u062c\u0647\u0629\u060c \u0648\u0628\u0627\u0644\u0635\u064a\u0646 \u0648\u0631\u0648\u0633\u064a\u0627 \u0648\u062a\u0631\u0643\u064a\u0627 \u0645\u0646 \u062c\u0647\u0629 \u0623\u062e\u0631\u0649. \u0648\u0645\u0646 \u0638\u0646 \u0623\u0646 \u0627\u0644\u0645\u063a\u0631\u0628 \u0645\u0644\u0632\u0645 \u0628\u0625\u0628\u0642\u0627\u0626\u0647 \u0639\u0644\u0649 \u0635\u0644\u062a\u0647 \u0628\u0623\u0648\u0631\u0648\u0628\u0627 \u0643\u0645\u0627 \u0647\u064a \u0627\u0644\u0622\u0646\u060c \u0641\u0647\u0648 \u0645\u062e\u0637\u0626\u061b \u0648\u0633\u062a\u0643\u0648\u0646 \u0625\u0633\u0628\u0627\u0646\u064a\u0627 \u0639\u0646\u062f\u0626\u0630 \u0623\u0643\u0628\u0631 \u0627\u0644\u062e\u0627\u0633\u0631\u064a\u0646\u060c \u0645\u0627 \u062f\u0627\u0645\u062a \u0647\u064a \u0627\u0644\u062a\u064a \u0633\u062a\u0642\u0639 \u0639\u0644\u064a\u0647\u0627 \u0622\u062b\u0627\u0631 \u0643\u0644 \u0633\u064a\u0627\u0633\u0629 \u062c\u062f\u064a\u062f\u0629 \u0645\u0628\u0627\u0634\u0631\u0629\u064b!...<\/p>\n<p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\u0625\u0646 \u0643\u062b\u064a\u0631\u0627 \u0645\u0646 \u0627\u0644\u0641\u0627\u0639\u0644\u064a\u0646 \u0627\u0644\u0633\u064a\u0627\u0633\u064a\u064a\u0646 \u0627\u0644\u0645\u063a\u0627\u0631\u0628\u0629\u060c \u064a\u0628\u062a\u0632\u0648\u0646 \u062f\u0648\u0644\u062a\u0647\u0645 \u0628\u0627\u0644\u0645\u0644\u0641\u0627\u062a \u0627\u0644\u062d\u0642\u0648\u0642\u064a\u0629 \u0627\u0644\u062f\u0627\u062e\u0644\u064a\u0629\u060c \u0638\u0646\u0627 \u0645\u0646\u0647\u0645 \u0623\u0646 \u0627\u0644\u0648\u0642\u062a \u0645\u0646\u0627\u0633\u0628 \u0644\u0625\u062d\u062f\u0627\u062b \u062e\u0631\u0642 \u0641\u064a \u062c\u062f\u0627\u0631 \u0627\u0644\u062c\u0645\u0648\u062f \u0627\u0644\u0645\u0627\u062b\u0644 \u0645\u062f\u0629 \u0639\u0642\u0648\u062f\u061b \u0648\u0644\u0643\u0646 \u0645\u0627 \u064a\u0646\u0628\u063a\u064a \u0623\u0646 \u064a\u0639\u0644\u0645\u0647 \u0647\u0624\u0644\u0627\u0621\u060c \u0647\u0648 \u0623\u0646 \u0639\u0644\u064a\u0647\u0645 \u0623\u0646 \u064a\u0643\u0648\u0646\u0648\u0627 \u0639\u0644\u0649 \u0625\u062f\u0631\u0627\u0643 \u0623\u0643\u0628\u0631 \u0628\u062e\u0635\u0648\u0635\u064a\u0629 \u0627\u0644\u0646\u0638\u0627\u0645 \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u060c \u0625\u0646 \u0647\u0645 \u0623\u0631\u0627\u062f\u0648\u0627 \u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u0646\u062a\u0627\u0626\u062c \u0645\u0644\u0645\u0648\u0633\u0629. \u0623\u0645\u0627 \u0645\u0639\u0627\u0645\u0644\u062a\u0647\u0645 \u0644\u0646\u0638\u0627\u0645 \u0628\u0644\u062f\u0647\u0645 -\u0639\u0644\u0649 \u0645\u0627 \u0628\u0647 \u0645\u0646 \u0622\u0641\u0627\u062a- \u0645\u0639\u0627\u0645\u0644\u0629 \u0627\u0644\u0645\u0628\u0627\u064a\u0646 \u0644\u0645\u0639\u0646\u0649 &quot;\u0627\u0644\u0648\u0637\u0646&quot;\u061b \u0645\u0646 \u0645\u0646\u0637\u0644\u0642 \u0623\u064a\u062f\u064a\u0648\u0644\u0648\u062c\u064a\u0627\u062a \u0628\u0627\u0626\u062f\u0629\u060c \u0623\u0648 \u0646\u0627\u0642\u0635\u0629\u060c \u0641\u0625\u0646\u0647\u0627 \u0625\u0633\u0627\u0621\u0629 \u0644\u0623\u0646\u0641\u0633\u0647\u0645 \u0648\u0628\u0644\u062f\u0647\u0645\u060c \u0642\u0628\u0644 \u0623\u0646 \u062a\u0643\u0648\u0646 \u0625\u0633\u0627\u0621\u0629 \u0644\u0644\u0646\u0638\u0627\u0645. \u0648\u0627\u0644\u0625\u0635\u0644\u0627\u062d \u0627\u0644\u0630\u064a \u0646\u0631\u062c\u0648\u0647 \u0641\u064a \u0627\u0644\u0645\u063a\u0631\u0628\u060c \u0644\u0627 \u0628\u062f \u0645\u0646 \u0623\u0646 \u064a\u062a\u062d\u0645\u0644 \u0623\u062b\u0645\u0627\u0646\u0647 \u0627\u0644\u0646\u0638\u0627\u0645 \u0645\u0646 \u062c\u0647\u0629\u060c \u0648\u0642\u0648\u0649 \u0627\u0644\u0625\u0635\u0644\u0627\u062d \u0645\u0646 \u0627\u0644\u062c\u0647\u0629 \u0627\u0644\u0645\u0642\u0627\u0628\u0644\u0629\u061b \u0625\u0646 \u0643\u0627\u0646\u0627 \u0645\u0639\u0627 \u0645\u0624\u0647\u0644\u064a\u0652\u0646 \u0645\u0646 \u062c\u0647\u0629 \u0627\u0644\u0625\u062f\u0631\u0627\u0643\u060c \u0648\u0645\u0646 \u062c\u0647\u0629 \u0627\u0644\u0645\u0642\u062f\u0631\u0629 \u0627\u0644\u0641\u0639\u0644\u064a\u0629 \u062c\u0645\u064a\u0639\u0627. \u0648\u0647\u0648 \u0645\u0627 \u0644\u0627 \u0646\u0631\u0649 \u062a\u0635\u062f\u064a\u0642\u0627 \u0645\u0646 \u0627\u0644\u0648\u0627\u0642\u0639 \u0644\u0647\u060c \u0641\u064a \u0627\u0644\u0645\u062f\u0649 \u0627\u0644\u0642\u0631\u064a\u0628...<\/p>\n<p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\u0625\u0646 \u0627\u0644\u0645\u0628\u0627\u062f\u0631\u0627\u062a \u0627\u0644\u062a\u064a \u064a\u0642\u0648\u0645 \u0628\u0647\u0627 \u0627\u0644\u0645\u0644\u0643 \u0645\u0639\u0632\u0648\u0644\u0627 \u0639\u0646 \u0627\u0644\u062d\u0643\u0648\u0645\u0629 \u0648\u0639\u0646 \u0627\u0644\u0634\u0639\u0628 \u0645\u0639\u0627\u060c \u0644\u0627 \u0634\u0643 \u0647\u064a \u062d\u0644\u0648\u0644 \u0627\u0644\u0644\u062d\u0638\u0629 \u0627\u0644\u0623\u062e\u064a\u0631\u0629\u060c \u0628\u0639\u062f \u062a\u0628\u064a\u0651\u0646 \u0639\u062c\u0632 \u0627\u0644\u0625\u062f\u0627\u0631\u0627\u062a \u0627\u0644\u0631\u0633\u0645\u064a\u0629 \u0639\u0646 \u0645\u0639\u0627\u0644\u062c\u0629 \u0627\u0644\u0645\u0644\u0641\u0627\u062a \u0627\u0644\u0639\u0627\u062c\u0644\u0629\u061b \u0648\u0644\u0643\u0646 \u062a\u0644\u0643 \u0627\u0644\u0645\u0628\u0627\u062f\u0631\u0627\u062a\u060c \u0644\u0627 \u064a\u0645\u0643\u0646 \u0623\u0646 \u062a\u062d\u0644 \u0645\u062d\u0644 \u0627\u0644\u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0629 \u0627\u0644\u0645\u062f\u0631\u0648\u0633\u0629\u060c \u0648\u0627\u0644\u0645\u062a\u0631\u062c\u0645\u0629 \u0639\u0628\u0631 \u0627\u0644\u0628\u0631\u0627\u0645\u062c \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629 \u0627\u0644\u0645\u062a\u0639\u0627\u0642\u0628\u0629. \u0648\u0646\u0639\u0646\u064a \u0645\u0646 \u0643\u0644\u0627\u0645\u0646\u0627\u060c \u0623\u0646\u0646\u0627 \u0645\u0635\u0631\u0648\u0646 \u0639\u0644\u0649 \u0642\u0648\u0629 \u0627\u0644\u0645\u0644\u0643 \u0636\u0645\u0646 \u0645\u0646\u0638\u0648\u0645\u0629 \u0627\u0644\u062d\u0643\u0645\u061b \u0648\u0644\u0643\u0646\u0646\u0627 \u0646\u062d\u0630\u0631 \u0645\u0646 \u0628\u0642\u0627\u0621 \u0627\u0644\u0633\u064a\u0627\u0633\u064a\u064a\u0646 \u0627\u0644\u062d\u0632\u0628\u064a\u064a\u0646 -\u0628\u0645\u0627 \u0623\u0646\u0647\u0645 \u0647\u0645 \u0645\u0646 \u064a\u062a\u0648\u0644\u0648\u0646 \u0627\u0644\u0645\u0646\u0627\u0635\u0628 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629- \u0639\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u0636\u0639\u0641 \u0627\u0644\u0628\u0627\u062f\u064a\u060c \u0648\u0647\u0630\u0627 \u0627\u0644\u0641\u0633\u0627\u062f \u0627\u0644\u0645\u0647\u064a\u0643\u0644!... \u0648\u0639\u0644\u0649 \u0627\u0644\u0634\u0639\u0628 \u0623\u0646 \u064a\u0639\u0644\u0645 \u0645\u0648\u0637\u0646 \u0636\u0639\u0641 \u0627\u0644\u062f\u0648\u0644\u0629 \u0647\u0630\u0627\u060c \u0648\u0623\u0646 \u0644\u0627 \u064a\u062e\u0644\u0637 \u0628\u064a\u0646 \u0648\u0627\u062c\u0628\u0627\u062a \u0627\u0644\u0645\u0644\u0643 \u0648\u0648\u0627\u062c\u0628\u0627\u062a \u0627\u0644\u062d\u0643\u0648\u0645\u0627\u062a\u060c \u0625\u0646 \u0643\u0627\u0646 \u064a\u0628\u063a\u064a \u0625\u062f\u0631\u0627\u0643 \u0627\u0644\u0648\u0636\u0639 \u0639\u0644\u0649 \u0645\u0627 \u0647\u0648 \u0639\u0644\u064a\u0647\u060c \u062b\u0645 \u0628\u0639\u062f \u0630\u0644\u0643 \u0625\u0646 \u0643\u0627\u0646 \u064a\u0637\u0645\u062d \u0625\u0644\u0649 \u062a\u0635\u062d\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u0633\u064a\u0627\u0633\u064a \u0645\u0646 \u062c\u0647\u062a\u0647\u060c \u0628\u0645\u0627 \u064a\u0645\u0644\u0643 \u0645\u0646 \u0648\u0633\u0627\u0626\u0644 \u063a\u064a\u0631 \u0642\u0644\u064a\u0644\u0629...<\/p>\n<p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\u0648\u0627\u0644\u0643\u0644\u0627\u0645 \u0639\u0646 \u0627\u0644\u0623\u062d\u0632\u0627\u0628 \u0627\u0644\u0633\u064a\u0627\u0633\u064a\u0629\u060c \u0633\u064a\u062c\u0631\u0646\u0627 \u0625\u0644\u0649 \u0627\u0644\u0643\u0644\u0627\u0645 \u0639\u0646 \u0627\u0644\u0627\u0646\u062a\u062e\u0627\u0628\u0627\u062a \u0641\u064a \u0627\u0644\u0645\u063a\u0631\u0628. \u0648\u062d\u062a\u0649 \u0644\u0627 \u062a\u0643\u0648\u0646 \u0647\u0630\u0647 \u0627\u0644\u0627\u0646\u062a\u062e\u0627\u0628\u0627\u062a \u0634\u0628\u064a\u0647\u0629 \u0644\u0627\u0646\u062a\u062e\u0627\u0628\u0627\u062a \u0627\u0644\u062c\u0632\u0627\u0626\u0631 \u0627\u0644\u062a\u0634\u0631\u064a\u0639\u064a\u0629 \u0627\u0644\u0645\u0647\u0632\u0644\u0629\u060c \u0641\u0625\u0646 \u0639\u0644\u0649 \u0627\u0644\u0645\u063a\u0627\u0631\u0628\u0629 \u0645\u0646 \u0627\u0644\u0622\u0646\u060c \u0623\u0646 \u064a\u0639\u0645\u0644\u0648\u0627 \u0639\u0644\u0649 \u062a\u063a\u064a\u064a\u0631 \u0627\u0644\u0645\u0634\u0647\u062f \u0627\u0644\u062d\u0632\u0628\u064a \u0641\u064a\u0647\u0627\u060c \u0645\u0646 \u0628\u0627\u0628 \u0627\u0644\u0636\u0631\u0648\u0631\u0629 \u0644\u0627 \u0627\u0644\u062a\u0631\u0641. \u0648\u0646\u0639\u0646\u064a \u0628\u0643\u0644\u0627\u0645\u0646\u0627 \u0647\u0630\u0627\u060c \u0623\u0646 \u0627\u0644\u0634\u0639\u0628 \u0627\u0644\u0645\u063a\u0631\u0628\u064a \u064a\u0646\u0628\u063a\u064a \u0623\u0646 \u062a\u064f\u0639\u0644\u0646 \u0627\u0644\u0643\u062a\u0644\u0629 \u0627\u0644\u0645\u0642\u0627\u0637\u0650\u0639\u0629 \u0641\u064a\u0647\u060c \u0648\u0627\u0644\u062a\u064a \u064a\u0641\u0648\u0642 \u0639\u062f\u062f\u0647\u0627 \u0639\u062f\u062f \u0627\u0644\u0645\u0633\u062a\u0647\u0632\u0626\u064a\u0646 \u0628\u0645\u0635\u064a\u0631 \u0627\u0644\u0628\u0644\u062f \u0639\u0646 \u0637\u0631\u064a\u0642 \u0627\u0644\u0627\u0646\u062e\u0631\u0627\u0637 \u0641\u064a \u0644\u0639\u0628\u0629 \u0627\u0644\u0623\u062d\u0632\u0627\u0628 \u0627\u0644\u0631\u062e\u064a\u0635\u0629\u061b \u0639\u0646 \u0645\u0648\u0642\u0641 \u0645\u0628\u062f\u0626\u064a \u0645\u0642\u0627\u0637\u0639 \u0644\u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u0645\u0647\u0632\u0644\u0629\u060c \u0648\u0639\u0646 \u062e\u0637\u0648\u0627\u062a \u0641\u0639\u0644\u064a\u0629 \u064a\u064f\u0639\u0645\u0644 \u0628\u0647\u0627 \u062a\u0628\u0627\u0639\u0627 \u0648\u0628\u062d\u0633\u0628 \u0627\u0644\u062d\u0627\u062c\u0629\u060c \u062a\u0633\u0647\u0631 \u0639\u0644\u064a\u0647\u0627 \u0644\u062c\u0646\u0629 \u0648\u0637\u0646\u064a\u0629 \u0645\u0646 \u0637\u0631\u0627\u0632 \u062c\u062f\u064a\u062f\u061b \u062e\u0627\u0644\u064a\u0629 \u0645\u0646 \u0627\u0644\u0648\u062c\u0648\u0647 \u0627\u0644\u0645\u062a\u0623\u062f\u0644\u062c\u0629 \u0627\u0644\u063a\u0628\u064a\u0629\u060c \u0627\u0644\u062a\u064a \u0644\u0627 \u0634\u0639\u0648\u0631 \u0644\u0647\u0627 \u0628\u0641\u0639\u0644 \u0627\u0644\u0632\u0645\u0627\u0646 \u0648\u062a\u063a\u064a\u0631 \u0627\u0644\u0645\u0639\u0637\u064a\u0627\u062a \u0627\u0644\u0638\u0631\u0641\u064a\u0629. \u0648\u062d\u062a\u0649 \u0644\u0627 \u064a\u0628\u0642\u0649 \u0627\u0644\u0634\u0639\u0628 \u062d\u0628\u064a\u0633 \u0647\u0630\u0647 \u0627\u0644\u0644\u062d\u0638\u0629 \u0645\u0646 \u0627\u0644\u062a\u062e\u0644\u0641 \u0627\u0644\u0645\u0633\u062a\u0645\u0631\u060c \u0646\u0642\u062a\u0631\u062d \u0646\u062d\u0646 \u0623\u0646 \u064a\u0643\u0648\u0646 \u0627\u0644\u0645\u0634\u0631\u0641\u0648\u0646 \u0639\u0644\u0649 \u0627\u0644\u0644\u062c\u0646\u0629 \u0627\u0644\u0625\u0635\u0644\u0627\u062d\u064a\u0629 \u0645\u0646 \u0627\u0644\u0634\u0628\u0627\u0628 \u0627\u0644\u062d\u0627\u0626\u0632\u064a\u0646 \u0644\u0644\u0623\u0647\u0644\u064a\u0629 \u0627\u0644\u0641\u0643\u0631\u064a\u0629 \u0627\u0644\u0633\u064a\u0627\u0633\u064a\u0629 \u062d\u0642\u064a\u0642\u0629 -\u0628\u0639\u064a\u062f\u0627 \u0639\u0646 &quot;\u0627\u0644\u0631\u0641\u0627\u0642&quot; \u0648&quot;\u0627\u0644\u0631\u0641\u064a\u0642\u0627\u062a&quot; \u0648&quot;\u0627\u0644\u0625\u062e\u0648\u0627\u0646&quot; \u0648&quot;\u0627\u0644\u0623\u062e\u0648\u0627\u062a&quot;- \u0645\u0646 \u0631\u062c\u0627\u0644 \u0648\u0646\u0633\u0627\u0621 \u0645\u062b\u0642\u0641\u064a\u0646 \u0648\u0645\u062b\u0642\u0641\u0627\u062a\u060c \u0645\u0628\u062f\u0639\u064a\u0646 \u0633\u064a\u0627\u0633\u064a\u0627 \u0648\u0645\u0628\u062f\u0639\u0627\u062a. \u0623\u0645\u0627 \u063a\u064a\u0631 \u0647\u0630\u0627 \u0627\u0644\u0641\u0639\u0644\u060c \u0645\u0646 \u0623\u0641\u0631\u0627\u062f \u0627\u0644\u0634\u0639\u0628\u060c \u0641\u0647\u0648 \u062c\u0631\u064a\u0645\u0629 \u0645\u062a\u0643\u0631\u0631\u0629 \u0641\u064a \u062d\u0642 \u0627\u0644\u0628\u0644\u0627\u062f\u061b \u064a\u064f\u062d\u0627\u0633\u0628 \u0639\u0644\u064a\u0647\u0627 \u0627\u0644\u0633\u0644\u0628\u064a\u0651\u0648\u0646 \u0627\u0644\u0645\u062a\u062e\u0627\u0630\u0644\u0648\u0646 \u0645\u0646\u0647\u0645\u060c \u0642\u0628\u0644 \u0623\u0646 \u064a\u064f\u062d\u0627\u0633\u0628 \u0627\u0644\u0641\u0627\u0639\u0644\u0648\u0646 \u0627\u0644\u0641\u0627\u0633\u062f\u0648\u0646!...<\/p>\n<p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\u0625\u0646 \u0627\u0644\u0645\u063a\u0631\u0628 \u0628\u0623\u0632\u0645\u062a\u0647 \u0645\u0639 \u0623\u0644\u0645\u0627\u0646\u064a\u0627 \u0648\u0625\u0633\u0628\u0627\u0646\u064a\u0627\u060c \u0642\u062f \u062f\u0634\u0646 \u0645\u0631\u062d\u0644\u0629 \u062c\u062f\u064a\u062f\u0629 \u0645\u0646 \u0627\u0644\u0646\u0651\u062f\u0651\u064a\u0651\u0629 \u0627\u0644\u0625\u0642\u0644\u064a\u0645\u064a\u0629\u060c \u0627\u0644\u062a\u064a \u064a\u064f\u0645\u0643\u0646 \u0623\u0646 \u062a\u0635\u0644 \u0641\u064a \u0627\u0644\u0645\u0633\u062a\u0642\u0628\u0644 \u0625\u0644\u0649 \u0627\u0644\u062a\u0641\u0648\u0642 \u0627\u0644\u0633\u064a\u0627\u0633\u064a \u0648\u0627\u0644\u062d\u0636\u0627\u0631\u064a \u0627\u0644\u0645\u063a\u0631\u0628\u064a. \u0648\u0643\u0644 \u0645\u0646 \u064a\u0633\u062a\u0628\u0639\u062f \u0645\u0627 \u0646\u0642\u0648\u0644\u060c \u0641\u0644\u064a\u0639\u0644\u0645 \u0623\u0646\u0647 \u063a\u064a\u0631 \u0645\u0624\u0647\u0644 \u0644\u0644\u0631\u0623\u064a \u0627\u0644\u0633\u064a\u0627\u0633\u064a \u0627\u0644\u0622\u0646\u061b \u0648\u0644\u064a\u0639\u0644\u0645 \u0623\u064a\u0636\u0627 \u0623\u0646 \u0633\u0643\u0648\u062a\u0647 \u0623\u0641\u0636\u0644 \u0645\u0646 \u0643\u0644\u0627\u0645\u0647\u060c \u0625\u0646 \u0643\u0627\u0646 \u064a\u0628\u063a\u064a \u0627\u0644\u062e\u064a\u0631 \u0627\u0644\u0639\u0627\u0645. \u0625\u0646 \u0627\u0644\u0634\u0639\u0628 \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u060c \u0639\u0644\u064a\u0647 \u0623\u0646 \u064a\u0635\u0644 \u0625\u0644\u0649 \u062f\u0631\u062c\u0629 \u0625\u062f\u0631\u0627\u0643 \u0627\u0644\u0645\u0644\u0643 \u0644\u0647\u0630\u0647 \u0627\u0644\u062d\u0642\u064a\u0642\u0629\u060c \u0648\u0628\u0627\u0644\u062a\u0627\u0644\u064a \u0623\u0646 \u064a\u0639\u064a\u0646\u0647 \u0639\u0644\u0649 \u0627\u0644\u0645\u0636\u064a \u0641\u064a \u062a\u0644\u0643 \u0627\u0644\u0637\u0631\u064a\u0642\u061b \u0644\u0643\u0646 \u0628\u0634\u0631\u0648\u0637 \u062c\u062f\u064a\u062f\u0629\u060c \u062a\u0646\u0638\u0645 \u0627\u0644\u0639\u0644\u0627\u0642\u0629 \u0628\u064a\u0646 \u0627\u0644\u0645\u0644\u0643 \u0648\u0634\u0639\u0628\u0647. \u0648\u0647\u0630\u0627\u060c \u0644\u0623\u0646 \u0627\u0644\u0637\u0631\u064a\u0642\u0629 \u0627\u0644\u0639\u062a\u064a\u0642\u0629 \u0627\u0644\u062a\u064a \u062a\u064f\u062f\u0627\u0631 \u0628\u0647\u0627 \u0647\u0630\u0647 \u0627\u0644\u0639\u0644\u0627\u0642\u0629 \u0645\u0646 \u0642\u0650\u0628\u0644 \u0627\u0644\u0646\u062e\u0628\u0629 \u0627\u0644\u0645\u062e\u0632\u0646\u064a\u0629 \u0645\u0646 \u062c\u0647\u0629\u060c \u0648\u0645\u0646 \u0642\u0650\u0628\u0644 \u0627\u0644\u062c\u0627\u0645\u062f\u064a\u0646 \u0645\u0646 \u0627\u0644\u0646\u062e\u0628\u0629 \u0627\u0644\u0633\u064a\u0627\u0633\u064a\u0629 \u0627\u0644\u0645\u062a\u0643\u0644\u0633\u0629\u060c \u0623\u0648 \u0645\u0646 \u0642\u0650\u0628\u0644 \u0627\u0644\u0634\u0628\u0627\u0628 \u0627\u0644\u0630\u064a\u0646 \u064a\u062e\u0631\u062c\u0648\u0646 \u0645\u0646 \u062a\u062d\u062a \u064a\u062f\u0647\u0627 \u0646\u064f\u0633\u062e\u0627 \u0637\u0628\u0642 \u0627\u0644\u0623\u0635\u0644\u060c \u0648\u0643\u0623\u0646\u0647\u0645 \u0634\u064a\u0648\u062e \u0644\u0627 \u0634\u0628\u0627\u0628\u060c \u0645\u0646 \u062c\u0647\u0629 \u0623\u062e\u0631\u0649\u061b \u0644\u0627 \u064a\u0645\u0643\u0646 \u0623\u0646 \u062a\u0648\u0635\u0644 \u0625\u0644\u0649 \u0648\u0636\u0639 \u0645\u062d\u0645\u0648\u062f. \u0648\u0646\u062d\u0646 \u0646\u0639\u0644\u0645 \u0645\u0642\u062f\u0627\u0631 \u0647\u0630\u0627 \u0627\u0644\u062a\u062d\u062f\u064a \u0627\u0644\u0642\u0627\u0626\u0645 \u0641\u064a \u0627\u0644\u0645\u063a\u0631\u0628\u060c \u0648\u0627\u0644\u0630\u064a \u064a\u062a\u0637\u0644\u0628 \u0625\u0642\u062f\u0627\u0645\u0627 \u0645\u0646 \u0627\u0644\u0645\u0644\u0643 \u0648\u0645\u0646 \u0631\u062c\u0627\u0644 \u0648\u0646\u0633\u0627\u0621 \u0627\u0644\u0645\u063a\u0631\u0628 \u0627\u0644\u062d\u0642\u064a\u0642\u064a (\u063a\u064a\u0631 \u0627\u0644\u062d\u0632\u0628\u064a)\u061b \u0644\u0630\u0644\u0643 \u0641\u0625\u0646\u0646\u0627 \u0644\u0646 \u0646\u0631\u062d\u0628 \u0628\u0623\u064a \u0645\u0642\u062a\u0631\u062d \u0623\u0648 \u062e\u0637\u0648\u0629 \u0639\u0645\u0644\u064a\u0629 \u0628\u0633\u0647\u0648\u0644\u0629\u060c \u0648\u0644\u0646 \u0646\u0646\u062e\u0631\u0637 \u0641\u064a \u0623\u064a \u0639\u0645\u0644 \u0625\u0635\u0644\u0627\u062d\u064a \u0645\u062c\u0627\u0632\u0641 \u0623\u0648 \u062a\u0631\u0642\u064a\u0639\u064a\u061b \u0644\u0623\u0646 \u0627\u0644\u0638\u0631\u0641 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a \u0627\u0644\u0630\u064a \u0646\u0639\u064a\u0634\u0647\u060c \u0645\u0627 \u0639\u0627\u062f \u064a\u0633\u0645\u062d \u0628\u0627\u0644\u062a\u062c\u0631\u064a\u0628. \u0641\u0625\u0645\u0627 \u0625\u0644\u0649 \u0646\u0647\u0636\u0629 \u0645\u063a\u0631\u0628\u064a\u0629 \u0633\u0644\u064a\u0645\u0629\u060c \u062a\u0643\u0648\u0646 \u0628\u062f\u0627\u064a\u0629 \u0644\u0646\u0647\u0636\u0629 \u0639\u0631\u0628\u064a\u0629 \u0636\u0631\u0648\u0631\u064a\u0629 \u0628\u0639\u062f\u0647\u0627\u061b \u0648\u0625\u0645\u0627 \u0625\u0644\u0649 \u0633\u0642\u0648\u0637 \u0641\u064a \u0627\u0644\u0647\u0627\u0648\u064a\u0629\u060c \u0648\u0627\u0646\u0642\u0637\u0627\u0639 \u0639\u0646 \u0627\u0644\u0639\u0627\u0644\u0645 \u0627\u0644\u0645\u0639\u0627\u0635\u0631 \u0628\u0627\u0644\u0641\u0639\u0644. \u0648\u0647\u0630\u0627\u060c \u0645\u0627 \u0646\u0631\u0649 \u0627\u0644\u0645\u063a\u0631\u0628 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a\u060c \u0648\u0645\u0627 \u0646\u0631\u0649 \u0627\u0644\u0645\u0644\u0643 \u0648\u0627\u0644\u0634\u0639\u0628\u060c \u064a\u0633\u062a\u062d\u0642\u0648\u0646 \u0627\u0644\u0641\u0648\u0632 \u0641\u064a\u0647 \u0628\u0627\u0644\u0642\u0633\u0645\u0629 \u0627\u0644\u0641\u0636\u0644\u0649!... \u0641\u0647\u0644 \u0645\u0646 \u0633\u0627\u0645\u0639 \u0648\u0627\u0639\u061f!...<\/p>\n","protected":false},"excerpt":{"rendered":"<p>&nbsp; &nbsp; &nbsp; &nbsp;\u0644\u0642\u062f \u0627\u0637\u0644\u0639 \u0627\u0644\u0646\u0627\u0633 \u0639\u0644\u0649 \u0627\u0644\u0623\u0632\u0645\u0629 \u0627\u0644\u062a\u064a \u0639\u0631\u0641\u062a\u0647\u0627 \u0627\u0644\u0639\u0644\u0627\u0642\u0627\u062a \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u0629 \u0627\u0644\u0625\u0633\u0628\u0627\u0646\u064a\u0629\u060c \u0628\u0633\u0628\u0628 \u062f\u062e\u0648\u0644 \u0631\u0626\u064a\u0633 \u0627\u0644\u0628\u0648\u0644\u064a\u0633\u0627\u0631\u064a\u0648 \u0625\u0644\u0649 \u0627\u0644\u0623\u0631\u0636 \u0627\u0644\u0625\u0633\u0628\u0627\u0646\u064a\u0629 \u0628\u0647\u0648\u064a\u0629 \u0645\u0632\u0648\u0631\u0629. \u0648\u0645\u0627 \u0644\u0645 \u0646\u0641\u0647\u0645\u0647\u060c \u0647\u0648 \u0645\u0633\u0627\u0631\u0639\u0629 \u0628\u0639\u0636 \u0627\u0644\u0645\u0639\u0627\u0631\u0636\u064a\u0646\u060c \u0648\u0623\u0634\u0628\u0627\u0647 \u0627\u0644\u0645\u0639\u0627\u0631\u0636\u064a\u0646 \u0644\u0644\u0646\u0638\u0627\u0645 \u0627\u0644\u0645\u