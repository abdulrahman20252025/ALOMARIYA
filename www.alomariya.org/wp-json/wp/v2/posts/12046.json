{"id":12046,"date":"2024-12-09T13:22:26","date_gmt":"2024-12-09T13:22:26","guid":{"rendered":"http:\/\/alomariya.test\/%d8%a7%d9%84%d8%a3%d9%8e%d8%b3%d9%80%d9%92%d9%85%d9%8e%d8%a7-%d8%a3%d9%8e%d8%b3%d9%80%d9%92%d9%85%d9%8e%d8%a7%d9%86%d9%8e%d8%a7\/"},"modified":"2025-03-02T10:27:16","modified_gmt":"2025-03-02T10:27:16","slug":"%d8%a7%d9%84%d8%a3%d8%b3%d9%85%d8%a7_%d8%a7%d8%b3%d9%85%d8%a7%d9%86%d8%a7","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d8%a7%d9%84%d8%a3%d8%b3%d9%85%d8%a7_%d8%a7%d8%b3%d9%85%d8%a7%d9%86%d8%a7\/","title":{"rendered":"\u0627\u0644\u0623\u064e\u0633\u0640\u0652\u0645\u064e\u0627 \u0623\u064e\u0633\u0640\u0652\u0645\u064e\u0627\u0646\u064e\u0627"},"content":{"rendered":"<p style=\"text-align: center; font-size: 16px; line-height: 2.5em;\">\u0627\u0644\u0623\u0633\u0640\u0640\u0640\u0640\u0640\u0645\u0627 \u0623\u064e\u0633\u0640\u0640\u0640\u0640\u0640\u0640\u0652\u0645\u064e\u0627\u0646\u064e\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e \u0627\u0644\u0640\u0640\u0640\u0630\u064e\u0651\u0627\u062a\u064f \u0630\u064e\u0627\u062a\u064f\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0648\u064e \u0627\u0644\u0652\u063a\u064e\u064a\u0640\u0640\u0640\u0640\u0640\u0640\u0652\u0631\u064f \u063a\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u064a\u0652\u0631\u064f\u0646\u064e\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0645\u064e\u0627 \u062b\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0645\u064e\u0651 \u063a\u064e\u0640\u0640\u0640\u0640\u0640\u064a\u0652\u0631\u064f\u0646\u064e\u0627<br \/>\n\u0642\u064f\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u0652\u0628\u064c \u0647\u064f\u0648\u064e \u0645\u064e\u0640\u0640\u0648\u0652\u062a\u064c\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0645\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0648\u0652\u062a\u064c \u0648\u064e \u062d\u064e\u064a\u064e\u0640\u0640\u0640\u0627\u0629\u064c<br \/>\n\u0645\u064e\u0627 \u0639\u0650\u0646\u0640\u0640\u0640\u0640\u0640\u0640\u0652\u062f\u064e\u0646\u064e\u0627 \u0641\u064e\u0640\u0640\u0640\u0640\u0640\u0648\u0652\u062a\u064c\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0644\u0627\u064e \u062a\u064e\u0640\u0640\u0642\u0640\u0640\u0640\u0640\u0640\u0652\u0631\u064e\u0628\u0652 \u062d\u064e\u0640\u0640\u064a\u064e\u0651\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0645\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0646\u0652 \u0648\u064e\u062c\u064e\u062f\u064e \u0641\u064e\u0642\u064e\u0640\u0640\u0640\u0640\u062f\u0652 \u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0645\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0646\u0652 \u0641\u064e\u0642\u064e\u062f\u064e \u0631\u064e\u0634\u064e\u0640\u0640\u0640\u062f\u0652<br \/>\n\u0648\u064e\u0627\u0644\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u062f\u064c \u0648\u064e \u0648\u064e\u0644\u064e\u0640\u0640\u0640\u0640\u0640\u062f\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0639\u064e\u062c\u0650\u064a\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0628\u064c \u0623\u064e\u0645\u0640\u0640\u0640\u0640\u0640\u0652\u0631\u064f\u0646\u064e\u0627<br \/>\n\u062c\u064e\u0645\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0652\u0639\u064c \u0647\u064f\u0648\u064e \u0641\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u0652\u0642\u064c\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0639\u0650\u0640\u0634\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0642\u064c \u0647\u064f\u0648\u064e \u062d\u064e\u0640\u0640\u0640\u0631\u0652\u0642\u064c<br \/>\n\u062e\u064e\u0627\u0644\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0642\u064c \u0648\u064e \u062e\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0644\u0652\u0640\u0642\u064c \u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0627\u0644\u0623\u064e\u0645\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u064f \u0628\u064e\u0640\u0640\u064a\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0652\u0646\u064e\u0646\u064e\u0627<br \/>\n\u0633\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0644\u0650\u0651\u0645\u0652 \u0644\u064e\u0646\u064e\u0627 \u062a\u064e\u0633\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0644\u064e\u0645\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e \u0627\u0642\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u064e\u0628\u0652 \u0645\u0650\u0646\u064e\u0651\u0627 \u062a\u064e\u063a\u0652\u0640\u0646\u064e\u0645\u0652<br \/>\n\u0648\u064e \u0627\u062d\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0643\u064f\u0645\u0652 \u0628\u0650\u0645\u064e\u0627 \u062a\u064e\u0640\u0639\u0652\u0640\u0640\u0640\u0644\u064e\u0645\u0652 \u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0644\u0627\u064e \u062a\u064e\u0640\u0640\u0639\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u062f\u064f \u0639\u064e\u0644\u064e\u064a\u0652\u0640\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0627\u0650\u0633\u0652\u0640\u0640\u0640\u0640\u0640\u0643\u064e\u0631\u0652 \u0648\u064e \u0644\u0627\u064e \u062a\u064f\u0641\u0650\u0640\u0640\u0640\u0640\u0640\u0642\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e \u0627\u0646\u0652\u0638\u0640\u0640\u0640\u0640\u0640\u0640\u064f\u0631\u0652 \u0625\u0650\u0644\u064e\u0649 \u0627\u0644\u0631\u064e\u0651\u0641\u0650\u064a\u0642\u0652<br \/>\n\u0648\u064e \u0633\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u0652 \u0639\u064e\u0644\u064e\u0649 \u0627\u0644\u0637\u064e\u0651\u0631\u0650\u064a\u0642\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0641\u064e\u0623\u064e\u0645\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u064f\u0643\u064e \u0644\u064e\u0646\u064e\u0627<br \/>\n\u062e\u0640\u0640\u0640\u0640\u0640\u064e\u064a\u064e\u0627\u0644\u064f\u0646\u064e\u0627 \u0638\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0644\u064c\u0651\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e \u0634\u064e\u0640\u0640\u0645\u0652\u0633\u064f\u0640\u0640\u0640\u0646\u064e\u0627 \u0643\u064e\u0640\u0640\u0640\u0640\u0640\u0644\u064c\u0651<br \/>\n\u0648\u064e \u062e\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0644\u0652\u0642\u064f\u0646\u064e\u0627 \u0637\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0644\u064c\u0651\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0645\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0646\u0652 \u0628\u064e\u0640\u0640\u0640\u0640\u062d\u0652\u0631\u0650 \u0630\u064e\u0627\u062a\u0650\u0646\u064e\u0627<br \/>\n\u0627\u064f\u0646\u0652\u0640\u0640\u0640\u0640\u0638\u0640\u0640\u0640\u0640\u0640\u064f\u0631\u0652 \u062b\u064f\u0645\u064e\u0651 \u0623\u064e\u0628\u0652\u0635\u0650\u0640\u0640\u0640\u0631\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0623\u064e\u0642\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0635\u0650\u0631\u0652 \u0644\u0627\u064e \u062a\u064f\u0640\u0642\u064e\u0635\u0650\u0651\u0640\u0640\u0631\u0652<br \/>\n\u0627\u0650\u0639\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0642\u0650\u0644\u0652 \u0644\u0627\u064e \u062a\u064f\u0641\u064e\u0640\u0640\u0640\u0643\u0650\u0651\u0631\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0641\u064e\u0627\u0644\u0652\u0640\u0640\u0640\u0640\u0640\u062d\u0650\u0645\u064e\u0649 \u062d\u0650\u0640\u0640\u0640\u0645\u064e\u0627\u0646\u064e\u0627<br \/>\n\u0633\u064e\u0627\u0645\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u0652\u0646\u064e\u0640\u0627 \u0648\u064e \u0633\u064e\u0627\u0645\u0650\u0640\u0640\u0640\u0631\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0627\u0650\u062d\u0652\u0640\u0640\u0640\u0640\u0640\u0630\u064e\u0631\u0652 \u0644\u0627 \u062a\u064f\u063a\u064e\u0627\u0645\u0650\u0640\u0640\u0640\u0631\u0652<br \/>\n\u0648\u064e \u0633\u064e\u0627\u064a\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0650\u0631\u0652\u0646\u064e\u0627 \u0633\u064e\u0640\u0640\u0627\u064a\u0650\u0631\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0644\u0627\u064e \u062a\u064e\u0623\u0652\u0645\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0646\u0652 \u0645\u064e\u0643\u0652\u0640\u0631\u064e\u0646\u064e\u0627<br \/>\n\u0642\u064e\u0631\u0650\u064a\u0628\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u064f\u0646\u064e\u0627 \u0628\u064e\u0640\u0639\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u064a\u062f\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u00a0\u0648\u064e \u0627\u0644\u0652\u0628\u064e\u0639\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u064a\u062f\u064f \u0633\u064e\u0640\u062f\u0650\u064a\u0640\u0640\u0640\u062f\u0652<br \/>\n\u0627\u0644\u0652\u062c\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0628\u064e\u0627\u0644\u064f \u062a\u064e\u0640\u0640\u0645\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u064a\u062f\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u00a0\u0648\u064e \u0627\u0644\u0652\u0628\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0642\u064e\u0627\u0621\u064f \u0644\u064e\u0646\u064e\u0627<br \/>\n\u0627\u0650\u0634\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u064e\u0628\u0652 \u062e\u064e\u0645\u0652\u0640\u0640\u0640\u0631\u064e\u062a\u064e\u0646\u064e\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0644\u0627\u064e \u062a\u064e\u0634\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u064e\u0628\u0652 \u0645\u064e\u0639\u064e\u0646\u064e\u0627<br \/>\n\u0627\u0644\u0652\u063a\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u064e\u062f\u0652\u0631\u064f \u0637\u064e\u0628\u0652\u0639\u064f\u0640\u0640\u0640\u0640\u0646\u064e\u0627\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e \u0627\u0644\u0633\u064e\u0651\u0640\u0640\u0640\u0640\u064a\u0652\u0641\u064f \u0634\u064e\u0640\u0640\u0640\u0623\u0652\u0646\u064f\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0644\u0627\u064e \u062a\u064e\u0633\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0645\u064e\u0639\u0650 \u0627\u0644\u0652\u0643\u064e\u0640\u0640\u0644\u0627\u064e\u0645\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0648\u064e \u0633\u0650\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0631\u0652 \u0628\u0650\u0644\u0627\u064e \u0644\u0650\u062c\u064e\u0640\u0640\u0640\u0627\u0645\u0652<br \/>\n\u0648\u064e \u0633\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0644\u0650\u0651\u0645\u0652 \u064a\u064e\u0627 \u0633\u064e\u0640\u0640\u0640\u0644\u0627\u064e\u0645\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0643\u064f\u0640\u0640\u0640\u0644\u064e\u0651 \u0627\u0644\u0652\u0641\u0650\u0640\u0640\u0639\u0652\u0640\u0644\u0650 \u0644\u064e\u0640\u0640\u0640\u0640\u0646\u064e\u0627<br \/>\n\u0645\u064e\u0627 \u062b\u064e\u0645\u0651\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u064e\u0629\u064e \u063a\u064e\u0631\u0650\u064a\u0640\u0640\u0640\u0628\u0652\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u0628\u064e\u0640\u0640\u0640\u0640\u0640\u0639\u0650\u0640\u0640\u064a\u062f\u064c \u0648\u064e\u0642\u064e\u0631\u0650\u064a\u0640\u0640\u0640\u0640\u0628\u0652<br \/>\n\u0627\u0644\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u062d\u0650\u0628\u064f\u0651 \u0648\u064e \u0627\u0644\u0652\u062d\u064e\u0628\u0650\u0640\u0640\u0640\u064a\u0628\u0652\u00a0\u00a0\u00a0 \u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u0641\u064e\u0643\u064f\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0644\u064f\u0651\u0647\u064e\u0627 \u0623\u064e\u0646\u064e\u0627<br \/>\n\u0627\u0644\u0652\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u062d\u064e\u0627\u0644\u064f \u062d\u064e\u0627\u0626\u0650\u0640\u0640\u0640\u0640\u0644\u064c\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0 \u00a0\u0648\u064e \u0627\u0644\u0652\u0642\u064e\u0640\u0640\u0640\u0640\u0640\u0640\u0648\u0652\u0644\u064f \u0628\u064e\u0627\u0637\u0650\u0640\u0640\u0640\u0644\u064c<br \/>\n\u0648\u064e \u0627\u0644\u0652\u0639\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0650\u0644\u0652\u0640\u0640\u0645\u064f \u062c\u064e\u0627\u06