{"id":40537,"date":"2024-12-16T23:16:48","date_gmt":"2024-12-16T23:16:48","guid":{"rendered":"https:\/\/alomariya.fmarkets.co\/?p=40537"},"modified":"2025-04-28T15:19:15","modified_gmt":"2025-04-28T15:19:15","slug":"%d8%a7%d8%ad%d8%b0%d8%b1%d9%88%d8%a7-%d8%aa%d8%b1%d9%83%d9%8a%d8%a7-%d9%88%d9%82%d8%b7%d8%b1-%d9%88%d8%a7%d9%84%d8%aa%d9%81%d9%88%d8%a7-%d8%ad%d9%88%d9%84-%d9%85%d8%b5%d8%b1","status":"publish","type":"post","link":"https:\/\/www.alomariya.org\/%d8%a7%d8%ad%d8%b0%d8%b1%d9%88%d8%a7-%d8%aa%d8%b1%d9%83%d9%8a%d8%a7-%d9%88%d9%82%d8%b7%d8%b1-%d9%88%d8%a7%d9%84%d8%aa%d9%81%d9%88%d8%a7-%d8%ad%d9%88%d9%84-%d9%85%d8%b5%d8%b1\/","title":{"rendered":"\u0627\u062d\u0630\u0631\u0648\u0627 \u062a\u0631\u0643\u064a\u0627 \u0648\u0642\u0637\u0631 \u0648\u0627\u0644\u062a\u0641\u0648\u0627 \u062d\u0648\u0644 \u0645\u0635\u0631!..."},"content":{"rendered":"<p>\u0628\u0633\u0645 \u0627\u0644\u0644\u0647\u060c \u0648\u0627\u0644\u062d\u0645\u062f \u0644\u0644\u0647\u060c \u0648\u0627\u0644\u0635\u0644\u0627\u0629 \u0648\u0627\u0644\u0633\u0644\u0627\u0645 \u0639\u0644\u0649 \u0631\u0633\u0648\u0644 \u0627\u0644\u0644\u0647 \u0648\u0622\u0644\u0647 \u0648\u0635\u062d\u0628\u0647\u061b \u0623\u0645\u0627 \u0628\u0639\u062f:<br \/>\n<span class=\"custom-indent\">\u0646\u062d\u0630\u0651\u0631 \u0627\u0644\u0639\u0631\u0628 \u0648\u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0645\u0646 \u0628\u0639\u062f\u0647\u0645\u060c \u0627\u0644\u0630\u064a\u0646 \u064a\u0628\u063a\u0648\u0646 \u0623\u0646 \u064a\u0643\u0648\u0646\u0648\u0627 \u0641\u064a \u062c\u0647\u0629 \u0627\u0644\u062d\u0642\u060c \u0639\u0646\u062f\u0645\u0627 \u064a\u0624\u0648\u0646 \u0623\u0648\u0627\u0646 \u0627\u0644\u0645\u0644\u062d\u0645\u0629 \u0627\u0644\u0643\u0628\u0631\u0649\u060c \u0645\u0646 \u0639\u0645\u0644 \u062a\u0631\u0643\u064a\u0627 \u0648\u0642\u0637\u0631 \u0644\u063a\u064a\u0631 \u0645\u0635\u0644\u062d\u0629 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u060c \u0628\u062f\u0639\u0645\u0647\u0645\u0627 \u0644\u0644\u062a\u0646\u0638\u064a\u0645 \u0627\u0644\u0639\u0627\u0644\u0645\u064a \u0644\u0644\u0625\u062e\u0648\u0627\u0646 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0627\u0644\u0635\u0647\u064a\u0648\u0646\u064a\u060c \u0648\u0628\u062a\u0641\u0627\u0647\u0645\u0647\u0645\u0627 \u0645\u0639 \u0627\u0644\u0642\u0648\u0649 \u0627\u0644\u0645\u0639\u0627\u062f\u064a\u0629 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629. \u0648\u0644\u064a\u0633 \u0628\u0644\u062f \u0645\u0646 \u0627\u0644\u0628\u0644\u062f\u0627\u0646 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0628\u0645\u0646\u0623\u0649 \u0639\u0645\u0627 \u064a\u064f\u062e\u0637\u0651\u0637 \u0644\u0647 \u0647\u0624\u0644\u0627\u0621\u060c \u0641\u0644\u0627 \u064a\u063a\u062a\u0631 \u0623\u062d\u062f \u0628\u0627\u0644\u0645\u0638\u0627\u0647\u0631\u060c \u0648\u0644\u0627 \u0628\u0627\u0644\u0634\u0639\u0627\u0631\u0627\u062a \u0627\u0644\u0631\u0646\u0627\u0646\u0629 \u0627\u0644\u0641\u0627\u0631\u063a\u0629...<\/span><br \/>\n<span class=\"custom-indent\">\u0648\u0625\u0646 \u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0645\u0635\u0631\u064a \u0648\u0627\u0644\u0634\u0639\u0628 \u0627\u0644\u0645\u0635\u0631\u064a\u0651\u060c \u0628\u0639\u062f \u0627\u0646\u0642\u0637\u0627\u0639 \u0633\u0645\u0648\u0645 \u0627\u0644\u0625\u062e\u0648\u0627\u0646 \u0648\u0627\u0644\u0645\u062a\u0633\u0644\u0641\u0629 \u0639\u0646\u0647\u0645\u0627\u060c \u0647\u0645\u0627 \u0645\u0646 \u064a\u0645\u062b\u0651\u0644 \u0627\u0644\u0622\u0646 \u0627\u0644\u0639\u0645\u0642 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a \u0627\u0644\u0635\u062d\u064a\u062d\u060c \u0628\u0627\u0639\u062a\u0645\u0627\u062f \u0627\u0644\u0645\u0635\u0631\u064a\u064a\u0646 \u0627\u0644\u062f\u064a\u0646 \u0627\u0644\u0645\u062d\u0645\u062f\u064a \u0627\u0644\u0623\u0635\u0644\u064a\u060c \u0627\u0644\u0645\u0646\u0628\u0646\u064a \u0639\u0644\u0649 \u0645\u062d\u0628\u0629 \u0627\u0644\u0646\u0628\u064a \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0622\u0644\u0647 \u0648\u0633\u0644\u0645\u060c \u0648\u0639\u0644\u0649 \u062a\u062d\u0631\u0651\u064a \u0627\u0644\u062d\u0642. \u0648\u0647\u0630\u0627 \u0627\u0644\u0635\u0646\u0641 \u0645\u0646 \u0627\u0644\u062a\u062f\u064a\u0651\u0646\u060c \u0648\u0625\u0646 \u0642\u0627\u0631\u0628\u062a\u0647 \u0628\u0639\u0636 \u0627\u0644\u0634\u0639\u0648\u0628\u060c \u0641\u0625\u0646 \u0627\u0644\u0625\u0645\u0627\u0645\u0629 \u0641\u064a\u0647 \u0644\u0639\u0648\u0627\u0645 \u0627\u0644\u0645\u0635\u0631\u064a\u0651\u064a\u0646\u060c \u0642\u0628\u0644 \u062e\u0648\u0627\u0635 \u0639\u0644\u0645\u0627\u0626\u0647\u0645...<\/span><br \/>\n<span class=\"custom-indent\">\u0648\u0646\u062d\u0646 \u0646\u062f\u0639\u0648 \u0647\u0646\u0627 \u0645\u0634\u064a\u062e\u0629 \u0627\u0644\u0623\u0632\u0647\u0631 \u0648\u0639\u0644\u0645\u0627\u0621\u0647\u060c \u0625\u0644\u0649 \u0627\u0644\u0627\u0635\u0637\u0641\u0627\u0641 \u0627\u0644\u0639\u0644\u0645\u064a\u0651 \u0627\u0644\u062c\u0644\u064a\u0651\u060c \u0625\u0644\u0649 \u062c\u0627\u0646\u0628 \u0627\u0644\u0634\u0639\u0628 \u0627\u0644\u0645\u0635\u0631\u064a\u0651 \u0648\u062c\u064a\u0634\u0647\u061b \u0648\u0625\u0644\u0649 \u062a\u0637\u0647\u064a\u0631 \u0627\u0644\u062c\u0627\u0645\u0639 \u0648\u0627\u0644\u062c\u0627\u0645\u0639\u0629 \u0645\u0646 \u0627\u0644\u062a\u064a\u0651\u0627\u0631\u064a\u0652\u0646 \u0627\u0644\u0645\u0633\u0645\u0648\u0645\u064a\u0652\u0646: \u0627\u0644\u0645\u062a\u0633\u0644\u0651\u0641 \u0627\u0644\u062a\u064a\u0645\u064a\u0651\u060c \u0648\u0627\u0644\u0625\u062e\u0648\u0627\u0646\u064a \u0627\u0644\u0642\u0637\u0628\u064a. \u0641\u0625\u0646 \u0627\u0644\u0632\u0645\u0627\u0646 \u0645\u0627 \u0639\u0627\u062f \u064a\u0633\u0645\u062d \u0628\u0627\u0644\u0648\u0642\u0648\u0641 \u0641\u064a \u0627\u0644\u0648\u0633\u0637\u060c \u0648\u0623\u0646\u062a\u0645 \u0639\u0644\u0645\u0627\u0621 \u062f\u064a\u0646 \u0644\u0627 \u0631\u062c\u0627\u0644 \u0633\u064a\u0627\u0633\u0629!...<\/span><br \/>\n<span class=\"custom-indent\">\u0643\u0645\u0627 \u0646\u062f\u0639\u0648 \u0627\u0644\u0645\u063a\u0627\u0631\u0628\u0629\u060c \u0625\u0644\u0649 \u0623\u0646 \u064a\u062a\u0641\u0637\u0651\u0646\u0648\u0627 \u0625\u0644\u0649 \u0627\u0644\u0625\u0633\u0644\u0627\u0645\u064a\u0651\u064a\u0646 \u0639\u0646\u062f\u0647\u0645\u060c \u0648\u0627\u0644\u0630\u064a\u0646 \u064a\u0648\u0627\u0644\u0648\u0646 \u062a\u0631\u0643\u064a\u0627 \u0648\u0642\u0637\u0631\u060c \u0623\u0643\u062b\u0631 \u0645\u0645\u0627 \u064a\u0648\u0627\u0644\u0648\u0646 \u062f\u0648\u0644\u062a\u0647\u0645 \u0648\u0634\u0639\u0628\u0647\u0645. \u0648\u0642\u062f \u0641\u0631\u0651\u0637\u062a \u0627\u0644\u062f\u0648\u0644\u0629 \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u0629 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u062c\u0627\u0646\u0628\u060c \u0625\u0644\u0649 \u0627\u0644\u062d\u062f \u0627\u0644\u0630\u064a \u062c\u0639\u0644 \u0627\u0644\u0637\u0627\u0645\u0639\u064a\u0646 \u064a\u0637\u0645\u0639\u0648\u0646 \u0641\u064a\u0647\u0627 \u0648\u0641\u064a \u0627\u0644\u0647\u064a\u0645\u0646\u0629 \u0639\u0644\u064a\u0647\u0627 \u0648\u0627\u0633\u062a\u062a\u0628\u0627\u0639\u0647\u0627\u061b \u0645\u0646\u0630 \u062a\u0648\u0644\u0651\u064a \u062d\u0632\u0628 \"\u0627\u0644\u0639\u062f\u0627\u0644\u0629 \u0648\u0627\u0644\u062a\u0646\u0645\u064a\u0629\" \u0644\u0631\u0626\u0627\u0633\u0629 \u0627\u0644\u062d\u0643\u0648\u0645\u0629 \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u0629 \u0641\u064a \u0648\u0642\u062a \u0645\u0636\u0649 \u062e\u0627\u0635\u0629... \u0648\u0646\u062d\u0646 \u0646\u0630\u0643\u0651\u0631 \u0627\u0644\u0622\u0646 \u0628\u0625\u062d\u062f\u0649 \u0632\u064a\u0627\u0631\u0627\u062a \u064a\u0648\u0633\u0641 \u0627\u0644\u0642\u0631\u0636\u0627\u0648\u064a (\u0645\u0641\u062a\u064a \u0627\u0644\u062a\u0646\u0638\u064a\u0645 \u0627\u0644\u0639\u0627\u0644\u0645\u064a \u0644\u0644\u0625\u062e\u0648\u0627\u0646) \u0625\u0644\u0649 \u0627\u0644\u0645\u063a\u0631\u0628 \u0622\u0646\u0630\u0627\u0643\u060c \u062d\u064a\u062b \u0643\u0627\u0646\u062a \u0627\u0644\u062f\u0648\u0644\u0629 -\u0645\u0639 \u0627\u0644\u0623\u0633\u0641- \u062a\u0628\u062f\u0648 \u0636\u0639\u064a\u0641\u0629 \u0648\u0639\u0644\u0649 \u0648\u0634\u0643 \u0627\u0644\u062a\u0633\u0644\u064a\u0645 \u0628\u0627\u0644\u0623\u0645\u0631 \u0627\u0644\u0648\u0627\u0642\u0639 \u0644\u0647 \u0648\u0644\u0623\u062a\u0628\u0627\u0639\u0647. \u0648\u0642\u062f \u0643\u0646\u0651\u0627 \u0646\u062d\u0630\u0651\u0631 \u0627\u0644\u0645\u063a\u0627\u0631\u0628\u0629 \u0645\u0646 \u0643\u0644 \u062a\u0644\u0643 \u0627\u0644\u0623\u062e\u0637\u0627\u0631 \u0641\u064a \u0625\u0628\u0627\u0646\u0647\u0627\u060c \u0648\u0644\u0643\u0646\u0651 \u0634\u0637\u0631\u0627 \u0645\u0646 \u0627\u0644\u0645\u062e\u0632\u0646 \u0643\u0627\u0646 \u064a\u064f\u062d\u0627\u0635\u0631\u0646\u0627 \u0646\u062d\u0646\u060c \u0628\u062f\u0644 \u0623\u0646 \u064a\u064f\u062d\u0627\u0635\u0631 \u0627\u0644\u0645\u0639\u0644\u0646\u064a\u0646 \u0628\u062a\u0647\u062f\u064a\u062f\u0647\u0645 \u0644\u0644\u062f\u0648\u0644\u0629 \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u0629. \u0648\u0644\u0633\u0646\u0627 \u0645\u062d\u062a\u0627\u062c\u064a\u0646 \u0647\u0646\u0627\u060c \u0625\u0644\u0649 \u0627\u0644\u062a\u0630\u0643\u064a\u0631 \u0628\u0628\u0639\u0636 \u0627\u0644\u062e\u0637\u0628 \u0627\u0644\u0646\u0627\u0631\u064a\u0629 \u0627\u0644\u062a\u064a \u0643\u0627\u0646 \u064a\u062e\u0631\u062c \u0628\u0647\u0627 \u0627\u0628\u0646 \u0643\u064a\u0631\u0627\u0646\u060c \u0645\u062a\u062c\u0627\u0648\u0632\u0627 \u0641\u064a\u0647\u0627 \u0644\u062d\u062f\u0648\u062f \u0627\u0644\u0623\u062f\u0628 \u0645\u0639 \u0645\u0644\u0643 \u0627\u0644\u0628\u0644\u0627\u062f \u0646\u0641\u0633\u0647!...<\/span><br \/>\n<span class=\"custom-indent\">\u0646\u0642\u0648\u0644 \u0641\u064a \u062e\u062a\u0627\u0645 \u0647\u0630\u0647 \u0627\u0644\u0631\u0633\u0627\u0644\u0629\/\u0627\u0644\u0628\u064a\u0627\u0646 \u0644\u0643\u0644 \u0627\u0644\u0645\u063a\u0631\u0636\u064a\u0646: \u0646\u062d\u0646 \u0647\u0646\u0627\u060c \u0648\u0644\u0646 \u0646\u062a\u0631\u0643\u0643\u0645 \u062a\u062a\u0644\u0627\u0639\u0628\u0648\u0646 \u0628\u0627\u0644\u0645\u0635\u064a\u0631 \u0627\u0644\u0623\u062e\u0631\u0648\u064a \u0644\u0644\u0634\u0639\u0648\u0628 \u0627\u0644\u0645\u0633\u0644\u0645\u0629\u060c \u0648\u062a\u0648\u0641\u064a\u0642\u0646\u0627 \u0628\u0627\u0644\u0644\u0647 \u0645\u0648\u0644\u0627\u0646\u0627\u060c \u0648\u0639\u0644\u064a\u0647 \u0648\u062d\u062f\u0647 \u062a\u0648\u0643\u0651\u0644\u0646\u0627. \u0648\u0646\u062f\u0639\u0648 \u0627\u0644\u0634\u0639\u0648\u0628 \u0627\u0644\u0645\u0639\u0646\u064a\u0629 \u0643\u0644\u0647\u0627\u060c \u0625\u0644\u0649 \u062d\u0633\u0645 \u0623\u0645\u0631\u0647\u0627\u060c \u0648\u0627\u0644\u0648\u0642\u0648\u0641 \u0645\u0639 \u0645\u0646 \u064a\u0646\u0628\u063a\u064a \u0627\u0644\u0648\u0642\u0648\u0641 \u0645\u0639\u0647 \u0641\u064a \u0628\u0644\u062f\u0627\u0646\u0647\u0627\u060c \u0639\u0646\u062f\u0645\u0627 \u062a\u0639\u0644\u0646 \u0643\u0644 \u062c\u0647\u0629 \u0639\u0646 \u0645\u0648\u0642\u0641\u0647\u0627 \u0635\u0631\u0627\u062d\u0629 \u0648\u0645\u0646 \u062f\u0648\u0646 \u062a\u0648\u0631\u064a\u0629. \u0647\u0630\u0627\u060c \u0648\u0627\u0644\u0644\u0647 \u062a\u0639\u0627\u0644\u0649 \u064a\u0642\u0648\u0644: {\u06cc\u064e\u0640\u0670\u06e4\u0623\u064e\u06cc\u0651\u064f\u0647\u064e\u0627 \u0671\u0644\u0651\u064e\u0630\u0650\u06cc\u0646\u064e \u0621\u064e\u0627\u0645\u064e\u0646\u064f\u0648\u0627\u06df \u0642\u064f\u0648\u06e4\u0627\u06df \u0623\u064e\u0646\u0641\u064f\u0633\u064e\u0643\u064f\u0645\u06e1 \u0648\u064e\u0623\u064e\u0647\u06e1\u0644\u0650\u06cc\u0643\u064f\u0645\u06e1 \u0646\u064e\u0627\u0631\u064b\u0627 \u0648\u064e\u0642\u064f\u0648\u062f\u064f\u0647\u064e\u0627 \u0671\u0644\u0646\u0651\u064e\u0627\u0633\u064f \u0648\u064e\u0671\u0644\u06e1\u062d\u0650\u062c\u064e\u0627\u0631\u064e\u0629\u064f \u0639\u064e\u0644\u064e\u06cc\u06e1\u0647\u064e\u0627 \u0645\u064e\u0644\u064e\u0640\u0670\u06e4\u0649\u0655\u0650\u0643\u064e\u0629\u064c \u063a\u0650\u0644\u064e\u0627\u0638\u064c \u0634\u0650\u062f\u064e\u0627\u062f\u064c \u0644\u0651\u064e\u0627 \u06cc\u064e\u0639\u06e1\u0635\u064f\u0648\u0646\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u0645\u064e\u0627\u06e4 \u0623\u064e\u0645\u064e\u0631\u064e\u0647\u064f\u0645\u06e1 \u0648\u064e\u06cc\u064e\u0641\u06e1\u0639\u064e\u0644\u064f\u0648\u0646\u064e \u0645\u064e\u0627 \u06cc\u064f\u0624\u06e1\u0645\u064e\u0631\u064f\u0648\u0646\u064e} [\u0627\u0644\u062a\u062d\u0631\u064a\u0645: 6]\u061b \u0641\u0644\u0627 \u062a\u062a\u0631\u0643\u0648\u0627 \u0644\u0644\u062f\u0646\u064a\u0627 \u0639\u0644\u0649 \u0623\u0646\u0641\u0633\u0643\u0645 \u0633\u0644\u0637\u0627\u0646\u0627\u060c \u0648\u0627\u0644\u0634\u064a\u0637\u0627\u0646 \u064a\u062a\u0635\u064a\u0651\u062f\u0643\u0645 \u0628\u0647\u0627\u061b \u0648\u0622\u062b\u0631\u0648\u0627 \u0628\u0623\u0641\u0639\u0627\u0644\u0643\u0645 \u0644\u0627 \u0628\u0623\u0642\u0648\u0627\u0644\u0643\u0645 \u0648\u062d\u062f\u0647\u0627\u060c \u0622\u062e\u0631\u062a\u064e\u0643\u0645 \u0639\u0644\u0649 \u062f\u0646\u064a\u0627\u0643\u0645\u060c \u0641\u0625\u0646\u0647\u0627 \u0648\u062d\u062f\u0647\u0627 \u062f\u0627\u0631 \u0627\u0644\u0642\u0631\u0627\u0631. \u064a\u0642\u0648\u0644 \u0627\u0644\u0644\u0647 \u062a\u0639\u0627\u0644\u0649: {\u06cc\u064e\u0640\u0670\u0642\u064e\u0648\u06e1\u0645\u0650 \u0625\u0650\u0646\u0651\u064e\u0645\u064e\u0627 \u0647\u064e\u0640\u0670\u0630\u0650\u0647\u0650 \u0671\u0644\u06e1\u062d\u064e\u06cc\u064e\u0648\u0670\u0629\u064f \u0671\u0644\u062f\u0651\u064f\u0646\u06e1\u06cc\u064e\u0627 \u0645\u064e\u062a\u064e\u0640\u0670\u0639\u064c \u0648\u064e\u0625\u0650\u0646\u0651\u064e \u0671\u0644\u06e1\u0640\u0654\u064e\u0627\u062e\u0650\u0631\u064e\u0629\u064e \u0647\u0650\u06cc\u064e \u062f\u064e\u0627\u0631\u064f \u0671\u0644\u06e1\u0642\u064e\u0631\u064e\u0627\u0631\u0650} [\u063a\u0627\u0641\u0631: 39]. \u0641\u0625\u064a\u0627\u0643\u0645 \u064a\u0627 \u0634\u0639\u0648\u0628\u0646\u0627 \u0627\u0644\u0645\u0633\u0644\u0645\u0629\u060c \u0623\u0646 \u062a\u0646\u0635\u062a\u0648\u0627 \u0625\u0644\u0649 \u062f\u0639\u0627\u0629 \u0627\u0644\u0641\u062a\u0646\u0629\u060c \u0648\u0642\u062f \u0641\u0636\u062d\u0646\u0627\u0647\u0645 \u0644\u0643\u0645 \u0641\u064a \u0643\u0644\u0651 \u0645\u0631\u0651\u0629\u061b \u0648\u0627\u0633\u062a\u0639\u064a\u0646\u0648\u0627 \u0628\u0627\u0644\u0635\u0628\u0631 \u0648\u0627\u0644\u0635\u0644\u0627\u0629\u060c \u0644\u0642\u0648\u0644 \u0631\u0628\u0646\u0627 \u0648\u0631\u0628\u0651\u0643\u0645: {\u0648\u064e\u0671\u0633\u06e1\u062a\u064e\u0639\u0650\u06cc\u0646\u064f\u0648\u0627\u06df \u0628\u0650\u0671\u0644\u0635\u0651\u064e\u0628\u06e1\u0631\u0650 \u0648\u064e\u0671\u0644\u0635\u0651\u064e\u0644\u064e\u0648\u0670\u0629\u0650\u06da \u0648\u064e\u0625\u0650\u0646\u0651\u064e\u0647\u064e\u0627 \u0644\u064e\u0643\u064e\u0628\u0650\u06cc\u0631\u064e\u0629\u064c \u0625\u0650\u0644\u0651\u064e\u0627 \u0639\u064e\u0644\u064e\u0649 \u0671\u0644\u06e1\u062e\u064e\u0640\u0670\u0634\u0650\u0639\u0650\u06cc\u0646\u064e . \u0671\u0644\u0651\u064e\u0630\u0650\u06cc\u0646\u064e \u06cc\u064e\u0638\u064f\u0646\u0651\u064f\u0648\u0646\u064e \u0623\u064e\u0646\u0651\u064e\u0647\u064f\u0645 \u0645\u0651\u064f\u0644\u064e\u0640\u0670\u0642\u064f\u0648\u0627\u06df \u0631\u064e\u0628\u0651\u0650\u0647\u0650\u0645\u06e1 \u0648\u064e\u0623\u064e\u0646\u0651\u064e\u0647\u064f\u0645\u06e1 \u0625\u0650\u0644\u064e\u06cc\u06e1\u0647\u0650 \u0631\u064e\u200a\u0670\u2060\u062c\u0650\u0639\u064f\u0648\u0646\u064e} [\u0627\u0644\u0628\u0642\u0631\u0629: 45-46]. \u0648\u0645\u0639\u0646\u0649 \u064a\u0638\u0646\u0651\u0648\u0646 \u0641\u064a \u0627\u0644\u0622\u064a\u0629: \u064a\u0624\u0645\u0646\u0648\u0646 \u062d\u0642\u064a\u0642\u0629. \u0641\u0648\u0637\u0651\u0650\u0646\u0648\u0627 \u0623\u0646\u0641\u0633\u0643\u0645 \u0648\u0644\u0627 \u062a\u0646\u0647\u0632\u0645\u0648\u0627 \u0641\u064a \u0642\u0644\u0648\u0628\u0643\u0645\u060c \u0641\u0625\u0646 \u0647\u0632\u064a\u0645\u0629 \u0627\u0644\u0642\u0644\u0628 \u062a\u0623\u062a\u064a \u0628\u0627\u0644\u0647\u0632\u064a\u0645\u0629 \u0627\u0644\u0638\u0627\u0647\u0631\u0629 \u0627\u0644\u0639\u0644\u0646\u064a\u0651\u0629. \u0648\u0625\u064a\u0651\u0627\u0643\u0645 \u0648\u0627\u062a\u0628\u0627\u0639 \u0633\u0628\u064a\u0644 \u0627\u0644\u0623\u064a\u062f\u064a\u0648\u0644\u0648\u062c\u064a\u0627\u060c \u0641\u0625\u0646\u0647\u0627 \u063a\u064a\u0631 \u0633\u0628\u064a\u0644 \u0627\u0644\u0645\u0624\u0645\u0646\u064a\u0646 \u0627\u0644\u062a\u064a \u0646\u0647\u0649 \u0627\u0644\u0644\u0647 \u0639\u0628\u0627\u062f\u0647 \u0639\u0646 \u0627\u062a\u0628\u0627\u0639\u0647\u0627 \u0641\u064a \u0642\u0648\u0644\u0647 \u062a\u0639\u0627\u0644\u0649: {\u0648\u064e\u0645\u064e\u0646 \u06cc\u064f\u0634\u064e\u0627\u0642\u0650\u0642\u0650 \u0671\u0644\u0631\u0651\u064e\u0633\u064f\u0648\u0644\u064e \u0645\u0650\u0646\u06e2 \u0628\u064e\u0639\u06e1\u062f\u0650 \u0645\u064e\u0627 \u062a\u064e\u0628\u064e\u06cc\u0651\u064e\u0646\u064e \u0644\u064e\u0647\u064f \u0671\u0644\u06e1\u0647\u064f\u062f\u064e\u0649\u0670 \u0648\u064e\u06cc\u064e\u062a\u0651\u064e\u0628\u0650\u0639\u06e1 \u063a\u064e\u06cc\u06e1\u0631\u064e \u0633\u064e\u0628\u0650\u06cc\u0644\u0650 \u0671\u0644\u06e1\u0645\u064f\u0624\u06e1\u0645\u0650\u0646\u0650\u06cc\u0646\u064e \u0646\u064f\u0648\u064e\u0644\u0651\u0650\u0647\u0650\u06e6 \u0645\u064e\u0627 \u062a\u064e\u0648\u064e\u0644\u0651\u064e\u0649\u0670 \u0648\u064e\u0646\u064f\u0635\u06e1\u0644\u0650\u0647\u0650\u06e6 \u062c\u064e\u0647\u064e\u0646\u0651\u064e\u0645\u064e\u06d6 \u0648\u064e\u0633\u064e\u0627\u06e4\u0621\u064e\u062a\u06e1 \u0645\u064e\u0635\u0650\u06cc\u0631\u064b\u0627} [\u0627\u0644\u0646\u0633\u0627\u0621: 115]... \u0641\u0627\u0644\u0644\u0647\u064e \u0627\u0644\u0644\u0647\u064e \u0641\u064a \u0623\u0646\u0641\u0633\u0643\u0645 \u0648\u0625\u064a\u0645\u0627\u0646\u0643\u0645\u060c \u0648\u0641\u064a \u0623\u0647\u0644\u064a\u0643\u0645 \u0648\u0642\u0648\u0645\u0643\u0645!...<\/span><br \/>\n<span class=\"custom-indent\">\u0648\u0627\u0644\u062d\u0645\u062f \u0644\u0644\u0647 \u0631\u0628 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0646\u060c \u0648\u0627\u0644\u0644\u0647 \u0623\u0643\u0628\u0631!...<\/span><br \/>\n\u0627\u0644\u0644\u0647\u0645 \u0647\u0644 \u0628\u0644\u0651\u063a\u062a\u061f \u0627\u0644\u0644\u0647\u0645 \u0641\u0627\u0634\u0647\u062f!...<\/p>\n<p style=\"text-align: left;\"><u>\u00a0\u0639\u0628\u062f \u0627\u0644\u063a\u0646\u064a \u0627\u0644\u0639\u0645\u0631\u064a \u0627\u0644\u062d\u0633\u0646\u064a<\/u><\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u0628\u0633\u0645 \u0627\u0644\u0644\u0647\u060c \u0648\u0627\u0644\u062d\u0645\u062f \u0644\u0644\u0647\u060c \u0648\u0627\u0644\u0635\u0644\u0627\u0629 \u0648\u0627\u0644\u0633\u0644\u0627\u0645 \u0639\u0644\u0649 \u0631\u0633\u0648\u0644 \u0627\u0644\u0644\u0647 \u0648\u0622\u0644\u0647 \u0648\u0635\u062d\u0628\u0647\u061b \u0623\u0645\u0627 \u0628\u0639\u062f: \u0646\u062d\u0630\u0651\u0631 \u0627\u0644\u0639\u0631\u0628 \u0648\u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0645\u0646 \u0628\u0639\u062f\u0647\u0645\u060c \u0627\u0644\u0630\u064a\u0646 \u064a\u0628\u063a\u0648\u0646 \u0623\u0646 \u064a\u0643\u0648\u0646\u0648\u0627 \u0641\u064a \u062c\u0647\u0629 \u0627\u0644\u062d\u0642\u060c \u0639\u0646\u062f\u0645\u0627 \u064a\u0624\u0648\u0646 \u0623\u0648\u0627\u0646 \u0627\u0644\u0645\u0644\u062d\u0645\u0629 \u0627\u0644\u0643\u0628\u0631\u0649\u060c \u0645\u0646 \u0639\u0645\u0644 \u062a\u0631\u0643\u064a\u0627 \u0648\u0642\u0637\u0631 \u0644\u063a\u064a\u0631 \u0645\u0635\u0644\u062d\u0629 \u0627\u0644\u0625\u0633\u0644\